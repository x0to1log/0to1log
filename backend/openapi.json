    "/api/recommendations/similar": {
      "get": {
        "tags": [
          "recommendations"
        ],
        "summary": "Similar Posts",
        "description": "Return similar posts to the given post_id using vector similarity.",
        "operationId": "similar_posts_api_recommendations_similar_get",
        "parameters": [
          {
            "name": "post_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "title": "Post Id"
            }
          },
          {
            "name": "locale",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^(en|ko)$",
              "default": "en",
              "title": "Locale"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RecommendedPost"
                  },
                  "title": "Response Similar Posts Api Recommendations Similar Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
