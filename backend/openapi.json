{
  "openapi": "3.1.0",
  "info": {
    "title": "0to1log API",
    "version": "0.1.0"
  },
  "paths": {
    "/api/cron/news-pipeline": {
      "post": {
        "tags": [
          "cron"
        ],
        "summary": "Run News Pipeline",
        "description": "Trigger daily news pipeline. Returns 202 immediately; runs async.",
        "operationId": "run_news_pipeline_api_cron_news_pipeline_post",
        "parameters": [
          {
            "name": "x-cron-secret",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "title": "X-Cron-Secret"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PipelineAcceptedResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid cron secret",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/drafts": {
      "get": {
        "tags": [
          "admin"
        ],
        "summary": "List Drafts",
        "description": "List all posts with status='draft'.",
        "operationId": "list_drafts_api_admin_drafts_get",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "title": "Authorization"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PostDraftListItem"
                  },
                  "title": "Response List Drafts Api Admin Drafts Get"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Not an admin",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/drafts/{slug}": {
      "get": {
        "tags": [
          "admin"
        ],
