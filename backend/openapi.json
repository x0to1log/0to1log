  "components": {
    "schemas": {
      "AiAdviseRequest": {
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "generate",
              "seo",
              "review",
              "factcheck",
              "deepverify",
              "conceptcheck",
              "voicecheck",
              "retrocheck"
            ],
            "title": "Action"
          },
          "post_id": {
            "type": "string",
            "title": "Post Id"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "content": {
            "type": "string",
            "title": "Content"
          },
          "category": {
            "type": "string",
            "title": "Category"
          },
          "tags": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Tags",
            "default": []
          },
          "excerpt": {
            "type": "string",
            "title": "Excerpt",
            "default": ""
          },
          "slug": {
            "type": "string",
            "title": "Slug",
            "default": ""
          },
          "post_type": {
            "type": "string",
            "title": "Post Type",
            "default": ""
          },
          "guide_items": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Guide Items"
          }
        },
        "type": "object",
        "required": [
          "action",
          "post_id",
          "title",
          "content",
          "category"
        ],
        "title": "AiAdviseRequest"
      },
      "AiAdviseResponse": {
        "properties": {
          "action": {
            "type": "string",
            "title": "Action"
          },
          "success": {
            "type": "boolean",
            "title": "Success"
          },
          "result": {
            "additionalProperties": true,
            "type": "object",
            "title": "Result"
          },
          "model_used": {
            "type": "string",
            "title": "Model Used"
          },
          "tokens_used": {
            "type": "integer",
            "title": "Tokens Used"
          }
        },
        "type": "object",
        "required": [
          "action",
          "success",
          "result",
          "model_used",
          "tokens_used"
        ],
        "title": "AiAdviseResponse"
      },
      "BlogAdviseRequest": {
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "outline",
              "draft",
              "rewrite",
              "suggest",
              "review",
              "generate",
              "generate_bilingual",
              "conceptcheck",
              "voicecheck",
              "retrocheck"
            ],
            "title": "Action"
          },
          "post_id": {
            "type": "string",
            "title": "Post Id"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "content": {
            "type": "string",
            "title": "Content"
          },
          "category": {
            "type": "string",
            "title": "Category"
          },
          "tags": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Tags",
            "default": []
          },
          "excerpt": {
            "type": "string",
            "title": "Excerpt",
            "default": ""
          },
          "slug": {
            "type": "string",
            "title": "Slug",
            "default": ""
          },
          "locale": {
            "type": "string",
            "title": "Locale",
            "default": "en"
          }
        },
        "type": "object",
        "required": [
          "action",
          "post_id",
          "title",
