---
import { t } from '../../i18n/index';

interface Props {
  locale: 'en' | 'ko';
  volumeLabel?: string;
}

const { locale, volumeLabel } = Astro.props;
const isKo = locale === 'ko';
const nonce = Astro.locals.cspNonce || '';

const now = new Date();
const browserLocale = isKo ? 'ko-KR' : 'en-US';
const browserDateIso = now.toISOString();
const dateLabel = isKo
  ? now.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })
  : now.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', weekday: 'long' });

const editionLabel = t[locale]['home.edition'];
const volLabel = volumeLabel ?? (isKo ? 'AI 뉴스 · 용어집 · 블로그' : 'AI News · AI Glossary · IT Blog');
---

<header class="home-masthead">
  <div class="home-masthead-top">
    <span class="home-masthead-kicker-left">{editionLabel}</span>
    <h1 class="home-masthead-brand">0to1log</h1>
    <span class="home-masthead-kicker-right" data-local-date data-date-iso={browserDateIso} data-date-locale={browserLocale}>
      {dateLabel}
    </span>
  </div>
  <div class="home-masthead-pillars">
    <span>{volLabel}</span>
  </div>
</header>

<script is:inline nonce={nonce}>
  function updateHomeDates(root) {
    var scope = root && root.querySelectorAll ? root : document;
    scope.querySelectorAll('[data-local-date]').forEach(function(node) {
      var iso = node.getAttribute('data-date-iso');
      var locale = node.getAttribute('data-date-locale') || 'en-US';
      if (!iso) return;
      node.textContent = new Date(iso).toLocaleDateString(locale, {
        year: 'numeric', month: 'long', day: 'numeric', weekday: 'long',
      });
    });
  }
  updateHomeDates(document);
  document.addEventListener('astro:after-swap', function() { updateHomeDates(document); });
</script>
