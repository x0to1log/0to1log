---
import type { ProductCategory, ProductCardData } from '../../lib/pageData/productsPage';
import ProductCard from './ProductCard.astro';
import { getCategoryIcon } from '../../lib/productCategoryIcons';

interface Props {
  category: ProductCategory;
  products: ProductCardData[];
  locale: 'en' | 'ko';
}

const { category, products, locale } = Astro.props;

const label = locale === 'ko' ? category.label_ko : category.label_en;
const description = locale === 'ko' ? category.description_ko : category.description_en;
---

<section
  class="product-category-section"
  id={`category-${category.id}`}
  data-category-id={category.id}
>
  <div class="product-category-header">
    <span class="product-category-icon" set:html={getCategoryIcon(category.id)} />
    <h2 class="product-category-title">{label}</h2>
  </div>

  {description && (
    <p class="product-category-description">{description}</p>
  )}

  {products.length > 0 ? (
    <div class="product-category-grid">
      {products.map((product) => (
        <ProductCard
          href={`/${locale}/products/${product.slug}/`}
          name={product.name}
          tagline={product.tagline}
          logoUrl={product.logo_url}
          pricing={product.pricing}
          platform={product.platform}
          koreanSupport={product.korean_support}
          locale={locale}
        />
      ))}
    </div>
  ) : (
    <p class="product-category-empty">
      {locale === 'ko' ? '곧 추가될 예정입니다.' : 'Coming soon.'}
    </p>
  )}
</section>
