---
import type { ProductCategory } from '../../lib/pageData/productsPage';
import { t } from '../../i18n/index';

interface Props {
  categories: ProductCategory[];
  totalProducts: number;
  locale: 'en' | 'ko';
}

const { categories, totalProducts, locale } = Astro.props;
const tr = t[locale];
---

<section class="product-hero">
  <div class="product-hero-text">
    <h1 class="product-hero-title">{tr['products.heroTitle']}</h1>
    <p class="product-hero-subtitle">{tr['products.heroSubtitle']}</p>
    <p class="product-hero-stats">
      <span class="product-hero-stat">
        <strong>{totalProducts}+</strong> {locale === 'ko' ? 'AI 도구' : 'AI Tools'}
      </span>
      <span class="product-hero-stat-sep" aria-hidden="true">·</span>
      <span class="product-hero-stat">
        <strong>{categories.length}</strong> {locale === 'ko' ? '카테고리' : 'Categories'}
      </span>
    </p>
  </div>
</section>
