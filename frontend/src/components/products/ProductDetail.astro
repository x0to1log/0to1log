---
import type { ProductDetailData, ProductCardData } from '../../lib/pageData/productsPage';
import { t } from '../../i18n/index';
import MediaGallery from './MediaGallery.astro';
import ProductCard from './ProductCard.astro';

interface Props {
  product: ProductDetailData;
  htmlDescription: string;
  locale: 'en' | 'ko';
  alternatives: ProductCardData[];
}

const { product, htmlDescription, locale, alternatives } = Astro.props;
const tr = t[locale];

const pricingLabel: Record<string, string> = {
  free: locale === 'ko' ? '무료' : 'Free',
  freemium: 'Freemium',
  paid: locale === 'ko' ? '유료' : 'Paid',
  enterprise: locale === 'ko' ? '기업용' : 'Enterprise',
};

const platformLabels: Record<string, string> = {
  web: 'Web',
  ios: 'iOS',
  android: 'Android',
  api: 'API',
  desktop: 'Desktop',
};

const releasedYear = product.released_at
  ? new Date(product.released_at).getFullYear()
  : null;

const features = locale === 'ko' && product.features_ko.length > 0
  ? product.features_ko : product.features;
const useCases = locale === 'ko' && product.use_cases_ko.length > 0
  ? product.use_cases_ko : product.use_cases;
---

<article class="product-detail" id="products-top">
  <!-- Header -->
  <header class="product-detail-header">
    <div class="product-detail-header-left">
      {product.logo_url && (
        <img
          src={product.logo_url}
          alt={product.name}
          class="product-detail-logo"
          width="64"
          height="64"
          loading="eager"
        />
      )}
      <div class="product-detail-title-group">
        <h1 class="product-detail-name">{product.name}</h1>
        {product.tagline && (
          <p class="product-detail-tagline">{product.tagline}</p>
        )}
      </div>
    </div>

    <div class="product-detail-header-right">
      {product.pricing && (
        <span class="product-pricing-badge" data-pricing={product.pricing}>
          {pricingLabel[product.pricing] ?? product.pricing}
        </span>
      )}
      <a
        href={product.url}
        target="_blank"
        rel="noopener noreferrer"
        class="product-visit-btn"
      >
        {tr['products.visitSite']} ↗
      </a>
    </div>
  </header>

  <div class="product-detail-body">
    <!-- Main content -->
    <div class="product-detail-main">
      {product.demo_media.length > 0 && (
        <MediaGallery media={product.demo_media} />
      )}

      {htmlDescription && (
        <div class="product-detail-description prose">
          <Fragment set:html={htmlDescription} />
        </div>
      )}

      {features.length > 0 && (
        <section class="product-detail-features">
          <h2 class="product-detail-section-title">
            {locale === 'ko' ? '주요 기능' : 'Key Features'}
          </h2>
          <ul class="product-detail-feature-list">
            {features.map((f) => <li>{f}</li>)}
          </ul>
        </section>
      )}

      {useCases.length > 0 && (
        <section class="product-detail-usecases">
          <h2 class="product-detail-section-title">
            {locale === 'ko' ? '이런 상황에 추천' : 'Use Cases'}
          </h2>
          <ul class="product-detail-usecase-list">
            {useCases.map((u) => <li>{u}</li>)}
          </ul>
        </section>
      )}
    </div>

    <!-- Sidebar -->
    <aside class="product-detail-sidebar">
      {product.pricing && (
        <div class="product-detail-sidebar-section">
          <h3 class="product-detail-sidebar-label">{tr['products.pricing']}</h3>
          <span class="product-pricing-badge" data-pricing={product.pricing}>
            {pricingLabel[product.pricing] ?? product.pricing}
          </span>
          {product.pricing_note && (
            <p class="product-detail-pricing-note">{product.pricing_note}</p>
          )}
        </div>
      )}

      {product.platform && product.platform.length > 0 && (
        <div class="product-detail-sidebar-section">
          <h3 class="product-detail-sidebar-label">{tr['products.platforms']}</h3>
          <div class="product-platform-list">
            {product.platform.map((p) => (
              <span class="product-platform-item">{platformLabels[p] ?? p}</span>
            ))}
          </div>
        </div>
      )}

      {releasedYear && (
        <div class="product-detail-sidebar-section">
          <h3 class="product-detail-sidebar-label">{tr['products.releasedAt']}</h3>
          <span class="product-detail-sidebar-value">{releasedYear}</span>
        </div>
      )}

      {product.korean_support && (
        <div class="product-detail-sidebar-section">
          <span class="product-korean-badge">{tr['products.koreanSupport']} ✓</span>
        </div>
      )}

      {product.tags && product.tags.length > 0 && (
        <div class="product-detail-sidebar-section">
          <h3 class="product-detail-sidebar-label">{tr['products.tags']}</h3>
          <div class="product-tags-list">
            {product.tags.map((tag) => (
              <span class="product-tag">{tag}</span>
            ))}
          </div>
        </div>
      )}

      <div class="product-detail-stats">
        <span class="product-detail-stat">👁 {product.view_count.toLocaleString()}</span>
        <span class="product-detail-stat">♡ {product.like_count.toLocaleString()}</span>
      </div>
    </aside>
  </div>

  {alternatives.length > 0 && (
    <section class="product-detail-alternatives">
      <h2 class="product-detail-section-title">
        {locale === 'ko' ? '비슷한 도구' : 'Similar Tools'}
      </h2>
      <div class="product-grid product-grid--preview">
        {alternatives.map((alt) => {
          const firstImg = alt.demo_media?.find((m) => m.type === 'image');
          return (
            <ProductCard
              href={`/${locale}/products/${alt.slug}/`}
              name={alt.name}
              tagline={alt.tagline}
              logoUrl={alt.logo_url}
              thumbnailUrl={alt.thumbnail_url}
              demoMediaFirst={firstImg?.url ?? null}
              pricing={alt.pricing}
              platform={alt.platform}
              koreanSupport={alt.korean_support}
              locale={locale}
              categoryId={alt.primary_category}
              viewCount={alt.view_count}
            />
          );
        })}
      </div>
    </section>
  )}

  <section class="product-detail-faq">
    <h2 class="product-detail-section-title">FAQ</h2>

    {product.pricing && (
      <details class="product-faq-item">
        <summary>
          {locale === 'ko'
            ? `${product.name}은(는) 무료인가요?`
            : `Is ${product.name} free?`}
        </summary>
        <p>
          {product.pricing === 'free'
            ? (locale === 'ko' ? '네, 무료로 사용할 수 있습니다.' : 'Yes, it is completely free to use.')
            : product.pricing === 'freemium'
              ? (locale === 'ko' ? '무료 플랜과 유료 플랜이 있습니다.' : 'It offers both free and paid plans.')
              : product.pricing === 'paid'
                ? (locale === 'ko' ? '유료 서비스입니다.' : 'It is a paid service.')
                : (locale === 'ko' ? '기업용 요금제입니다. 영업팀에 문의하세요.' : 'Enterprise pricing. Contact sales for details.')}
          {product.pricing_note && ` ${product.pricing_note}`}
        </p>
      </details>
    )}

    {product.platform && product.platform.length > 0 && (
      <details class="product-faq-item">
        <summary>
          {locale === 'ko'
            ? `${product.name}은(는) 어떤 플랫폼에서 사용할 수 있나요?`
            : `What platforms is ${product.name} available on?`}
        </summary>
        <p>
          {locale === 'ko'
            ? `${product.platform.map(p => platformLabels[p] ?? p).join(', ')}에서 사용 가능합니다.`
            : `Available on ${product.platform.map(p => platformLabels[p] ?? p).join(', ')}.`}
        </p>
      </details>
    )}

    <details class="product-faq-item">
      <summary>
        {locale === 'ko'
          ? `${product.name}이(가) 한국어를 지원하나요?`
          : `Does ${product.name} support Korean?`}
      </summary>
      <p>
        {product.korean_support
          ? (locale === 'ko' ? '네, 한국어 UI를 지원합니다.' : 'Yes, it supports Korean language.')
          : (locale === 'ko' ? '현재 한국어는 지원하지 않습니다.' : 'Korean is not currently supported.')}
      </p>
    </details>
  </section>
</article>
