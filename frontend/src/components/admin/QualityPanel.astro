---
import {
  normalizeQualityData,
  scoreColorClass,
  severityLabel,
  type NormalizedQuality,
} from '../../lib/admin/qualityPanel';

interface Props {
  factPack: unknown;
}

const { factPack } = Astro.props;
const q: NormalizedQuality = normalizeQualityData(factPack);

const aggregateChips = [
  { label: 'Structure', value: q.aggregates.deterministic.structure, max: 15 },
  { label: 'Traceability', value: q.aggregates.deterministic.traceability, max: 15 },
  { label: 'Locale', value: q.aggregates.deterministic.locale, max: 10 },
  { label: 'Expert Body (wt)', value: q.aggregates.weightedLlm.expert_body, max: 24 },
  { label: 'Learner Body (wt)', value: q.aggregates.weightedLlm.learner_body, max: 24 },
  { label: 'Frontload (wt)', value: q.aggregates.weightedLlm.frontload, max: 12 },
];

const majorIssues = q.issues.filter((i) => i.severity === 'major');
const minorIssues = q.issues.filter((i) => i.severity === 'minor');

const personaLabels = {
  expert: 'Expert Body',
  learner: 'Learner Body',
  frontload: 'Frontload',
} as const;
type PersonaKey = keyof typeof personaLabels;
const personaOrder: PersonaKey[] = ['expert', 'learner', 'frontload'];

const scoreChipClass = q.score === null
  ? ''
  : q.score >= 85
    ? 'admin-quality-score-chip admin-quality-score-chip--high'
    : q.score >= 70
      ? 'admin-quality-score-chip admin-quality-score-chip--mid'
      : 'admin-quality-score-chip admin-quality-score-chip--low';
---

<section class="admin-quality-panel">
  <header class="admin-quality-panel-header">
    <div>
      <h3 class="admin-quality-panel-title">Quality Analysis</h3>
      <p class="admin-quality-panel-subtitle">
        {q.isLegacy
          ? 'Legacy post (pre-v11 rubric) — aggregate scores only, sub-score evidence not available'
          : 'v11 rubric — click a category below to see sub-score evidence'}
      </p>
    </div>
    <div class="flex items-center gap-2">
      {q.score !== null && (
        <span class={scoreChipClass}>
          {q.score}/100
        </span>
      )}
      {q.autoPublishEligible && (
        <span class="admin-quality-eligible-badge">
          Auto-publish eligible
        </span>
      )}
    </div>
  </header>

  <div class="mt-3 flex flex-wrap gap-2">
    {aggregateChips.map((chip) => (
      <span class="admin-quality-chip">
        <span class="admin-quality-chip-label">{chip.label}:</span>{' '}
        <span class="admin-quality-chip-value">{chip.value}/{chip.max}</span>
      </span>
    ))}
  </div>

  {(q.capsApplied.length > 0 || q.structuralPenalty > 0 || q.urlValidationFailed) && (
    <div class="mt-3 space-y-1">
      {q.capsApplied.map((cap) => (
        <p class="admin-quality-alert admin-quality-alert--warning">
          Cap applied: <code class="admin-quality-alert-code">{cap}</code>
        </p>
      ))}
      {q.structuralPenalty > 0 && (
        <p class="admin-quality-alert admin-quality-alert--error">
          Structural penalty: {q.structuralPenalty}
          {q.structuralWarnings.length > 0 && ` — ${q.structuralWarnings.join('; ')}`}
        </p>
      )}
      {q.urlValidationFailed && (
        <p class="admin-quality-alert admin-quality-alert--error">URL validation failed (auto-publish blocked)</p>
      )}
    </div>
  )}

  {!q.isLegacy && (
    <div class="mt-4 space-y-2">
      {personaOrder.map((persona) => {
        const breakdown = q.breakdowns[persona];
        if (!breakdown) return null;
        return (
          <details class="admin-quality-details">
            <summary class="admin-quality-details-summary">
              {personaLabels[persona]}
            </summary>
            <div class="admin-quality-details-body">
              {Object.entries(breakdown).map(([category, subs]) => (
                <div>
                  <h4 class="admin-quality-category-title">
                    {category.replace(/_/g, ' ')}
                  </h4>
                  <ul class="m-0 p-0 list-none">
                    {Object.entries(subs).map(([subKey, sub]) => (
                      <li class="admin-quality-subscore">
                        <span class={scoreColorClass(sub.score)}>
                          {sub.score}/10
                        </span>
                        <div class="flex-1">
                          <span class="admin-quality-subscore-label">{subKey.replace(/_/g, ' ')}</span>
                          {sub.evidence && (
                            <p class="admin-quality-subscore-evidence">{sub.evidence}</p>
                          )}
                        </div>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </details>
        );
      })}
    </div>
  )}

  {q.issues.length > 0 && (
    <div class="mt-4">
      <h4 class="admin-quality-issues-header">
        Issues ({majorIssues.length} major, {minorIssues.length} minor)
      </h4>
      <ul class="mt-2 m-0 p-0 list-none">
        {q.issues.map((issue) => {
          const { label, className } = severityLabel(issue.severity);
          return (
            <li class="admin-quality-issue">
              <span class={className}>
                {label}
              </span>
              <div class="flex-1">
                <p class="m-0">
                  <span class="admin-quality-issue-scope">[{issue.scope || '?'}/{issue.category || '?'}]</span>{' '}
                  <span class="admin-quality-issue-message">{issue.message}</span>
                </p>
              </div>
            </li>
          );
        })}
      </ul>
    </div>
  )}
</section>
