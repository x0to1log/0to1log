---
interface Props {
  activeSection?: 'dashboard' | 'posts' | 'pipeline' | 'pipeline-analytics' | 'site-analytics' | 'blog' | 'handbook' | 'products' | 'settings';
  recentPosts?: Array<{ title: string; slug: string; type: 'post' | 'term' }>;
  stats?: { posts: number; terms: number; drafts: number };
}

const { activeSection = 'dashboard', recentPosts = [], stats } = Astro.props;
const currentPath = Astro.url.pathname;
---

<aside class="admin-sidebar" id="admin-sidebar">
  <div class="admin-sidebar-brand">
    <a href="/admin/" class="admin-sidebar-logo">0to1log <span class="admin-sidebar-label">Admin</span></a>
    <button class="admin-sidebar-collapse-btn" id="sidebar-toggle" type="button" title="Toggle sidebar">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M10 3L5 8l5 5" />
      </svg>
    </button>
  </div>

  <nav class="admin-sidebar-nav">
    <a href="/admin/" class:list={['admin-sidebar-link', { 'admin-sidebar-link--active': activeSection === 'dashboard' }]}>
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M2 2h5v5H2zM9 2h5v5H9zM2 9h5v5H2zM9 9h5v5H9z" />
      </svg>
      <span>Dashboard</span>
    </a>
    <a href="/admin/pipeline-runs" class:list={['admin-sidebar-link', { 'admin-sidebar-link--active': activeSection === 'pipeline' }]}>
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M3 13V8M8 13V3M13 13V6" />
      </svg>
      <span>Pipeline Runs</span>
    </a>
    <a href="/admin/pipeline-analytics" class:list={['admin-sidebar-link', { 'admin-sidebar-link--active': activeSection === 'pipeline-analytics' }]}>
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M2 13V8M5 13V5M8 13V9M11 13V3M14 13V7" />
      </svg>
      <span>Pipeline Costs</span>
    </a>
    <a href="/admin/analytics" class:list={['admin-sidebar-link', { 'admin-sidebar-link--active': activeSection === 'site-analytics' }]}>
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M2 14l4-5 3 3 5-7" />
        <circle cx="14" cy="5" r="1.5" />
      </svg>
      <span>Site Analytics</span>
    </a>
    <a href="/admin/posts/" class:list={['admin-sidebar-link', { 'admin-sidebar-link--active': activeSection === 'posts' }]}>
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M2 3h12M2 7h8M2 11h10" />
      </svg>
      <span>News</span>
    </a>
    <a href="/admin/handbook/" class:list={['admin-sidebar-link', { 'admin-sidebar-link--active': activeSection === 'handbook' }]}>
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M3 2h10v12H3zM6 2v12" />
      </svg>
      <span>Handbook</span>
    </a>
    <a href="/admin/blog/" class:list={['admin-sidebar-link', { 'admin-sidebar-link--active': activeSection === 'blog' }]}>
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M12 1L5 8l-1 3 3-1 7-7zM11 2l2 2" />
      </svg>
      <span>Blog</span>
    </a>
    <a href="/admin/products/" class:list={['admin-sidebar-link', { 'admin-sidebar-link--active': activeSection === 'products' }]}>
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M2 4l6-2 6 2v8l-6 2-6-2z" /><path d="M8 6v8" /><path d="M2 4l6 2 6-2" />
      </svg>
      <span>Products</span>
    </a>
    <a href="/admin/settings" class:list={['admin-sidebar-link', { 'admin-sidebar-link--active': activeSection === 'settings' }]}>
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M8 10a2 2 0 1 0 0-4 2 2 0 0 0 0 4z" />
        <path d="M13.4 10a1.2 1.2 0 0 0 .2 1.3l.1.1a1.4 1.4 0 1 1-2 2l-.1-.1a1.2 1.2 0 0 0-1.3-.2 1.2 1.2 0 0 0-.7 1.1v.2a1.4 1.4 0 1 1-2.8 0v-.1a1.2 1.2 0 0 0-.8-1.1 1.2 1.2 0 0 0-1.3.2l-.1.1a1.4 1.4 0 1 1-2-2l.1-.1a1.2 1.2 0 0 0 .2-1.3 1.2 1.2 0 0 0-1.1-.7h-.2a1.4 1.4 0 1 1 0-2.8h.1a1.2 1.2 0 0 0 1.1-.8 1.2 1.2 0 0 0-.2-1.3l-.1-.1a1.4 1.4 0 1 1 2-2l.1.1a1.2 1.2 0 0 0 1.3.2h.1a1.2 1.2 0 0 0 .7-1.1v-.2a1.4 1.4 0 1 1 2.8 0v.1a1.2 1.2 0 0 0 .7 1.1 1.2 1.2 0 0 0 1.3-.2l.1-.1a1.4 1.4 0 1 1 2 2l-.1.1a1.2 1.2 0 0 0-.2 1.3v.1a1.2 1.2 0 0 0 1.1.7h.2a1.4 1.4 0 1 1 0 2.8h-.1a1.2 1.2 0 0 0-1.1.7z" />
      </svg>
      <span>Settings</span>
    </a>
  </nav>

  {recentPosts.length > 0 && (
    <div class="admin-sidebar-section">
      <div class="admin-sidebar-section-title">Recent Updates</div>
      <ul class="admin-sidebar-recent">
        {recentPosts.slice(0, 5).map((item) => (
          <li>
            <a
              href={item.type === 'post' ? `/admin/edit/${item.slug}` : `/admin/handbook/edit/${item.slug}`}
              class="admin-sidebar-recent-link"
            >
              <span class="admin-sidebar-recent-type">{item.type === 'post' ? 'P' : 'H'}</span>
              <span>{item.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  {stats && (
    <div class="admin-sidebar-section">
      <div class="admin-sidebar-section-title">Overview</div>
      <div class="admin-sidebar-stats">
        <div class="admin-sidebar-stat">
          <span class="admin-sidebar-stat-value">{stats.posts}</span>
          <span class="admin-sidebar-stat-label">Posts</span>
        </div>
        <div class="admin-sidebar-stat">
          <span class="admin-sidebar-stat-value">{stats.terms}</span>
          <span class="admin-sidebar-stat-label">Terms</span>
        </div>
        <div class="admin-sidebar-stat">
          <span class="admin-sidebar-stat-value">{stats.drafts}</span>
          <span class="admin-sidebar-stat-label">Drafts</span>
        </div>
      </div>
    </div>
  )}

  <div class="admin-sidebar-footer">
    <button type="button" class="admin-sidebar-link admin-sidebar-link--button" id="sidebar-theme-toggle">
      <svg id="sidebar-theme-icon-dark" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
      <svg id="sidebar-theme-icon-light" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="display:none;">
        <circle cx="12" cy="12" r="5"></circle>
        <line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
        <line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
      </svg>
      <svg id="sidebar-theme-icon-pink" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="display:none;">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
      </svg>
      <span id="sidebar-theme-label">Theme</span>
    </button>
    <a href="/en/" class="admin-sidebar-link" target="_blank">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M6 3H3v10h10v-3M9 2h5v5M14 2L7 9" />
      </svg>
      <span>View Site</span>
    </a>
    <form method="POST" action={`/api/auth/logout?redirectTo=${encodeURIComponent(currentPath)}`}>
      <button type="submit" class="admin-sidebar-link admin-sidebar-link--button">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M6 2H3v12h3M11 5l3 3-3 3M6 8h8" />
        </svg>
        <span>Logout</span>
      </button>
    </form>
  </div>
</aside>
<div class="admin-sidebar-overlay" id="sidebar-overlay"></div>

<script>
  // @ts-nocheck

  // Mobile menu — separated from initSidebar so the sidebar guard cannot skip it
  function initMobileMenu() {
    const sidebar = document.getElementById('admin-sidebar');
    const overlay = document.getElementById('sidebar-overlay');
    const mobileBtn = document.getElementById('mobile-menu-btn');
    if (!sidebar || !mobileBtn || mobileBtn.dataset.mobileInit === '1') return;
    mobileBtn.dataset.mobileInit = '1';

    function openMobileSidebar() {
      sidebar.classList.add('admin-sidebar--mobile-open');
      overlay?.classList.add('admin-sidebar-overlay--visible');
      document.body.style.overflow = 'hidden';
    }

    function closeMobileSidebar() {
      sidebar.classList.remove('admin-sidebar--mobile-open');
      overlay?.classList.remove('admin-sidebar-overlay--visible');
      document.body.style.overflow = '';
    }

    mobileBtn.addEventListener('click', openMobileSidebar);
    overlay?.addEventListener('click', closeMobileSidebar);

    sidebar.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        if (window.innerWidth < 768) closeMobileSidebar();
      });
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768) closeMobileSidebar();
    });
  }

  // Desktop sidebar collapse/expand + theme toggle
  function initSidebar() {
    const sidebar = document.getElementById('admin-sidebar');
    const toggle = document.getElementById('sidebar-toggle');
    if (!sidebar || sidebar.dataset.sidebarInit === '1') return;
    sidebar.dataset.sidebarInit = '1';

    sessionStorage.removeItem('admin-sidebar-collapsed-legacy');

    if (toggle && sessionStorage.getItem('admin-sidebar-collapsed') === '1') {
      sidebar.classList.add('admin-sidebar--collapsed');
      document.querySelectorAll('.admin-dashboard, .admin-editor-layout, #preview-mode').forEach((el) => {
        el.classList.add('admin-sidebar-collapsed');
      });
    }

    toggle?.addEventListener('click', () => {
      const collapsed = sidebar.classList.toggle('admin-sidebar--collapsed');
      sessionStorage.setItem('admin-sidebar-collapsed', collapsed ? '1' : '0');
      document.querySelectorAll('.admin-dashboard, .admin-editor-layout, #preview-mode').forEach((el) => {
        el.classList.toggle('admin-sidebar-collapsed', collapsed);
      });
    });

    const themeList = ['dark', 'light', 'pink'];
    const themeColors = { dark: '#18140F', light: '#F4F1EA', pink: '#FFF0F3' };

    function getSidebarTheme() {
      const stored = localStorage.getItem('theme') || document.documentElement.getAttribute('data-theme') || 'dark';
      return themeList.includes(stored) ? stored : 'dark';
    }

    function updateSidebarThemeUI() {
      const current = getSidebarTheme();
      const labelEl = document.getElementById('sidebar-theme-label');
      if (labelEl) labelEl.textContent = current.charAt(0).toUpperCase() + current.slice(1);
      themeList.forEach((t) => {
        const icon = document.getElementById(`sidebar-theme-icon-${t}`);
        if (icon) icon.style.display = t === current ? '' : 'none';
      });
    }

    document.getElementById('sidebar-theme-toggle')?.addEventListener('click', () => {
      const current = getSidebarTheme();
      const idx = themeList.indexOf(current);
      const next = themeList[(idx + 1) % themeList.length];
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      const meta = document.querySelector('meta[name="theme-color"]');
      if (meta) meta.setAttribute('content', themeColors[next] || themeColors.dark);
      updateSidebarThemeUI();
    });

    updateSidebarThemeUI();
  }

  document.addEventListener('astro:page-load', initSidebar);
  document.addEventListener('astro:page-load', initMobileMenu);
  document.addEventListener('DOMContentLoaded', initMobileMenu);
  initSidebar();
  initMobileMenu();
</script>
