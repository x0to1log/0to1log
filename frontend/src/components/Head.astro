---
interface ArticleData {
  datePublished: string;
  dateModified?: string;
  image?: string;
}

interface Props {
  title: string;
  description?: string;
  locale?: 'en' | 'ko';
  slug?: string;
  article?: ArticleData;
  needsKatex?: boolean;
}

const { title, description = '0to1log — AI News & Insights', locale = 'en', slug = '', article, needsKatex = false } = Astro.props;
const isBlogPage = Astro.url.pathname.includes('/blog/');
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://0to1log.com';
const canonicalUrl = `${siteUrl}/${locale}/${slug}`.replace(/\/+$/, '/');
const altLocale = locale === 'en' ? 'ko' : 'en';
const altUrl = `${siteUrl}/${altLocale}/${slug}`.replace(/\/+$/, '/');

const jsonLd = article ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": title,
  "datePublished": article.datePublished,
  "dateModified": article.dateModified || article.datePublished,
  "author": { "@type": "Person", "name": "Amy" },
  "publisher": {
    "@type": "Organization",
    "name": "0to1log",
    "url": siteUrl,
  },
  "mainEntityOfPage": canonicalUrl,
  ...(article.image ? { "image": article.image } : {}),
}) : null;
---

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="dns-prefetch" href="https://luwipptjfyjsleqouasj.supabase.co" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <script is:inline nonce={Astro.locals.cspNonce || ''}>
    (function(){var f=['https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Space+Grotesk:wght@400;500;600;700&family=Jost:wght@300;400;500;600;700&display=swap','https://hangeul.pstatic.net/hangeul_static/css/nanum-square.css'];f.forEach(function(h){var l=document.createElement('link');l.rel='stylesheet';l.href=h;document.head.appendChild(l)})})();
  </script>

  {needsKatex && <link rel="stylesheet" href="/katex/katex.min.css" />}

  <title>{title} | 0to1log</title>
  <meta name="description" content={description} />

  <!-- Canonical & Hreflang -->
  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" hreflang={locale} href={canonicalUrl} />
  <link rel="alternate" hreflang={altLocale} href={altUrl} />
  <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en/`} />

  <!-- Open Graph -->
  <meta property="og:title" content={`${title} | 0to1log`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content={locale === 'ko' ? 'ko_KR' : 'en_US'} />
  <meta property="og:image" content={article?.image || `${siteUrl}/og-default.png`} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | 0to1log`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={article?.image || `${siteUrl}/og-default.png`} />

  <!-- RSS Autodiscovery -->
  <link rel="alternate" type="application/rss+xml" title="0to1log RSS" href="/rss.xml" />

  <!-- Theme Color -->
  <meta name="theme-color" content="#241F1C" />

  <!-- JSON-LD (article pages only) -->
  {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}

</head>
