---
import { getCategoryColorVar, getCategoryLabel, getDefaultCategories, normalizeCategorySlug } from '../../lib/categories';

interface FilterItem {
  value: string;
  label: string;
  colorVar?: string;
}

interface Props {
  locale: 'en' | 'ko';
  categories?: string[];
  items?: FilterItem[];
  filterKey?: string;
}

const { locale, categories = getDefaultCategories(), items, filterKey = 'category' } = Astro.props;
const isKo = locale === 'ko';

const tabs: FilterItem[] = items
  ? items
  : Array.from(
      new Set(categories.map((c) => normalizeCategorySlug(c)).filter(Boolean) as string[]),
    ).map((slug) => ({
      value: slug,
      label: getCategoryLabel(locale, slug) || slug,
      colorVar: getCategoryColorVar(slug),
    }));
---

<nav class="newsprint-filter-tabs" role="tablist" aria-label={isKo ? '카테고리 필터' : 'Category filter'} data-filter-key={filterKey}>
  <button
    class="newsprint-filter-tab"
    role="tab"
    data-filter="all"
    aria-selected="true"
    tabindex="0"
    style="--tab-cat-color: var(--color-accent);"
  >
    {isKo ? '전체' : 'All'}
  </button>
  {tabs.map((tab) => (
    <button
      class="newsprint-filter-tab"
      role="tab"
      data-filter={tab.value}
      aria-selected="false"
      tabindex="-1"
      style={`--tab-cat-color: ${tab.colorVar || 'var(--color-accent)'};`}
    >
      {tab.label}
    </button>
  ))}
</nav>

<script>
  function initCategoryFilter(): void {
    const nav = document.querySelector<HTMLElement>('.newsprint-filter-tabs');
    if (!nav) return;

    const tabs = Array.from(nav.querySelectorAll<HTMLButtonElement>('.newsprint-filter-tab'));
    if (tabs.length === 0) return;

    const filterKey = nav.dataset.filterKey || 'category';
    const params = new URLSearchParams(window.location.search);
    const rawFilter = params.get(filterKey);
    const initialCat = filterKey === 'category' && rawFilter === 'tech' ? 'study' : (rawFilter || 'all');

    function activate(value: string, focusTab = false): void {
      tabs.forEach((tab) => {
        const isActive = tab.dataset.filter === value;
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
        tab.setAttribute('tabindex', isActive ? '0' : '-1');
        if (isActive && focusTab) tab.focus();
      });

      const dataAttr = filterKey === 'category' ? 'category' : 'postType';
      document.querySelectorAll<HTMLElement>('.newsprint-card[data-category]').forEach((card) => {
        const cardValue = card.dataset[dataAttr];
        const visible = value === 'all' || cardValue === value;
        card.setAttribute('data-filtered', visible ? 'true' : 'false');
      });

      document.querySelectorAll<HTMLElement>('.newsprint-featured').forEach((section) => {
        const sectionValue = section.dataset[dataAttr];
        const visible = value === 'all' || sectionValue === value;
        section.setAttribute('data-filtered', visible ? 'true' : 'false');
      });

      const url = new URL(window.location.href);
      if (value === 'all') {
        url.searchParams.delete(filterKey);
      } else {
        url.searchParams.set(filterKey, value);
      }
      history.replaceState(null, '', url.toString());
    }

    nav.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.newsprint-filter-tab');
      if (btn) activate(btn.dataset.filter || 'all');
    });

    nav.addEventListener('keydown', (e) => {
      const current = document.activeElement as HTMLButtonElement;
      const idx = tabs.indexOf(current);
      if (idx === -1) return;

      let next = -1;
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
        next = (idx + 1) % tabs.length;
      } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
        next = (idx - 1 + tabs.length) % tabs.length;
      } else if (e.key === 'Home') {
        next = 0;
      } else if (e.key === 'End') {
        next = tabs.length - 1;
      }

      if (next !== -1) {
        e.preventDefault();
        activate(tabs[next].dataset.filter || 'all', true);
      }
    });

    activate(initialCat);
  }

  document.addEventListener('astro:page-load', initCategoryFilter);
</script>
