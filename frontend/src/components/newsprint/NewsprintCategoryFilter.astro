---
import { getCategoryColorVar, getCategoryLabel, getDefaultCategories, normalizeCategorySlug } from '../../lib/categories';

interface Props {
  locale: 'en' | 'ko';
  categories?: string[];
}

const { locale, categories = getDefaultCategories() } = Astro.props;
const isKo = locale === 'ko';
const tabs = [
  'all',
  ...Array.from(
    new Set(categories.map((category) => normalizeCategorySlug(category)).filter(Boolean) as string[]),
  ),
];
---

<nav class="newsprint-filter-tabs" role="tablist" aria-label={isKo ? '카테고리 필터' : 'Category filter'}>
  {tabs.map((cat) => (
    <button
      class="newsprint-filter-tab"
      role="tab"
      data-filter={cat}
      aria-selected={cat === 'all' ? 'true' : 'false'}
      tabindex={cat === 'all' ? '0' : '-1'}
      style={`--tab-cat-color: ${cat === 'all' ? 'var(--color-accent)' : getCategoryColorVar(cat)};`}
    >
      {cat === 'all' ? (locale === 'ko' ? '전체' : 'All') : getCategoryLabel(locale, cat)}
    </button>
  ))}
</nav>

<script>
  function initCategoryFilter(): void {
    const nav = document.querySelector<HTMLElement>('.newsprint-filter-tabs');
    if (!nav) return;

    const tabs = Array.from(nav.querySelectorAll<HTMLButtonElement>('.newsprint-filter-tab'));
    if (tabs.length === 0) return;

    const params = new URLSearchParams(window.location.search);
    const rawCategory = params.get('category');
    const initialCat = rawCategory === 'tech' ? 'study' : (rawCategory || 'all');

    function activate(category: string, focusTab = false): void {
      tabs.forEach((tab) => {
        const isActive = tab.dataset.filter === category;
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
        tab.setAttribute('tabindex', isActive ? '0' : '-1');
        if (isActive && focusTab) tab.focus();
      });

      document.querySelectorAll<HTMLElement>('.newsprint-card[data-category]').forEach((card) => {
        const visible = category === 'all' || card.dataset.category === category;
        card.setAttribute('data-filtered', visible ? 'true' : 'false');
      });

      document.querySelectorAll<HTMLElement>('.newsprint-featured').forEach((section) => {
        const visible = category === 'all' || section.dataset.category === category;
        section.setAttribute('data-filtered', visible ? 'true' : 'false');
      });

      const url = new URL(window.location.href);
      if (category === 'all') {
        url.searchParams.delete('category');
      } else {
        url.searchParams.set('category', category);
      }
      history.replaceState(null, '', url.toString());
    }

    nav.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.newsprint-filter-tab');
      if (btn) activate(btn.dataset.filter || 'all');
    });

    nav.addEventListener('keydown', (e) => {
      const current = document.activeElement as HTMLButtonElement;
      const idx = tabs.indexOf(current);
      if (idx === -1) return;

      let next = -1;
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
        next = (idx + 1) % tabs.length;
      } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
        next = (idx - 1 + tabs.length) % tabs.length;
      } else if (e.key === 'Home') {
        next = 0;
      } else if (e.key === 'End') {
        next = tabs.length - 1;
      }

      if (next !== -1) {
        e.preventDefault();
        activate(tabs[next].dataset.filter || 'all', true);
      }
    });

    activate(initialCat);
  }

  document.addEventListener('astro:page-load', initCategoryFilter);
</script>
