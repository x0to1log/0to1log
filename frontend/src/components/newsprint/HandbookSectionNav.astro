---
/**
 * HandbookSectionNav — dynamic section TOC (HB-UX Phase 1.5)
 *
 * Extracts h2 headings from #handbook-body at runtime and builds a sticky
 * nav in the side rail. Rebuilds on `reading-content-changed` so the
 * Basic/Advanced level switch stays in sync. Hidden when the current
 * level has fewer than 2 headings and on viewports below 1024px.
 *
 * NOTE: styles live in global.css, not in a scoped <style> block, because
 * the <li>/<a> children are created at runtime via document.createElement
 * and therefore don't carry Astro's data-astro-cid scoping attribute.
 * Scoped styles would silently fail to apply to them.
 */
interface Props {
  locale: 'ko' | 'en';
}
const { locale } = Astro.props;
const isKo = locale === 'ko';
const label = isKo ? '목차' : 'Contents';
---

<nav class="handbook-toc" data-handbook-toc aria-label={label} hidden>
  <p class="handbook-toc__title">{label}</p>
  <ol class="handbook-toc__list" data-handbook-toc-list></ol>
</nav>

<script>
  let observer: IntersectionObserver | null = null;
  const liByHeadingId = new Map<string, HTMLLIElement>();

  function buildTOC(): void {
    const nav = document.querySelector<HTMLElement>('[data-handbook-toc]');
    const list = document.querySelector<HTMLOListElement>('[data-handbook-toc-list]');
    const body = document.getElementById('handbook-body');
    if (!nav || !list || !body) return;

    const headings = Array.from(body.querySelectorAll<HTMLHeadingElement>('h2'));
    if (headings.length < 2) {
      nav.hidden = true;
      list.innerHTML = '';
      if (observer) { observer.disconnect(); observer = null; }
      liByHeadingId.clear();
      return;
    }

    if (observer) { observer.disconnect(); observer = null; }
    liByHeadingId.clear();
    list.innerHTML = '';

    headings.forEach((h, idx) => {
      if (!h.id) h.id = `handbook-section-${idx}`;
      const li = document.createElement('li');
      li.className = 'handbook-toc__item';
      li.dataset.active = 'false';

      const a = document.createElement('a');
      a.className = 'handbook-toc__link';
      a.href = `#${h.id}`;
      const fullText = (h.textContent || '').trim();
      a.title = fullText;

      const textSpan = document.createElement('span');
      textSpan.className = 'handbook-toc__text';
      textSpan.textContent = fullText;
      a.appendChild(textSpan);

      a.addEventListener('click', (e) => {
        e.preventDefault();
        const top = h.getBoundingClientRect().top + window.scrollY - 96;
        window.scrollTo({ top, behavior: 'smooth' });
        history.replaceState(null, '', `#${h.id}`);
      });

      li.appendChild(a);
      list.appendChild(li);
      liByHeadingId.set(h.id, li);
    });

    nav.hidden = false;

    observer = new IntersectionObserver(
      (entries) => {
        const visible = entries.filter((e) => e.isIntersecting);
        if (visible.length === 0) return;
        const topmost = visible.reduce((a, b) =>
          a.boundingClientRect.top < b.boundingClientRect.top ? a : b
        );
        const activeId = (topmost.target as HTMLElement).id;
        liByHeadingId.forEach((li, id) => {
          li.dataset.active = id === activeId ? 'true' : 'false';
        });
      },
      { rootMargin: '-20% 0% -60% 0%', threshold: 0 }
    );

    headings.forEach((h) => observer!.observe(h));
  }

  function init(): void {
    buildTOC();
    window.addEventListener('reading-content-changed', buildTOC);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
