---
import { getCategoryColorVar, getCategoryLabel, normalizeCategorySlug } from '../../lib/categories';

interface Props {
  href: string;
  title: string;
  excerpt?: string | null;
  category?: string | null;
  publishedAt?: string | null;
  readingTimeMin?: number | null;
  tags?: string[] | null;
  locale: 'en' | 'ko';
  isRead?: boolean;
  isBookmarked?: boolean;
  itemId?: string;
  itemType?: 'news' | 'blog' | 'term';
  postType?: string | null;
}

const { href, title, excerpt, category, publishedAt, readingTimeMin, tags, locale, isRead = false, isBookmarked = false, itemId, itemType, postType } = Astro.props;
const dateLabel = publishedAt
  ? new Date(publishedAt).toLocaleDateString(locale === 'ko' ? 'ko-KR' : 'en-US')
  : null;
const readingLabel = readingTimeMin
  ? locale === 'ko'
    ? `약 ${readingTimeMin}분`
    : `${readingTimeMin} min read`
  : null;
const normalizedCategory = normalizeCategorySlug(category);
const categoryLabel = getCategoryLabel(locale, category);
const catColor = getCategoryColorVar(category);

const cardClasses = ['newsprint-card', isRead && 'newsprint-card--read'].filter(Boolean).join(' ');
const searchText = [title, excerpt, tags?.join(' ')].filter(Boolean).join(' ');
---

<article
  class={cardClasses}
  data-category={normalizedCategory || 'uncategorized'}
  data-post-type={postType || 'business'}
  data-search-text={searchText}
>
  {categoryLabel && (
    <span class="newsprint-card-kicker" style={`color: ${catColor};`}>{categoryLabel}{postType && <span class={`newsprint-card-kicker-type newsprint-card-kicker-type--${postType}`}>{postType === 'weekly' ? 'Weekly' : postType === 'research' ? 'Research' : 'Business'}</span>}</span>
  )}
  <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 0.5rem;">
    <h2 class="newsprint-card-title" style="flex: 1;"><a href={href} class="newsprint-card-stretched-link">{title}</a></h2>
    {itemId && (
      <button
        class={`newsprint-bookmark-icon ${isBookmarked ? 'newsprint-bookmark-icon--active' : ''}`}
        data-item-id={itemId}
        data-item-type={itemType}
        data-bookmarked={isBookmarked ? 'true' : 'false'}
        aria-label={isBookmarked ? 'Remove bookmark' : 'Add bookmark'}
      >
        <svg viewBox="0 0 24 24" fill={isBookmarked ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2">
          <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" />
        </svg>
      </button>
    )}
  </div>
  {excerpt && <p class="newsprint-excerpt">{excerpt}</p>}
  <div class="newsprint-card-bottom">
    {tags && tags.length > 0 && (
      <span class="newsprint-tags-inline">
        {tags.slice(0, 4).map((tag) => (
          <span class="newsprint-tag">{tag}</span>
        ))}
      </span>
    )}
    <span class="newsprint-meta-inline">
      {readingLabel && <span class="newsprint-reading-time"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>{readingLabel}</span>}
      {dateLabel && <time datetime={publishedAt ?? undefined}>{dateLabel}</time>}
    </span>
  </div>
</article>
