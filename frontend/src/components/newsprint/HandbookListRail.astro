---
import { getHandbookCategoryLabel, getHandbookCategories } from '../../lib/handbookCategories';

interface RailTerm {
  term: string;
  slug: string;
  difficulty?: string | null;
}

interface CategoryIcon {
  title: string;
  paths: string[];
}

interface Props {
  locale: 'en' | 'ko';
  terms: RailTerm[];
  editorialNote?: string;
}

const { locale, terms, editorialNote: editorialNoteProp } = Astro.props;
const isKo = locale === 'ko';
const categories = getHandbookCategories();

const editorialNote = editorialNoteProp || (isKo
  ? 'AI, 백엔드, 프론트엔드, 보안, 운영 전반의 기술 용어를 한 곳에서 읽기 쉽게 정리합니다.'
  : 'A concise reference of technical terms across AI, backend, frontend, security, and operations.');

const CATEGORY_ICONS: Record<string, CategoryIcon> = {
  web3: {
    title: 'Web3',
    paths: [
      'M8 2.5 12.5 5v6L8 13.5 3.5 11V5L8 2.5Z',
      'M8 6.2 10 7.2v2.6L8 10.8 6 9.8V7.2l2-1Z',
    ],
  },
  'ai-ml': {
    title: 'AI/ML',
    paths: [
      'M5 5.5h6v5H5z',
      'M8 2.5v2M8 11v2M2.5 8h2M11.5 8h2M4 4l1.2 1.2M10.8 10.8 12 12M12 4l-1.2 1.2M5.2 10.8 4 12',
    ],
  },
  performance: {
    title: 'Performance',
    paths: [
      'M3 10.5a5 5 0 0 1 10 0',
      'M8 10.5 10.8 7.8',
      'M5.5 13h5',
    ],
  },
  devops: {
    title: 'DevOps',
    paths: [
      'M4.2 5.2h4v-2.2L11.8 6l-3.6 3V6.8h-4',
      'M11.8 10.8h-4V13L4.2 10l3.6-3v2.2h4',
    ],
  },
  'frontend-ux': {
    title: 'Frontend',
    paths: [
      'M3 4h10v8H3z',
      'M3 6.5h10',
      'M6 13.5h4',
      'M5.2 9.2 6.8 7.6 8.4 9.2',
    ],
  },
  backend: {
    title: 'Backend',
    paths: [
      'M4 4.5h8v2.5H4z',
      'M4 8.5h8V11H4z',
      'M5.2 5.8h.01M5.2 9.8h.01',
    ],
  },
  security: {
    title: 'Security',
    paths: [
      'M8 3l4 1.5v3.2c0 2.4-1.6 4.6-4 5.8-2.4-1.2-4-3.4-4-5.8V4.5L8 3Z',
      'M6.8 8V6.9a1.2 1.2 0 1 1 2.4 0V8',
      'M6.3 8h3.4v2.3H6.3z',
    ],
  },
  'db-data': {
    title: 'Database',
    paths: [
      'M3.5 5.2c0-1.2 2-2.2 4.5-2.2s4.5 1 4.5 2.2-2 2.2-4.5 2.2-4.5-1-4.5-2.2Z',
      'M3.5 5.2v4.6c0 1.2 2 2.2 4.5 2.2s4.5-1 4.5-2.2V5.2',
    ],
  },
  network: {
    title: 'Network',
    paths: [
      'M8 3.2a1 1 0 1 0 0 2 1 1 0 0 0 0-2Zm-4 6a1 1 0 1 0 0 2 1 1 0 0 0 0-2Zm8 0a1 1 0 1 0 0 2 1 1 0 0 0 0-2Z',
      'M8 5.2v3.1M8 8.3 4.8 9.4M8 8.3l3.2 1.1',
    ],
  },
  'os-core': {
    title: 'OS',
    paths: [
      'M5 4h6v8H5z',
      'M7 2.8h2M7 13.2h2',
      'M3.8 6v4M12.2 6v4',
    ],
  },
};
---

<section>
  <h3 class="newsprint-section-title">{isKo ? '핸드북 소개' : 'About This Handbook'}</h3>
  <p class="newsprint-rail-note">{editorialNote}</p>
</section>

<div style="margin-top: 1.5rem;"></div>

<section>
  <h3 class="newsprint-section-title">{isKo ? '많이 찾는 용어' : 'Popular Terms'}</h3>
  {terms.length === 0 ? (
    <p class="newsprint-empty">{isKo ? '아직 표시할 용어가 없습니다.' : 'No items yet.'}</p>
  ) : (
    <div class="newsprint-stack">
      {terms.map((t) => (
        <a class="newsprint-card" href={`/${locale}/handbook/${t.slug}/`}>
          <strong class="newsprint-rail-link">{t.term}</strong>
        </a>
      ))}
    </div>
  )}
</section>

<div style="margin-top: 1.5rem;"></div>

<section>
  <h3 class="newsprint-section-title">{isKo ? '카테고리 둘러보기' : 'Browse by Category'}</h3>
  <div class="newsprint-stack">
      {categories.map((cat) => (
        <a class="newsprint-card newsprint-rail-category-link" href={`/${locale}/handbook/?category=${cat}`}>
          <span class="newsprint-rail-category-icon" aria-hidden="true" title={CATEGORY_ICONS[cat]?.title || cat}>
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round">
              {CATEGORY_ICONS[cat]?.paths.map((path) => (
                <path d={path} />
              ))}
            </svg>
          </span>
          <span class="newsprint-rail-note newsprint-rail-category-label">{getHandbookCategoryLabel(locale, cat)}</span>
        </a>
      ))}
    </div>
</section>
