---
import { getCategoryLabel } from '../../lib/categories';

interface StarterSection {
  slug: string;
  label: string;
  description: string;
}

interface RailPost {
  title: string;
  slug: string;
  category?: string | null;
}

interface Props {
  locale: 'en' | 'ko';
  posts: RailPost[];
  editorialNote?: string;
  startHereSections?: StarterSection[];
  basePath?: string;
}

const { locale, posts, editorialNote: editorialNoteProp, startHereSections: startHereProp, basePath } = Astro.props;
const resolvedBasePath = basePath || `/${locale}/news`;
const isKo = locale === 'ko';

const editorialNote = editorialNoteProp || (isKo
  ? '오늘의 변화와 작업 기록을 AI 뉴스, 서재, 커리어, 프로젝트의 흐름으로 엮어 둡니다.'
  : 'A daily record of shifts, working notes, and build logs across AI, study, career, and projects.');

const getStarterHref = (slug: string) => {
  switch (slug) {
    case 'ai-news':
      return `/${locale}/news/`;
    case 'study':
      return `/${locale}/handbook/`;
    case 'career':
      return '/library/';
    case 'project':
      return `/${locale}/blog/`;
    default:
      return `/${locale}/news/`;
  }
};

const defaultStarterSections: StarterSection[] = isKo
  ? [
      { slug: 'ai-news', label: 'AI 뉴스', description: '오늘 꼭 봐야 할 AI 변화부터 빠르게 읽습니다.' },
      { slug: 'study', label: 'AI 용어집', description: '읽다가 막히는 AI 용어를 바로 찾아 이해합니다.' },
      { slug: 'career', label: '나의 서재', description: '읽은 뉴스와 용어를 차곡차곡 모아둡니다.' },
      { slug: 'project', label: 'IT 블로그', description: '빌드 과정과 기록을 찬찬히 풀어봅니다.' },
    ]
  : [
      { slug: 'ai-news', label: 'AI News', description: 'Read the most important AI shifts first.' },
      { slug: 'study', label: 'AI Glossary', description: 'Look up unfamiliar terms without leaving the flow.' },
      { slug: 'career', label: 'My Library', description: 'Keep the news and terms that stay with you.' },
      { slug: 'project', label: 'IT Blog', description: 'Explore the builds, reflections, and technical work behind the product.' },
    ];

const starterSections = (startHereProp && startHereProp.length > 0) ? startHereProp : defaultStarterSections;
---

<section>
  <h3 class="newsprint-section-title">{isKo ? '오늘의 편집 노트' : "Editor's Note"}</h3>
  <p class="newsprint-rail-note">{editorialNote}</p>
</section>

<hr class="newsprint-rail-divider" />

<section>
  <h3 class="newsprint-section-title">{isKo ? '지금 많이 읽는 글' : 'Most Read'}</h3>
  {posts.length === 0 ? (
    <p class="newsprint-empty">{isKo ? '아직 표시할 글이 없습니다.' : 'No items yet.'}</p>
  ) : (
    <div class="newsprint-stack">
      {posts.map((post) => (
        <a class="newsprint-card" href={`${resolvedBasePath}/${post.slug}/`}>
          <strong class="newsprint-rail-link">{post.title}</strong>
          {getCategoryLabel(locale, post.category) && (
            <span class="newsprint-category newsprint-rail-category">
              {getCategoryLabel(locale, post.category)}
            </span>
          )}
        </a>
      ))}
    </div>
  )}
</section>

