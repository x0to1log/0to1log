---
import { getCategoryLabel } from '../../lib/categories';

interface SimilarPost {
  post_id: string;
  slug: string;
  title: string;
  category: string;
}

interface RelatedTerm {
  slug: string;
  term: string;
  koreanName: string;
  definition: string;
}

interface Props {
  locale: 'en' | 'ko';
  focusItems: string[];
  basePath?: string;
  similarPosts?: SimilarPost[];
  relatedTerms?: RelatedTerm[];
}

const { locale, focusItems, basePath, similarPosts = [], relatedTerms = [] } = Astro.props;
const resolvedBasePath = basePath || `/${locale}/news`;
const isKo = locale === 'ko';
---

<section>
  <h3 class="newsprint-section-title">{isKo ? '이 글의 요약' : 'Summary of This Article'}</h3>
  {focusItems.length === 0 ? (
    <p class="newsprint-empty">{isKo ? '핵심 포인트를 준비 중입니다.' : 'Key points are on the way.'}</p>
  ) : (
    <ul class="newsprint-rail-list">
      {focusItems.map((item) => <li>{item}</li>)}
    </ul>
  )}
</section>

{relatedTerms.length > 0 && (
  <>
    <div style="margin-top: 1.5rem;"></div>
    <section>
      <h3 class="newsprint-section-title">{isKo ? '이 글의 키워드' : 'Keywords in This Article'}</h3>
      <div class="newsprint-stack">
        {relatedTerms.map((t) => (
          <a class="newsprint-card" href={`/${locale}/handbook/${t.slug}/`}>
            <strong class="newsprint-rail-link">{isKo && t.koreanName ? t.koreanName : t.term}</strong>
            {!isKo || t.koreanName ? <span class="newsprint-related-tag" style="font-weight: 400;">{t.term}</span> : null}
            {t.definition && <p class="newsprint-related-summary">{t.definition}</p>}
          </a>
        ))}
      </div>
    </section>
  </>
)}

{similarPosts.length > 0 && (
  <>
    <div style="margin-top: 1.5rem;"></div>
    <section>
      <h3 class="newsprint-section-title">{isKo ? '비슷한 뉴스 더 보기' : 'More Like This'}</h3>
      <div class="newsprint-stack">
        {similarPosts.map((p) => (
          <a class="newsprint-card" href={`${resolvedBasePath}/${p.slug}/`}>
            <strong class="newsprint-rail-link">{p.title}</strong>
            {getCategoryLabel(locale, p.category) && (
              <span class="newsprint-category newsprint-rail-category">
                {getCategoryLabel(locale, p.category)}
              </span>
            )}
          </a>
        ))}
      </div>
    </section>
  </>
)}
