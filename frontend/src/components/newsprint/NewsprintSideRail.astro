---
import { getCategoryLabel } from '../../lib/categories';

interface RailPost {
  title: string;
  slug: string;
  category?: string | null;
}

interface RelatedNewsItem {
  title: string;
  url: string;
  summary: string;
}

interface RelatedNews {
  big_tech?: RelatedNewsItem | null;
  industry_biz?: RelatedNewsItem | null;
  new_tools?: RelatedNewsItem | null;
}

interface SimilarPost {
  post_id: string;
  slug: string;
  title: string;
  category: string;
}

interface Props {
  locale: 'en' | 'ko';
  posts: RailPost[];
  focusItems: string[];
  relatedNews?: RelatedNews | null;
  basePath?: string;
  similarPosts?: SimilarPost[];
}

const { locale, posts, focusItems, relatedNews, basePath, similarPosts = [] } = Astro.props;
const resolvedBasePath = basePath || `/${locale}/news`;
const isKo = locale === 'ko';

const relatedEntries: { tag: string; item: RelatedNewsItem }[] = [];
if (relatedNews?.big_tech) relatedEntries.push({ tag: 'Big Tech', item: relatedNews.big_tech });
if (relatedNews?.industry_biz) relatedEntries.push({ tag: isKo ? '산업·비즈' : 'Industry & Biz', item: relatedNews.industry_biz });
if (relatedNews?.new_tools) relatedEntries.push({ tag: isKo ? '새 도구' : 'New Tools', item: relatedNews.new_tools });
---

<section>
  <h3 class="newsprint-section-title">{isKo ? '이 글의 요약' : 'Summary of This Article'}</h3>
  {focusItems.length === 0 ? (
    <p class="newsprint-empty">{isKo ? '핵심 포인트를 준비 중입니다.' : 'Key points are on the way.'}</p>
  ) : (
    <ul class="newsprint-rail-list">
      {focusItems.map((item) => <li>{item}</li>)}
    </ul>
  )}
</section>

<div style="margin-top: 1.5rem;"></div>

<section>
  <h3 class="newsprint-section-title">{isKo ? '비슷한 뉴스 더 보기' : 'More in This Issue'}</h3>
  {posts.length === 0 ? (
    <p class="newsprint-empty">{isKo ? '아직 연결된 글이 없습니다.' : 'No related items yet.'}</p>
  ) : (
    <div class="newsprint-stack">
      {posts.map((post) => (
        <a class="newsprint-card" href={`${resolvedBasePath}/${post.slug}/`}>
          <strong class="newsprint-rail-link">{post.title}</strong>
          {getCategoryLabel(locale, post.category) && (
            <span class="newsprint-category newsprint-rail-category">
              {getCategoryLabel(locale, post.category)}
            </span>
          )}
        </a>
      ))}
    </div>
  )}
</section>

{relatedEntries.length > 0 && (
  <>
    <div style="margin-top: 1.5rem;"></div>
    <section>
      <h3 class="newsprint-section-title">{isKo ? '관련 뉴스' : 'Related News'}</h3>
      <div class="newsprint-stack">
        {relatedEntries.map(({ tag, item }) => (
          <a class="newsprint-card newsprint-related-card" href={item.url} target="_blank" rel="noopener noreferrer">
            <span class="newsprint-related-tag">{tag}</span>
            <strong class="newsprint-rail-link">{item.title}</strong>
            <p class="newsprint-related-summary">{item.summary}</p>
          </a>
        ))}
      </div>
    </section>
  </>
)}

{similarPosts.length > 0 && (
  <>
    <div style="margin-top: 1.5rem;"></div>
    <section>
      <h3 class="newsprint-section-title">{isKo ? '비슷한 글' : 'You Might Also Like'}</h3>
      <div class="newsprint-stack">
        {similarPosts.map((p) => (
          <a class="newsprint-card" href={`${resolvedBasePath}/${p.slug}/`}>
            <strong class="newsprint-rail-link">{p.title}</strong>
            {getCategoryLabel(locale, p.category) && (
              <span class="newsprint-category newsprint-rail-category">
                {getCategoryLabel(locale, p.category)}
              </span>
            )}
          </a>
        ))}
      </div>
    </section>
  </>
)}
