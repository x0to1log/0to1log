---
interface Props {
  locale: 'en' | 'ko';
}

const { locale } = Astro.props;

const copy =
  locale === 'ko'
    ? {
        title: '이 설명이 도움이 되었나요?',
        body: '짧은 피드백은 더 좋은 설명을 만드는 데 도움이 됩니다.',
        helpful: '도움 됨',
        confusing: '헷갈림',
      }
    : {
        title: 'Was this explanation helpful?',
        body: 'Quick feedback helps improve future explanations.',
        helpful: 'Helpful',
        confusing: 'Confusing',
      };
---

<section class="handbook-feedback" aria-label={copy.title}>
  <div class="handbook-feedback-inner">
    <div class="handbook-feedback-copy">
      <h3 class="handbook-feedback-title">{copy.title}</h3>
      <p class="handbook-feedback-body">{copy.body}</p>
    </div>
    <div class="handbook-feedback-actions">
      <button type="button" class="handbook-feedback-btn handbook-feedback-btn--helpful" aria-label={copy.helpful}>
        {copy.helpful}
      </button>
      <button type="button" class="handbook-feedback-btn handbook-feedback-btn--confusing" aria-label={copy.confusing}>
        {copy.confusing}
      </button>
    </div>
  </div>
</section>
