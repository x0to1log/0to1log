---
interface Props {
  locale: 'en' | 'ko';
  termId: string;
  isAuthenticated?: boolean;
  loginUrl: string;
}

const { locale, termId, isAuthenticated = false, loginUrl } = Astro.props;

const copy =
  locale === 'ko'
    ? {
        title: '이 설명이 도움이 되었나요?',
        body: '짧은 피드백은 더 좋은 설명을 만드는 데 도움이 됩니다.',
        helpful: '도움 됨',
        confusing: '헷갈림',
        thanksHelpful: '피드백 감사합니다.',
        thanksConfusing: '헷갈린다는 신호를 기록했습니다.',
        error: '피드백 저장에 실패했습니다.',
      }
    : {
        title: 'Was this explanation helpful?',
        body: 'Quick feedback helps improve future explanations.',
        helpful: 'Helpful',
        confusing: 'Confusing',
        thanksHelpful: 'Thanks for the feedback.',
        thanksConfusing: 'Got it. We recorded that this felt unclear.',
        error: 'Failed to save feedback.',
      };
---

<section
  class="handbook-feedback"
  aria-label={copy.title}
  data-handbook-feedback
  data-term-id={termId}
  data-locale={locale}
  data-authenticated={isAuthenticated ? 'true' : 'false'}
  data-auth-action="feedback"
  data-login-url={loginUrl}
  data-thanks-helpful={copy.thanksHelpful}
  data-thanks-confusing={copy.thanksConfusing}
  data-error={copy.error}
>
  <div class="handbook-feedback-inner">
    <div class="handbook-feedback-copy">
      <h3 class="handbook-feedback-title">{copy.title}</h3>
      <p class="handbook-feedback-body">{copy.body}</p>
      <p class="handbook-feedback-status" data-feedback-status aria-live="polite" hidden></p>
    </div>
    <div class="handbook-feedback-actions">
      <button
        type="button"
        class="handbook-feedback-btn handbook-feedback-btn--confusing"
        aria-label={copy.confusing}
        aria-pressed="false"
        data-reaction="confusing"
        data-auth-action="feedback"
      >
        {copy.confusing}
      </button>
      <button
        type="button"
        class="handbook-feedback-btn handbook-feedback-btn--helpful"
        aria-label={copy.helpful}
        aria-pressed="false"
        data-reaction="helpful"
        data-auth-action="feedback"
      >
        {copy.helpful}
      </button>
    </div>
  </div>
</section>
