---
import { getCategoryLabel } from '../../lib/categories';

interface Props {
  locale: 'en' | 'ko';
  slug: string;
  showSlug?: boolean;
  title: string;
  excerpt?: string | null;
  category?: string | null;
  publishedAt?: string | null;
  readingTimeMin?: number | null;
  tags?: string[] | null;
  htmlContent: string;
  backLabel: string;
  nextPost?: { title: string; slug: string; category?: string | null } | null;
  isBookmarked?: boolean;
  itemId?: string;
  itemType?: 'post' | 'term';
}

const {
  locale,
  slug,
  showSlug = false,
  title,
  excerpt,
  category,
  publishedAt,
  readingTimeMin,
  tags,
  htmlContent,
  backLabel,
  nextPost = null,
  isBookmarked = false,
  itemId,
  itemType,
} = Astro.props;

const dateLabel = publishedAt
  ? new Date(publishedAt).toLocaleDateString(locale === 'ko' ? 'ko-KR' : 'en-US')
  : null;
const readingLabel = readingTimeMin
  ? locale === 'ko'
    ? `약 ${readingTimeMin}분`
    : `${readingTimeMin} min read`
  : null;
const categoryLabel = getCategoryLabel(locale, category);
const nextCategoryLabel = nextPost?.category ? getCategoryLabel(locale, nextPost.category) : null;
---

<article class="newsprint-article">
  <div class="newsprint-article-header">
    <div class="newsprint-article-header-left">
      {categoryLabel && <span class="newsprint-category">{categoryLabel}</span>}
      {tags && tags.length > 0 && (
        <>
          {tags.slice(0, 6).map((tag) => (
            <span class="newsprint-tag">{tag}</span>
          ))}
        </>
      )}
    </div>
    <div class="newsprint-article-header-right">
      {readingLabel && <span>{readingLabel}</span>}
      {dateLabel && <time datetime={publishedAt ?? undefined}>{dateLabel}</time>}
    </div>
  </div>

  <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem;">
    <h1 class="newsprint-lead-title" style="flex: 1;">{title}</h1>
    {itemId && (
      <button
        class={`newsprint-bookmark-icon newsprint-bookmark-icon--detail ${isBookmarked ? 'newsprint-bookmark-icon--active' : ''}`}
        data-item-id={itemId}
        data-item-type={itemType}
        data-bookmarked={isBookmarked ? 'true' : 'false'}
        aria-label={isBookmarked ? 'Remove bookmark' : 'Add bookmark'}
        style="margin-top: 0.5rem;"
      >
        <svg viewBox="0 0 24 24" fill={isBookmarked ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2">
          <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" />
        </svg>
      </button>
    )}
  </div>
  {excerpt && <p class="newsprint-deck">{excerpt}</p>}
  <div class="newsprint-divider"></div>

  <div class="newsprint-prose">
    <Fragment set:html={htmlContent} />
  </div>

  <nav class="newsprint-article-nav" aria-label={locale === 'ko' ? '글 탐색' : 'Article navigation'}>
    <div class="newsprint-article-nav-row">
      <a class="newsprint-nav-back" href={`/${locale}/log/`}>
        <span class="newsprint-nav-back-arrow">&larr;</span>
        <span>{backLabel}</span>
      </a>
      {nextPost && (
        <a class="newsprint-nav-next" href={`/${locale}/log/${nextPost.slug}/`}>
          <span class="newsprint-nav-next-arrow">&rarr;</span>
          <div class="newsprint-nav-next-title">{nextPost.title}</div>
          {nextCategoryLabel && (
            <div class="newsprint-nav-next-meta">{nextCategoryLabel}</div>
          )}
        </a>
      )}
    </div>
  </nav>
</article>
