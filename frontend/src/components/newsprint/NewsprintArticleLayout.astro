---
import { getCategoryLabel, getCategoryColorVar } from '../../lib/categories';
import PreviewReadonlyBanner from '../common/PreviewReadonlyBanner.astro';
import StickyReadingActions from '../common/StickyReadingActions.astro';
import ReadingProgressBar from '../common/ReadingProgressBar.astro';
import ContentFeedback from '../common/ContentFeedback.astro';

interface QuizPoll {
  question: string;
  options: string[];
  answer: string;
  explanation: string;
}

interface GuideItems {
  one_liner?: string;
  action_item?: string;
  critical_gotcha?: string;
  rotating_item?: string;
  quiz_poll?: QuizPoll | null;
}

interface FactPackItem {
  id: string;
  claim: string;
  why_it_matters: string;
  source_ids?: string[];
  confidence?: string;
}

interface SourceCard {
  id: string;
  title: string;
  publisher: string;
  url: string;
  published_at?: string;
  evidence_snippet?: string;
  claim_ids?: string[];
}

interface Props {
  locale: 'en' | 'ko';
  slug: string;
  showSlug?: boolean;
  title: string;
  excerpt?: string | null;
  category?: string | null;
  publishedAt?: string | null;
  readingTimeMin?: number | null;
  tags?: string[] | null;
  htmlContent: string;
  analysisHtml?: string;
  factPack?: FactPackItem[] | null;
  sourceCards?: SourceCard[] | null;
  backLabel: string;
  nextPost?: { title: string; slug: string; category?: string | null } | null;
  isBookmarked?: boolean;
  itemId?: string;
  itemType?: 'news' | 'blog' | 'term';
  basePath?: string;
  isAdmin?: boolean;
  isAuthenticated?: boolean;
  likeCount?: number;
  commentCount?: number;
  isLiked?: boolean;
  activePersona?: string | null;
  personaHtmlMap?: Record<string, string>;
  personaDisplayMap?: Record<string, { title?: string; excerpt?: string | null }>;
  guideItems?: GuideItems | null;
  initialFindQuery?: string;
  previewMode?: boolean;
  showStickyActions?: boolean;
  postType?: string | null;
}

const {
  locale,
  slug,
  showSlug = false,
  title,
  excerpt,
  category,
  publishedAt,
  readingTimeMin,
  tags,
  htmlContent,
  analysisHtml = '',
  factPack = [],
  sourceCards = [],
  backLabel,
  nextPost = null,
  isBookmarked = false,
  itemId,
  itemType,
  basePath,
  isAdmin = false,
  isAuthenticated = false,
  likeCount = 0,
  commentCount = 0,
  isLiked = false,
  activePersona = null,
  personaHtmlMap,
  personaDisplayMap,
  guideItems = null,
  initialFindQuery = '',
  previewMode = false,
  showStickyActions = true,
  postType = null,
} = Astro.props;

const isKo = locale === 'ko';
// Resolve persona-specific quiz: try quiz_poll_{persona} first, fall back to quiz_poll
const guideItemsAny = guideItems as Record<string, any> | undefined;
const activeQuiz: QuizPoll | null = (() => {
  if (!guideItemsAny) return null;
  const personaKey = `quiz_poll_${activePersona || 'learner'}`;
  const q = guideItemsAny[personaKey] || guideItemsAny.quiz_poll || null;
  return q?.question ? q : null;
})();
const hasQuizData = !!(guideItemsAny?.quiz_poll_expert?.question || guideItemsAny?.quiz_poll_learner?.question || guideItemsAny?.quiz_poll?.question);
const hasGuideItems = guideItems && (guideItems.one_liner || guideItems.action_item || guideItems.critical_gotcha || guideItems.rotating_item || hasQuizData);
const hasFactPack = !!factPack?.length;
const hasAnalysis = !!analysisHtml;
const hasSources = !!sourceCards?.length;
const sourcePublisherSummary = Array.from(new Set((sourceCards || []).map((card) => card.publisher).filter(Boolean))).slice(0, 3).join(' · ');

// Resolve quiz answer: backend may store "A"/"B"/"C" index instead of the option text
const resolvedQuizAnswer = (() => {
  if (!activeQuiz) return '';
  const idx = 'ABCD'.indexOf(activeQuiz.answer);
  return idx >= 0 && idx < activeQuiz.options.length ? activeQuiz.options[idx] : activeQuiz.answer;
})();

const personaLabels: Record<string, Record<string, string>> = {
  en: { learner: 'Learner', expert: 'Expert' },
  ko: { learner: '학습자', expert: '현직자' },
};
const showPersonaSwitcher = personaHtmlMap && Object.keys(personaHtmlMap).length > 1;

const dateLabel = publishedAt
  ? new Date(publishedAt).toLocaleDateString(locale === 'ko' ? 'ko-KR' : 'en-US')
  : null;
const readingLabel = readingTimeMin
  ? locale === 'ko'
    ? `약 ${readingTimeMin}분`
    : `${readingTimeMin} min read`
  : null;
const categoryLabel = getCategoryLabel(locale, category);
const catColor = getCategoryColorVar(category);
const nextCategoryLabel = nextPost?.category ? getCategoryLabel(locale, nextPost.category) : null;

const editHref = itemType === 'term' ? `/admin/handbook/edit/${slug}` : `/admin/edit/${slug}`;
const unpublishApi = itemType === 'term' ? '/api/admin/handbook/status' : '/api/admin/posts/status';

const resolvedBasePath = basePath || `/${locale}/news`;
const shareUrl = `${import.meta.env.PUBLIC_SITE_URL || 'https://0to1log.com'}${resolvedBasePath}/${slug}/`;
const articleRedirect = `${resolvedBasePath}/${slug}/`;
const commentRedirect = `${resolvedBasePath}/${slug}/#comments`;

const sourcePublisherSummaryText = Array.from(
  new Set((sourceCards || []).map((card) => card.publisher).filter(Boolean)),
).slice(0, 3).join(' / ');

const sectionCopy = {
  factPack: isKo ? '핵심 팩트' : 'Fact Pack',
  factLabel: isKo ? '핵심' : 'Fact',
  coreAnalysis: isKo ? '핵심 분석' : 'Core Analysis',
  personaInsights: isKo ? '페르소나 인사이트' : 'Persona Insights',
  sources: isKo ? '출처' : 'Sources',
  sourceCount: isKo ? `${(sourceCards || []).length}개 출처` : `${(sourceCards || []).length} sources`,
  sourceDetails: isKo ? '출처 자세히 보기' : 'View source details',
};

function formatSourceDate(dateValue?: string) {
  if (!dateValue) return '';
  try {
    return new Date(dateValue).toLocaleDateString(isKo ? 'ko-KR' : 'en-US');
  } catch {
    return dateValue;
  }
}

const copy = {
  articleFindLabel: locale === 'ko' ? '기사에서 찾기' : 'Find in this article',
  articleFindPlaceholder: locale === 'ko' ? '이 기사에서 단어 찾기' : 'Find a word in this article',
  articleFindResult: locale === 'ko' ? '건' : 'match',
  articleFindResults: locale === 'ko' ? '건' : 'matches',
  articleFindEmpty: locale === 'ko' ? '일치 없음' : 'No matches',
  comments: locale === 'ko' ? '댓글' : 'Comments',
  writeComment:
    itemType === 'news'
      ? locale === 'ko'
        ? '핵심 변화에 대한 생각이나 해석을 남겨보세요.'
        : 'Share your take on what changed and why it matters.'
      : locale === 'ko'
        ? '댓글을 작성해주세요...'
        : 'Write a comment...',
  postComment: locale === 'ko' ? '게시' : 'Post',
  loginToComment:
    itemType === 'news'
      ? locale === 'ko'
        ? '의견을 남기려면 로그인하세요.'
        : 'Log in to share your thoughts.'
      : locale === 'ko'
        ? '댓글을 작성하려면 로그인하세요'
        : 'Log in to comment',
  deleteConfirm: locale === 'ko' ? '댓글을 삭제할까요?' : 'Delete this comment?',
  copied: locale === 'ko' ? '복사됨' : 'Copied',
};

const previewCommentsReadonly = 'Preview mode · comments are read-only.';
---

<article class="newsprint-article">
  {previewMode && (
    <>
      <!-- Admin preview -->
      <PreviewReadonlyBanner locale={locale} />
    </>
  )}
  <div class="newsprint-article-topline">
    <div class="newsprint-article-topline-left">
      {categoryLabel && (
        <span class="newsprint-card-kicker newsprint-article-kicker" style={`color: ${catColor};`}>{categoryLabel}{postType && <span class={`newsprint-card-kicker-type newsprint-card-kicker-type--${postType}`}>{postType === 'research' ? 'Research' : 'Business'}</span>}</span>
      )}
    </div>
    <div class="newsprint-article-topline-right">
      {readingLabel && <span class="newsprint-reading-time"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>{readingLabel}</span>}
      {dateLabel && <time datetime={publishedAt ?? undefined}>{dateLabel}</time>}
    </div>
  </div>

  {tags && tags.length > 0 && (
    <div class="newsprint-article-tags">
      {tags.slice(0, 6).map((tag) => (
        <span class="newsprint-tag">{tag}</span>
      ))}
    </div>
  )}

  <h1 class="newsprint-lead-title">{title}</h1>
  {excerpt && <p class="newsprint-deck">{excerpt}</p>}
  <div class="newsprint-divider"></div>

  <div class="newsprint-article-find">
    <label class="newsprint-article-find-label" for="article-find">{copy.articleFindLabel}</label>
    <div class="newsprint-article-find-row">
      <input
        type="search"
        id="article-find"
        class="handbook-search-input newsprint-article-find-input"
        placeholder={copy.articleFindPlaceholder}
        value={initialFindQuery}
      />
      <div
        class="newsprint-article-find-count"
        data-article-find-count
        data-result-label={copy.articleFindResult}
        data-results-label={copy.articleFindResults}
        data-empty-label={copy.articleFindEmpty}
        aria-live="polite"
      ></div>
    </div>
  </div>

  {hasFactPack && (
    <section class="newsprint-fact-pack">
      <h2 class="newsprint-section-title">{sectionCopy.factPack}</h2>
      <div class="newsprint-fact-pack-grid">
        {factPack!.map((item, index) => (
          <article class="newsprint-fact-pack-item">
            <div class="newsprint-guide-label">{sectionCopy.factLabel} {index + 1}</div>
            <p>{item.claim}</p>
            <p class="newsprint-fact-pack-meta">{item.why_it_matters}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  {hasAnalysis && (
    <section class="newsprint-core-analysis">
      <h2 class="newsprint-section-title">{sectionCopy.coreAnalysis}</h2>
      <div class="newsprint-prose newsprint-prose--analysis">
        <Fragment set:html={analysisHtml} />
      </div>
    </section>
  )}

  {showPersonaSwitcher && (
    <>
      <div class="switcher-bar">
        <div class="switcher-bar-line"></div>
        <span class="switcher-bar-label">{locale === 'ko' ? '읽기 모드' : 'Reading Mode'}</span>
        <div class="persona-switcher">
        {(['learner', 'expert'] as const).filter(p => personaHtmlMap![p]).map(p => (
          <button
            type="button"
            class={`persona-switcher-btn ${p === activePersona ? 'persona-switcher-btn--active' : ''}`}
            data-persona={p}
          >
            {personaLabels[locale]?.[p] || p}
          </button>
        ))}
        </div>
        <div class="switcher-bar-line"></div>
      </div>
      <template id="persona-data" data-map={JSON.stringify(personaHtmlMap)} data-display={JSON.stringify(personaDisplayMap || {})} data-quizzes={JSON.stringify({
        expert: guideItemsAny?.quiz_poll_expert || null,
        learner: guideItemsAny?.quiz_poll_learner || null,
      })} data-sources={JSON.stringify({
        expert: guideItemsAny?.sources_expert || null,
        learner: guideItemsAny?.sources_learner || null,
      })}></template>
    </>
  )}

  {showPersonaSwitcher ? (
    <div class="persona-float" id="persona-float" aria-hidden="true">
      <a href={basePath ?? `/${locale}/news/`} class="persona-float-btn persona-float-btn--link">
        {backLabel}
        <svg aria-hidden="true" width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="margin-left:0.35em;flex-shrink:0;"><line x1="2" y1="4" x2="14" y2="4"/><line x1="2" y1="8" x2="14" y2="8"/><line x1="2" y1="12" x2="14" y2="12"/></svg>
      </a>
      {(['learner', 'expert'] as const).filter(p => personaHtmlMap![p]).map(p => (
        <button
          type="button"
          class={`persona-float-btn ${p === activePersona ? 'persona-float-btn--active' : ''}`}
          data-persona={p}
        >
          {personaLabels[locale]?.[p] || p}
        </button>
      ))}
    </div>
  ) : (
    <div class="persona-float persona-float--back">
      <a href={basePath ?? `/${locale}/news/`} class="persona-float-btn persona-float-btn--link">
        {backLabel}
        <svg aria-hidden="true" width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="margin-left:0.35em;flex-shrink:0;"><line x1="2" y1="4" x2="14" y2="4"/><line x1="2" y1="8" x2="14" y2="8"/><line x1="2" y1="12" x2="14" y2="12"/></svg>
      </a>
    </div>
  )}

  <div class={`reading-actions-layout ${showStickyActions ? 'reading-actions-layout--article' : ''}`.trim()}>
    {showStickyActions && (
      <StickyReadingActions
        locale={locale}
        variant={itemType === 'blog' ? 'blog' : 'news'}
        title={title}
        shareUrl={shareUrl}
        itemId={itemId}
        itemType={itemType}
        isBookmarked={isBookmarked}
        previewMode={previewMode}
        isAuthenticated={isAuthenticated}
        articleRedirect={articleRedirect}
        commentRedirect={commentRedirect}
        likeCount={likeCount}
        commentCount={commentCount}
        isLiked={isLiked}
      />
    )}
    <div class="reading-actions-layout__body">
      <div class="newsprint-prose" data-article-find-root>
        <Fragment set:html={htmlContent} />
      </div>

  {hasGuideItems && (
    <aside class="newsprint-guide-items">
      <h3 class="newsprint-section-title">{isKo ? '한눈에 보기' : 'At a Glance'}</h3>

      {guideItems!.one_liner && (
        <div class="newsprint-guide-block newsprint-guide-oneliner">
          <span class="newsprint-guide-label">{isKo ? '한 줄 요약' : 'In One Line'}</span>
          <p>{guideItems!.one_liner}</p>
        </div>
      )}

      {guideItems!.action_item && (
        <div class="newsprint-guide-block">
          <span class="newsprint-guide-label">{isKo ? '지금 해볼 수 있는 것' : 'Try This Now'}</span>
          <p>{guideItems!.action_item}</p>
        </div>
      )}

      {guideItems!.critical_gotcha && (
        <div class="newsprint-guide-block newsprint-guide-gotcha">
          <span class="newsprint-guide-label">{isKo ? '주의할 점' : 'Watch Out'}</span>
          <p>{guideItems!.critical_gotcha}</p>
        </div>
      )}

      {guideItems!.rotating_item && (
        <div class="newsprint-guide-block">
          <span class="newsprint-guide-label">{isKo ? '맥락 노트' : 'Context Note'}</span>
          <p>{guideItems!.rotating_item}</p>
        </div>
      )}

      {activeQuiz && (
        <div class="newsprint-guide-block newsprint-guide-quiz" data-quiz-answer={resolvedQuizAnswer}>
          <span class="newsprint-guide-label">{isKo ? '오늘의 퀴즈' : "Today's Quiz"}</span>
          <p class="newsprint-quiz-question">{activeQuiz.question}</p>
          <div class="newsprint-quiz-options">
            {activeQuiz.options.map((opt: string) => (
              <button type="button" class="newsprint-quiz-option" data-option={opt}>{opt}</button>
            ))}
          </div>
          <p class="newsprint-quiz-explanation" style="display:none;">{activeQuiz.explanation}</p>
        </div>
      )}
    </aside>
  )}

  {hasSources && (
    <section class="newsprint-sources">
      <h2 class="newsprint-section-title">{sectionCopy.sources} <span class="newsprint-sources-count">{(sourceCards || []).length}</span></h2>
      <div class="newsprint-sources-list">
        {sourceCards!.map((card, index) => (
          <a class="source-card" id={`source-card-${index + 1}`} href={card.url} target="_blank" rel="noopener noreferrer">
            <span class="source-card-index">[{index + 1}]</span>
            <span class="source-card-publisher">{card.publisher}</span>
            {card.title && card.title !== card.publisher && <span class="source-card-title">{card.title}</span>}
            <svg class="source-card-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        ))}
      </div>
    </section>
  )}


  <!-- Admin Actions (admin only) -->
  {isAdmin && itemId && (
    <div class="newsprint-admin-actions" data-toolbar-id={itemId} data-toolbar-api={unpublishApi}>
      <a href={editHref} class="newsprint-admin-action-btn">Edit</a>
      <button type="button" class="newsprint-admin-action-btn newsprint-admin-action-btn--unpublish">Unpublish</button>
    </div>
  )}

  <div data-reading-end></div>

  <ContentFeedback
    sourceType={itemType === 'blog' ? 'blog' : 'news'}
    sourceId={itemId ?? ''}
    locale={locale}
    isAuthenticated={isAuthenticated}
    loginUrl={`/api/auth/login?redirect=${encodeURIComponent(Astro.url.pathname)}`}
    previewMode={previewMode}
  />

  <!-- Comments Section -->
  <section
    id="comments"
    class="newsprint-comments"
    data-preview-mode={previewMode ? 'true' : 'false'}
    data-post-id={itemId}
    data-content-type={itemType === 'blog' ? 'blog' : 'news'}
    data-locale={locale}
    data-authenticated={isAuthenticated ? 'true' : 'false'}
    data-comment-redirect={commentRedirect}
  >
    <h3 class="newsprint-comments-title">{copy.comments} (<span data-comment-total>{commentCount}</span>)</h3>
    {previewMode && (
      <>
        <!-- Preview mode 쨌 comments are read-only. -->
        <p class="newsprint-preview-note">{previewCommentsReadonly}</p>
      </>
    )}
    <div data-comments-list class="newsprint-comments-list"></div>
    <div data-comment-form-wrapper>
      <form data-comment-form class="newsprint-comment-form" style="display:none;">
        <textarea
          data-comment-input
          placeholder={copy.writeComment}
          maxlength="2000"
          rows="3"
          class="newsprint-comment-input"
        ></textarea>
        <div class="newsprint-comment-form-actions">
          <span data-comment-charcount class="newsprint-comment-charcount"></span>
          <button type="submit" class="newsprint-comment-submit">{copy.postComment}</button>
        </div>
      </form>
      <button
        type="button"
        data-comment-login
        class="newsprint-comment-login"
        data-auth-gate
        data-auth-action="comment"
        data-auth-redirect={commentRedirect}
        style="display:none;"
      >
        <div class="newsprint-comment-login-box">
          <div class="newsprint-comment-login-input" aria-hidden="true">{copy.writeComment}</div>
          <div class="newsprint-comment-form-actions">
            <span class="newsprint-comment-charcount">0/2000</span>
            <span class="newsprint-comment-submit newsprint-comment-submit--disabled" aria-hidden="true">{copy.postComment}</span>
          </div>
          <span class="newsprint-comment-login-hint">{copy.loginToComment}</span>
        </div>
      </button>
    </div>
  </section>

    </div>
  </div>
</article>

<ReadingProgressBar locale={locale} />

<script src="../../scripts/share.ts"></script>

<script>
  import '../../scripts/articleFind';
</script>


<script>
  let _personaObserver: IntersectionObserver | null = null;

  function initPersonaSwitcher() {
    if (_personaObserver) { _personaObserver.disconnect(); _personaObserver = null; }

    const template = document.getElementById('persona-data') as HTMLTemplateElement | null;
    if (!template) return;
    const map: Record<string, string> = JSON.parse(template.dataset.map || '{}');
    const displayMap: Record<string, { title?: string; excerpt?: string }> = JSON.parse(template.dataset.display || '{}');
    const quizMap: Record<string, any> = JSON.parse(template.dataset.quizzes || '{}');
    const sourcesMap: Record<string, any[]> = JSON.parse(template.dataset.sources || '{}');
    const prose = document.querySelector('.newsprint-prose');
    const switcher = document.querySelector<HTMLElement>('.persona-switcher');
    const floatEl = document.getElementById('persona-float');
    if (!prose || !switcher) return;

    function updateQuiz(persona: string) {
      const quizBlock = document.querySelector<HTMLElement>('.newsprint-guide-quiz');
      if (!quizBlock) return;
      const quiz = quizMap[persona];
      if (!quiz?.question) {
        quizBlock.style.display = 'none';
        return;
      }
      quizBlock.style.display = '';
      const idx = 'ABCD'.indexOf(quiz.answer);
      const resolvedAnswer = idx >= 0 && idx < quiz.options.length ? quiz.options[idx] : quiz.answer;
      quizBlock.dataset.quizAnswer = resolvedAnswer;
      const qEl = quizBlock.querySelector('.newsprint-quiz-question');
      if (qEl) qEl.textContent = quiz.question;
      const expEl = quizBlock.querySelector<HTMLElement>('.newsprint-quiz-explanation');
      if (expEl) { expEl.textContent = quiz.explanation; expEl.style.display = 'none'; }
      const optContainer = quizBlock.querySelector('.newsprint-quiz-options');
      if (optContainer) {
        optContainer.innerHTML = quiz.options.map((opt: string) =>
          `<button type="button" class="newsprint-quiz-option" data-option="${opt.replace(/"/g, '&quot;')}">${opt}</button>`
        ).join('');
      }
      initQuiz();
    }

    function updateSources(persona: string) {
      const sourcesList = document.querySelector('.newsprint-sources-list');
      const sourcesCount = document.querySelector('.newsprint-sources-count');
      if (!sourcesList) return;
      const cards = sourcesMap[persona];
      if (!Array.isArray(cards) || cards.length === 0) return;
      const hostname = (url: string) => { try { return new URL(url).hostname.replace(/^www\./, ''); } catch { return 'Source'; } };
      sourcesList.innerHTML = cards.map((card: any, i: number) => {
        const pub = card.publisher || hostname(card.url || '');
        const title = card.title && card.title !== pub ? `<span class="source-card-title">${card.title}</span>` : '';
        return `<a class="source-card" id="source-card-${i + 1}" href="${card.url || ''}" target="_blank" rel="noopener noreferrer">
          <span class="source-card-index">[${i + 1}]</span>
          <span class="source-card-publisher">${pub}</span>
          ${title}
          <svg class="source-card-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>`;
      }).join('');
      if (sourcesCount) sourcesCount.textContent = String(cards.length);
    }

    function setActivePersona(p: string) {
      if (!map[p]) return;
      prose!.innerHTML = map[p];
      const leadTitle = document.querySelector<HTMLElement>('.newsprint-lead-title');
      let deck = document.querySelector<HTMLElement>('.newsprint-deck');
      const nextDisplay = displayMap[p] || {};
      const nextTitle = (nextDisplay.title || '').trim();
      const nextExcerpt = (nextDisplay.excerpt || '').trim();
      if (leadTitle && nextTitle) leadTitle.textContent = nextTitle;
      if (leadTitle) {
        if (nextExcerpt) {
          if (!deck) {
            deck = document.createElement('p');
            deck.className = 'newsprint-deck';
            leadTitle.insertAdjacentElement('afterend', deck);
          }
          deck.textContent = nextExcerpt;
          deck.style.display = '';
        } else if (deck) {
          deck.textContent = '';
          deck.style.display = 'none';
        }
      }
      document.title = nextTitle ? `${nextTitle} | 0to1log` : '0to1log';
      switcher!.querySelectorAll('.persona-switcher-btn').forEach(b =>
        b.classList.toggle('persona-switcher-btn--active',
          (b as HTMLElement).dataset.persona === p));
      floatEl?.querySelectorAll('.persona-float-btn').forEach(b =>
        b.classList.toggle('persona-float-btn--active',
          (b as HTMLElement).dataset.persona === p));
      updateQuiz(p);
      updateSources(p);
      document.querySelector('.newsprint-lead-title')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      document.dispatchEvent(new CustomEvent('newsprint:article-content-updated', {
        detail: { root: prose, persona: p },
      }));
    }

    switcher.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.persona-switcher-btn');
      if (btn) setActivePersona(btn.dataset.persona!);
    });

    if (floatEl) {
      floatEl.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.persona-float-btn');
        if (btn) setActivePersona(btn.dataset.persona!);
      });

      let hasShownOnce = false;
      _personaObserver = new IntersectionObserver(([entry]) => {
        if (!entry.isIntersecting) {
          floatEl.classList.add('persona-float--visible');
          floatEl.removeAttribute('aria-hidden');
          if (!hasShownOnce) {
            hasShownOnce = true;
            floatEl.classList.add('persona-float--pulse');
            floatEl.addEventListener('animationend', () =>
              floatEl.classList.remove('persona-float--pulse'), { once: true });
          }
        } else {
          floatEl.classList.remove('persona-float--visible');
          floatEl.setAttribute('aria-hidden', 'true');
        }
      }, { threshold: 0.1 });

      _personaObserver.observe(switcher);
    }
  }

  function initQuiz() {
    const quizBlock = document.querySelector<HTMLElement>('.newsprint-guide-quiz');
    if (!quizBlock) return;
    const answer = quizBlock.dataset.quizAnswer || '';
    const explanation = quizBlock.querySelector<HTMLElement>('.newsprint-quiz-explanation');
    const options = quizBlock.querySelectorAll<HTMLButtonElement>('.newsprint-quiz-option');
    let answered = false;

    options.forEach(btn => {
      btn.addEventListener('click', () => {
        if (answered) return;
        answered = true;
        const selected = btn.dataset.option || '';
        const isCorrect = selected === answer;
        btn.classList.add(isCorrect ? 'newsprint-quiz-option--correct' : 'newsprint-quiz-option--wrong');
        // Highlight the correct answer if wrong
        if (!isCorrect) {
          options.forEach(b => {
            if (b.dataset.option === answer) b.classList.add('newsprint-quiz-option--correct');
          });
        }
        options.forEach(b => b.setAttribute('disabled', 'true'));
        if (explanation) explanation.style.display = '';
      });
    });
  }

  document.addEventListener('astro:page-load', initPersonaSwitcher);
  document.addEventListener('astro:page-load', initQuiz);
  initPersonaSwitcher();
</script>
