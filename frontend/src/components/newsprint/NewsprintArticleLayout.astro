---
import { getCategoryLabel } from '../../lib/categories';

interface Props {
  locale: 'en' | 'ko';
  slug: string;
  showSlug?: boolean;
  title: string;
  excerpt?: string | null;
  category?: string | null;
  publishedAt?: string | null;
  readingTimeMin?: number | null;
  tags?: string[] | null;
  htmlContent: string;
  backLabel: string;
  nextPost?: { title: string; slug: string; category?: string | null } | null;
  isBookmarked?: boolean;
  itemId?: string;
  itemType?: 'post' | 'term';
}

const {
  locale,
  slug,
  showSlug = false,
  title,
  excerpt,
  category,
  publishedAt,
  readingTimeMin,
  tags,
  htmlContent,
  backLabel,
  nextPost = null,
  isBookmarked = false,
  itemId,
  itemType,
} = Astro.props;

const dateLabel = publishedAt
  ? new Date(publishedAt).toLocaleDateString(locale === 'ko' ? 'ko-KR' : 'en-US')
  : null;
const readingLabel = readingTimeMin
  ? locale === 'ko'
    ? `약 ${readingTimeMin}분`
    : `${readingTimeMin} min read`
  : null;
const categoryLabel = getCategoryLabel(locale, category);
const nextCategoryLabel = nextPost?.category ? getCategoryLabel(locale, nextPost.category) : null;
---

<article class="newsprint-article">
  <div class="newsprint-article-header">
    <div class="newsprint-article-header-left">
      {categoryLabel && <span class="newsprint-category">{categoryLabel}</span>}
      {tags && tags.length > 0 && (
        <>
          {tags.slice(0, 6).map((tag) => (
            <span class="newsprint-tag">{tag}</span>
          ))}
        </>
      )}
    </div>
    <div class="newsprint-article-header-right">
      {readingLabel && <span>{readingLabel}</span>}
      {dateLabel && <time datetime={publishedAt ?? undefined}>{dateLabel}</time>}
    </div>
  </div>

  <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem;">
    <h1 class="newsprint-lead-title" style="flex: 1;">{title}</h1>
    {itemId && (
      <button
        class={`newsprint-bookmark-icon newsprint-bookmark-icon--detail ${isBookmarked ? 'newsprint-bookmark-icon--active' : ''}`}
        data-item-id={itemId}
        data-item-type={itemType}
        data-bookmarked={isBookmarked ? 'true' : 'false'}
        aria-label={isBookmarked ? 'Remove bookmark' : 'Add bookmark'}
        style="margin-top: 0.5rem;"
      >
        <svg viewBox="0 0 24 24" fill={isBookmarked ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2">
          <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" />
        </svg>
      </button>
    )}
  </div>
  {excerpt && <p class="newsprint-deck">{excerpt}</p>}
  <div class="newsprint-divider"></div>

  <div class="newsprint-prose">
    <Fragment set:html={htmlContent} />
  </div>

  <div class="newsprint-share-bar" data-share-url={`${import.meta.env.PUBLIC_SITE_URL || 'https://0to1log.com'}/${locale}/log/${slug}/`} data-share-title={title}>
    <span class="newsprint-share-bar-label">{locale === 'ko' ? '공유' : 'Share'}</span>
    <button type="button" class="newsprint-share-btn newsprint-share-btn--native" aria-label="Share" style="display:none;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
    </button>
    <button type="button" class="newsprint-share-btn newsprint-share-btn--x" aria-label="Share on X">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
    </button>
    <button type="button" class="newsprint-share-btn newsprint-share-btn--linkedin" aria-label="Share on LinkedIn">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
    </button>
    <button type="button" class="newsprint-share-btn newsprint-share-btn--copy" aria-label={locale === 'ko' ? 'URL 복사' : 'Copy URL'}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
    </button>
    <span class="newsprint-share-toast">{locale === 'ko' ? '복사됨' : 'Copied'}</span>
  </div>

  <nav class="newsprint-article-nav" aria-label={locale === 'ko' ? '글 탐색' : 'Article navigation'}>
    <div class="newsprint-article-nav-row">
      <a class="newsprint-nav-back" href={`/${locale}/log/`}>
        <span class="newsprint-nav-back-arrow">&larr;</span>
        <span>{backLabel}</span>
      </a>
      {nextPost && (
        <a class="newsprint-nav-next" href={`/${locale}/log/${nextPost.slug}/`}>
          <span class="newsprint-nav-next-arrow">&rarr;</span>
          <div class="newsprint-nav-next-title">{nextPost.title}</div>
          {nextCategoryLabel && (
            <div class="newsprint-nav-next-meta">{nextCategoryLabel}</div>
          )}
        </a>
      )}
    </div>
  </nav>
</article>

<script src="../../scripts/share.ts"></script>
