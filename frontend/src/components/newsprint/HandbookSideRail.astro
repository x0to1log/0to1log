---
interface RailTerm {
  term: string;
  slug: string;
  korean_name?: string | null;
}

interface RailArticle {
  title: string;
  slug: string;
  published_at?: string | null;
  post_type?: string | null;
}

interface Props {
  locale: 'en' | 'ko';
  relatedTerms: RailTerm[];
  sameCategoryTerms: RailTerm[];
  relatedArticles: RailArticle[];
}

const { locale, relatedTerms, sameCategoryTerms, relatedArticles } = Astro.props;
const isKo = locale === 'ko';
const hasRelated = relatedTerms.length > 0;
---

{/* Primary: Related Terms (curated) */}
{hasRelated && (
  <section>
    <h3 class="newsprint-section-title">{isKo ? '연관 개념' : 'Related Terms'}</h3>
    <div class="newsprint-stack">
      {relatedTerms.map((rt) => (
        <a class="newsprint-card" href={`/${locale}/handbook/${rt.slug}/`}>
          <strong class="newsprint-rail-link">{rt.term}</strong>
          {rt.korean_name && (
            <span class="newsprint-rail-subtitle">{rt.korean_name}</span>
          )}
        </a>
      ))}
    </div>
  </section>
)}

{/* Fallback: Same Category — only when Related Terms is empty */}
{!hasRelated && sameCategoryTerms.length > 0 && (
  <section>
    <h3 class="newsprint-section-title">{isKo ? '같은 분야' : 'More in This Area'}</h3>
    <div class="newsprint-stack">
      {sameCategoryTerms.map((ct) => (
        <a class="newsprint-card" href={`/${locale}/handbook/${ct.slug}/`}>
          <strong class="newsprint-rail-link">{ct.term}</strong>
          {ct.korean_name && (
            <span class="newsprint-rail-subtitle">{ct.korean_name}</span>
          )}
        </a>
      ))}
    </div>
  </section>
)}

{/* Related Articles */}
{relatedArticles.length > 0 && (
  <>
    {(hasRelated || sameCategoryTerms.length > 0) && (
      <hr class="newsprint-rail-divider" />
    )}
    <section>
      <h3 class="newsprint-section-title">{isKo ? '최근 뉴스에서' : 'In Recent News'}</h3>
      <div class="newsprint-stack">
        {relatedArticles.map((article) => {
          const dateStr = article.published_at
            ? new Date(article.published_at).toLocaleDateString(isKo ? 'ko-KR' : 'en-US', { month: 'short', day: 'numeric' })
            : '';
          return (
            <a class="newsprint-card" href={`/${locale}/news/${article.slug}/`}>
              <strong class="newsprint-rail-link">{article.title}</strong>
              <span class="newsprint-rail-meta">
                {article.post_type && (
                  <span class={`newsprint-card-kicker-type newsprint-card-kicker-type--${article.post_type}`}>
                    {article.post_type === 'research' ? 'Research' : 'Business'}
                  </span>
                )}
                {dateStr && <span class="newsprint-rail-date">{dateStr}</span>}
              </span>
            </a>
          );
        })}
      </div>
    </section>
  </>
)}

{relatedTerms.length === 0 && sameCategoryTerms.length === 0 && relatedArticles.length === 0 && (
  <p class="newsprint-empty">{isKo ? '아직 연결된 콘텐츠가 없습니다.' : 'No related content yet.'}</p>
)}
