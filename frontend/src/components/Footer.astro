---
interface Props {
  locale?: 'en' | 'ko';
}

const { locale = 'en' } = Astro.props;
const year = new Date().getFullYear();

const categories = [
  { en: 'AI News', ko: 'AI 뉴스', slug: '?category=ai-news' },
  { en: 'Study', ko: '서재', slug: '?category=tech' },
  { en: 'Career', ko: '커리어', slug: '?category=career' },
  { en: 'Project', ko: '프로젝트', slug: '?category=project' },
];
---

<footer style={`background-color: var(--color-bg-secondary); border-top: 1px solid var(--color-border); padding: 2rem; text-align: center;`}>
  <div class="newsprint-footer-nav">
    {categories.map((cat, i) => (
      <>
        <a href={`/${locale}/log/${cat.slug}`}>{locale === 'ko' ? cat.ko : cat.en}</a>
        {i < categories.length - 1 && <span class="newsprint-footer-dot">&middot;</span>}
      </>
    ))}
  </div>
  <p style={`color: var(--color-text-muted); font-size: 0.875rem;`}>
    &copy; {year} 0to1log. All rights reserved.
  </p>
</footer>
