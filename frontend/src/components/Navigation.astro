---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  locale?: 'en' | 'ko';
  alwaysVisible?: boolean;
}

const { locale = 'en', alwaysVisible = false } = Astro.props;
const altLocale = locale === 'en' ? 'ko' : 'en';
const currentPath = Astro.url.pathname;
const altPath = currentPath.replace(`/${locale}/`, `/${altLocale}/`);
---

<header class="site-header" data-always-visible={alwaysVisible ? "true" : undefined} style={`background-color: var(--color-bg-secondary); border-bottom: 1px solid var(--color-border);`}>
  <nav style={`max-width: 1280px; margin: 0 auto; padding: 1rem; display: flex; align-items: center; justify-content: space-between;`}>
    <a href={`/${locale}/`} style={`font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; color: var(--color-accent); text-decoration: none;`}>
      0to1log
    </a>

    <div style="display: flex; align-items: center; gap: 1.5rem;">
      <a href={`/${locale}/log/`} class="newsprint-nav-link">Log</a>
      <a href="/portfolio/" class="newsprint-nav-link">Portfolio</a>
      <a href={altPath} class="newsprint-nav-link" style="font-size: 0.875rem;">
        {locale === 'en' ? '한국어' : 'EN'}
      </a>
      <ThemeToggle />
    </div>
  </nav>
</header>

<script>
  function initHeaderReveal(): void {
    const header = document.querySelector('.site-header') as HTMLElement | null;
    if (!header) return;

    if (header.dataset.alwaysVisible === 'true') {
      header.classList.remove('site-header--fixed', 'site-header--hidden');
      return;
    }

    const headerH = header.offsetHeight;
    let lastY = window.scrollY;
    let ticking = false;
    let fixed = false;

    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const currentY = window.scrollY;

        if (currentY <= headerH) {
          // Header is still in (or returning to) its natural position
          if (fixed) {
            header!.classList.add('site-header--no-transition');
            header!.classList.remove('site-header--fixed', 'site-header--hidden');
            requestAnimationFrame(() => {
              header!.classList.remove('site-header--no-transition');
            });
            fixed = false;
          }
        } else {
          // Header has scrolled out — switch to fixed mode
          if (!fixed) {
            header!.classList.add('site-header--fixed', 'site-header--hidden', 'site-header--no-transition');
            requestAnimationFrame(() => {
              header!.classList.remove('site-header--no-transition');
            });
            fixed = true;
          }

          if (currentY < lastY - 5) {
            header!.classList.remove('site-header--hidden');
          } else if (currentY > lastY + 5) {
            header!.classList.add('site-header--hidden');
          }
        }

        lastY = currentY;
        ticking = false;
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
  }

  document.addEventListener('astro:page-load', initHeaderReveal);
</script>
