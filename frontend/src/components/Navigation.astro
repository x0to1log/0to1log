---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  locale?: 'en' | 'ko';
  alwaysVisible?: boolean;
  altSlug?: string;
}

const { locale = 'en', alwaysVisible = false, altSlug } = Astro.props;
const altLocale = locale === 'en' ? 'ko' : 'en';
const currentPath = Astro.url.pathname;
const altPath = altSlug
  ? `/${altLocale}/log/${altSlug}/`
  : currentPath.replace(`/${locale}/`, `/${altLocale}/`);

const user = Astro.locals.user;
const isAdmin = Astro.locals.isAdmin;
const avatarUrl = user?.user_metadata?.avatar_url;
const displayName = user?.user_metadata?.full_name || user?.email || '';
const initials = displayName ? displayName.charAt(0).toUpperCase() : '?';
---

<header class="site-header" data-always-visible={alwaysVisible ? "true" : undefined} style={`background-color: var(--color-bg-secondary); border-bottom: 1px solid var(--color-border);`}>
  <nav aria-label="Main navigation" style={`max-width: 1280px; margin: 0 auto; padding: 1rem; display: flex; align-items: center; justify-content: space-between;`}>
    <a href={`/${locale}/`} style={`font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; color: var(--color-accent); text-decoration: none;`}>
      0to1log
    </a>

    <div style="display: flex; align-items: center; gap: 1.5rem;">
      <a href={`/${locale}/log/`} class="newsprint-nav-link">Log</a>
      <a href={`/${locale}/handbook/`} class="newsprint-nav-link">Handbook</a>
      <a href={altPath} class="newsprint-nav-link" style="font-size: 0.875rem;">
        {locale === 'en' ? '한국어' : 'EN'}
      </a>
      <ThemeToggle />

      {user ? (
        <div style="position: relative;">
          <button class="user-avatar-btn" data-user-menu-toggle aria-label="User menu">
            {avatarUrl ? (
              <img src={avatarUrl} alt={displayName} />
            ) : (
              initials
            )}
          </button>
          <div class="user-dropdown" data-user-dropdown>
            <a href="/library/" class="user-dropdown-item">
              {locale === 'ko' ? '내 서재' : 'My Library'}
            </a>
            {isAdmin && (
              <a href="/admin/" class="user-dropdown-item">
                Dashboard
              </a>
            )}
            <form method="POST" action={`/api/auth/logout?redirectTo=${encodeURIComponent(currentPath)}`} style="margin: 0;">
              <button type="submit" class="user-dropdown-item" style="border-top: 1px solid var(--color-border);">
                {locale === 'ko' ? '로그아웃' : 'Sign Out'}
              </button>
            </form>
          </div>
        </div>
      ) : (
        <a href={`/login?redirectTo=${encodeURIComponent(currentPath)}`} class="newsprint-nav-link" style="font-size: 0.875rem;">
          {locale === 'ko' ? '로그인' : 'Sign In'}
        </a>
      )}
    </div>
  </nav>
</header>
<div class="site-header-spacer" aria-hidden="true"></div>

<script>
  function initUserDropdown(): void {
    const toggle = document.querySelector('[data-user-menu-toggle]');
    const dropdown = document.querySelector('[data-user-dropdown]');
    if (!toggle || !dropdown) return;

    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = dropdown.getAttribute('data-open') === 'true';
      dropdown.setAttribute('data-open', isOpen ? 'false' : 'true');
    });

    document.addEventListener('click', () => {
      dropdown.setAttribute('data-open', 'false');
    });
  }

  document.addEventListener('astro:page-load', initUserDropdown);
</script>

<script>
  function initHeaderReveal(): void {
    const header = document.querySelector('.site-header') as HTMLElement | null;
    const spacer = document.querySelector('.site-header-spacer') as HTMLElement | null;
    if (!header || !spacer) return;

    if (header.dataset.alwaysVisible === 'true') {
      header.classList.remove('site-header--fixed', 'site-header--hidden');
      spacer.style.display = 'none';
      return;
    }

    const headerH = header.offsetHeight;
    spacer.style.height = headerH + 'px';
    spacer.style.display = 'none';

    let lastY = window.scrollY;
    let ticking = false;
    let fixed = false;

    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const currentY = window.scrollY;

        if (currentY <= headerH) {
          if (fixed) {
            header!.classList.add('site-header--no-transition');
            header!.classList.remove('site-header--fixed', 'site-header--hidden');
            spacer!.style.display = 'none';
            requestAnimationFrame(() => {
              header!.classList.remove('site-header--no-transition');
            });
            fixed = false;
          }
        } else {
          if (!fixed) {
            header!.classList.add('site-header--fixed', 'site-header--hidden', 'site-header--no-transition');
            spacer!.style.display = 'block';
            requestAnimationFrame(() => {
              header!.classList.remove('site-header--no-transition');
            });
            fixed = true;
          }

          if (currentY < lastY - 5) {
            header!.classList.remove('site-header--hidden');
          } else if (currentY > lastY + 5) {
            header!.classList.add('site-header--hidden');
          }
        }

        lastY = currentY;
        ticking = false;
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
  }

  document.addEventListener('astro:page-load', initHeaderReveal);
</script>
