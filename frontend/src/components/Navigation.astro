---
interface Props {
  locale?: 'en' | 'ko';
  alwaysVisible?: boolean;
  altSlug?: string;
}

const { locale = 'en', alwaysVisible = false, altSlug } = Astro.props;
const altLocale = locale === 'en' ? 'ko' : 'en';
const currentPath = Astro.url.pathname;
const hasLocaleSegment = currentPath.startsWith('/en/') || currentPath.startsWith('/ko/');
// Determine which section the current page belongs to for altPath
const isInBlog = currentPath.startsWith(`/${locale}/blog/`);
const isInNews = currentPath.startsWith(`/${locale}/news/`);
const isInProducts = currentPath.startsWith(`/${locale}/products/`);
const isInHandbook = currentPath.startsWith(`/${locale}/handbook/`);
const altSection = isInBlog ? 'blog' : isInProducts ? 'products' : isInHandbook ? 'handbook' : 'news';
const altPath = altSlug
  ? `/${altLocale}/${altSection}/${altSlug}/`
  : hasLocaleSegment
    ? currentPath.replace(`/${locale}/`, `/${altLocale}/`)
    : `${currentPath}?lang=${altLocale}`;

const user = Astro.locals.user;
const isAdmin = Astro.locals.isAdmin;
const profile = Astro.locals.profile;
const avatarUrl = profile?.avatar_url || user?.user_metadata?.avatar_url;
const displayName = profile?.display_name || user?.user_metadata?.full_name || user?.email || '';
const initials = displayName ? displayName.charAt(0).toUpperCase() : '?';

const nlCopy = locale === 'ko'
  ? {
      nlLabel: '뉴스레터 구독',
      nlTitle: '0to1log Weekly',
      nlSubtitle: '매주 AI 뉴스를 이메일로 받아보세요',
      nlPlaceholder: '이메일 입력',
      nlButton: '구독하기',
      nlSubmitting: '구독 중...',
      nlSuccess: '구독 완료! 이메일을 확인해주세요.',
      nlError: '구독에 실패했습니다. 다시 시도해주세요.',
      nlAlt: '다른 방법으로 받아보기:',
    }
  : {
      nlLabel: 'Subscribe to newsletter',
      nlTitle: '0to1log Weekly',
      nlSubtitle: 'Get weekly AI news in your inbox',
      nlPlaceholder: 'Enter your email',
      nlButton: 'Subscribe',
      nlSubmitting: 'Subscribing...',
      nlSuccess: 'Success! Check your email to confirm.',
      nlError: 'Something went wrong. Please try again.',
      nlAlt: 'Other ways to follow:',
    };

const copy = locale === 'ko'
  ? {
      aiNews: 'AI 뉴스',
      handbook: 'AI 용어집',
      library: '나의 서재',
      blog: 'IT 블로그',
      products: 'AI 제품군',
      pageHome: '홈',
      pageArticle: '기사',
      pageTerm: '용어',
      pageProduct: '제품',
      pageAdmin: '관리자',
      pageLibrary: '나의 서재',
      languageItem: '언어 · English',
      themeLabel: '테마',
      themeDark: '다크',
      themeLight: '라이트',
      themePink: '핑크',
      themeMidnight: '미드나잇',
      signIn: '로그인',
      signOut: '로그아웃',
      settings: '설정',
      admin: '관리자',
      menuLabel: user ? '프로필 메뉴' : '설정 메뉴',
      utilityLabel: '설정',
    }
  : {
      aiNews: 'AI News',
      handbook: 'Glossary',
      library: 'My Library',
      blog: 'IT Blog',
      products: 'Products',
      pageHome: 'Home',
      pageArticle: 'Article',
      pageTerm: 'Term',
      pageProduct: 'Product',
      pageAdmin: 'Admin',
      pageLibrary: 'My Library',
      languageItem: 'Language · 한국어',
      themeLabel: 'Theme',
      themeDark: 'Dark',
      themeLight: 'Light',
      themePink: 'Pink',
      themeMidnight: 'Midnight',
      signIn: 'Sign In',
      signOut: 'Sign Out',
      settings: 'Settings',
      admin: 'Admin',
      menuLabel: user ? 'Profile menu' : 'Settings menu',
      utilityLabel: 'Settings',
    };

const handbookRoot = `/${locale}/handbook/`;
const newsRoot = `/${locale}/news/`;
const blogRoot = `/${locale}/blog/`;
const productsRoot = `/${locale}/products/`;

function getCurrentPageLabel(pathname: string): string {
  if (pathname.startsWith('/admin')) return copy.pageAdmin;
  if (pathname.startsWith('/library')) return copy.pageLibrary;

  if (pathname === handbookRoot || pathname === handbookRoot.slice(0, -1)) return copy.handbook;
  if (pathname.startsWith(handbookRoot)) return copy.pageTerm;
  if (pathname === newsRoot || pathname === newsRoot.slice(0, -1)) return copy.aiNews;
  if (pathname.startsWith(newsRoot)) return copy.pageArticle;
  if (pathname === blogRoot || pathname === blogRoot.slice(0, -1)) return copy.blog;
  if (pathname.startsWith(blogRoot)) return copy.pageArticle;
  if (pathname === productsRoot || pathname === productsRoot.slice(0, -1)) return copy.products;
  if (pathname.startsWith(productsRoot)) return copy.pageProduct;

  return copy.pageHome;
}

const currentPageLabel = getCurrentPageLabel(currentPath);

// On detail pages, the page label becomes a back link to the section list
const detailBack = (() => {
  if (currentPath.startsWith(handbookRoot) && currentPath !== handbookRoot && currentPath !== handbookRoot.slice(0, -1))
    return { label: copy.handbook, href: handbookRoot };
  if (currentPath.startsWith(newsRoot) && currentPath !== newsRoot && currentPath !== newsRoot.slice(0, -1))
    return { label: copy.aiNews, href: newsRoot };
  if (currentPath.startsWith(blogRoot) && currentPath !== blogRoot && currentPath !== blogRoot.slice(0, -1))
    return { label: copy.blog, href: blogRoot };
  if (currentPath.startsWith(productsRoot) && currentPath !== productsRoot && currentPath !== productsRoot.slice(0, -1))
    return { label: copy.products, href: productsRoot };
  return null;
})();

const navItems = [
  {
    href: `/${locale}/news/`,
    label: copy.aiNews,
    active: currentPath.startsWith(`/${locale}/news`),
  },
  {
    href: `/${locale}/handbook/`,
    label: copy.handbook,
    active: currentPath.startsWith(`/${locale}/handbook`),
  },
  {
    href: productsRoot,
    label: copy.products,
    active: currentPath.startsWith(`/${locale}/products`),
  },
  {
    href: '/library/',
    label: copy.library,
    active: currentPath.startsWith('/library'),
  },
  {
    href: `/${locale}/blog/`,
    label: copy.blog,
    active: currentPath.startsWith(`/${locale}/blog`),
  },
];
---

<header class="site-header" data-always-visible={alwaysVisible ? 'true' : undefined} style={`background-color: var(--color-bg-secondary); border-bottom: 1px solid var(--color-border);`}>
  <nav aria-label="Main navigation" class="site-header-shell">
    <div class="site-header-topline">
      <div class="site-header-brand-block">
        <a href={`/${locale}/`} class="site-brand-link">
          0to1log
        </a>
        {detailBack ? (
          <a href={detailBack.href} class="site-page-label site-page-label--link">
            {detailBack.label}
          </a>
        ) : (
          <span class="site-page-label">{currentPageLabel}</span>
        )}
      </div>

      <div class="site-primary-nav site-primary-nav--desktop" aria-label="Primary navigation">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`site-nav-pill${item.active ? ' site-nav-pill--active' : ''}`}
            aria-current={item.active ? 'page' : undefined}
            data-astro-prefetch="viewport"
          >
            {item.label}
          </a>
        ))}
      </div>

      <div class="site-utility-wrap">
        <button
          type="button"
          class="site-utility-btn site-nl-toggle"
          data-nl-toggle
          aria-label={nlCopy.nlLabel}
          title={nlCopy.nlLabel}
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2" />
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
          </svg>
        </button>

        <button
          type="button"
          class="site-theme-toggle"
          data-theme-cycle
          data-label-prefix={copy.themeLabel}
          data-dark-label={copy.themeDark}
          data-light-label={copy.themeLight}
          data-pink-label={copy.themePink}
          data-midnight-label={copy.themeMidnight}
          aria-label={copy.themeLabel}
          title={copy.themeLabel}
        >
          <svg data-theme-icon="dark" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
          <svg data-theme-icon="light" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none;">
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="1" x2="12" y2="3"></line>
            <line x1="12" y1="21" x2="12" y2="23"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line x1="1" y1="12" x2="3" y2="12"></line>
            <line x1="21" y1="12" x2="23" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
          </svg>
          <svg data-theme-icon="pink" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none;">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
          <svg data-theme-icon="midnight" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none;">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
          </svg>
        </button>

        <a href={altPath} class="site-lang-toggle" aria-label={copy.languageItem} title={copy.languageItem}>
          {altLocale.toUpperCase()}
        </a>

        <div style="position: relative;">
          <button
            class="user-avatar-btn site-utility-btn"
            data-user-menu-toggle
            aria-label={copy.menuLabel}
            title={copy.utilityLabel}
          >
            {user ? (
              avatarUrl ? (
                <img src={avatarUrl} alt={displayName} />
              ) : (
                initials
              )
            ) : (
              <span class="site-utility-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 21a8 8 0 0 0-16 0"></path>
                  <circle cx="12" cy="8" r="4"></circle>
                </svg>
              </span>
            )}
          </button>

          <div class="user-dropdown user-dropdown--utility" data-user-dropdown>
            {user && (
              <a href="/library/" class="user-dropdown-item user-dropdown-item--has-icon">
                <span>{copy.library}</span>
                <svg class="dropdown-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"></path>
                </svg>
              </a>
            )}

            {user && (
              <a href="/settings/" class="user-dropdown-item user-dropdown-item--has-icon">
                <span>{copy.settings}</span>
                <svg class="dropdown-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="3"></circle>
                  <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                </svg>
              </a>
            )}

            {isAdmin && (
              <a href="/admin/" class="user-dropdown-item user-dropdown-item--has-icon">
                <span>{copy.admin}</span>
                <svg class="dropdown-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="7.5" cy="15.5" r="2.5"></circle>
                  <path d="M10 15.5H20"></path>
                  <path d="M17 12.5v6"></path>
                  <path d="M14 13.5v4"></path>
                </svg>
              </a>
            )}

            {user ? (
              <form method="POST" action={`/api/auth/logout?redirectTo=${encodeURIComponent(currentPath)}`} style="margin: 0;">
                <div class="user-dropdown-divider"></div>
                <button type="submit" class="user-dropdown-item user-dropdown-item--button user-dropdown-item--danger">
                  <span>{copy.signOut}</span>
                </button>
              </form>
            ) : (
              <a href={`/login?redirectTo=${encodeURIComponent(currentPath)}`} class="user-dropdown-item">
                {copy.signIn}
              </a>
            )}
          </div>
        </div>
      </div>
    </div>

    <div class="site-primary-nav site-primary-nav--mobile" aria-label="Primary navigation">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`site-nav-pill${item.active ? ' site-nav-pill--active' : ''}`}
          aria-current={item.active ? 'page' : undefined}
          data-astro-prefetch="viewport"
        >
          {item.label}
        </a>
      ))}
    </div>
  </nav>
</header>
<div class="site-header-spacer" aria-hidden="true"></div>

<!-- Newsletter Envelope -->
<div class="nl-env" data-nl-env data-open="false" aria-hidden="true" hidden>
  <button type="button" class="nl-env-overlay" data-nl-close aria-label="Close"></button>
  <div class="nl-env-stage" role="dialog" aria-modal="true" aria-labelledby="nl-env-title">
    <div class="nl-env-envelope">
      <div class="nl-env-envelope-back"></div>
      <div class="nl-env-letter">
        <button type="button" class="nl-env-close" data-nl-close aria-label="Close">&times;</button>
        <p class="nl-env-brand" aria-hidden="true">0to1log</p>
        <div class="nl-env-rule"></div>
        <h2 id="nl-env-title" class="nl-env-title">{nlCopy.nlTitle}</h2>
        <p class="nl-env-sub">{nlCopy.nlSubtitle}</p>
        <form class="nl-env-form" data-nl-form
          data-form-src="https://subscribe-forms.beehiiv.com/8b66eb99-0f38-420d-9d08-e4a729e0c14b"
          data-submitting={nlCopy.nlSubmitting} data-success={nlCopy.nlSuccess}
          data-error={nlCopy.nlError} data-button={nlCopy.nlButton}>
          <label for="nl-env-email" class="sr-only">Email</label>
          <input id="nl-env-email" type="email" required placeholder={nlCopy.nlPlaceholder}
            class="nl-env-input" autocomplete="email" />
