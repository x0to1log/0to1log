---
interface Props {
  locale?: 'en' | 'ko';
}
---

<script>
  let progressAbort: AbortController | null = null;

  function initProgress() {
    if (progressAbort) { progressAbort.abort(); progressAbort = null; }

    const article = document.querySelector('.newsprint-article')
      || document.querySelector('article')
      || document.querySelector('[data-article-body]');
    if (!article) return;

    const fills = document.querySelectorAll<HTMLElement>('.reading-progress__fill');
    if (!fills.length) return;

    document.querySelectorAll('.reading-progress-bar--done').forEach((b) => {
      b.classList.remove('reading-progress-bar--done');
    });
    fills.forEach((f) => { f.style.width = '0%'; });

    let hasCompleted = false;
    let targetProgress = 0;
    let currentProgress = 0;
    let animating = false;

    function spawnConfetti(bar: Element) {
      bar.classList.add('reading-progress-bar--done');
      const colors = [
        'var(--color-accent)',
        'color-mix(in srgb, var(--color-accent) 70%, white)',
        'color-mix(in srgb, var(--color-accent) 50%, white)',
        'var(--color-text-primary)',
      ];
      for (let i = 0; i < 12; i++) {
        const dot = document.createElement('span');
        dot.className = 'confetti-particle';
        dot.style.setProperty('--cx', (Math.random() * 40 - 20) + 'px');
        dot.style.setProperty('--cy', -(Math.random() * 40 + 15) + 'px');
        dot.style.setProperty('--cr', (Math.random() * 360) + 'deg');
        dot.style.setProperty('--cd', (Math.random() * 0.4 + 0.8) + 's');
        dot.style.background = colors[i % colors.length];
        bar.appendChild(dot);
      }
      setTimeout(() => {
        bar.querySelectorAll('.confetti-particle').forEach((p) => p.remove());
      }, 2000);
    }

    function getTarget() {
      const rect = article.getBoundingClientRect();
      if (rect.height === 0) return -1; // 레이아웃 미완료 신호
      const scrolled = window.scrollY + window.innerHeight;
      const articleTop = rect.top + window.scrollY;

      // [data-reading-end] 마커가 있으면 그 지점을 100% 기준으로 사용
      const endEl = document.querySelector('[data-reading-end]');
      if (endEl) {
        const endTop = endEl.getBoundingClientRect().top + window.scrollY;
        const range = endTop - articleTop;
        if (range <= 0) return 100;
        return Math.min(100, Math.max(0, ((scrolled - articleTop) / range) * 100));
      }

      return Math.min(100, Math.max(0, ((scrolled - articleTop) / rect.height) * 100));
    }

    function animate() {
      // lerp: currentProgress가 targetProgress를 천천히 따라옴
      currentProgress += (targetProgress - currentProgress) * 0.06;
      fills.forEach((f) => { f.style.width = currentProgress + '%'; });

      if (currentProgress >= 99.5 && !hasCompleted) {
        hasCompleted = true;
        document.querySelectorAll('.reading-progress-bar').forEach((bar) => {
          spawnConfetti(bar);
        });
      }

      if (Math.abs(targetProgress - currentProgress) > 0.1) {
        requestAnimationFrame(animate);
      } else {
        currentProgress = targetProgress;
        fills.forEach((f) => { f.style.width = currentProgress + '%'; });
        animating = false;
      }
    }

    function onScroll() {
      const t = getTarget();
      if (t === -1) { requestAnimationFrame(onScroll); return; } // 레이아웃 재시도
      targetProgress = t;
      if (!animating) { animating = true; requestAnimationFrame(animate); }
    }

    progressAbort = new AbortController();
    window.addEventListener('scroll', onScroll, { passive: true, signal: progressAbort.signal });
    onScroll();
  }

  document.addEventListener('astro:page-load', initProgress);
  initProgress();
</script>
