---
interface Props {
  sourceType: 'news' | 'handbook' | 'blog' | 'product';
  sourceId: string;
  locale: 'ko' | 'en';
  isAuthenticated: boolean;
  loginUrl: string;
  previewMode?: boolean;
}

const {
  sourceType,
  sourceId,
  locale,
  isAuthenticated,
  loginUrl,
  previewMode = false,
} = Astro.props;

const copy =
  locale === 'ko'
    ? {
        title: '도움이 되었나요?',
        positive: '도움이 됐어요',
        negative: '아쉬워요',
        thanks: '피드백 감사합니다.',
        error: '피드백 저장에 실패했습니다.',
        previewNote: 'Preview mode',
      }
    : {
        title: 'Helpful?',
        positive: 'Yes',
        negative: 'Not really',
        thanks: 'Thanks for your feedback.',
        error: 'Failed to save feedback.',
        previewNote: 'Preview mode',
      };
---

<section
  class="content-feedback"
  aria-label={copy.title}
  data-content-feedback
  data-source-type={sourceType}
  data-source-id={sourceId}
  data-locale={locale}
  data-authenticated={isAuthenticated ? 'true' : 'false'}
  data-auth-action="feedback"
  data-login-url={loginUrl}
  data-preview-mode={previewMode ? 'true' : 'false'}
  data-thanks={copy.thanks}
  data-error={copy.error}
>
  <span class="content-feedback-label">{copy.title}</span>
  <div class="content-feedback-actions">
    <button
      type="button"
      class="content-feedback-btn content-feedback-btn--positive"
      aria-label={copy.positive}
      aria-pressed="false"
      data-reaction="positive"
      data-auth-action="feedback"
      aria-disabled={previewMode ? 'true' : undefined}
      tabindex={previewMode ? '-1' : undefined}
      disabled={previewMode}
      title={copy.positive}
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
    </button>
    <button
      type="button"
      class="content-feedback-btn content-feedback-btn--negative"
      aria-label={copy.negative}
      aria-pressed="false"
      data-reaction="negative"
      data-auth-action="feedback"
      aria-disabled={previewMode ? 'true' : undefined}
      tabindex={previewMode ? '-1' : undefined}
      disabled={previewMode}
      title={copy.negative}
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3H10z"/><path d="M17 2h3a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2h-3"/></svg>
    </button>
  </div>
  <span class="content-feedback-status" data-feedback-status aria-live="polite" hidden></span>
</section>
