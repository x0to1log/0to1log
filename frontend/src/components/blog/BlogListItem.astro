---
import { getCategoryLabel, getCategoryColorVar } from '../../lib/categories';

interface Props {
  href: string;
  title: string;
  category?: string | null;
  publishedAt?: string | null;
  readingTimeMin?: number | null;
  locale: 'en' | 'ko';
  isRead?: boolean;
  isBookmarked?: boolean;
  itemId?: string;
  itemType?: 'blog';
}

const {
  href,
  title,
  category,
  publishedAt,
  readingTimeMin,
  locale,
  isRead,
  isBookmarked = false,
  itemId,
  itemType = 'blog',
} = Astro.props;

const catLabel = getCategoryLabel(locale, category);
const catColor = getCategoryColorVar(category);

const dateStr = publishedAt
  ? new Date(publishedAt).toLocaleDateString(locale === 'ko' ? 'ko-KR' : 'en-US', { month: 'short', day: 'numeric' })
  : null;
const readingLabel = readingTimeMin
  ? locale === 'ko' ? `${readingTimeMin}분` : `${readingTimeMin} min`
  : null;
---

<a href={href} class:list={['blog-list-item', { 'blog-list-item--read': isRead }]}>
  <div class="blog-list-item-left">
    <svg class="blog-list-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M4 4h16v16H4zM8 8h8M8 12h5" />
    </svg>
    <span class="blog-list-item-title">{title}</span>
  </div>
  <div class="blog-list-item-meta">
    {catLabel && (
      <span class="blog-list-item-category blog-category-badge" style={`background: color-mix(in srgb, ${catColor} 15%, transparent); color: ${catColor}`}>
        {catLabel}
      </span>
    )}
    {readingLabel && <span class="blog-list-item-reading-time">{readingLabel}</span>}
    {dateStr && <span class="blog-list-item-date">{dateStr}</span>}
    {itemId && (
      <button
        type="button"
        class={`newsprint-bookmark-icon ${isBookmarked ? 'newsprint-bookmark-icon--active' : ''}`}
        data-item-id={itemId}
        data-item-type={itemType}
        data-bookmarked={isBookmarked ? 'true' : 'false'}
        aria-label={isBookmarked ? 'Remove bookmark' : 'Add bookmark'}
      >
        <svg viewBox="0 0 24 24" fill={isBookmarked ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2">
          <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" />
        </svg>
      </button>
    )}
  </div>
</a>
