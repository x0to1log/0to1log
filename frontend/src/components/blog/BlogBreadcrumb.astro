---
import { normalizeCategorySlug } from '../../lib/categories';
import { t } from '../../i18n/index';
import type { BlogCategory } from '../../lib/pageData/blogCategories';

interface Props {
  locale: 'en' | 'ko';
  category?: string | null;
  title: string;
  categories?: BlogCategory[];
}

const { locale, category, title, categories = [] } = Astro.props;
const normalizedCat = normalizeCategorySlug(category);
const catLabel = normalizedCat
  ? (categories.find(c => c.slug === normalizedCat)?.['label_' + locale] ?? normalizedCat)
  : null;
---

<nav class="blog-breadcrumb">
  <a href={`/${locale}/blog/`}>{t[locale]['blog.title']}</a>
  <span>/</span>
  {catLabel && (
    <>
      <a href={`/${locale}/blog/category/${normalizedCat}/`}>{catLabel}</a>
      <span>/</span>
    </>
  )}
  <span class="blog-breadcrumb-current">
    <span>📘</span> {title}
  </span>
</nav>
