---
import { t } from '../../i18n/index';
import {
  getBlogSidebarCategoryState,
  getBlogSidebarCurrentCategory,
  getBlogSidebarGroupExpanded,
  type BlogSidebarMode,
  type SidebarPost,
} from '../../lib/pageData/blogSidebar';
import { supabase } from '../../lib/supabase';
import { fetchCategories, fetchCategoryGroups } from '../../lib/pageData/blogCategories';

const CATEGORY_ICONS: Record<string, string> = {
  study:
    '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>',
  project:
    '<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>',
  career:
    '<rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>',
  'work-note':
    '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/>',
  daily:
    '<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>',
};

interface Props {
  locale: 'en' | 'ko';
  posts: SidebarPost[];
  currentSlug?: string;
  currentCategory?: string;
  totalCount: number;
  mode?: BlogSidebarMode;
}

const {
  locale,
  posts,
  currentSlug,
  currentCategory: explicitCurrentCategory,
  totalCount,
  mode = 'index',
} = Astro.props as Props;

// Fetch categories & groups from DB
const dbCategories = supabase ? await fetchCategories(supabase) : [];
const dbGroups = supabase ? await fetchCategoryGroups(supabase) : [];

const allCategorySlugs = dbCategories.map((c) => c.slug);
const subCategorySlugs = dbCategories.filter((c) => c.group_slug === 'sub').map((c) => c.slug);

// Build category groups with their category slugs
const categoryGroups = dbGroups.map((g) => ({
  slug: g.slug,
  label: locale === 'ko' ? g.label_ko : g.label_en,
  categories: dbCategories.filter((c) => c.group_slug === g.slug).map((c) => c.slug),
}));

// Build label maps from DB
const sidebarLabelMap = new Map(dbCategories.map((c) => [c.slug, locale === 'ko' ? c.label_ko : c.label_en]));
const groupLabelMap = new Map(dbGroups.map((g) => [g.slug, locale === 'ko' ? g.label_ko : g.label_en]));

const postsByCategory = allCategorySlugs.reduce((acc, category) => {
  acc[category] = posts.filter((post) => post.category === category);
  return acc;
}, {} as Record<string, SidebarPost[]>);

const currentCategory = getBlogSidebarCurrentCategory(posts, currentSlug, explicitCurrentCategory);

const comingSoonLabel = locale === 'ko' ? '글 준비 중' : 'Coming soon';
const moreLabel = locale === 'ko' ? '개 더 보기' : ' more';
const searchLabel = locale === 'ko' ? '글 검색' : 'Search posts';
---

<aside class="blog-sidebar" data-blog-sidebar>
  <div class="blog-sidebar-search">
    <button class="blog-sidebar-search-btn" type="button" aria-label={searchLabel}>
      <span>{t[locale]['blog.search']}</span>
      <kbd class="blog-sidebar-search-kbd">/</kbd>
    </button>
  </div>

  <nav class="blog-sidebar-nav">
    {categoryGroups.map((group) => {
      const groupCount = group.categories.reduce((total, category) => {
        return total + (postsByCategory[category]?.length ?? 0);
      }, 0);
      const groupExpanded = getBlogSidebarGroupExpanded(group.categories, {
        mode,
        currentCategory,
        groupCount,
      });

      return (
        <div class="blog-folder blog-folder--group">
          <button
            class="blog-folder-btn blog-folder-btn--group"
            type="button"
            aria-expanded={groupExpanded ? 'true' : 'false'}
          >
            <svg class="blog-folder-arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M6 4l4 4-4 4" />
            </svg>
            <span class="blog-folder-group-label">{groupLabelMap.get(group.slug) ?? group.slug}</span>
            <span class="blog-folder-group-count">({groupCount})</span>
          </button>

          <div class="blog-folder-children blog-folder-children--group" {...(!groupExpanded && { hidden: true })}>
            {group.categories.map((category) => {
              const categoryPosts = postsByCategory[category] || [];
              const { expanded: categoryExpanded, extraPosts, visiblePosts } = getBlogSidebarCategoryState(
                categoryPosts,
                {
                  mode,
                  category,
                  currentCategory,
                  currentSlug,
                },
                subCategorySlugs,
              );
              const categoryLabel = sidebarLabelMap.get(category) ?? category;
              const dbCat = dbCategories.find(c => c.slug === category);
              const colorVar = dbCat?.color ?? 'var(--color-border)';

              const iconSvg = CATEGORY_ICONS[category] ?? '';

              return (
                <div class="blog-folder" style={`--folder-color: ${colorVar}`}>
                  <div class="blog-folder-header">
                    <button class="blog-folder-arrow-btn" type="button" aria-expanded={categoryExpanded ? 'true' : 'false'}>
                      <svg class="blog-folder-arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M6 4l4 4-4 4" />
                      </svg>
                    </button>
                    <a class="blog-folder-category-link" href={`/${locale}/blog/category/${category}/`}
                       style={`--folder-color: ${colorVar}`}>
                      <svg class="blog-folder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                           stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
                           aria-hidden="true" style={`color: ${colorVar}`}
                           set:html={iconSvg} />
                      <span>{categoryLabel}</span>
                      <span class="blog-folder-count">({categoryPosts.length})</span>
                    </a>
                  </div>

                  <div class="blog-folder-children" {...(!categoryExpanded && { hidden: true })}>
                    {categoryPosts.length === 0 && <span class="blog-folder-empty">{comingSoonLabel}</span>}

                    {visiblePosts.map((post) => (
                      <a
                        class:list={[
                          'blog-sidebar-link',
                          { 'blog-sidebar-link--active': post.slug === currentSlug },
                        ]}
                        href={`/${locale}/blog/${post.slug}/`}
                      >
                        <span class="blog-sidebar-link__title">{post.title}</span>
                      </a>
                    ))}

                    {extraPosts.length > 0 && (
                      <>
                        <div class="blog-folder-extra" hidden>
                          {extraPosts.map((post) => (
                            <a
                              class:list={[
                                'blog-sidebar-link',
                                { 'blog-sidebar-link--active': post.slug === currentSlug },
                              ]}
                              href={`/${locale}/blog/${post.slug}/`}
                            >
                              <span class="blog-sidebar-link__title">{post.title}</span>
                            </a>
                          ))}
                        </div>
                        <button class="blog-folder-more" type="button" data-folder-more>
                          +{extraPosts.length}
                          {moreLabel}
                        </button>
                      </>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      );
    })}
  </nav>

  <div class="blog-sidebar-footer">
    <a href={`/${locale}/blog/`}>
      {t[locale]['blog.allPostsCount']} ({totalCount})
    </a>
  </div>
</aside>

<script>
  function initBlogSidebar(): void {
    const sidebar = document.querySelector<HTMLElement>('[data-blog-sidebar]');
    const overlay = document.querySelector<HTMLElement>('[data-sidebar-overlay]');
    if (!sidebar) return;

    const mobileBreakpoint = window.matchMedia('(max-width: 1023px)');

    function closeSidebar(): void {
      if (!sidebar) return;
      sidebar.classList.remove('blog-sidebar--open');
      overlay?.classList.remove('blog-sidebar-overlay--open');
      document.body.style.overflow = '';
    }

    function openSidebar(): void {
      if (!sidebar) return;
      sidebar.classList.add('blog-sidebar--open');
      overlay?.classList.add('blog-sidebar-overlay--open');
      document.body.style.overflow = 'hidden';
    }

    function toggleSidebar(): void {
      if (!sidebar) return;
      if (!mobileBreakpoint.matches) return;
      if (sidebar.classList.contains('blog-sidebar--open')) {
        closeSidebar();
      } else {
        openSidebar();
      }
    }

    // Sidebar-internal bindings — only once
    if (sidebar.dataset.blogSidebarInit !== '1') {
      sidebar.dataset.blogSidebarInit = '1';

      sidebar.querySelectorAll<HTMLButtonElement>('.blog-folder-btn, .blog-folder-arrow-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const expanded = btn.getAttribute('aria-expanded') === 'true';
          btn.setAttribute('aria-expanded', String(!expanded));
          // For group buttons, children div is the next sibling of the button.
          // For arrow buttons, children div is the next sibling of the parent .blog-folder-header.
          const parent = btn.closest('.blog-folder-header');
          const children = parent
            ? (parent.nextElementSibling as HTMLElement | null)
            : (btn.nextElementSibling as HTMLElement | null);
          if (children) {
            children.hidden = expanded;
          }
        });
      });

      sidebar.querySelectorAll<HTMLButtonElement>('[data-folder-more]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const extra = btn.previousElementSibling as HTMLElement | null;
          if (extra && extra.classList.contains('blog-folder-extra')) {
            extra.hidden = false;
          }
          btn.remove();
        });
      });

      if (overlay && overlay.dataset.mobileMenuInit !== '1') {
        overlay.dataset.mobileMenuInit = '1';
        overlay.addEventListener('click', closeSidebar);
      }

      sidebar.querySelectorAll<HTMLAnchorElement>('a').forEach((link) => {
        link.addEventListener('click', () => {
          if (mobileBreakpoint.matches) closeSidebar();
        });
      });

      window.addEventListener('resize', () => {
        if (!mobileBreakpoint.matches) {
          closeSidebar();
        }
      });
    }

    // Toggle buttons — always re-bind (new buttons appear on view transitions)
    document.querySelectorAll<HTMLButtonElement>('[data-sidebar-toggle]').forEach((btn) => {
      if (btn.dataset.mobileMenuInit === '1') return;
      btn.dataset.mobileMenuInit = '1';
      btn.addEventListener('click', toggleSidebar);
    });
  }

  document.addEventListener('astro:page-load', initBlogSidebar);
  initBlogSidebar();
</script>
