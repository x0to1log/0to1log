---
import { t } from '../../i18n/index';
import {
  BLOG_CATEGORIES,
  BLOG_CATEGORY_GROUPS,
  getBlogCategoryGroupLabel,
  getBlogSidebarLabel,
  getCategoryColorVar,
} from '../../lib/categories';

interface SidebarPost {
  title: string;
  slug: string;
  category: string;
}

interface Props {
  locale: 'en' | 'ko';
  posts: SidebarPost[];
  currentSlug?: string;
  totalCount: number;
}

const { locale, posts, currentSlug, totalCount } = Astro.props;

const VISIBLE_LIMIT = 3;
const postsByCategory = BLOG_CATEGORIES.reduce((acc, category) => {
  acc[category] = posts.filter((post) => post.category === category);
  return acc;
}, {} as Record<string, SidebarPost[]>);

const currentCategory = currentSlug
  ? posts.find((post) => post.slug === currentSlug)?.category
  : undefined;

const sidebarBrand = locale === 'ko' ? '글쓰기' : 'Writing';
const closeLabel = locale === 'ko' ? '사이드바 닫기' : 'Close sidebar';
const comingSoonLabel = locale === 'ko' ? '글 준비 중' : 'Coming soon';
const moreLabel = locale === 'ko' ? '개 더 보기' : ' more';
const searchLabel = locale === 'ko' ? '글 검색' : 'Search posts';
---

<aside class="blog-sidebar" data-blog-sidebar>
  <div class="blog-sidebar-header">
    <span class="blog-sidebar-brand">{sidebarBrand}</span>
    <button class="blog-sidebar-close" data-sidebar-close aria-label={closeLabel} type="button">
      &times;
    </button>
  </div>

  <div class="blog-sidebar-search">
    <button class="blog-sidebar-search-btn" type="button" aria-label={searchLabel}>
      <span>{t[locale]['blog.search']}</span>
      <kbd class="blog-sidebar-search-kbd">/</kbd>
    </button>
  </div>

  <nav class="blog-sidebar-nav">
    {BLOG_CATEGORY_GROUPS.map((group) => {
      const groupCount = group.categories.reduce((total, category) => {
        return total + (postsByCategory[category]?.length ?? 0);
      }, 0);
      const groupExpanded = group.categories.some((category) => category === currentCategory) || groupCount > 0;

      return (
        <div class="blog-folder blog-folder--group">
          <button
            class="blog-folder-btn blog-folder-btn--group"
            type="button"
            aria-expanded={groupExpanded ? 'true' : 'false'}
          >
            <svg class="blog-folder-arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M6 4l4 4-4 4" />
            </svg>
            <span class="blog-folder-group-label">{getBlogCategoryGroupLabel(locale, group.slug)}</span>
            <span class="blog-folder-group-count">({groupCount})</span>
          </button>

          <div class="blog-folder-children blog-folder-children--group" {...(!groupExpanded && { hidden: true })}>
            {group.categories.map((category) => {
              const categoryPosts = postsByCategory[category] || [];
              const visiblePosts = categoryPosts.slice(0, VISIBLE_LIMIT);
              const extraPosts = categoryPosts.slice(VISIBLE_LIMIT);
              const categoryExpanded = currentCategory === category || categoryPosts.length > 0;
              const categoryLabel = getBlogSidebarLabel(locale, category);
              const colorVar = getCategoryColorVar(category);

              return (
                <div class="blog-folder" style={`--folder-color: ${colorVar}`}>
                  <button
                    class="blog-folder-btn"
                    type="button"
                    aria-expanded={categoryExpanded ? 'true' : 'false'}
                  >
                    <svg class="blog-folder-arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                      <path d="M6 4l4 4-4 4" />
                    </svg>
                    <span class="blog-folder-dot" style={`background: ${colorVar}`}></span>
                    <span>{categoryLabel}</span>
                    <span class="blog-folder-count">({categoryPosts.length})</span>
                  </button>

                  <div class="blog-folder-children" {...(!categoryExpanded && { hidden: true })}>
                    {categoryPosts.length === 0 && (
                      <span class="blog-folder-empty">{comingSoonLabel}</span>
                    )}

                    {visiblePosts.map((post) => (
                      <a
                        class:list={[
                          'blog-sidebar-link',
                          { 'blog-sidebar-link--active': post.slug === currentSlug },
                        ]}
                        href={`/${locale}/blog/${post.slug}/`}
                      >
                        {post.title}
                      </a>
                    ))}

                    {extraPosts.length > 0 && (
                      <>
                        <div class="blog-folder-extra" hidden>
                          {extraPosts.map((post) => (
                            <a
                              class:list={[
                                'blog-sidebar-link',
                                { 'blog-sidebar-link--active': post.slug === currentSlug },
                              ]}
                              href={`/${locale}/blog/${post.slug}/`}
                            >
                              {post.title}
                            </a>
                          ))}
                        </div>
                        <button class="blog-folder-more" type="button" data-folder-more>
                          +{extraPosts.length}
                          {moreLabel}
                        </button>
                      </>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      );
    })}
  </nav>

  <div class="blog-sidebar-footer">
    <a href={`/${locale}/blog/`}>
      {t[locale]['blog.allPostsCount']} ({totalCount})
    </a>
  </div>
</aside>

<script>
  function initBlogSidebar() {
    document.querySelectorAll<HTMLButtonElement>('.blog-folder-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!expanded));
        const children = btn.nextElementSibling as HTMLElement | null;
        if (children) {
          children.hidden = expanded;
        }
      });
    });

    document.querySelectorAll<HTMLButtonElement>('[data-folder-more]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const extra = btn.previousElementSibling as HTMLElement | null;
        if (extra && extra.classList.contains('blog-folder-extra')) {
          extra.hidden = false;
        }
        btn.remove();
      });
    });

    function closeSidebar() {
      document.querySelectorAll('.blog-sidebar').forEach((sidebar) => {
        sidebar.classList.remove('blog-sidebar--open');
      });
      document.querySelectorAll('.blog-sidebar-overlay').forEach((overlay) => {
        overlay.classList.remove('blog-sidebar-overlay--open');
      });
    }

    document.querySelectorAll('.blog-sidebar-overlay').forEach((overlay) => {
      overlay.addEventListener('click', closeSidebar);
    });

    document.querySelectorAll<HTMLButtonElement>('[data-sidebar-close]').forEach((btn) => {
      btn.addEventListener('click', closeSidebar);
    });
  }

  document.addEventListener('DOMContentLoaded', initBlogSidebar);
  initBlogSidebar();
</script>
