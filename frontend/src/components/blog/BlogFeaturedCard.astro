---
import { normalizeCategorySlug } from '../../lib/categories';
import type { BlogCategory } from '../../lib/pageData/blogCategories';

interface Props {
  href: string;
  title: string;
  excerpt?: string | null;
  category?: string | null;
  readingTimeMin?: number | null;
  tags?: string[] | null;
  locale: 'en' | 'ko';
  isBookmarked?: boolean;
  itemId?: string;
  itemType?: 'blog';
  categories?: BlogCategory[];
}

const {
  href,
  title,
  excerpt,
  category,
  readingTimeMin,
  tags,
  locale,
  isBookmarked = false,
  itemId,
  itemType = 'blog',
  categories = [],
} = Astro.props;

const normalizedCat = normalizeCategorySlug(category);
const catLabel = categories.find(c => c.slug === normalizedCat)?.['label_' + locale] ?? normalizedCat;
const catColor = categories.find(c => c.slug === normalizedCat)?.color ?? 'var(--color-border)';
const readingLabel = readingTimeMin
  ? locale === 'ko' ? `${readingTimeMin}분` : `${readingTimeMin} min`
  : null;
---

<article class="blog-featured-card">
  <div class="blog-featured-card-top">
    <div>
      <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.25rem;">
        {catLabel && (
          <span
            class="blog-category-badge"
            style={`background: color-mix(in srgb, ${catColor} 15%, transparent); color: ${catColor};`}
          >
            {catLabel}
          </span>
        )}
        {readingLabel && (
          <span class="blog-list-item-reading-time">{readingLabel}</span>
        )}
      </div>
      <h3 class="blog-featured-card-title"><a href={href} class="newsprint-card-stretched-link">{title}</a></h3>
    </div>
    <div class="blog-featured-card-actions">
      {itemId && (
        <button
          type="button"
          class={`newsprint-bookmark-icon ${isBookmarked ? 'newsprint-bookmark-icon--active' : ''}`}
          data-item-id={itemId}
          data-item-type={itemType}
          data-bookmarked={isBookmarked ? 'true' : 'false'}
          aria-label={isBookmarked ? 'Remove bookmark' : 'Add bookmark'}
        >
          <svg viewBox="0 0 24 24" fill={isBookmarked ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2">
            <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" />
          </svg>
        </button>
      )}
      <svg class="blog-featured-card-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M7 17L17 7M17 7H7M17 7v10" />
      </svg>
    </div>
  </div>
  {excerpt && <p class="blog-featured-card-excerpt">{excerpt}</p>}
  {tags && tags.length > 0 && (
    <div class="blog-featured-card-tags">
      {tags.map(tag => (
        <span
          class="blog-mono-tag"
          style={`background: color-mix(in srgb, ${catColor} 15%, transparent); color: ${catColor}`}
        >
          #{tag}
        </span>
      ))}
    </div>
  )}
</article>
