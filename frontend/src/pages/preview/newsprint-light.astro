---
import MainLayout from '../../layouts/MainLayout.astro';
import NewsprintShell from '../../components/newsprint/NewsprintShell.astro';
import NewsprintListCard from '../../components/newsprint/NewsprintListCard.astro';
import NewsprintSideRail from '../../components/newsprint/NewsprintSideRail.astro';
import NewsprintCategoryFilter from '../../components/newsprint/NewsprintCategoryFilter.astro';

const mockPosts = [
  {
    title: 'GPT-5 Release Shakes Up Enterprise AI Adoption',
    slug: 'preview-gpt5-enterprise',
    category: 'ai-news',
    published_at: new Date().toISOString(),
    reading_time_min: 6,
    tags: ['gpt-5', 'enterprise', 'adoption'],
    excerpt: 'Early benchmarks suggest a 40% improvement in complex reasoning tasks, reshaping how enterprises approach AI integration at scale.',
  },
  {
    title: 'Building a RAG Pipeline with LangChain and Pinecone',
    slug: 'preview-rag-pipeline',
    category: 'tech',
    published_at: new Date().toISOString(),
    reading_time_min: 8,
    tags: ['rag', 'langchain', 'pinecone', 'tutorial'],
    excerpt: 'A step-by-step guide to building a production-ready retrieval-augmented generation pipeline using LangChain and Pinecone vector database.',
  },
  {
    title: 'From Bootcamp to Senior Engineer: A 3-Year Retrospective',
    slug: 'preview-bootcamp-retro',
    category: 'career',
    published_at: new Date().toISOString(),
    reading_time_min: 5,
    tags: ['growth', 'retrospective', 'career-path'],
    excerpt: 'Three years ago I could barely write a for loop. Here is what I learned about growth, mentorship, and the moments that actually mattered.',
  },
  {
    title: 'Architecting 0to1log: From Monolith to Microservices',
    slug: 'preview-0to1log-arch',
    category: 'project',
    published_at: new Date().toISOString(),
    reading_time_min: 10,
    tags: ['architecture', 'fastapi', 'supabase'],
    excerpt: 'How we broke apart a monolithic FastAPI backend into event-driven microservices with Supabase, and what we would do differently next time.',
  },
  {
    title: 'Anthropic Raises $5B as AI Safety Market Heats Up',
    slug: 'preview-anthropic-funding',
    category: 'ai-news',
    published_at: new Date().toISOString(),
    reading_time_min: 4,
    tags: ['funding', 'anthropic', 'safety'],
    excerpt: 'The latest funding round signals growing investor confidence in AI safety as a market category, not just a research concern.',
  },
];
---

<MainLayout title="Newsprint Preview (Light)" locale="en" slug="preview/newsprint-light/">
  <script is:inline>document.documentElement.setAttribute('data-theme','light');localStorage.setItem('theme','light');</script>
  <NewsprintShell locale="en" masthead="From Void to Value" editionLabel="Preview / Light"
      subkicker={['AI · Papers · Projects', 'Preview Edition', 'Free']}>

      <NewsprintCategoryFilter locale="en" />

      <section class="newsprint-grid-cards">
        {mockPosts.map((post) => (
          <NewsprintListCard
            href="#"
            title={post.title}
            excerpt={post.excerpt}
            category={post.category}
            publishedAt={post.published_at}
            readingTimeMin={post.reading_time_min}
            tags={post.tags}
            locale="en"
          />
        ))}
      </section>

      <Fragment slot="rail">
        <NewsprintSideRail
          locale="en"
          posts={mockPosts}
          categories={['ai-news', 'tech', 'career', 'project']}
        />
      </Fragment>
    </NewsprintShell>
</MainLayout>
