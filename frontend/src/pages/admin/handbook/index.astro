---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import AdminSidebar from '../../../components/admin/AdminSidebar.astro';
import NewsprintNotice from '../../../components/newsprint/NewsprintNotice.astro';
import { createClient } from '@supabase/supabase-js';
import { getHandbookCategoryLabel } from '../../../lib/handbookCategories';

const accessToken = Astro.locals.accessToken;
const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
);

let fetchError: string | null = null;

const { data: terms, error } = await supabase
  .from('handbook_terms')
  .select('id, term, slug, korean_name, status, categories, definition_ko, definition_en, body_basic_ko, body_basic_en, body_advanced_ko, body_advanced_en, updated_at, published_at, source')
  .order('updated_at', { ascending: false })
  .limit(500);

if (error) {
  fetchError = error.message;
}

const STATUS_PRIORITY: Record<string, number> = { queued: 0, draft: 1, published: 2, archived: 3 };
const allTerms = (terms ?? []).sort((a, b) => {
  const pa = STATUS_PRIORITY[a.status] ?? 9;
  const pb = STATUS_PRIORITY[b.status] ?? 9;
  if (pa !== pb) return pa - pb;
  return new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime();
});

const queuedCount = allTerms.filter((term) => term.status === 'queued').length;
const draftCount = allTerms.filter((term) => term.status === 'draft').length;
const publishedCount = allTerms.filter((term) => term.status === 'published').length;
const archivedCount = allTerms.filter((term) => term.status === 'archived').length;
const categoryOptions = Array.from(new Set(allTerms.flatMap((term) => term.categories || []))).sort();
---

<MainLayout title="Admin Handbook" locale="en">
  <AdminSidebar activeSection="handbook" />

  <div class="admin-dashboard">
    <div class="admin-main">
      <div class="admin-main-header">
        <div class="admin-main-header-top">
          <button class="admin-mobile-menu-btn" id="mobile-menu-btn" type="button" aria-label="Menu">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 5h14M3 10h14M3 15h14" />
            </svg>
          </button>
          <div>
            <h1 class="admin-main-title">Handbook</h1>
          </div>
        </div>
      </div>

      <div class="admin-list-toolbar">
        <div class="admin-list-toolbar-row">
          <div class="admin-list-toolbar-left">
            <a href="/admin/handbook/edit/new" class="admin-btn admin-btn-primary">New Term</a>
            <div class="admin-filter-tabs">
              {queuedCount > 0 && <button class="admin-filter-btn" data-filter="queued">Queued ({queuedCount})</button>}
              <button class="admin-filter-btn admin-filter-btn--active" data-filter="draft">Draft ({draftCount})</button>
              <button class="admin-filter-btn" data-filter="published">Published ({publishedCount})</button>
              {archivedCount > 0 && <button class="admin-filter-btn" data-filter="archived">Archived ({archivedCount})</button>}
              <button class="admin-filter-btn" data-filter="all">All ({allTerms.length})</button>
            </div>
          </div>
          <div class="admin-list-toolbar-right">
            <select id="admin-source-filter" class="admin-select">
              <option value="">All sources</option>
              <option value="manual">Manual</option>
              <option value="pipeline">Pipeline</option>
              <option value="ai-suggested">AI Suggested</option>
            </select>
            <div class="admin-search-wrapper">
              <input
                type="search"
                class="admin-input admin-search-input"
                id="admin-search"
                placeholder="Search terms or Korean names..."
                aria-label="Search handbook terms"
              />
              <button class="admin-search-clear" id="search-clear" type="button" hidden aria-label="Clear search">x</button>
            </div>
            <button class="admin-btn admin-filters-toggle" id="filters-toggle" type="button">
              Filters
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 5l3 3 3-3" />
              </svg>
            </button>
          </div>
        </div>
        <div class="admin-list-toolbar-filters" id="filters-panel" hidden>
          <select id="admin-category-filter" class="admin-select">
            <option value="">All categories</option>
            {categoryOptions.map((category) => (
              <option value={category}>{getHandbookCategoryLabel('en', category)}</option>
            ))}
          </select>
        </div>
      </div>

      <!-- Result count + completeness legend -->
      <div class="handbook-results-bar">
        <span class="handbook-results-count" id="results-count">{allTerms.length} terms</span>
        <span class="handbook-legend">
          <span class="handbook-legend-label">Body:</span>
          <span class="handbook-dot handbook-dot--ok"></span> KO Basic
          <span class="handbook-dot handbook-dot--ok"></span> KO Adv
          <span class="handbook-dot handbook-dot--ok"></span> EN Basic
          <span class="handbook-dot handbook-dot--ok"></span> EN Adv
        </span>
      </div>

      <!-- Bulk action bar -->
      <div class="handbook-bulk-bar" id="bulk-bar" hidden>
        <label class="handbook-bulk-count" id="bulk-count">0 selected</label>
        <button class="admin-btn admin-btn-primary admin-btn-sm" id="bulk-publish">Publish</button>
        <button class="admin-btn admin-btn-sm" id="bulk-unpublish">Unpublish</button>
        <button class="admin-btn admin-btn-sm" id="bulk-archive">Archive</button>
        <button class="admin-btn admin-btn-sm" id="bulk-deselect">Deselect All</button>
      </div>

      {fetchError ? (
        <NewsprintNotice
          variant="unauthorized"
          message={`Failed to load terms: ${fetchError}`}
          linkHref="/admin/handbook/"
          linkLabel="Retry"
        />
      ) : allTerms.length === 0 ? (
        <div class="handbook-empty-state">
          <p class="handbook-empty-title">No handbook terms yet</p>
          <p class="handbook-empty-desc">Create your first term to start building the AI glossary.</p>
          <a href="/admin/handbook/edit/new" class="admin-btn admin-btn-primary">Create First Term</a>
        </div>
      ) : (
        <>
          <ul class="admin-list" id="term-list">
            {allTerms.map((term) => (
              <li
                class={`admin-list-item handbook-card${term.status === 'published' ? ' admin-list-item--published' : ''}`}
                data-status={term.status}
                data-title={`${term.term} ${term.korean_name || ''}`.toLowerCase()}
                data-categories={(term.categories || []).join(',')}
                data-source={term.source || 'manual'}
                data-id={term.id}
                data-site-url={term.status === 'published' ? `/ko/handbook/${term.slug}/` : ''}
              >
                <input type="checkbox" class="handbook-bulk-check" data-bulk-id={term.id} />
                <div class="admin-list-info">
                  <div class="admin-list-title">
                    <a
                      href={term.status === 'published'
                        ? `/ko/handbook/${term.slug}/`
                        : `/admin/handbook/edit/${term.slug}`}
                      target={term.status === 'published' ? '_blank' : undefined}
                      rel={term.status === 'published' ? 'noopener noreferrer' : undefined}
                    >{term.term}</a>
                    {term.korean_name && <span class="admin-list-subtitle"> · {term.korean_name}</span>}
                  </div>
                  <div class="handbook-meta-row">
                    <span class={`admin-status-badge admin-status-badge--${term.status}`}>{term.status}</span>
                    <span class="handbook-completeness" title="KO Basic / KO Advanced / EN Basic / EN Advanced">
                      <span class={`handbook-dot ${term.body_basic_ko ? 'handbook-dot--ok' : ''}`}></span>
                      <span class={`handbook-dot ${term.body_advanced_ko ? 'handbook-dot--ok' : ''}`}></span>
                      <span class={`handbook-dot ${term.body_basic_en ? 'handbook-dot--ok' : ''}`}></span>
                      <span class={`handbook-dot ${term.body_advanced_en ? 'handbook-dot--ok' : ''}`}></span>
                    </span>
                    {term.source && term.source !== 'manual' && (
                      <span class={`admin-source-badge admin-source-badge--${term.source}`}>
                        {term.source === 'pipeline' ? 'Pipeline' : 'AI'}
                      </span>
                    )}
                  </div>
                  {(term.categories || []).length > 0 && (
                    <div class="handbook-meta-row handbook-meta-tags">
                      <span>{(term.categories || []).map((category: string) => getHandbookCategoryLabel('en', category)).join(' · ')}</span>
                    </div>
                  )}
                  <div class="handbook-meta-row handbook-meta-date">
                    Updated {new Date(term.updated_at).toLocaleDateString('en-US', { month: 'numeric', day: 'numeric' })}
                  </div>
                </div>
                <div class="admin-list-actions">
                  <a href={`/admin/handbook/edit/${term.slug}`} class="admin-btn admin-btn-success">Edit</a>
                  <a href={`/admin/handbook/edit/${term.slug}?mode=preview`} class="admin-btn">Preview</a>
                  {term.status === 'queued' ? (
                    <button class="admin-btn admin-btn-primary" data-action="approve" data-id={term.id} data-slug={term.slug}>Approve</button>
                  ) : term.status === 'draft' ? (
                    <button class="admin-btn admin-btn-primary" data-action="publish" data-id={term.id}>Publish</button>
                  ) : term.status === 'published' ? (
                    <button class="admin-btn" data-action="unpublish" data-id={term.id}>Unpublish</button>
                  ) : null}
                  <button class="admin-btn-danger" data-action="delete" data-id={term.id} data-title={term.term}>Delete</button>
                </div>
              </li>
            ))}
          </ul>
          <div id="lazy-sentinel" class="lazy-sentinel" style="display:none;"></div>
          <p id="admin-no-results" class="admin-no-results" hidden>No matching terms found. Try adjusting your search or filters.</p>
        </>
      )}
    </div>
  </div>
</MainLayout>

<style>
  .admin-list-toolbar {
    display: grid;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .admin-list-toolbar-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .admin-list-toolbar-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .admin-list-toolbar-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto;
  }

  .admin-search-wrapper {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .admin-search-wrapper .admin-search-input {
    width: 200px;
    padding-right: 1.8rem;
  }

  .admin-search-clear {
    position: absolute;
    right: 0.4rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    font-size: 0.75rem;
    font-family: var(--font-ui);
    padding: 0.15rem 0.3rem;
    border-radius: 3px;
    line-height: 1;
  }

  .admin-search-clear:hover {
    color: var(--color-text-primary);
    background: var(--color-accent-subtle);
  }

  .admin-search-clear:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 1px;
  }

  .admin-filters-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.82rem;
    white-space: nowrap;
    cursor: pointer;
  }

  .admin-filters-toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .admin-filters-toggle[aria-expanded="true"] svg {
    transform: rotate(180deg);
  }

  .admin-list-toolbar-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    justify-content: flex-end;
  }

  .admin-list-toolbar-filters .admin-select {
    width: auto;
  }

  /* Results bar with count + legend */
  .handbook-results-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.4rem 0;
    margin-bottom: 0.5rem;
    font-family: var(--font-ui);
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  .handbook-results-count {
    font-weight: 600;
  }

  .handbook-legend {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    flex-wrap: wrap;
  }

  .handbook-legend-label {
    margin-right: 2px;
  }

  .handbook-legend .handbook-dot {
    width: 6px;
    height: 6px;
  }

  .handbook-bulk-bar {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    margin-bottom: 0.75rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-accent, #6366f1);
    border-radius: 6px;
    font-size: 0.82rem;
    color: var(--color-text-primary);
    position: sticky;
    top: calc(var(--header-h, 3.5rem) + 0.5rem);
    z-index: 20;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .handbook-bulk-count {
    font-weight: 600;
    margin-right: auto;
  }

  .admin-btn-sm {
    padding: 0.25rem 0.5rem;
    font-size: 0.78rem;
  }

  .handbook-bulk-check {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    cursor: pointer;
    accent-color: var(--admin-primary, #3b82f6);
    align-self: center;
  }

  .handbook-meta-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    font-size: 0.8rem;
    line-height: 1.4;
  }

  .handbook-meta-tags {
    color: var(--admin-text-secondary, #6b7280);
  }

  .handbook-meta-date {
    color: var(--admin-text-tertiary, #9ca3af);
    font-size: 0.75rem;
  }

  .handbook-completeness {
    display: inline-flex;
    align-items: center;
    gap: 3px;
  }

  .handbook-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--admin-muted, #d1d5db);
    border: 1px solid var(--admin-muted, #c5c9d0);
  }

  .handbook-dot--ok {
    background: #22c55e;
    border-color: #16a34a;
  }

  .handbook-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.5rem 1rem;
    cursor: pointer;
    transition: background 150ms ease, box-shadow 150ms ease;
    border-radius: 2px;
  }

  @media (max-width: 640px) {
    .handbook-card {
      grid-template-columns: auto 1fr;
    }
    .handbook-card .admin-list-actions {
      grid-column: 1 / -1;
    }
  }

  .handbook-card:hover {
    background: var(--color-accent-subtle);
  }

  .handbook-card:focus-within {
    background: var(--color-accent-subtle);
  }

  /* Lazy scroll sentinel */
  .lazy-sentinel {
    height: 1px;
    margin-bottom: 1rem;
  }

  /* Empty state */
  .handbook-empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 3rem 1.5rem;
    text-align: center;
    border: 1px dashed var(--color-border);
    border-radius: 8px;
    margin-top: 1rem;
  }

  .handbook-empty-title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0 0 0.5rem 0;
  }

  .handbook-empty-desc {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 0 0 1.25rem 0;
  }

  /* Focus visible states for interactive elements */
  .admin-filter-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .admin-list-title a:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .admin-btn:focus-visible,
  .admin-btn-danger:focus-visible,
  .admin-btn-primary:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  @media (max-width: 640px) {
    .admin-list-toolbar-row {
      flex-direction: column;
      align-items: stretch;
    }

    .admin-list-toolbar-left {
      flex-wrap: wrap;
    }

    .admin-list-toolbar-right {
      margin-left: 0;
      flex-wrap: wrap;
    }

    .admin-search-wrapper {
      flex: 1 1 100%;
      min-width: 0;
    }

    .admin-search-wrapper .admin-search-input {
      width: 100%;
    }

    .admin-list-toolbar-filters {
      flex-direction: column;
      align-items: stretch;
    }


    .handbook-bulk-check {
      margin-top: 0.2rem;
    }

    .handbook-results-bar {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }
  }
</style>

<script>
  // @ts-nocheck
  function initHandbookAdmin() {
    const list = document.getElementById('term-list');
    if (!list || list.dataset.init === '1') return;
    list.dataset.init = '1';

    let currentFilter = 'draft';
    const BATCH_SIZE = 50;
    let maxVisible = BATCH_SIZE;
    const searchInput = document.getElementById('admin-search');
    const searchClear = document.getElementById('search-clear');
    const categoryFilter = document.getElementById('admin-category-filter');
    const sourceFilter = document.getElementById('admin-source-filter');
    const noResults = document.getElementById('admin-no-results');
    const resultsCount = document.getElementById('results-count');
    const filtersToggle = document.getElementById('filters-toggle');
    const filtersPanel = document.getElementById('filters-panel');
    const sentinel = document.getElementById('lazy-sentinel');
    const allItems = list ? Array.from(list.querySelectorAll('.admin-list-item')) : [];
    const totalCount = allItems.length;

    filtersToggle?.addEventListener('click', () => {
      const open = filtersPanel?.hidden === false;
      if (filtersPanel) filtersPanel.hidden = open;
      filtersToggle.setAttribute('aria-expanded', String(!open));
    });

    // Search clear button
    function updateSearchClear() {
      if (searchClear) {
        searchClear.hidden = !(searchInput?.value);
      }
    }

    searchClear?.addEventListener('click', () => {
      if (searchInput) searchInput.value = '';
      updateSearchClear();
      applyFilter();
      searchInput?.focus();
    });

    function applyFilter() {
      const query = (searchInput?.value || '').toLowerCase().trim();
      const category = categoryFilter?.value || '';
      const source = sourceFilter?.value || '';
      const hasActiveSearch = !!(query || category || source);
      let visibleCount = 0;
      let matchCount = 0;

      allItems.forEach((item) => {
        const matchesStatus = currentFilter === 'all' || item.dataset.status === currentFilter;
        const matchesQuery = !query || (item.dataset.title || '').includes(query);
        const matchesCategory = !category || (item.dataset.categories || '').split(',').includes(category);
        const matchesSource = !source || (item.dataset.source || 'manual') === source;
        const matches = matchesStatus && matchesQuery && matchesCategory && matchesSource;

        if (matches) {
          matchCount++;
          // When searching/filtering, show all matches. Otherwise, respect lazy limit.
          const withinLimit = hasActiveSearch || matchCount <= maxVisible;
          item.style.display = withinLimit ? '' : 'none';
          if (withinLimit) visibleCount++;
        } else {
          item.style.display = 'none';
        }
      });

      if (noResults) noResults.hidden = visibleCount > 0;

      // Show/hide sentinel (only when lazy loading has more items to show)
      if (sentinel) {
        sentinel.style.display = (!hasActiveSearch && matchCount > maxVisible) ? '' : 'none';
      }

      // Update result count
      if (resultsCount) {
        if (visibleCount < matchCount) {
          resultsCount.textContent = `Showing ${visibleCount} of ${matchCount} terms`;
        } else {
          resultsCount.textContent = `${visibleCount} term${visibleCount !== 1 ? 's' : ''}`;
        }
      }

      updateSearchClear();
    }

    document.querySelectorAll('[data-filter]').forEach((btn) => {
      btn.addEventListener('click', () => {
        currentFilter = btn.dataset.filter || 'draft';
        maxVisible = BATCH_SIZE;
        document.querySelectorAll('[data-filter]').forEach((target) => target.classList.remove('admin-filter-btn--active'));
        btn.classList.add('admin-filter-btn--active');
        applyFilter();
      });
    });

    // Debounced search
    let searchTimer = null;
    searchInput?.addEventListener('input', () => {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(applyFilter, 200);
    });
    categoryFilter?.addEventListener('change', applyFilter);
    sourceFilter?.addEventListener('change', applyFilter);

    document.querySelectorAll('[data-action]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const action = btn.dataset.action;
        const id = btn.dataset.id;
        if (!action || !id) return;

        if (action === 'approve') {
          const slug = btn.dataset.slug;
          const res = await fetch('/api/admin/handbook/status', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id, action: 'approve' }),
          });
          if (res.ok) {
            window.location.href = `/admin/handbook/edit/${slug}`;
            return;
          }
          const data = await res.json();
          window.alert(`Approve failed: ${data.error || 'Unknown error'}`);
          return;
        }

        if (action === 'delete') {
          const title = btn.dataset.title || 'this term';
          if (!window.confirm(`Delete "${title}"? This cannot be undone.`)) return;
          const res = await fetch('/api/admin/handbook/delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id }),
          });
          if (res.ok) { window.location.reload(); return; }
          const data = await res.json();
          window.alert(`Delete failed: ${data.error || 'Unknown error'}`);
          return;
        }

        const res = await fetch('/api/admin/handbook/status', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, action }),
        });

        if (res.ok) {
          window.location.reload();
          return;
        }

        const data = await res.json();
        window.alert(`${action} failed: ${data.error || 'Unknown error'}`);
      });
    });

    // Card row click: published → open site in new tab, draft → navigate to edit
    list.querySelectorAll('.handbook-card').forEach((card) => {
      card.addEventListener('click', (e) => {
        const target = e.target;
        if (target.closest('a') || target.closest('button') || target.closest('input')) return;
        const siteUrl = card.dataset.siteUrl;
        if (siteUrl) {
          window.open(siteUrl, '_blank', 'noopener,noreferrer');
        } else {
          const link = card.querySelector('.admin-list-title a');
          if (link) window.location.href = link.href;
        }
      });
    });

    // Lazy scroll: load more items when sentinel enters viewport
    if (sentinel) {
      const observer = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) {
          maxVisible += BATCH_SIZE;
          applyFilter();
        }
      }, { rootMargin: '300px' });
      observer.observe(sentinel);
    }

    applyFilter();

    // --- Bulk selection ---
    const bulkBar = document.getElementById('bulk-bar');
    const bulkCount = document.getElementById('bulk-count');
    const checkboxes = list.querySelectorAll('.handbook-bulk-check');

    function updateBulkBar() {
      const checked = list.querySelectorAll('.handbook-bulk-check:checked');
      const count = checked.length;
      if (bulkBar) bulkBar.hidden = count === 0;
      if (bulkCount) bulkCount.textContent = `${count} selected`;
    }

    checkboxes.forEach((cb) => cb.addEventListener('change', updateBulkBar));

    document.getElementById('bulk-deselect')?.addEventListener('click', () => {
      checkboxes.forEach((cb) => { cb.checked = false; });
      updateBulkBar();
    });

    async function bulkAction(action) {
      const checked = list.querySelectorAll('.handbook-bulk-check:checked');
      const ids = Array.from(checked).map((cb) => cb.dataset.bulkId);
      if (ids.length === 0) return;

      const label = action === 'publish' ? 'Publish' : 'Archive';
      if (!window.confirm(`${label} ${ids.length} term(s)?`)) return;

      const res = await fetch('/api/admin/handbook/bulk-action', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action, ids }),
      });

      const data = await res.json();
      if (data.errors?.length > 0) {
        const reasons = data.errors.map((e) => e.reason).join(', ');
        window.alert(`${data.success} succeeded, ${data.failed} failed: ${reasons}`);
      } else {
        window.alert(`${data.success} term(s) ${action === 'publish' ? 'published' : 'archived'}.`);
      }
      window.location.reload();
    }

    document.getElementById('bulk-publish')?.addEventListener('click', () => bulkAction('publish'));
    document.getElementById('bulk-unpublish')?.addEventListener('click', () => bulkAction('unpublish'));
    document.getElementById('bulk-archive')?.addEventListener('click', () => bulkAction('archive'));
  }

  document.addEventListener('DOMContentLoaded', initHandbookAdmin);
  initHandbookAdmin();
</script>




