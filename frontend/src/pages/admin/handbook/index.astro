---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import AdminSidebar from '../../../components/admin/AdminSidebar.astro';
import NewsprintNotice from '../../../components/newsprint/NewsprintNotice.astro';
import { createClient } from '@supabase/supabase-js';
import { getHandbookCategoryLabel } from '../../../lib/handbookCategories';

const accessToken = Astro.locals.accessToken;
const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
);

let fetchError: string | null = null;

const { data: terms, error } = await supabase
  .from('handbook_terms')
  .select('id, term, slug, korean_name, status, categories, difficulty, definition_ko, definition_en, updated_at, published_at, source')
  .order('updated_at', { ascending: false });

if (error) {
  fetchError = error.message;
}

const allTerms = (terms ?? []).sort((a, b) => {
  if (a.status === 'draft' && b.status !== 'draft') return -1;
  if (a.status !== 'draft' && b.status === 'draft') return 1;
  return new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime();
});

const draftCount = allTerms.filter((term) => term.status === 'draft').length;
const publishedCount = allTerms.filter((term) => term.status === 'published').length;
const categoryOptions = Array.from(new Set(allTerms.flatMap((term) => term.categories || []))).sort();
const difficultyOptions = Array.from(new Set(allTerms.map((term) => term.difficulty).filter(Boolean))).sort();
---

<MainLayout title="Admin Handbook" locale="en">
  <AdminSidebar activeSection="handbook" />

  <div class="admin-dashboard">
    <div class="admin-main">
      <div class="admin-main-header">
        <div class="admin-main-header-top">
          <button class="admin-mobile-menu-btn" id="mobile-menu-btn" type="button" aria-label="Menu">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 5h14M3 10h14M3 15h14" />
            </svg>
          </button>
          <div>
            <h1 class="admin-main-title">Handbook</h1>
          </div>
        </div>
      </div>

      <div class="admin-list-toolbar">
        <div class="admin-list-toolbar-row">
          <div class="admin-list-toolbar-left">
            <a href="/admin/handbook/edit/new" class="admin-btn admin-btn-primary">New Term</a>
            <div class="admin-filter-tabs">
              <button class="admin-filter-btn admin-filter-btn--active" data-filter="draft">Draft ({draftCount})</button>
              <button class="admin-filter-btn" data-filter="published">Published ({publishedCount})</button>
              <button class="admin-filter-btn" data-filter="all">All ({allTerms.length})</button>
            </div>
          </div>
          <div class="admin-list-toolbar-right">
            <select id="admin-source-filter" class="admin-select">
              <option value="">All sources</option>
              <option value="manual">Manual</option>
              <option value="pipeline">Pipeline</option>
              <option value="ai-suggested">AI Suggested</option>
            </select>
            <input
              type="search"
              class="admin-input admin-search-input"
              id="admin-search"
              placeholder="Search..."
            />
            <button class="admin-btn admin-filters-toggle" id="filters-toggle" type="button">
              Filters
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 5l3 3 3-3" />
              </svg>
            </button>
          </div>
        </div>
        <div class="admin-list-toolbar-filters" id="filters-panel" hidden>
          <select id="admin-difficulty-filter" class="admin-select">
            <option value="">All difficulties</option>
            {difficultyOptions.map((difficulty) => (
              <option value={difficulty}>{difficulty}</option>
            ))}
          </select>
          <select id="admin-category-filter" class="admin-select">
            <option value="">All categories</option>
            {categoryOptions.map((category) => (
              <option value={category}>{getHandbookCategoryLabel('en', category)}</option>
            ))}
          </select>
        </div>
      </div>

      {fetchError ? (
        <NewsprintNotice
          variant="unauthorized"
          message={`Failed to load terms: ${fetchError}`}
          linkHref="/admin/handbook/"
          linkLabel="Retry"
        />
      ) : allTerms.length === 0 ? (
        <NewsprintNotice variant="empty" message="No handbook terms yet. Create one to get started." />
      ) : (
        <>
          <ul class="admin-list" id="term-list">
            {allTerms.map((term) => (
              <li
                class="admin-list-item"
                data-status={term.status}
                data-title={`${term.term} ${term.korean_name || ''}`.toLowerCase()}
                data-difficulty={term.difficulty || ''}
                data-categories={(term.categories || []).join(',')}
                data-source={term.source || 'manual'}
              >
                <div class="admin-list-info">
                  <div class="admin-list-title">
                    <a href={`/admin/handbook/edit/${term.slug}`}>{term.term}</a>
                    {term.korean_name && <span class="admin-list-subtitle"> · {term.korean_name}</span>}
                  </div>
                  <div class="admin-list-meta">
                    <span class={`admin-status-badge admin-status-badge--${term.status}`}>{term.status}</span>
                    <span class={`admin-lang-badge ${term.definition_ko ? 'admin-lang-badge--ready' : 'admin-lang-badge--missing'}`}>
                      KO {term.definition_ko ? '✓' : '✗'}
                    </span>
                    <span class={`admin-lang-badge ${term.definition_en ? 'admin-lang-badge--ready' : 'admin-lang-badge--missing'}`}>
                      EN {term.definition_en ? '✓' : '✗'}
                    </span>
                    {term.source && term.source !== 'manual' && (
                      <span class={`admin-source-badge admin-source-badge--${term.source}`}>
                        {term.source === 'pipeline' ? 'Pipeline' : 'AI'}
                      </span>
                    )}
                    {(term.categories || []).length > 0 && (
                      <>
                        <span class="admin-meta-sep">·</span>
                        <span>{(term.categories || []).map((category: string) => getHandbookCategoryLabel('en', category)).join(' · ')}</span>
                      </>
                    )}
                    {term.difficulty && (
                      <>
                        <span class="admin-meta-sep">·</span>
                        <span>{term.difficulty}</span>
                      </>
                    )}
                    <span class="admin-meta-sep">·</span>
                    <span class="admin-meta-date">Updated {new Date(term.updated_at).toLocaleDateString('en-US', { month: 'numeric', day: 'numeric' })}</span>
                  </div>
                </div>
                <div class="admin-list-actions">
                  <a href={`/admin/handbook/edit/${term.slug}`} class="admin-btn admin-btn-success">Edit</a>
                  <a href={`/admin/handbook/edit/${term.slug}?mode=preview`} class="admin-btn">Preview</a>
                  {term.status === 'draft' ? (
                    <button class="admin-btn admin-btn-primary" data-action="publish" data-id={term.id}>Publish</button>
                  ) : (
                    <button class="admin-btn" data-action="unpublish" data-id={term.id}>Unpublish</button>
                  )}
                  <button class="admin-btn-danger" data-action="delete" data-id={term.id} data-title={term.term}>Delete</button>
                </div>
              </li>
            ))}
          </ul>
          <p id="admin-no-results" class="admin-no-results" hidden>No matching terms.</p>
        </>
      )}
    </div>
  </div>
</MainLayout>

<style>
  .admin-list-toolbar {
    display: grid;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .admin-list-toolbar-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .admin-list-toolbar-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .admin-list-toolbar-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto;
  }

  .admin-list-toolbar-right .admin-search-input {
    width: 160px;
  }

  .admin-filters-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.82rem;
    white-space: nowrap;
    cursor: pointer;
  }

  .admin-filters-toggle[aria-expanded="true"] svg {
    transform: rotate(180deg);
  }

  .admin-list-toolbar-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    justify-content: flex-end;
  }

  .admin-list-toolbar-filters .admin-select {
    width: auto;
  }

  @media (max-width: 640px) {
    .admin-list-toolbar-row {
      flex-direction: column;
      align-items: stretch;
    }

    .admin-list-toolbar-left {
      flex-wrap: wrap;
    }

    .admin-list-toolbar-right {
      margin-left: 0;
      flex-wrap: wrap;
    }

    .admin-list-toolbar-right .admin-search-input {
      width: 100%;
      flex: 1 1 100%;
      min-width: 0;
    }

    .admin-list-toolbar-filters {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>

<script>
  // @ts-nocheck
  function initHandbookAdmin() {
    const list = document.getElementById('term-list');
    if (!list || list.dataset.init === '1') return;
    list.dataset.init = '1';

    let currentFilter = 'draft';
    const searchInput = document.getElementById('admin-search');
    const difficultyFilter = document.getElementById('admin-difficulty-filter');
    const categoryFilter = document.getElementById('admin-category-filter');
    const sourceFilter = document.getElementById('admin-source-filter');
    const noResults = document.getElementById('admin-no-results');
    const filtersToggle = document.getElementById('filters-toggle');
    const filtersPanel = document.getElementById('filters-panel');

    filtersToggle?.addEventListener('click', () => {
      const open = filtersPanel?.hidden === false;
      if (filtersPanel) filtersPanel.hidden = open;
      filtersToggle.setAttribute('aria-expanded', String(!open));
    });

    function applyFilter() {
      const query = (searchInput?.value || '').toLowerCase().trim();
      const difficulty = difficultyFilter?.value || '';
      const category = categoryFilter?.value || '';
      const source = sourceFilter?.value || '';
      let visibleCount = 0;

      Array.from(list.querySelectorAll('.admin-list-item')).forEach((item) => {
        const matchesStatus = currentFilter === 'all' || item.dataset.status === currentFilter;
        const matchesQuery = !query || (item.dataset.title || '').includes(query);
        const matchesDifficulty = !difficulty || item.dataset.difficulty === difficulty;
        const matchesCategory = !category || (item.dataset.categories || '').split(',').includes(category);
        const matchesSource = !source || (item.dataset.source || 'manual') === source;
        const visible = matchesStatus && matchesQuery && matchesDifficulty && matchesCategory && matchesSource;
        item.style.display = visible ? '' : 'none';
        if (visible) visibleCount += 1;
      });

      if (noResults) noResults.hidden = visibleCount > 0;
    }

    document.querySelectorAll('[data-filter]').forEach((btn) => {
      btn.addEventListener('click', () => {
        currentFilter = btn.dataset.filter || 'draft';
        document.querySelectorAll('[data-filter]').forEach((target) => target.classList.remove('admin-filter-btn--active'));
        btn.classList.add('admin-filter-btn--active');
        applyFilter();
      });
    });

    searchInput?.addEventListener('input', applyFilter);
    difficultyFilter?.addEventListener('change', applyFilter);
    categoryFilter?.addEventListener('change', applyFilter);
    sourceFilter?.addEventListener('change', applyFilter);

    document.querySelectorAll('[data-action]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const action = btn.dataset.action;
        const id = btn.dataset.id;
        if (!action || !id) return;

        if (action === 'delete') {
          const title = btn.dataset.title || 'this term';
          if (!window.confirm(`Delete "${title}"? This cannot be undone.`)) return;
          const res = await fetch('/api/admin/handbook/delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id }),
          });
          if (res.ok) { window.location.reload(); return; }
          const data = await res.json();
          window.alert(`Delete failed: ${data.error || 'Unknown error'}`);
          return;
        }

        const res = await fetch('/api/admin/handbook/status', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, action }),
        });

        if (res.ok) {
          window.location.reload();
          return;
        }

        const data = await res.json();
        window.alert(`${action} failed: ${data.error || 'Unknown error'}`);
      });
    });

    applyFilter();
  }

  document.addEventListener('DOMContentLoaded', initHandbookAdmin);
  initHandbookAdmin();
</script>




