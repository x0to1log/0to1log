---
export const prerender = false;
import MainLayout from '../../../layouts/MainLayout.astro';
import AdminHeader from '../../../components/admin/AdminHeader.astro';
import NewsprintNotice from '../../../components/newsprint/NewsprintNotice.astro';
import { createClient } from '@supabase/supabase-js';
import { getHandbookCategoryLabel } from '../../../lib/handbookCategories';

const accessToken = Astro.locals.accessToken;
const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
);

const { data: terms, error } = await supabase
  .from('handbook_terms')
  .select('id, term, slug, korean_name, status, category, difficulty, updated_at')
  .order('updated_at', { ascending: false });

const fetchError = error ? error.message : null;
const allTerms = terms || [];
const draftCount = allTerms.filter((t) => t.status === 'draft').length;
const publishedCount = allTerms.filter((t) => t.status === 'published').length;
---

<MainLayout title="Admin — Handbook" locale="en">
  <div style="max-width: 800px; margin: 0 auto;">
    <AdminHeader activeTab="handbook" />

    {fetchError ? (
      <NewsprintNotice
        variant="unauthorized"
        message={`Failed to load terms: ${fetchError}`}
        linkHref="/admin/handbook/"
        linkLabel="Retry"
      />
    ) : (
      <>
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
          <div class="admin-filter-tabs">
            <button class="admin-filter-btn admin-filter-btn--active" data-filter="all">
              All ({allTerms.length})
            </button>
            <button class="admin-filter-btn" data-filter="draft">
              Draft ({draftCount})
            </button>
            <button class="admin-filter-btn" data-filter="published">
              Published ({publishedCount})
            </button>
          </div>
          <a href="/admin/handbook/edit/new" class="admin-btn">+ New Term</a>
        </div>

        {allTerms.length === 0 ? (
          <NewsprintNotice
            variant="empty"
            message="No handbook terms yet. Create one to get started."
          />
        ) : (
          <ul class="admin-draft-list" id="term-list">
            {allTerms.map((t) => (
              <li class="admin-term-item" data-status={t.status}>
                <div class="admin-term-info">
                  <div class="admin-term-title">
                    <a href={`/admin/handbook/edit/${t.slug}`}>{t.term}</a>
                    {t.korean_name && <span style="color: var(--color-text-secondary); font-weight: 400;"> · {t.korean_name}</span>}
                  </div>
                  <div class="admin-term-meta">
                    <span class={`admin-status-badge admin-status-badge--${t.status}`}>
                      {t.status}
                    </span>
                    {t.category && (
                      <span>{getHandbookCategoryLabel('en', t.category)}</span>
                    )}
                    {t.difficulty && (
                      <span>{t.difficulty}</span>
                    )}
                    <span>{new Date(t.updated_at).toLocaleDateString('en-US')}</span>
                  </div>
                </div>
                <div class="admin-term-actions">
                  {t.status === 'draft' ? (
                    <button class="admin-btn" data-action="publish" data-id={t.id} style="font-size: 0.8rem;">
                      Publish
                    </button>
                  ) : t.status === 'published' ? (
                    <button class="admin-btn" data-action="unpublish" data-id={t.id} style="font-size: 0.8rem;">
                      Unpublish
                    </button>
                  ) : null}
                  <a href={`/admin/handbook/edit/${t.slug}`} class="admin-btn" style="font-size: 0.8rem;">Edit</a>
                  <button class="admin-btn-danger" data-action="delete" data-id={t.id} data-term={t.term} style="font-size: 0.8rem;">
                    Delete
                  </button>
                </div>
              </li>
            ))}
          </ul>
        )}
      </>
    )}
  </div>
</MainLayout>

<script>
  // Filter tabs
  document.querySelectorAll<HTMLButtonElement>('[data-filter]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;

      document.querySelectorAll<HTMLButtonElement>('[data-filter]').forEach((b) =>
        b.classList.remove('admin-filter-btn--active')
      );
      btn.classList.add('admin-filter-btn--active');

      document.querySelectorAll<HTMLElement>('[data-status]').forEach((item) => {
        if (filter === 'all' || item.dataset.status === filter) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    });
  });

  // Quick actions (publish/unpublish/delete)
  document.querySelectorAll<HTMLButtonElement>('[data-action]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const action = btn.dataset.action!;
      const id = btn.dataset.id!;

      if (action === 'delete') {
        const term = btn.dataset.term || 'this term';
        if (!confirm(`Delete "${term}"? This cannot be undone.`)) return;

        const res = await fetch('/api/admin/handbook/delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });

        if (res.ok) {
          window.location.reload();
        } else {
          const err = await res.json();
          alert(`Delete failed: ${err.error}`);
        }
        return;
      }

      // publish or unpublish
      const res = await fetch('/api/admin/handbook/status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, action }),
      });

      if (res.ok) {
        window.location.reload();
      } else {
        const err = await res.json();
        alert(`${action} failed: ${err.error}`);
      }
    });
  });
</script>
