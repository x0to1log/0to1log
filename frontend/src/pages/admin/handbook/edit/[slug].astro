---
export const prerender = false;
import MainLayout from '../../../../layouts/MainLayout.astro';
import AdminSidebar from '../../../../components/admin/AdminSidebar.astro';
import { createClient } from '@supabase/supabase-js';
import { getHandbookCategories, getHandbookCategoryLabel } from '../../../../lib/handbookCategories';
import { levelLabels } from '../../../../lib/handbookUtils';
import { renderMarkdown } from '../../../../lib/markdown';
import NewsprintShell from '../../../../components/newsprint/NewsprintShell.astro';
import HandbookSideRail from '../../../../components/newsprint/HandbookSideRail.astro';

const { slug } = Astro.params;
const isNew = slug === 'new';
const accessToken = Astro.locals.accessToken;
const startInPreview = Astro.url.searchParams.get('mode') === 'preview';

let term: Record<string, any> | null = null;
let loadError: string | null = null;

if (!accessToken) {
  return Astro.redirect('/admin/login');
}

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
);

if (!isNew) {
  const { data, error } = await supabase
    .from('handbook_terms')
    .select('*')
    .eq('slug', slug)
    .single();

  if (error || !data) {
    loadError = error?.message || 'Term not found';
  } else {
    term = data;
  }
}

// Resolve related_term_slugs to {slug, term} pairs for chip display
let resolvedRelatedTerms: { slug: string; term: string }[] = [];
if (term?.related_term_slugs?.length) {
  const { data: relData } = await supabase
    .from('handbook_terms')
    .select('slug, term')
    .in('slug', term.related_term_slugs);
  if (relData) {
    resolvedRelatedTerms = relData;
  }
}

const categories = getHandbookCategories();

const pageTitle = isNew ? 'New Term' : `Edit: ${term?.term || slug}`;
const initialTermName = term?.term || '';
const initialKoreanName = term?.korean_name || '';
const initialCategories = term?.categories || [];

// Preview: server-side initial HTML for body_basic
const initialBodyKo = term?.body_basic_ko || '';
const initialBodyHtml = initialBodyKo ? await renderMarkdown(initialBodyKo) : '';
---

<MainLayout title={`Admin — ${pageTitle}`} locale="en">
    {loadError ? (
      <div style="max-width: 800px; margin: 0 auto; padding: 2rem;">
        <div class="admin-feedback admin-feedback--error" style="margin-bottom: 1rem;">
          {loadError}
        </div>
      </div>
    ) : (
      <>
        <AdminSidebar activeSection="handbook" />
        {/* ===== DRAFT MODE ===== */}
        <div class="admin-editor-layout" id="draft-mode" style={startInPreview ? 'display: none;' : undefined}>
        {/* Top Bar */}
        <div class="admin-editor-topbar">
          <div class="admin-editor-topbar-left">
            <button class="admin-mobile-menu-btn" id="mobile-menu-btn" type="button" aria-label="Menu">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 5h14M3 10h14M3 15h14" />
              </svg>
            </button>
            <a href="/admin/handbook/" class="admin-editor-back">&larr; Back</a>
            {term && (
              <span class={`admin-status-badge admin-status-badge--${term.status}`}>
                {term.status}
              </span>
            )}
            {term?.source && term.source !== 'manual' && (
              <span class={`admin-source-badge admin-source-badge--${term.source}`}>
                {term.source === 'pipeline' ? 'Pipeline' : 'AI Suggested'}
              </span>
            )}
          </div>
          <div class="admin-editor-topbar-right">
            <span class="hb-action-bar__saved-time" id="last-saved-time" style="font-size:0.72rem;color:var(--color-text-muted)"></span>
            <button id="btn-ai-toggle" class="admin-ai-panel-toggle" type="button">AI</button>
            <button id="btn-save" class="admin-btn" type="button">Save</button>
            <button id="btn-preview" class="admin-btn" type="button">Preview</button>
            <button id="btn-publish" class="admin-btn admin-btn-primary" type="button">Publish</button>
          </div>
        </div>

        {/* Editor Content */}
        <div class="admin-editor-content">
        <form id="term-form" style="display: flex; flex-direction: column; gap: 1rem;">
          <input type="hidden" name="id" value={term?.id || ''} />

          {/* Term (always visible) */}
          <div class="admin-field">
            <label for="field-term">Term (English) *</label>
            <input type="text" name="term" id="field-term" class="admin-input" value={term?.term || ''} required />
          </div>

          {/* Korean Name (always visible) */}
          <div class="admin-field">
            <label for="field-korean-name">Korean Name *</label>
            <input type="text" name="korean_name" id="field-korean-name" class="admin-input" value={term?.korean_name || ''} />
          </div>

          {/* Categories (always visible) */}
          <div class="admin-field">
            <label>Categories (1-4) *</label>
            <div class="admin-category-grid">
              {categories.map((cat) => (
                <label class="admin-category-check">
                  <input type="checkbox" name="categories" value={cat}
                         checked={term?.categories?.includes(cat)} />
                  {getHandbookCategoryLabel('en', cat)}
                </label>
              ))}
            </div>
          </div>

          {/* Collapsible secondary fields */}
          <details class="admin-details" id="meta-details">
            <summary id="meta-details-summary">More fields <span class="hb-meta-filled-count" id="meta-filled-count"></span></summary>
            <div class="admin-details-body">
              <div class="admin-field">
                <label for="field-slug">Slug</label>
                <input type="text" name="slug" id="field-slug" class="admin-input" value={term?.slug || ''} placeholder="auto-generated from term" />
              </div>
              <div class="admin-field">
                <label for="field-term-full">Full Name (EN)</label>
                <input type="text" name="term_full" id="field-term-full" class="admin-input" value={term?.term_full || ''} placeholder="e.g., Long Short-Term Memory" />
              </div>
              <div class="admin-field">
                <label for="field-korean-full">Full Name (KO)</label>
                <input type="text" name="korean_full" id="field-korean-full" class="admin-input" value={term?.korean_full || ''} placeholder="e.g., 장단기 기억 네트워크" />
              </div>
              <div class="admin-field">
                <label>Related Terms</label>
                <div class="admin-chips-container" id="related-terms-chips">
                  {resolvedRelatedTerms.map((rt) => (
                    <span class="admin-chip" data-slug={rt.slug}>
                      <a href={`/admin/handbook/edit/${rt.slug}`} target="_blank">{rt.term}</a>
                      <button type="button" class="admin-chip-remove" data-remove-slug={rt.slug}>&times;</button>
                    </span>
                  ))}
                </div>
                <input type="hidden" name="related_term_slugs" id="related-term-slugs-hidden"
                  value={JSON.stringify((term?.related_term_slugs || []))} />
              </div>
              <div class="admin-field admin-field--checkbox">
                <label>
                  <input type="checkbox" name="is_favourite" checked={term?.is_favourite} />
                  Favourite (pinned in list)
                </label>
              </div>
            </div>
          </details>

          {/* Completeness indicator */}
          <div class="hb-completeness" id="completeness-bar">
            <span class="hb-completeness__label">Completeness</span>
            <div class="hb-completeness__track">
              <div class="hb-completeness__fill" id="completeness-fill"></div>
            </div>
            <span class="hb-completeness__text" id="completeness-text">0/8</span>
          </div>

          {/* Language tabs */}
          <div class="admin-lang-tabs">
            <button type="button" class="admin-lang-tab admin-lang-tab--active" data-lang="ko">KO <span class="hb-tab-indicator" id="lang-indicator-ko" hidden></span></button>
            <button type="button" class="admin-lang-tab" data-lang="en">EN <span class="hb-tab-indicator" id="lang-indicator-en" hidden></span></button>
          </div>

          {/* KO content */}
          <div id="lang-ko">
            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
              <div class="admin-field">
                <label for="field-definition-ko">Definition (KO)</label>
                <textarea name="definition_ko" id="field-definition-ko" class="admin-textarea" rows="3">{term?.definition_ko || ''}</textarea>
              </div>
              <div class="admin-level-tabs">
                <button type="button" class="admin-level-tab admin-level-tab--active" data-level-lang="ko" data-level="basic">Basic <span class="hb-tab-indicator" id="level-indicator-basic-ko" hidden></span></button>
                <button type="button" class="admin-level-tab" data-level-lang="ko" data-level="advanced">Advanced <span class="hb-tab-indicator" id="level-indicator-advanced-ko" hidden></span></button>
              </div>
              <div class="admin-field-group admin-field-group--body" id="level-basic-ko">
                <span class="admin-field-group-label">Basic Body (KO)</span>
                <div class="admin-field">
                  <label>Body Basic (KO)
                    <button type="button" class="admin-btn admin-btn--small admin-btn--outline" data-ai-generate-body="basic_ko" style="margin-left: 0.5rem; font-size: 0.75rem;">AI Generate</button>
                  </label>
                  <div class="admin-editor-wrapper admin-editor-wrapper--handbook"
                       id="body-editor-basic-ko"
                       data-content={term?.body_basic_ko || ''}></div>
                  <div class="hb-char-count" id="charcount-basic-ko"></div>
                </div>
              </div>
              <div class="admin-field-group admin-field-group--body" id="level-advanced-ko" style="display: none;">
                <span class="admin-field-group-label">Advanced Body (KO)</span>
                <div class="admin-field">
                  <label>Body Advanced (KO)
                    <button type="button" class="admin-btn admin-btn--small admin-btn--outline" data-ai-generate-body="advanced_ko" style="margin-left: 0.5rem; font-size: 0.75rem;">AI Generate</button>
                  </label>
                  <div class="admin-editor-wrapper admin-editor-wrapper--handbook"
                       id="body-editor-advanced-ko"
                       data-content={term?.body_advanced_ko || ''}></div>
                  <div class="hb-char-count" id="charcount-advanced-ko"></div>
                </div>
              </div>
            </div>
          </div>

          {/* EN content */}
          <div id="lang-en" style="display: none;">
            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
              <div class="admin-field">
                <label for="field-definition-en">Definition (EN)</label>
                <textarea name="definition_en" id="field-definition-en" class="admin-textarea" rows="3">{term?.definition_en || ''}</textarea>
              </div>
              <div class="admin-level-tabs">
                <button type="button" class="admin-level-tab admin-level-tab--active" data-level-lang="en" data-level="basic">Basic <span class="hb-tab-indicator" id="level-indicator-basic-en" hidden></span></button>
                <button type="button" class="admin-level-tab" data-level-lang="en" data-level="advanced">Advanced <span class="hb-tab-indicator" id="level-indicator-advanced-en" hidden></span></button>
              </div>
              <div class="admin-field-group admin-field-group--body" id="level-basic-en">
                <span class="admin-field-group-label">Basic Body (EN)</span>
                <div class="admin-field">
                  <label>Body Basic (EN)
                    <button type="button" class="admin-btn admin-btn--small admin-btn--outline" data-ai-generate-body="basic_en" style="margin-left: 0.5rem; font-size: 0.75rem;">AI Generate</button>
                  </label>
                  <div class="admin-editor-wrapper admin-editor-wrapper--handbook"
                       id="body-editor-basic-en"
                       data-content={term?.body_basic_en || ''}></div>
                  <div class="hb-char-count" id="charcount-basic-en"></div>
                </div>
              </div>
              <div class="admin-field-group admin-field-group--body" id="level-advanced-en" style="display: none;">
                <span class="admin-field-group-label">Advanced Body (EN)</span>
                <div class="admin-field">
                  <label>Body Advanced (EN)
                    <button type="button" class="admin-btn admin-btn--small admin-btn--outline" data-ai-generate-body="advanced_en" style="margin-left: 0.5rem; font-size: 0.75rem;">AI Generate</button>
                  </label>
                  <div class="admin-editor-wrapper admin-editor-wrapper--handbook"
                       id="body-editor-advanced-en"
                       data-content={term?.body_advanced_en || ''}></div>
                  <div class="hb-char-count" id="charcount-advanced-en"></div>
                </div>
              </div>
            </div>
          </div>
        </form>

        {term && (
          <div class="admin-danger-zone">
            <div class="admin-danger-zone__label">
              <strong>Danger Zone</strong>
              이 용어를 영구 삭제합니다. 복구할 수 없습니다.
            </div>
            <button id="btn-delete" class="admin-btn-danger" type="button">Delete</button>
          </div>
        )}
        </div>{/* /admin-editor-content */}

        {/* AI Advisor Panel */}
        <div class="admin-ai-backdrop" id="ai-backdrop"></div>
        <div class="admin-ai-panel" id="ai-panel">
          <div class="admin-ai-panel-header">
            <span class="admin-ai-panel-title">AI Advisor</span>
            <button id="btn-ai-close" class="admin-ai-panel-toggle" type="button">&times;</button>
          </div>
          <div class="admin-ai-actions">
            <div class="admin-ai-group">
              <span class="admin-ai-group__label">Content</span>
              <button class="admin-ai-action-btn admin-ai-action-btn--primary" data-ai-action="generate" type="button" title="Auto-generate all empty fields (definition, body, metadata) using AI">
                Generate All Fields<span class="ai-btn-model">gpt-4o</span>
              </button>
            </div>
            <div class="admin-ai-group">
              <span class="admin-ai-group__label">Quality</span>
              <button class="admin-ai-action-btn" data-ai-action="factcheck" type="button" title="LLM이 작성된 콘텐츠의 기술적 정확성을 자체 검증합니다">
                Quick Check<span class="ai-btn-model">gpt-4o</span>
              </button>
              <button class="admin-ai-action-btn" data-ai-action="deepverify" type="button" title="LLM이 팩트를 추출하고 Tavily로 웹 검색하여 근거를 확인합니다">
                Deep Verify<span class="ai-btn-model">gpt-4o + Tavily</span>
              </button>
            </div>
            <div class="admin-ai-group">
              <span class="admin-ai-group__label">Utility</span>
              <button class="admin-ai-action-btn" data-ai-action="related_terms" type="button" title="Find related handbook terms to link to this entry">
                Related Terms<span class="ai-btn-model">gpt-4o + Exa</span>
              </button>
              <div class="admin-ai-translate-row">
                <button class="admin-ai-action-btn" data-ai-action="translate" type="button" title="Translate content between Korean and English">
                  Translate<span class="ai-btn-model">gpt-4o</span>
                </button>
                <select id="ai-translate-direction" class="admin-select admin-ai-direction-select" aria-label="Translation direction">
                  <option value="auto">Auto</option>
                  <option value="ko2en">KO &rarr; EN</option>
                  <option value="en2ko">EN &rarr; KO</option>
                </select>
              </div>
            </div>
          </div>
          <div id="ai-loading" class="admin-ai-loading" hidden>
            <span class="ai-spinner"></span>
            <span id="ai-loading-text">Analyzing...</span>
          </div>
          <div id="ai-result" class="admin-ai-result"></div>
        </div>
        </div>{/* /admin-editor-layout (draft-mode) */}

        {/* ===== PREVIEW MODE ===== */}
        <div id="preview-mode" style={startInPreview ? undefined : 'display: none;'}>
          <div class="admin-preview-bar">
            <div class="admin-toolbar-left">
              <a href="/admin/handbook/" class="admin-editor-back">&larr; Back</a>
            </div>
            <div class="admin-toolbar-right">
              <button id="btn-edit-back" class="admin-btn">Edit</button>
              <button id="btn-publish-preview" class="admin-btn admin-btn-primary">Publish</button>
            </div>
          </div>

          <div class="admin-preview-frame-shell" data-preview-shell>
            <div class="admin-preview-frame-loading" data-preview-loading role="status" aria-live="polite" hidden>
              <span class="admin-preview-frame-spinner" aria-hidden="true"></span>
              <span data-preview-loading-text>Loading live preview...</span>
            </div>
            <iframe
              id="preview-iframe"
              class="admin-preview-iframe"
              title="Handbook preview"
              loading="lazy"
            ></iframe>
          </div>
          <div style="display: none;">
          <NewsprintShell
            locale="en"
            masthead="Handbook"
            editionLabel="CS · AI · Infra"
            subkicker={['Glossary', 'Reference', 'Learn']}
          >
            <article id="preview-article">
              <header style="margin-bottom: 1.5rem;">
                <div class="handbook-detail-meta">
                  {initialCategories.map((c: string) => (
                    <span style="font-size: 0.8rem; color: var(--color-text-muted);">
                      {getHandbookCategoryLabel('en', c)}
                    </span>
                  ))}
                </div>
                <h1 id="preview-term" class="handbook-detail-title" style="margin-top: 0.75rem;">
                  {initialTermName}
                </h1>
                <p id="preview-korean" class="handbook-detail-subtitle">
                  {initialKoreanName}
                </p>
              </header>

              <p id="preview-definition" class="handbook-definition"></p>
              <div class="newsprint-divider"></div>
              <div id="preview-body" class="newsprint-prose newsprint-prose--no-dropcap">
                <Fragment set:html={initialBodyHtml} />
              </div>
            </article>

          <Fragment slot="rail">
            <HandbookSideRail
              locale="en"
              relatedTerms={[]}
              sameCategoryTerms={[]}
              relatedArticles={[]}
            />
          </Fragment>
          </NewsprintShell>
          </div>
        </div>
      </>
    )}

    {/* Toast feedback (fixed position, outside form flow) */}
    <div id="admin-feedback" class="admin-feedback admin-feedback--toast" hidden></div>
</MainLayout>

<style>
  .hb-completeness {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0;
    margin-bottom: 0.75rem;
  }
  .hb-completeness__label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--color-text-muted);
    white-space: nowrap;
  }
  .hb-completeness__track {
    flex: 1;
    height: 6px;
    background: var(--color-border);
    border-radius: 3px;
    overflow: hidden;
  }
  .hb-completeness__fill {
    height: 100%;
    border-radius: 3px;
    transition: width 0.3s, background-color 0.3s;
    width: 0%;
  }
  .hb-completeness__text {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  /* Ensure text selection is visible */
  .admin-editor-content ::selection,
  .admin-editor-content *::selection {
    background: rgba(59, 130, 246, 0.3);
    color: inherit;
  }

  /* --- Tab content indicators --- */
  .hb-tab-indicator {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-success, #22c55e);
    margin-left: 4px;
    vertical-align: middle;
  }

  /* --- Character count below editors --- */
  .hb-char-count {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    text-align: right;
    padding: 0.25rem 0.5rem 0;
    min-height: 1.2em;
  }

  /* --- Meta filled count badge --- */
  .hb-meta-filled-count {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-text-muted);
    margin-left: 0.25rem;
  }


  /* --- Accessibility: focus states & cursor --- */
  .admin-lang-tab,
  .admin-level-tab,
  .admin-ai-action-btn,
  .admin-ai-panel-toggle,
  .admin-btn,
  .admin-btn-primary,
  .admin-btn-danger,
  .admin-chip-remove,
  .admin-category-check,
  .admin-details summary {
    cursor: pointer;
  }
  .admin-input:focus,
  .admin-textarea:focus,
  .admin-select:focus,
  .admin-lang-tab:focus-visible,
  .admin-level-tab:focus-visible,
  .admin-btn:focus-visible,
  .admin-btn-primary:focus-visible,
  .admin-btn-danger:focus-visible,
  .admin-ai-action-btn:focus-visible,
  .admin-ai-panel-toggle:focus-visible {
    outline: 2px solid var(--color-accent, #3b82f6);
    outline-offset: 2px;
  }

  /* Prevent layout shift when AI content is applied to editors */
  .admin-editor-wrapper--handbook :global(.ProseMirror),
  .admin-editor-wrapper--handbook :global(.milkdown) {
    min-height: 200px;
    transition: min-height 0.3s ease;
  }

</style>

<script>
  import { Crepe } from '@milkdown/crepe';
  import { replaceAll } from '@milkdown/utils';
  import '@milkdown/crepe/theme/common/style.css';
  import { esc, showFeedback, createButtonManager } from '../../../../scripts/adminEditorUtils';
  import { createPreviewManager } from '../../../../scripts/adminEditorPreview';

  let crepeBasicKo: Crepe | null = null;
  let crepeBasicEn: Crepe | null = null;
  let crepeAdvancedKo: Crepe | null = null;
  let crepeAdvancedEn: Crepe | null = null;

  document.addEventListener('DOMContentLoaded', () => {
    // Clean up previous Crepe instances (View Transitions)
    if (crepeBasicKo) { crepeBasicKo.destroy(); crepeBasicKo = null; }
    if (crepeBasicEn) { crepeBasicEn.destroy(); crepeBasicEn = null; }
    if (crepeAdvancedKo) { crepeAdvancedKo.destroy(); crepeAdvancedKo = null; }
    if (crepeAdvancedEn) { crepeAdvancedEn.destroy(); crepeAdvancedEn = null; }
    const termForm = document.getElementById('term-form');
    if (!termForm) return; // Not the handbook editor page
    const draftMode = document.getElementById('draft-mode');
    const previewMode = document.getElementById('preview-mode');
    const btnSave = document.getElementById('btn-save') as HTMLButtonElement | null;
    const btnPreview = document.getElementById('btn-preview') as HTMLButtonElement | null;
    const btnPublish = document.getElementById('btn-publish') as HTMLButtonElement | null;
    const btnPublishPreview = document.getElementById('btn-publish-preview') as HTMLButtonElement | null;
    const btnEditBack = document.getElementById('btn-edit-back') as HTMLButtonElement | null;
    const btnDelete = document.getElementById('btn-delete') as HTMLButtonElement | null;
    const previewShell = document.querySelector<HTMLElement>('[data-preview-shell]');
    const previewLoading = document.querySelector<HTMLElement>('[data-preview-loading]');
    const previewLoadingText = document.querySelector<HTMLElement>('[data-preview-loading-text]');
    const previewFrame = document.getElementById('preview-iframe') as HTMLIFrameElement | null;
    const idInput = document.querySelector('[name="id"]') as HTMLInputElement | null;
    const slugInput = document.querySelector('[name="slug"]') as HTMLInputElement | null;
    const btnManager = createButtonManager(
      [btnSave, btnPreview, btnPublish, btnPublishPreview, btnEditBack, btnDelete]
        .filter((b): b is HTMLButtonElement => b instanceof HTMLButtonElement),
    );
    const preview = createPreviewManager({
      editorPath: '/admin/handbook/edit/',
      getSlug: () => slugInput?.value || '',
      buildPreviewUrl,
      btnManager,
      draftModeEl: draftMode,
      previewModeEl: previewMode,
      previewShell,
      previewLoading,
      previewLoadingText,
      previewFrame,
    });

    // Auto-open details on desktop
    if (window.innerWidth >= 768) {
      document.querySelector('.admin-details')?.setAttribute('open', '');
    }

    // AI panel toggle
    const aiToggleBtn = document.getElementById('btn-ai-toggle');
    const aiCloseBtn = document.getElementById('btn-ai-close');
    const editorLayout = document.querySelector('.admin-editor-layout');
    const aiBackdrop = document.getElementById('ai-backdrop');
    function toggleAiPanel() {
      const isMobile = window.innerWidth < 768;
      if (isMobile) {
        const panel = document.getElementById('ai-panel');
        const isOpen = panel?.classList.contains('admin-ai-panel--open');
        panel?.classList.toggle('admin-ai-panel--open', !isOpen);
        aiBackdrop?.classList.toggle('admin-ai-backdrop--visible', !isOpen);
      } else {
        editorLayout?.classList.toggle('admin-editor-layout--collapsed');
      }
    }
    aiToggleBtn?.addEventListener('click', toggleAiPanel);
    aiCloseBtn?.addEventListener('click', toggleAiPanel);
    aiBackdrop?.addEventListener('click', toggleAiPanel);

    // --- Related Terms Chip Management ---
    const chipsContainer = document.getElementById('related-terms-chips');
    const hiddenSlugsInput = document.getElementById('related-term-slugs-hidden') as HTMLInputElement | null;

    function getRelatedSlugs(): string[] {
      try { return JSON.parse(hiddenSlugsInput?.value || '[]'); } catch { return []; }
    }

    function setRelatedSlugs(slugs: string[]) {
      if (hiddenSlugsInput) hiddenSlugsInput.value = JSON.stringify(slugs);
    }

    function addChip(slug: string, termName: string) {
      const slugs = getRelatedSlugs();
      if (slugs.includes(slug)) return false;
      slugs.push(slug);
      setRelatedSlugs(slugs);

      if (chipsContainer) {
        const chip = document.createElement('span');
        chip.className = 'admin-chip';
        chip.dataset.slug = slug;
        chip.innerHTML = `<a href="/admin/handbook/edit/${esc(slug)}" target="_blank">${esc(termName)}</a> <button type="button" class="admin-chip-remove" data-remove-slug="${esc(slug)}">&times;</button>`;
        chip.querySelector('[data-remove-slug]')?.addEventListener('click', () => removeChip(slug));
        chipsContainer.appendChild(chip);
      }
      return true;
    }

    function removeChip(slug: string) {
      const slugs = getRelatedSlugs().filter(s => s !== slug);
      setRelatedSlugs(slugs);
      chipsContainer?.querySelector(`[data-slug="${slug}"]`)?.remove();
    }

    // Bind existing chip remove buttons
    chipsContainer?.querySelectorAll<HTMLButtonElement>('[data-remove-slug]').forEach(btn => {
      btn.addEventListener('click', () => removeChip(btn.dataset.removeSlug || ''));
    });

    // --- AI Advisor ---
    const aiActionBtns = document.querySelectorAll<HTMLButtonElement>('[data-ai-action]');
    const aiLoadingEl = document.getElementById('ai-loading') as HTMLElement | null;
    const aiLoadingText = document.getElementById('ai-loading-text');
    const aiResultEl = document.getElementById('ai-result') as HTMLElement | null;

    const aiActionLabels = new Map<string, string>();
    aiActionBtns.forEach(btn => {
      const a = btn.dataset.aiAction;
      if (a) aiActionLabels.set(a, btn.childNodes[0]?.textContent?.trim() || a);
    });
    let aiTimerInterval: ReturnType<typeof setInterval> | null = null;

    function setAiLoading(loading: boolean, action = '') {
      if (aiLoadingEl) aiLoadingEl.hidden = !loading;
      if (loading) {
        if (aiLoadingText) aiLoadingText.textContent = `Running ${action}... (0s)`;
        let elapsed = 0;
        if (aiTimerInterval) clearInterval(aiTimerInterval);
        aiTimerInterval = setInterval(() => {
          elapsed++;
          if (aiLoadingText) aiLoadingText.textContent = `Running ${action}... (${elapsed}s)`;
        }, 1000);
      } else {
        if (aiTimerInterval) { clearInterval(aiTimerInterval); aiTimerInterval = null; }
        if (aiLoadingText) aiLoadingText.textContent = '';
      }
      if (loading && aiResultEl) aiResultEl.innerHTML = '';
      // Map display label to data-ai-action value for button matching
      const actionMap: Record<string, string> = {
        'Finding related terms': 'related_terms',
        'Translating': 'translate',
        'Generating all fields': 'generate',
      };
      const matchAction = actionMap[action] || action;
      aiActionBtns.forEach(btn => {
        btn.disabled = loading;
        const a = btn.dataset.aiAction || '';
        if (loading && a === matchAction) {
          btn.classList.add('admin-ai-action-btn--loading');
          const orig = aiActionLabels.get(a) || a;
          btn.childNodes[0].textContent = `${orig}...`;
          const spinner = document.createElement('span');
          spinner.className = 'ai-btn-spinner';
          btn.prepend(spinner);
        } else {
          btn.classList.remove('admin-ai-action-btn--loading');
          btn.querySelector('.ai-btn-spinner')?.remove();
          const orig = aiActionLabels.get(a);
          if (orig && btn.childNodes[0]) btn.childNodes[0].textContent = orig;
        }
      });
    }


    // --- Diff / Undo helpers ---
    const previousValues = new Map<string, string>();
    const aiFieldValues = new Map<string, string>();

    function getCrepeEditor(fieldName: string): Crepe | null {
      if (fieldName === 'body_basic_ko') return crepeBasicKo;
      if (fieldName === 'body_basic_en') return crepeBasicEn;
      if (fieldName === 'body_advanced_ko') return crepeAdvancedKo;
      if (fieldName === 'body_advanced_en') return crepeAdvancedEn;
      return null;
    }

    function getHandbookValue(fieldName: string): string {
      const editor = getCrepeEditor(fieldName);
      if (editor) return editor.getMarkdown();
      const input = document.querySelector(`[name="${fieldName}"]`) as HTMLTextAreaElement | HTMLInputElement | null;
      return input?.value || '';
    }

    function setHandbookValue(fieldName: string, value: string) {
      const editor = getCrepeEditor(fieldName);
      if (editor) { editor.editor.action(replaceAll(value)); updateAllIndicators(); return; }
      const input = document.querySelector(`[name="${fieldName}"]`) as HTMLTextAreaElement | HTMLInputElement | null;
      if (input) { input.value = value; updateAllIndicators(); }
    }

    function showDiff(btn: HTMLButtonElement, fieldName: string, newValue: string) {
      const currentValue = getHandbookValue(fieldName);
      const container = btn.closest('.admin-ai-suggestion') as HTMLElement | null;
      if (!container) return;

      const diffId = `diff-${fieldName}-${Date.now()}`;
      const diffHtml = `<div class="admin-ai-diff" id="${diffId}">` +
        `<div class="admin-ai-diff--del">${esc(currentValue || '(empty)')}</div>` +
        `<div class="admin-ai-diff--add">${esc(newValue)}</div>` +
        `<div class="admin-ai-diff-actions">` +
        `<button class="admin-ai-diff-confirm" type="button">Apply</button>` +
        `<button class="admin-ai-diff-cancel" type="button">Cancel</button>` +
        `</div></div>`;

      btn.hidden = true;
      container.insertAdjacentHTML('beforeend', diffHtml);

      const diffEl = document.getElementById(diffId);
      diffEl?.querySelector('.admin-ai-diff-confirm')?.addEventListener('click', () => {
        previousValues.set(fieldName, currentValue);
        setHandbookValue(fieldName, newValue);
        diffEl.remove();
        btn.hidden = false;
        btn.textContent = 'Undo';
        btn.classList.add('admin-ai-undo-btn');
        btn.onclick = () => {
          const prev = previousValues.get(fieldName);
          if (prev !== undefined) { setHandbookValue(fieldName, prev); previousValues.delete(fieldName); }
          btn.textContent = 'Use';
          btn.classList.remove('admin-ai-undo-btn');
          btn.onclick = null;
          showFeedback(`${fieldName} reverted.`);
        };
        showFeedback(`${fieldName} applied.`);
      });

      diffEl?.querySelector('.admin-ai-diff-cancel')?.addEventListener('click', () => {
        diffEl.remove();
        btn.hidden = false;
      });
    }

    async function runHandbookAi(action: string, overrides?: Record<string, string>) {
      const form = document.getElementById('term-form') as HTMLFormElement;
      if (!form) return;
      const termInput = form.querySelector('[name="term"]') as HTMLInputElement;
      const term = termInput?.value?.trim();
      if (!term) {
        showFeedback('Term name is required for AI analysis.', true);
        return;
      }

      const loadingLabels: Record<string, string> = {
        related_terms: 'Finding related terms',
        translate: 'Translating',
        generate: 'Generating all fields',
      };
      setAiLoading(true, loadingLabels[action] || action);

      const body: Record<string, any> = {
        action,
        term_id: (form.querySelector('[name="id"]') as HTMLInputElement)?.value || 'new',
        term,
        term_full: (form.querySelector('[name="term_full"]') as HTMLInputElement)?.value || '',
        korean_name: (form.querySelector('[name="korean_name"]') as HTMLInputElement)?.value || '',
        korean_full: (form.querySelector('[name="korean_full"]') as HTMLInputElement)?.value || '',
        categories: Array.from(form.querySelectorAll<HTMLInputElement>('input[name="categories"]:checked')).map(cb => cb.value),
        definition_ko: (form.querySelector('[name="definition_ko"]') as HTMLTextAreaElement)?.value || '',
        definition_en: (form.querySelector('[name="definition_en"]') as HTMLTextAreaElement)?.value || '',
        body_basic_ko: crepeBasicKo ? crepeBasicKo.getMarkdown() : '',
        body_basic_en: crepeBasicEn ? crepeBasicEn.getMarkdown() : '',
        body_advanced_ko: crepeAdvancedKo ? crepeAdvancedKo.getMarkdown() : '',
        body_advanced_en: crepeAdvancedEn ? crepeAdvancedEn.getMarkdown() : '',
      };

      // Apply overrides (e.g. force body_basic/advanced empty for body-only generation)
      if (overrides) Object.assign(body, overrides);

      // Add translate direction if not auto
      if (action === 'translate') {
        const dirSelect = document.getElementById('ai-translate-direction') as HTMLSelectElement | null;
        const dir = dirSelect?.value || 'auto';
        if (dir !== 'auto') body.force_direction = dir;
      }

      try {
        const res = await fetch('/api/admin/ai/handbook-advise', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });

        if (!res.ok) {
          if (res.status === 429) showFeedback('Too many requests. Wait a moment.', true);
          else if (res.status === 504) showFeedback('AI request timed out.', true);
          else showFeedback('AI request failed.', true);
          setAiLoading(false);
          return;
        }

        const data = await res.json();
        setAiLoading(false);

        // Check for error responses
        if (data.error) {
          showFeedback(`AI error: ${data.error}`, true);
          return;
        }

        if (data.result && Object.keys(data.result).length > 0) {
          if (action === 'related_terms') renderRelatedTerms(data.result);
          else if (action === 'translate') renderTranslate(data.result);
          else if (action === 'generate') renderGenerate(data.result);
          else if (action === 'factcheck') renderFactcheck(data.result);
          else if (action === 'deepverify') renderDeepverify(data.result);
          // Show model/token footer
          if (aiResultEl && (data.model_used || data.tokens_used)) {
            aiResultEl.insertAdjacentHTML('beforeend',
              `<div class="admin-ai-meta-footer">${esc(data.model_used || '')}${data.tokens_used ? ` · ${data.tokens_used} tokens` : ''}</div>`
            );
          }
          // Show warnings if any
          if (data.validation_warnings?.length) {
            showFeedback(`Warnings: ${data.validation_warnings.join(', ')}`, false);
          }
        } else {
          showFeedback('AI returned empty result. Try again or check backend logs.', true);
        }
      } catch {
        showFeedback('Network error or request timed out. Try again.', true);
        setAiLoading(false);
      }
    }

    // --- Related Terms Render ---
    function renderRelatedTerms(r: any) {
      if (!aiResultEl) return;
      let html = '<h4>Related Terms</h4>';

      if (r.related_terms?.length) {
        r.related_terms.forEach((item: any) => {
          const termName = esc(item.term || '');
          const reason = esc(item.reason || '');
          if (item.exists_in_db && item.slug) {
            html += `<div class="admin-ai-related-term admin-ai-related-term--exists">`;
            html += `<div class="admin-ai-related-term-header"><strong>${termName}</strong>`;
            html += `<div class="admin-ai-related-term-actions">`;
            html += `<a href="/admin/handbook/edit/${esc(item.slug)}" target="_blank" class="admin-ai-source-link">View</a>`;
            html += `<button class="admin-ai-apply-btn" data-link-slug="${esc(item.slug)}" type="button">Link</button>`;
            html += `</div></div>`;
            html += `<span class="admin-ai-related-term-reason admin-ai-related-term-reason--collapsed">${reason}</span>`;
            html += `</div>`;
          } else {
            html += `<div class="admin-ai-related-term admin-ai-related-term--new">`;
            html += `<div class="admin-ai-related-term-header"><strong>${termName}</strong>`;
            html += `<button class="admin-ai-create-draft-btn" data-term="${termName}" type="button">+ Create Draft</button>`;
            html += `</div>`;
            html += `<span class="admin-ai-related-term-reason admin-ai-related-term-reason--collapsed">${reason}</span>`;
            html += `</div>`;
          }
        });
      } else {
        html += '<p>No related terms found.</p>';
      }

      aiResultEl.innerHTML = html;

      // Bind reason toggle (click term row to expand/collapse reason)
      aiResultEl.querySelectorAll<HTMLElement>('.admin-ai-related-term-header').forEach(header => {
        header.style.cursor = 'pointer';
        header.addEventListener('click', (e) => {
          if ((e.target as HTMLElement).closest('a, button')) return; // Don't toggle on button/link clicks
          const reason = header.parentElement?.querySelector('.admin-ai-related-term-reason');
          reason?.classList.toggle('admin-ai-related-term-reason--collapsed');
        });
      });

      // Bind Link buttons → add chip
      aiResultEl.querySelectorAll<HTMLButtonElement>('[data-link-slug]').forEach(btn => {
        btn.addEventListener('click', () => {
          const slug = btn.dataset.linkSlug || '';
          const termName = btn.closest('.admin-ai-related-term')?.querySelector('strong')?.textContent || slug;
          if (!slug) return;
          if (addChip(slug, termName)) {
            btn.textContent = 'Linked';
            btn.disabled = true;
            showFeedback(`Linked: ${termName}`);
          } else {
            showFeedback('Already linked.');
          }
        });
      });

      // Bind Create Draft buttons → create with source 'ai-suggested' + add chip
      aiResultEl.querySelectorAll<HTMLButtonElement>('.admin-ai-create-draft-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const termName = btn.dataset.term || '';
          if (!termName) return;
          btn.disabled = true;
          btn.textContent = 'Creating...';
          try {
            const res = await fetch('/api/admin/handbook/save', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                term: termName,
                status: 'draft',
                source: 'ai-suggested',
                categories: Array.from(document.querySelectorAll<HTMLInputElement>('input[name="categories"]:checked')).map(cb => cb.value),
              }),
            });
            if (res.ok) {
              const saved = await res.json();
              btn.textContent = 'Created';
              if (saved.slug) addChip(saved.slug, termName);
              showFeedback(`Draft created: ${termName}`);
            } else {
              btn.textContent = 'Failed';
              showFeedback('Failed to create draft.', true);
            }
          } catch {
            btn.textContent = 'Failed';
            showFeedback('Network error.', true);
          }
        });
      });
    }

    // --- Translate Render ---
    function renderTranslate(r: any) {
      if (!aiResultEl) return;
      const direction = `${(r.source_lang || '').toUpperCase()} → ${(r.target_lang || '').toUpperCase()}`;
      let html = `<h4>Translation (${esc(direction)})</h4>`;
      const targetLang = r.target_lang || 'en';

      const fields = [
        { key: 'definition', label: 'Definition' },
        { key: 'body_basic', label: 'Body (Basic)' },
        { key: 'body_advanced', label: 'Body (Advanced)' },
      ];

      fields.forEach(f => {
        const val = r[f.key];
        if (!val) return;
        const fieldName = `${f.key}_${targetLang}`;
        html += `<div class="admin-ai-suggestion">`;
        const truncLen = 300;
        const isTruncated = val.length > truncLen;
        const previewId = `preview-${f.key}-${Date.now()}`;
        html += `<span class="admin-ai-suggestion-text"><strong>${f.label}:</strong> ` +
          `<span id="${previewId}">${esc(isTruncated ? val.substring(0, truncLen) + '...' : val)}</span>` +
          (isTruncated ? ` <button class="admin-ai-expand-btn" data-preview="${previewId}" data-field-key="${esc(fieldName)}" type="button">Show more</button>` : '') +
          `</span>`;
        aiFieldValues.set(fieldName, val);
        html += `<button class="admin-ai-apply-btn" data-apply-field="${esc(fieldName)}" type="button">Use</button>`;
        html += `</div>`;
      });

      html += `<button class="admin-ai-apply-all-btn" id="ai-apply-all-translate" type="button">Apply All</button>`;
      aiResultEl.innerHTML = html;

      // Bind expand/collapse toggles
      aiResultEl.querySelectorAll<HTMLButtonElement>('.admin-ai-expand-btn').forEach(btn => {
        const previewId = btn.dataset.preview || '';
        const fullText = aiFieldValues.get(btn.dataset.fieldKey || '') || '';
        const previewEl = document.getElementById(previewId);
        if (!previewEl) return;
        const truncated = previewEl.textContent || '';
        let expanded = false;
        btn.addEventListener('click', () => {
          expanded = !expanded;
          previewEl.textContent = expanded ? fullText : truncated;
          btn.textContent = expanded ? 'Show less' : 'Show more';
        });
      });

      // Bind individual apply buttons — show diff before applying
      aiResultEl.querySelectorAll<HTMLButtonElement>('[data-apply-field]').forEach(btn => {
        btn.addEventListener('click', () => {
          const fieldName = btn.dataset.applyField || '';
          const value = aiFieldValues.get(fieldName) || '';
          showDiff(btn, fieldName, value);
        });
      });

      // Apply All — save previous values, apply all at once, show Undo All
      document.getElementById('ai-apply-all-translate')?.addEventListener('click', (e) => {
        const applyAllBtn = e.currentTarget as HTMLButtonElement;
        const targetLang = r.target_lang || 'en';
        const appliedFields: string[] = [];
        fields.forEach(f => {
          const val = r[f.key];
          if (!val) return;
          const fieldName = `${f.key}_${targetLang}`;
          previousValues.set(fieldName, getHandbookValue(fieldName));
          setHandbookValue(fieldName, val);
          appliedFields.push(fieldName);
        });
        applyAllBtn.textContent = 'Undo All';
        applyAllBtn.classList.add('admin-ai-undo-btn');
        const origClick = applyAllBtn.onclick;
        applyAllBtn.onclick = () => {
          appliedFields.forEach(fieldName => {
            const prev = previousValues.get(fieldName);
            if (prev !== undefined) { setHandbookValue(fieldName, prev); previousValues.delete(fieldName); }
          });
          applyAllBtn.textContent = 'Apply All';
          applyAllBtn.classList.remove('admin-ai-undo-btn');
          applyAllBtn.onclick = origClick;
          showFeedback('All translations reverted.');
        };
        showFeedback('All translations applied.');
      });
    }

    // --- Generate Render ---
    function renderGenerate(r: any) {
      if (!aiResultEl) return;
      let html = '<h4>Generated Content</h4>';

      // Metadata fields
      const metaFields = [
        { key: 'korean_name', label: 'Korean Name' },
        { key: 'term_full', label: 'Full Name (EN)' },
        { key: 'korean_full', label: '정식 명칭' },
      ];
      metaFields.forEach(f => {
        const val = r[f.key];
        if (!val) return;
        html += `<div class="admin-ai-suggestion">`;
        html += `<span class="admin-ai-suggestion-text"><strong>${f.label}:</strong> ${esc(val)}</span>`;
        aiFieldValues.set(f.key, val);
        html += `<button class="admin-ai-apply-btn" data-apply-field="${esc(f.key)}" type="button">Use</button>`;
        html += `</div>`;
      });

      // Categories
      if (r.categories?.length) {
        html += `<div class="admin-ai-suggestion">`;
        html += `<span class="admin-ai-suggestion-text"><strong>Categories:</strong> ${r.categories.map((c: string) => esc(c)).join(', ')}</span>`;
        html += `<button class="admin-ai-apply-btn" id="ai-apply-categories" type="button">Use</button>`;
        html += `</div>`;
      }

      // Content fields (bilingual)
      const contentFields = [
        { key: 'definition', label: 'Definition' },
        { key: 'body_basic', label: 'Body (Basic)' },
        { key: 'body_advanced', label: 'Body (Advanced)' },
      ];

      ['ko', 'en'].forEach(lang => {
        const langLabel = lang.toUpperCase();
        let hasContent = false;
        contentFields.forEach(f => {
          const val = r[`${f.key}_${lang}`];
          if (val) hasContent = true;
        });
        if (!hasContent) return;

        html += `<div class="admin-ai-generate-lang"><strong>${langLabel}</strong></div>`;
        contentFields.forEach(f => {
          const val = r[`${f.key}_${lang}`];
          if (!val) return;
          const fieldName = `${f.key}_${lang}`;
          const truncLen = 200;
          const isTruncated = val.length > truncLen;
          const previewId = `gen-preview-${fieldName}-${Date.now()}`;
          html += `<div class="admin-ai-suggestion">`;
          html += `<span class="admin-ai-suggestion-text"><strong>${f.label}:</strong> ` +
            `<span id="${previewId}">${esc(isTruncated ? val.substring(0, truncLen) + '...' : val)}</span>` +
            (isTruncated ? ` <button class="admin-ai-expand-btn" data-preview="${previewId}" data-field-key="${esc(fieldName)}" type="button">Show more</button>` : '') +
            `</span>`;
          aiFieldValues.set(fieldName, val);
          html += `<button class="admin-ai-apply-btn" data-apply-field="${esc(fieldName)}" type="button">Use</button>`;
          html += `</div>`;
        });
      });

      html += `<button class="admin-ai-apply-all-btn" id="ai-apply-all-generate" type="button">Apply All Empty</button>`;
      aiResultEl.innerHTML = html;

      // Bind expand/collapse
      aiResultEl.querySelectorAll<HTMLButtonElement>('.admin-ai-expand-btn').forEach(btn => {
        const previewId = btn.dataset.preview || '';
        const fullText = aiFieldValues.get(btn.dataset.fieldKey || '') || '';
        const previewEl = document.getElementById(previewId);
        if (!previewEl) return;
        const truncated = previewEl.textContent || '';
        let expanded = false;
        btn.addEventListener('click', () => {
          expanded = !expanded;
          previewEl.textContent = expanded ? fullText : truncated;
          btn.textContent = expanded ? 'Show less' : 'Show more';
        });
      });

      // Bind individual apply buttons with diff
      aiResultEl.querySelectorAll<HTMLButtonElement>('[data-apply-field]').forEach(btn => {
        btn.addEventListener('click', () => {
          const fieldName = btn.dataset.applyField || '';
          const value = aiFieldValues.get(fieldName) || '';
          if (['korean_name', 'term_full', 'korean_full'].includes(fieldName)) {
            const input = document.querySelector(`[name="${fieldName}"]`) as HTMLInputElement | HTMLSelectElement | null;
            if (input) {
              previousValues.set(fieldName, input.value);
              input.value = value;
              btn.textContent = 'Undo';
              btn.classList.add('admin-ai-undo-btn');
              btn.onclick = () => {
                const prev = previousValues.get(fieldName);
                if (prev !== undefined) { input.value = prev; previousValues.delete(fieldName); }
                btn.textContent = 'Use';
                btn.classList.remove('admin-ai-undo-btn');
                btn.onclick = null;
              };
              showFeedback(`${fieldName} applied.`);
            }
          } else {
            showDiff(btn, fieldName, value);
          }
        });
      });

      // Apply categories
      document.getElementById('ai-apply-categories')?.addEventListener('click', (e) => {
        const btn = e.currentTarget as HTMLButtonElement;
        const checkboxes = document.querySelectorAll<HTMLInputElement>('input[name="categories"]');
        const prevChecked = Array.from(checkboxes).filter(cb => cb.checked).map(cb => cb.value);
        checkboxes.forEach(cb => { cb.checked = r.categories.includes(cb.value); });
        btn.textContent = 'Undo';
        btn.classList.add('admin-ai-undo-btn');
        btn.onclick = () => {
          checkboxes.forEach(cb => { cb.checked = prevChecked.includes(cb.value); });
          btn.textContent = 'Use';
          btn.classList.remove('admin-ai-undo-btn');
          btn.onclick = null;
          showFeedback('Categories reverted.');
        };
        showFeedback('Categories applied.');
      });

      // Apply All Empty — only apply fields that are currently empty
      document.getElementById('ai-apply-all-generate')?.addEventListener('click', (e) => {
        const applyAllBtn = e.currentTarget as HTMLButtonElement;
        const appliedFields: string[] = [];

        // Metadata
        ['korean_name', 'term_full', 'korean_full'].forEach(metaKey => {
          if (r[metaKey]) {
            const input = document.querySelector(`[name="${metaKey}"]`) as HTMLInputElement;
            if (input && !input.value.trim()) {
              previousValues.set(metaKey, input.value);
              input.value = r[metaKey];
              appliedFields.push(metaKey);
            }
          }
        });
        if (r.categories?.length) {
          const checkboxes = document.querySelectorAll<HTMLInputElement>('input[name="categories"]');
          const anyChecked = Array.from(checkboxes).some(cb => cb.checked);
          if (!anyChecked) {
            checkboxes.forEach(cb => { cb.checked = r.categories.includes(cb.value); });
            appliedFields.push('categories');
          }
        }

        // Content fields
        contentFields.forEach(f => {
          ['ko', 'en'].forEach(lang => {
            const fieldName = `${f.key}_${lang}`;
            const val = r[fieldName];
            if (!val) return;
            const current = getHandbookValue(fieldName);
            if (current.trim()) return; // Skip non-empty
            previousValues.set(fieldName, current);
            setHandbookValue(fieldName, val);
            appliedFields.push(fieldName);
          });
        });

        applyAllBtn.textContent = `Undo All (${appliedFields.length})`;
        applyAllBtn.classList.add('admin-ai-undo-btn');
        const origClick = applyAllBtn.onclick;
        applyAllBtn.onclick = () => {
          appliedFields.forEach(fieldName => {
            if (fieldName === 'categories') {
              const checkboxes = document.querySelectorAll<HTMLInputElement>('input[name="categories"]');
              checkboxes.forEach(cb => { cb.checked = false; });
            } else {
              const prev = previousValues.get(fieldName);
              if (prev !== undefined) { setHandbookValue(fieldName, prev); previousValues.delete(fieldName); }
            }
          });
          applyAllBtn.textContent = 'Apply All Empty';
          applyAllBtn.classList.remove('admin-ai-undo-btn');
          applyAllBtn.onclick = origClick;
          showFeedback('All generated content reverted.');
        };
        showFeedback(`Applied ${appliedFields.length} empty fields.`);
      });
    }

    // --- Fact-check Result ---
    function renderFactcheck(r: any) {
      if (!aiResultEl) return;
      let html = '';

      if (r.overall_confidence) {
        html += `<span class="admin-ai-confidence admin-ai-confidence--${r.overall_confidence}">Confidence: ${r.overall_confidence}</span>`;
      }

      if (r.claims?.length) {
        html += '<h4>Claims</h4>';
        r.claims.forEach((c: any) => {
          html += `<div class="admin-ai-claim"><div class="admin-ai-claim-text">"${esc(c.claim)}"</div><div class="admin-ai-claim-meta"><span class="admin-ai-verdict admin-ai-verdict--${c.verdict}">${c.verdict}</span>`;
          if (c.note) html += `<span>${esc(c.note)}</span>`;
          html += `</div></div>`;
        });
      }

      if (r.broken_links?.length) {
        html += '<h4>Broken Links</h4>';
        r.broken_links.forEach((link: string) => {
          html += `<div class="admin-ai-suggestion"><span class="admin-ai-suggestion-text">${esc(link)}</span></div>`;
        });
      }

      if (r.missing_labels?.length) {
        html += '<h4>Missing "Unverified" Labels</h4>';
        r.missing_labels.forEach((label: string) => {
          html += `<div class="admin-ai-suggestion"><span class="admin-ai-suggestion-text">${esc(label)}</span></div>`;
        });
      }

      aiResultEl.innerHTML = html;
    }

    // --- Deep Verify Result ---
    function renderDeepverify(r: any) {
      if (!aiResultEl) return;
      let html = '';

      if (r.overall_confidence) {
        html += `<span class="admin-ai-confidence admin-ai-confidence--${r.overall_confidence}">Confidence: ${r.overall_confidence}</span>`;
      }
      if (r.confidence_reason) {
        html += `<p class="admin-ai-confidence-reason">${esc(r.confidence_reason)}</p>`;
      }

      if (r.claims?.length) {
        html += '<h4>Verified Claims</h4>';
        r.claims.forEach((c: any) => {
          html += `<div class="admin-ai-claim"><div class="admin-ai-claim-text">"${esc(c.claim)}"</div><div class="admin-ai-claim-meta"><span class="admin-ai-verdict admin-ai-verdict--${c.verdict}">${c.verdict}</span>`;
          if (c.note) html += `<span>${esc(c.note)}</span>`;
          html += `</div>`;
          if (c.sources?.length) {
            html += `<div class="admin-ai-claim-sources">`;
            c.sources.forEach((src: string) => {
              html += `<a href="${esc(src)}" target="_blank" rel="noopener" class="admin-ai-source-link">${esc(new URL(src).hostname)}</a>`;
            });
            html += `</div>`;
          }
          html += `</div>`;
        });
      }

      aiResultEl.innerHTML = html;
    }

    // Bind AI action buttons
    aiActionBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const action = btn.dataset.aiAction;
        if (action) runHandbookAi(action);
      });
    });

    // AI Generate Body buttons (basic_ko, basic_en, advanced_ko, advanced_en)
    document.querySelectorAll<HTMLButtonElement>('[data-ai-generate-body]').forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.aiGenerateBody; // 'basic_ko', 'basic_en', etc.
        if (target) {
          runHandbookAi('generate', { [`body_${target}`]: '' });
        }
      });
    });

    // Language tab switching
    document.querySelectorAll<HTMLButtonElement>('[data-lang]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const lang = btn.dataset.lang!;
        document.querySelectorAll<HTMLButtonElement>('[data-lang]').forEach((b) =>
          b.classList.remove('admin-lang-tab--active')
        );
        btn.classList.add('admin-lang-tab--active');

        document.getElementById('lang-ko')!.style.display = lang === 'ko' ? '' : 'none';
        document.getElementById('lang-en')!.style.display = lang === 'en' ? '' : 'none';
      });
    });

    // Level sub-tab switching (Basic / Advanced within each language)
    document.querySelectorAll<HTMLButtonElement>('[data-level-lang]').forEach(btn => {
      btn.addEventListener('click', () => {
        const lang = btn.dataset.levelLang!;
        const level = btn.dataset.level!;
        // Toggle active tab within same language
        document.querySelectorAll<HTMLButtonElement>(`[data-level-lang="${lang}"]`).forEach(b =>
          b.classList.remove('admin-level-tab--active')
        );
        btn.classList.add('admin-level-tab--active');
        // Show/hide level panels
        const basicPanel = document.getElementById(`level-basic-${lang}`);
        const advancedPanel = document.getElementById(`level-advanced-${lang}`);
        if (basicPanel) basicPanel.style.display = level === 'basic' ? '' : 'none';
        if (advancedPanel) advancedPanel.style.display = level === 'advanced' ? '' : 'none';
      });
    });

    // Enforce max 4 categories
    document.querySelectorAll<HTMLInputElement>('input[name="categories"]').forEach(cb => {
      cb.addEventListener('change', () => {
        const checked = document.querySelectorAll<HTMLInputElement>('input[name="categories"]:checked');
        if (checked.length > 4) {
          cb.checked = false;
          showFeedback('Maximum 4 categories allowed.', true);
        }
      });
    });

    // ===== Initialize Milkdown Crepe body editors (4 instances) =====
    async function initCrepe(elId: string, placeholder: string): Promise<Crepe | null> {
      const el = document.getElementById(elId);
      if (!el) return null;
      const crepe = new Crepe({
        root: el,
        defaultValue: el.dataset.content || '',
        featureConfigs: {
          [Crepe.Feature.Placeholder]: { text: placeholder, mode: 'block' },
        },
      });
      await crepe.create();
      return crepe;
    }

    async function initBodyEditors() {
      [crepeBasicKo, crepeBasicEn, crepeAdvancedKo, crepeAdvancedEn] = await Promise.all([
        initCrepe('body-editor-basic-ko', '기초 설명을 작성하세요...'),
        initCrepe('body-editor-basic-en', 'Write basic explanation...'),
        initCrepe('body-editor-advanced-ko', '심화 설명을 작성하세요...'),
        initCrepe('body-editor-advanced-en', 'Write advanced explanation...'),
      ]);
    }
    initBodyEditors().then(() => {
      updateAllIndicators();
      // Periodic char count / indicator refresh (Crepe doesn't fire input events reliably)
      setInterval(updateAllIndicators, 3000);
    });

    // --- Completeness indicator ---
    function updateCompleteness(): void {
      const fields = [
        () => (document.querySelector<HTMLInputElement>('[name="korean_name"]')?.value || '').length > 0,
        () => (document.querySelector<HTMLTextAreaElement>('[name="definition_ko"]')?.value || '').length > 0,
        () => (document.querySelector<HTMLTextAreaElement>('[name="definition_en"]')?.value || '').length > 0,
        () => {
          const cats = document.querySelectorAll<HTMLInputElement>('input[name="categories"]:checked');
          return cats.length > 0;
        },
        () => (crepeBasicKo ? crepeBasicKo.getMarkdown() : '').length > 50,
        () => (crepeBasicEn ? crepeBasicEn.getMarkdown() : '').length > 50,
        () => (crepeAdvancedKo ? crepeAdvancedKo.getMarkdown() : '').length > 50,
        () => (crepeAdvancedEn ? crepeAdvancedEn.getMarkdown() : '').length > 50,
      ];

      const filled = fields.filter(fn => { try { return fn(); } catch { return false; } }).length;
      const pct = Math.round((filled / 8) * 100);

      const fill = document.getElementById('completeness-fill');
      const text = document.getElementById('completeness-text');
      if (fill) {
        fill.style.width = `${pct}%`;
        fill.style.backgroundColor = filled <= 3 ? 'var(--color-error, #c44)' : filled <= 6 ? 'var(--color-warning, #f59e0b)' : 'var(--color-success)';
      }
      if (text) text.textContent = `${filled}/8`;
    }

    // --- Meta details filled count ---
    function updateMetaFilledCount(): void {
      const metaFields = [
        () => (document.querySelector<HTMLInputElement>('[name="slug"]')?.value || '').length > 0,
        () => (document.querySelector<HTMLInputElement>('[name="term_full"]')?.value || '').length > 0,
        () => (document.querySelector<HTMLInputElement>('[name="korean_full"]')?.value || '').length > 0,
        () => getRelatedSlugs().length > 0,
      ];
      const filled = metaFields.filter(fn => { try { return fn(); } catch { return false; } }).length;
      const el = document.getElementById('meta-filled-count');
      if (el) el.textContent = `(${filled}/${metaFields.length} filled)`;
    }

    // --- Tab content indicators ---
    function updateTabIndicators(): void {
      const defKo = (document.querySelector<HTMLTextAreaElement>('[name="definition_ko"]')?.value || '').trim();
      const bodyBasicKo = crepeBasicKo ? crepeBasicKo.getMarkdown().trim() : '';
      const bodyAdvKo = crepeAdvancedKo ? crepeAdvancedKo.getMarkdown().trim() : '';
      const koHasContent = defKo.length > 0 || bodyBasicKo.length > 0 || bodyAdvKo.length > 0;

      const defEn = (document.querySelector<HTMLTextAreaElement>('[name="definition_en"]')?.value || '').trim();
      const bodyBasicEn = crepeBasicEn ? crepeBasicEn.getMarkdown().trim() : '';
      const bodyAdvEn = crepeAdvancedEn ? crepeAdvancedEn.getMarkdown().trim() : '';
      const enHasContent = defEn.length > 0 || bodyBasicEn.length > 0 || bodyAdvEn.length > 0;

      const koIndicator = document.getElementById('lang-indicator-ko');
      const enIndicator = document.getElementById('lang-indicator-en');
      if (koIndicator) koIndicator.hidden = !koHasContent;
      if (enIndicator) enIndicator.hidden = !enHasContent;

      // Level indicators
      const indicators: [string, string][] = [
        ['level-indicator-basic-ko', bodyBasicKo],
        ['level-indicator-advanced-ko', bodyAdvKo],
        ['level-indicator-basic-en', bodyBasicEn],
        ['level-indicator-advanced-en', bodyAdvEn],
      ];
      indicators.forEach(([id, content]) => {
        const el = document.getElementById(id);
        if (el) el.hidden = content.length === 0;
      });
    }

    // --- Character count ---
    function updateCharCounts(): void {
      const editors: [Crepe | null, string][] = [
        [crepeBasicKo, 'charcount-basic-ko'],
        [crepeAdvancedKo, 'charcount-advanced-ko'],
        [crepeBasicEn, 'charcount-basic-en'],
        [crepeAdvancedEn, 'charcount-advanced-en'],
      ];
      editors.forEach(([editor, elId]) => {
        const el = document.getElementById(elId);
        if (!el) return;
        if (!editor) { el.textContent = ''; return; }
        const md = editor.getMarkdown();
        const charCount = md.length;
        const wordCount = md.trim() ? md.trim().split(/\s+/).length : 0;
        el.textContent = charCount > 0 ? `${charCount} chars / ${wordCount} words` : '';
      });
    }

    // Combined update for all indicators
    function updateAllIndicators(): void {
      updateCompleteness();
      updateMetaFilledCount();
      updateTabIndicators();
      updateCharCounts();
    }

    // Update completeness on meta field input changes
    document.querySelector<HTMLInputElement>('[name="korean_name"]')?.addEventListener('input', updateAllIndicators);
    document.querySelector<HTMLTextAreaElement>('[name="definition_ko"]')?.addEventListener('input', updateAllIndicators);
    document.querySelector<HTMLTextAreaElement>('[name="definition_en"]')?.addEventListener('input', updateAllIndicators);
    document.querySelectorAll<HTMLInputElement>('input[name="categories"]').forEach(cb => {
      cb.addEventListener('change', updateAllIndicators);
    });
    // Meta detail fields
    document.querySelector<HTMLInputElement>('[name="slug"]')?.addEventListener('input', updateMetaFilledCount);
    document.querySelector<HTMLInputElement>('[name="term_full"]')?.addEventListener('input', updateMetaFilledCount);
    document.querySelector<HTMLInputElement>('[name="korean_full"]')?.addEventListener('input', updateMetaFilledCount);


  function getFormData(): Record<string, any> {
    const form = document.getElementById('term-form') as HTMLFormElement;
    const fd = new FormData(form);
    const data: Record<string, any> = {};

    for (const [key, value] of fd.entries()) {
      if (key === 'categories') continue; // handled separately
      data[key] = value;
    }

    // Collect categories from checkbox group
    const catBoxes = form.querySelectorAll<HTMLInputElement>('input[name="categories"]:checked');
    data.categories = Array.from(catBoxes).map(cb => cb.value);

    data.is_favourite = (form.querySelector('[name="is_favourite"]') as HTMLInputElement).checked;

    try {
      data.related_term_slugs = JSON.parse(data.related_term_slugs as string || '[]');
    } catch { data.related_term_slugs = []; }

    if (!data.id) delete data.id;

    // Body content from Crepe editors (not in form anymore)
    data.body_basic_ko = crepeBasicKo ? crepeBasicKo.getMarkdown() : '';
    data.body_basic_en = crepeBasicEn ? crepeBasicEn.getMarkdown() : '';
    data.body_advanced_ko = crepeAdvancedKo ? crepeAdvancedKo.getMarkdown() : '';
    data.body_advanced_en = crepeAdvancedEn ? crepeAdvancedEn.getMarkdown() : '';

    return data;
  }

  function getActivePreviewLang() {
    return document.querySelector('.admin-lang-tab--active')?.getAttribute('data-lang') || 'ko';
  }

  function getActivePreviewLevel() {
    const activeLang = getActivePreviewLang();
    const activeLevelBtn = document.querySelector(`[data-level-lang="${activeLang}"].admin-level-tab--active`) as HTMLElement | null;
    return activeLevelBtn?.dataset.level || 'basic';
  }

  function syncSavedState(saved: { id?: string; slug?: string } | null) {
    if (!saved) return;
    if (saved.id && idInput) {
      idInput.value = saved.id;
    }
    if (saved.slug && slugInput) {
      slugInput.value = saved.slug;
    }
    if (saved.slug) {
      window.history.replaceState(window.history.state, '', preview.getEditorUrl(preview.isPreviewLocation() ? 'preview' : 'draft', saved.slug));
    }
  }

  function buildPreviewUrl() {
    const slug = (slugInput?.value || '').trim();
    if (!slug) return '';
    const locale = getActivePreviewLang();
    const level = getActivePreviewLevel();
    const params = new URLSearchParams({
      preview: '1',
      previewLevel: level,
      ts: `${Date.now()}`,
    });
    return `/${locale}/handbook/${slug}/?${params.toString()}`;
  }

  async function handleSave(options: { showFeedback?: boolean } = {}) {
    const { showFeedback: shouldShowFeedback = true } = options;
    const data = getFormData();
    if (!data.term) {
      if (shouldShowFeedback) showFeedback('Term is required.', true);
      return null;
    }

    try {
      const res = await fetch('/api/admin/handbook/save', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        const saved = await res.json();
        syncSavedState(saved);
        // Update last saved time display
        const savedTimeEl = document.getElementById('last-saved-time');
        if (savedTimeEl) {
          const now = new Date();
          savedTimeEl.textContent = `Saved ${now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}`;
        }
        updateAllIndicators();
        if (shouldShowFeedback) showFeedback('Saved successfully.');
        return saved;
      }

      let errMsg = 'Save failed.';
      try {
        const err = await res.json();
        errMsg = `Save failed: ${err.error}`;
      } catch { /* JSON parse failed, use fallback message */ }
      if (shouldShowFeedback) showFeedback(errMsg, true);
      return null;
    } catch {
      if (shouldShowFeedback) showFeedback('Save failed: network error. Check your connection.', true);
      return null;
    }
  }

  async function handlePublish() {
    const saved = await handleSave({ showFeedback: false });
    if (!saved) return false;

    const pubRes = await fetch('/api/admin/handbook/status', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: saved.id, action: 'publish' }),
    });
    if (pubRes.ok) {
      showFeedback('Published! Redirecting...');
      const slug = slugInput?.value || '';
      const lang = getActivePreviewLang();
      setTimeout(() => { window.location.href = `/${lang}/handbook/${slug}/`; }, 1500);
      return true;
    }

    const err = await pubRes.json();
    showFeedback(`Publish failed: ${err.error}`, true);
    return false;
  }

  // ===== Draft <-> Preview toggle =====
  previewFrame?.addEventListener('load', () => {
    preview.attachAutoResize();
    preview.setShellLoading(false);
    btnManager.restore();
    if (preview.announceReady) {
      showFeedback('Preview updated.');
      preview.announceReady = false;
    }
  });

  window.addEventListener('popstate', () => preview.syncFromLocation());

  btnPreview?.addEventListener('click', async () => {
    if (btnManager.isPending) return;
    btnManager.begin(btnPreview, 'Saving...');
    const saved = await handleSave({ showFeedback: false });
    if (!saved) {
      btnManager.restore();
      showFeedback('Preview failed: save the draft first.', true);
      return;
    }
    const previewUrl = buildPreviewUrl();
    if (!previewUrl) {
      btnManager.restore();
      showFeedback('Preview failed: save a valid slug first.', true);
      return;
    }
    btnManager.setLabel(btnPreview, 'Loading preview...');
    preview.loadFrame(previewUrl, { announce: true, pushHistory: true });
  });

  btnEditBack?.addEventListener('click', () => {
    if (btnManager.isPending) return;
    if (preview.isPreviewLocation() && preview.enteredFromEditor) {
      history.back();
      return;
    }
    preview.showDraft(true);
  });

  btnPublishPreview?.addEventListener('click', async () => {
    if (btnManager.isPending) return;
    btnManager.begin(btnPublishPreview, 'Publishing...');
    const published = await handlePublish();
    if (!published) btnManager.restore();
  });

  // ===== Save Draft =====
  btnSave?.addEventListener('click', async () => {
    if (btnManager.isPending) return;
    btnManager.begin(btnSave, 'Saving...');
    await handleSave();
    btnManager.restore();
  });

  btnPublish?.addEventListener('click', async () => {
    if (btnManager.isPending) return;
    btnManager.begin(btnPublish, 'Publishing...');
    const published = await handlePublish();
    if (!published) btnManager.restore();
  });

  btnDelete?.addEventListener('click', async () => {
    const idInput = document.querySelector('[name="id"]') as HTMLInputElement;
    const id = idInput.value;
    if (!id) return;

    const termInput = document.querySelector('[name="term"]') as HTMLInputElement;
    if (!confirm(`Delete "${termInput.value}"? This cannot be undone.`)) return;

    const res = await fetch('/api/admin/handbook/delete', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id }),
    });
    if (res.ok) {
      window.location.href = '/admin/handbook/';
    } else {
      const err = await res.json();
      showFeedback(`Delete failed: ${err.error}`, true);
    }
  });

  preview.syncFromLocation();
  }); // end DOMContentLoaded
</script>
