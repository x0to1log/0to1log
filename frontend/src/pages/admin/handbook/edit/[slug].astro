---
export const prerender = false;
import MainLayout from '../../../../layouts/MainLayout.astro';
import AdminHeader from '../../../../components/admin/AdminHeader.astro';
import { createClient } from '@supabase/supabase-js';
import { getHandbookCategories } from '../../../../lib/handbookCategories';

const { slug } = Astro.params;
const isNew = slug === 'new';
const accessToken = Astro.locals.accessToken;

let term: Record<string, any> | null = null;
let loadError: string | null = null;

if (!isNew) {
  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
    { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
  );
  const { data, error } = await supabase
    .from('handbook_terms')
    .select('*')
    .eq('slug', slug)
    .single();

  if (error || !data) {
    loadError = error?.message || 'Term not found';
  } else {
    term = data;
  }
}

const categories = getHandbookCategories();
const difficulties = ['beginner', 'intermediate', 'advanced'];

const pageTitle = isNew ? 'New Term' : `Edit: ${term?.term || slug}`;
---

<MainLayout title={`Admin — ${pageTitle}`} locale="en">
  <div style="max-width: 800px; margin: 0 auto; padding: 0 1rem;">
    <AdminHeader activeTab="handbook" />

    {loadError ? (
      <div class="admin-feedback admin-feedback--error" style="margin-bottom: 1rem;">
        {loadError}
      </div>
    ) : (
      <>
        {/* Toolbar */}
        <div class="admin-toolbar" style="margin-bottom: 1.5rem;">
          <div class="admin-toolbar-left">
            <a href="/admin/handbook/" class="admin-btn" style="font-size: 0.85rem;">&larr; Back</a>
            {term && (
              <span class={`admin-status-badge admin-status-badge--${term.status}`} style="margin-left: 0.75rem;">
                {term.status}
              </span>
            )}
          </div>
          <div class="admin-toolbar-right">
            <button id="btn-save" class="admin-btn" style="font-size: 0.85rem;">Save Draft</button>
            <button id="btn-publish" class="admin-btn" style="font-size: 0.85rem;">Publish</button>
            {term && (
              <button id="btn-delete" class="admin-btn-danger" style="font-size: 0.85rem;">Delete</button>
            )}
          </div>
        </div>

        {/* Form */}
        <form id="term-form" style="display: flex; flex-direction: column; gap: 1rem;">
          <input type="hidden" name="id" value={term?.id || ''} />

          {/* Term (always visible) */}
          <div class="admin-field">
            <label>Term (English) *</label>
            <input type="text" name="term" class="admin-input" value={term?.term || ''} required />
          </div>

          {/* Category + Difficulty (always visible) */}
          <div class="admin-field-row">
            <div class="admin-field">
              <label>Category</label>
              <select name="category" class="admin-input">
                <option value="">— select —</option>
                {categories.map((cat) => (
                  <option value={cat} selected={term?.category === cat}>{cat}</option>
                ))}
              </select>
            </div>
            <div class="admin-field">
              <label>Difficulty</label>
              <select name="difficulty" class="admin-input">
                <option value="">— select —</option>
                {difficulties.map((d) => (
                  <option value={d} selected={term?.difficulty === d}>{d}</option>
                ))}
              </select>
            </div>
          </div>

          {/* Collapsible secondary fields */}
          <details class="admin-details">
            <summary>More fields (Slug, Korean Name, Related Terms...)</summary>
            <div class="admin-details-body">
              <div class="admin-field">
                <label>Slug</label>
                <input type="text" name="slug" class="admin-input" value={term?.slug || ''} placeholder="auto-generated from term" />
              </div>
              <div class="admin-field">
                <label>Korean Name</label>
                <input type="text" name="korean_name" class="admin-input" value={term?.korean_name || ''} />
              </div>
              <div class="admin-field">
                <label>Related Term Slugs (comma-separated)</label>
                <input type="text" name="related_term_slugs" class="admin-input" value={(term?.related_term_slugs || []).join(', ')} />
              </div>
              <div class="admin-field admin-field--checkbox">
                <label>
                  <input type="checkbox" name="is_favourite" checked={term?.is_favourite} />
                  Favourite (pinned in list)
                </label>
              </div>
            </div>
          </details>

          {/* Language tabs */}
          <div class="admin-lang-tabs">
            <button type="button" class="admin-lang-tab admin-lang-tab--active" data-lang="ko">KO</button>
            <button type="button" class="admin-lang-tab" data-lang="en">EN</button>
          </div>

          {/* KO content */}
          <div id="lang-ko">
            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
              <div class="admin-field">
                <label>Definition (KO)</label>
                <textarea name="definition_ko" class="admin-textarea" rows="3">{term?.definition_ko || ''}</textarea>
              </div>
              <div class="admin-field">
                <label>Plain Explanation (KO)</label>
                <textarea name="plain_explanation_ko" class="admin-textarea" rows="3">{term?.plain_explanation_ko || ''}</textarea>
              </div>
              <div class="admin-field">
                <label>Technical Description (KO)</label>
                <textarea name="technical_description_ko" class="admin-textarea" rows="3">{term?.technical_description_ko || ''}</textarea>
              </div>
              <div class="admin-field">
                <label>Example / Analogy (KO)</label>
                <textarea name="example_analogy_ko" class="admin-textarea" rows="3">{term?.example_analogy_ko || ''}</textarea>
              </div>
              <div class="admin-field">
                <label>Body Markdown (KO)</label>
                <textarea name="body_markdown_ko" class="admin-textarea" rows="8">{term?.body_markdown_ko || ''}</textarea>
              </div>
            </div>
          </div>

          {/* EN content */}
          <div id="lang-en" style="display: none;">
            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
              <div class="admin-field">
                <label>Definition (EN)</label>
                <textarea name="definition_en" class="admin-textarea" rows="3">{term?.definition_en || ''}</textarea>
              </div>
              <div class="admin-field">
                <label>Plain Explanation (EN)</label>
                <textarea name="plain_explanation_en" class="admin-textarea" rows="3">{term?.plain_explanation_en || ''}</textarea>
              </div>
              <div class="admin-field">
                <label>Technical Description (EN)</label>
                <textarea name="technical_description_en" class="admin-textarea" rows="3">{term?.technical_description_en || ''}</textarea>
              </div>
              <div class="admin-field">
                <label>Example / Analogy (EN)</label>
                <textarea name="example_analogy_en" class="admin-textarea" rows="3">{term?.example_analogy_en || ''}</textarea>
              </div>
              <div class="admin-field">
                <label>Body Markdown (EN)</label>
                <textarea name="body_markdown_en" class="admin-textarea" rows="8">{term?.body_markdown_en || ''}</textarea>
              </div>
            </div>
          </div>
        </form>
      </>
    )}

    {/* Toast feedback (fixed position, outside form flow) */}
    <div id="feedback" class="admin-feedback admin-feedback--toast" hidden></div>
  </div>
</MainLayout>

<script>
  // Auto-open details on desktop
  if (window.innerWidth >= 768) {
    document.querySelector('.admin-details')?.setAttribute('open', '');
  }

  // Language tab switching
  document.querySelectorAll<HTMLButtonElement>('[data-lang]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const lang = btn.dataset.lang!;
      document.querySelectorAll<HTMLButtonElement>('[data-lang]').forEach((b) =>
        b.classList.remove('admin-lang-tab--active')
      );
      btn.classList.add('admin-lang-tab--active');

      document.getElementById('lang-ko')!.style.display = lang === 'ko' ? '' : 'none';
      document.getElementById('lang-en')!.style.display = lang === 'en' ? '' : 'none';
    });
  });

  function showFeedback(message: string, isError = false) {
    const el = document.getElementById('feedback')!;
    el.textContent = message;
    el.className = `admin-feedback admin-feedback--toast admin-feedback--${isError ? 'error' : 'success'}`;
    el.hidden = false;
    setTimeout(() => { el.hidden = true; }, 3000);
  }

  function getFormData(): Record<string, any> {
    const form = document.getElementById('term-form') as HTMLFormElement;
    const fd = new FormData(form);
    const data: Record<string, any> = {};

    for (const [key, value] of fd.entries()) {
      data[key] = value;
    }

    data.is_favourite = (form.querySelector('[name="is_favourite"]') as HTMLInputElement).checked;

    const related = (data.related_term_slugs as string || '').trim();
    data.related_term_slugs = related ? related.split(',').map((s: string) => s.trim()).filter(Boolean) : [];

    if (!data.id) delete data.id;

    return data;
  }

  document.getElementById('btn-save')?.addEventListener('click', async () => {
    const data = getFormData();
    if (!data.term) { showFeedback('Term is required.', true); return; }

    const res = await fetch('/api/admin/handbook/save', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });

    if (res.ok) {
      const saved = await res.json();
      const idInput = document.querySelector('[name="id"]') as HTMLInputElement;
      if (saved.id) idInput.value = saved.id;
      const slugInput = document.querySelector('[name="slug"]') as HTMLInputElement;
      if (saved.slug) slugInput.value = saved.slug;
      showFeedback('Saved successfully.');
      if (!data.id && saved.slug) {
        window.history.replaceState(null, '', `/admin/handbook/edit/${saved.slug}`);
      }
    } else {
      const err = await res.json();
      showFeedback(`Save failed: ${err.error}`, true);
    }
  });

  document.getElementById('btn-publish')?.addEventListener('click', async () => {
    const data = getFormData();
    if (!data.term) { showFeedback('Term is required.', true); return; }

    const saveRes = await fetch('/api/admin/handbook/save', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });
    if (!saveRes.ok) { const err = await saveRes.json(); showFeedback(`Save failed: ${err.error}`, true); return; }

    const saved = await saveRes.json();
    const idInput = document.querySelector('[name="id"]') as HTMLInputElement;
    if (saved.id) idInput.value = saved.id;

    const pubRes = await fetch('/api/admin/handbook/status', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: saved.id, action: 'publish' }),
    });
    if (pubRes.ok) {
      showFeedback('Published successfully.');
      setTimeout(() => window.location.reload(), 1000);
    } else {
      const err = await pubRes.json();
      showFeedback(`Publish failed: ${err.error}`, true);
    }
  });

  document.getElementById('btn-delete')?.addEventListener('click', async () => {
    const idInput = document.querySelector('[name="id"]') as HTMLInputElement;
    const id = idInput.value;
    if (!id) return;

    const termInput = document.querySelector('[name="term"]') as HTMLInputElement;
    if (!confirm(`Delete "${termInput.value}"? This cannot be undone.`)) return;

    const res = await fetch('/api/admin/handbook/delete', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id }),
    });
    if (res.ok) {
      window.location.href = '/admin/handbook/';
    } else {
      const err = await res.json();
      showFeedback(`Delete failed: ${err.error}`, true);
    }
  });
</script>
