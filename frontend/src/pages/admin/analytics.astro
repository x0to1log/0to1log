    background: color-mix(in srgb, var(--color-accent-subtle) 60%, var(--color-bg-secondary));
    transform: translateY(-1px);
  }

  .sa-chip__label { color: var(--color-text-secondary); font-size: 0.78rem; }
  .sa-chip__value { font-family: var(--font-code); font-size: 0.82rem; color: var(--color-text-primary); }

  /* ─── Recent List ───────────────────────────── */
  .sa-recent-list { list-style: none; padding: 0; margin: 0; }

  .sa-recent-item {
