  /* ─── Responsive ────────────────────────────── */
  @media (max-width: 900px) {
    .sa-briefs { grid-template-columns: 1fr; }
    .sa-chart-row { grid-template-columns: 1fr; }
    .sa-stats-grid--5 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
