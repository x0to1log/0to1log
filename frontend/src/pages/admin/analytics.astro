              </div>
              <div class="sa-stat-card">
                <span class="sa-stat-card__label">Breakdown</span>
                <div class="sa-stat-card__breakdown">
                  <span>News <strong>{newsLikeCount ?? 0}</strong></span>
                  <span>Blog <strong>{blogLikeCount ?? 0}</strong></span>
                  <span>Products <strong>{productLikeCount ?? 0}</strong></span>
                </div>
              </div>
            </div>
          </section>

          <section class="sa-section sa-section--half">
            <h2 class="sa-section__title">Content Feedback</h2>
            {feedbackTotal === 0 ? (
              <p class="sa-empty">No feedback yet.</p>
            ) : (
              <>
                <div class="sa-stats-grid sa-stats-grid--2">
                  <div class="sa-stat-card">
                    <span class="sa-stat-card__label">Positive</span>
                    <strong class="sa-stat-card__value sa-stat-card__value--success">{feedbackPositive}</strong>
                  </div>
                  <div class="sa-stat-card">
                    <span class="sa-stat-card__label">Negative</span>
                    <strong class="sa-stat-card__value sa-stat-card__value--danger">{feedbackNegative}</strong>
                  </div>
                </div>
                {Object.keys(feedbackBySource).length > 0 && (
                  <div class="sa-subsection">
                    <h3 class="sa-subsection__title">By Content Type</h3>
                    <div class="sa-chips">
                      {Object.entries(feedbackBySource).map(([src, { positive, negative }]) => (
                        <span class="sa-chip sa-chip--wide">
                          <span class="sa-chip__label">{src}</span>
                          <span class="sa-chip__value sa-chip__value--success">+{positive}</span>
                          <span class="sa-chip__value sa-chip__value--danger">-{negative}</span>
                        </span>
                      ))}
                    </div>
                  </div>
                )}
              </>
            )}
          </section>
        </div>

        <!-- ─── Popular Content ─── -->
        <section class="sa-section">
          <h2 class="sa-section__title">Popular Content</h2>
          <p class="sa-section__hint">Ranked by reads + bookmarks (bookmarks weighted 2x).</p>
          {topPopular.length === 0 ? (
            <p class="sa-empty">No reading activity yet.</p>
          ) : (
            <ol class="sa-popular-list">
              {topPopular.map((item, i) => {
                const info = titleMap.get(`${item.type}:${item.id}`);
                return (
                  <li class="sa-popular-item">
                    <span class="sa-popular-item__rank">{i + 1}</span>
                    {info ? (
                      <a href={info.slug} class="sa-popular-item__link">{info.title}</a>
                    ) : (
                      <span class="sa-popular-item__link sa-popular-item__link--unknown">{item.id}</span>
                    )}
                    <span class="sa-popular-item__meta">
                      <span class={`sa-badge sa-badge--${item.type === 'post' ? 'locale' : 'source'}`}>
                        {item.type === 'post' ? 'Paper' : 'Handbook'}
                      </span>
                      <span class="sa-popular-item__stats">
                        {item.reads > 0 && <span>{item.reads} reads</span>}
                        {item.bookmarks > 0 && <span>{item.bookmarks} bookmarks</span>}
                      </span>
                    </span>
                  </li>
                );
              })}
            </ol>
          )}
        </section>

        <!-- External Links -->
        <section class="sa-section sa-section--links">
          <h2 class="sa-section__title">External Dashboards</h2>
          <div class="sa-links-row">
            {ga4PropertyId ? (
              <a
                href={`https://analytics.google.com/analytics/web/#/p${ga4PropertyId}/reports/reportinghub`}
                target="_blank"
                rel="noopener noreferrer"
                class="sa-external-link"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6 M15 3h6v6 M10 14L21 3" />
                </svg>
                Open GA4 Dashboard
              </a>
            ) : (
              <span class="sa-external-link sa-external-link--disabled">GA4 not configured</span>
            )}
            {clarityId ? (
              <a
                href={`https://clarity.microsoft.com/projects/view/${clarityId}/dashboard`}
                target="_blank"
                rel="noopener noreferrer"
                class="sa-external-link"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6 M15 3h6v6 M10 14L21 3" />
                </svg>
                Open Clarity Dashboard
              </a>
            ) : (
              <span class="sa-external-link sa-external-link--disabled">Clarity not configured</span>
            )}
          </div>
        </section>
      </div>
    </div>
  </div>
</MainLayout>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js" nonce={nonce}></script>
<script is:inline nonce={nonce}>
  (function () {
    /* ── Tab switching ─────────────────────────────── */
    var tabs = document.querySelectorAll('.sa-tab');
    var panels = document.querySelectorAll('.sa-tab-panel');
    var briefCards = document.querySelectorAll('.sa-brief-card[data-tab-target]');
    var ga4Loaded = false;

    function activateTab(id) {
      tabs.forEach(function (t) {
        var active = t.id === 'tab-btn-' + id;
        t.classList.toggle('sa-tab--active', active);
        t.setAttribute('aria-selected', String(active));
      });
      panels.forEach(function (p) {
        p.hidden = p.id !== 'tab-' + id;
      });
      briefCards.forEach(function (c) {
        c.classList.toggle('sa-brief-card--selected', c.getAttribute('data-tab-target') === id);
      });
      history.replaceState(null, '', '#' + id);
      if (id === 'traffic' && !ga4Loaded) {
        ga4Loaded = true;
        loadGA4();
      }
    }

    tabs.forEach(function (t) {
      t.addEventListener('click', function () {
        activateTab(t.id.replace('tab-btn-', ''));
      });
    });
    briefCards.forEach(function (c) {
      c.addEventListener('click', function () {
        activateTab(c.getAttribute('data-tab-target'));
      });
    });

    var hash = location.hash.replace('#', '');
    var initial = ['traffic', 'news', 'handbook', 'blog', 'products'].indexOf(hash) !== -1 ? hash : 'traffic';
    activateTab(initial);

    /* ── GA4 fetch & render ────────────────────────── */
    function fmt(n) {
      return n.toLocaleString('en-US');
    }

    function loadGA4() {
      var loading = document.getElementById('ga4-loading');
      var errBox = document.getElementById('ga4-error');
      var content = document.getElementById('ga4-content');

      fetch('/api/admin/ga4?days=30')
        .then(function (r) {
          if (!r.ok) return r.json().then(function (d) { throw new Error(d.detail || d.error || 'Failed'); });
          return r.json();
        })
        .then(function (data) {
          loading.style.display = 'none';
          content.style.display = 'block';
          renderGA4(data);
        })
        .catch(function (err) {
          loading.style.display = 'none';
          errBox.style.display = 'flex';
          errBox.innerHTML =
            '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">' +
            '<circle cx="12" cy="12" r="10"/><path d="M12 16v-4 M12 8h.01"/></svg>' +
            '<span>GA4 data unavailable: ' + err.message + '</span>';
        });
    }

    function renderGA4(d) {
      document.getElementById('ga4-pageviews').textContent = fmt(d.summary.pageviews);
      document.getElementById('ga4-sessions').textContent = fmt(d.summary.sessions);
      document.getElementById('ga4-users').textContent = fmt(d.summary.users);
      document.getElementById('ga4-duration').textContent = d.summary.avg_session_duration.toFixed(1);
      document.getElementById('ga4-bounce').textContent = (d.summary.bounce_rate * 100).toFixed(1) + '%';
      document.getElementById('ga4-period').textContent = d.period_start + ' → ' + d.period_end;

      /* Chart theme colors */
      var style = getComputedStyle(document.documentElement);
      var accent = style.getPropertyValue('--color-accent').trim() || '#8B5F3C';
      var textMuted = style.getPropertyValue('--color-text-muted').trim() || '#999';
      var border = style.getPropertyValue('--color-border').trim() || '#ddd';

      var chartDefaults = {
        color: textMuted,
        borderColor: border,
      };
      Chart.defaults.color = textMuted;
      Chart.defaults.borderColor = border;
      Chart.defaults.font.family = style.getPropertyValue('--font-ui').trim() || 'Lora, serif';
      Chart.defaults.font.size = 11;

      /* Daily Pageviews — line chart */
      var dailyCtx = document.getElementById('ga4-chart-daily');
      if (dailyCtx && d.daily_pageviews.length) {
        new Chart(dailyCtx, {
          type: 'line',
          data: {
            labels: d.daily_pageviews.map(function (r) {
              return r.date.slice(5); /* MM-DD */
            }),
            datasets: [{
              label: 'Pageviews',
              data: d.daily_pageviews.map(function (r) { return r.pageviews; }),
              borderColor: accent,
              backgroundColor: accent + '18',
              fill: true,
              tension: 0.35,
              pointRadius: 2,
              pointHoverRadius: 5,
            }],
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              x: { grid: { display: false } },
              y: { beginAtZero: true },
            },
          },
        });
      }

      /* Traffic Sources — doughnut */
      var srcCtx = document.getElementById('ga4-chart-sources');
      if (srcCtx && d.traffic_sources.length) {
        var srcPalette = ['#8B5F3C', '#C3A370', '#6366f1', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6', '#ec4899', '#14b8a6', '#f97316'];
        new Chart(srcCtx, {
          type: 'doughnut',
          data: {
            labels: d.traffic_sources.map(function (r) { return r.source; }),
            datasets: [{
              data: d.traffic_sources.map(function (r) { return r.sessions; }),
              backgroundColor: srcPalette.slice(0, d.traffic_sources.length),
              borderWidth: 0,
            }],
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '55%',
            plugins: {
              legend: { position: 'bottom', labels: { boxWidth: 10, padding: 8, font: { size: 10 } } },
            },
          },
        });
      }

      /* Countries — horizontal bar */
      var countryCtx = document.getElementById('ga4-chart-countries');
      if (countryCtx && d.countries.length) {
        new Chart(countryCtx, {
          type: 'bar',
          data: {
            labels: d.countries.map(function (r) { return r.country; }),
            datasets: [{
              label: 'Sessions',
              data: d.countries.map(function (r) { return r.sessions; }),
              backgroundColor: accent + '60',
              borderColor: accent,
              borderWidth: 1,
            }],
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            indexAxis: 'y',
            plugins: { legend: { display: false } },
            scales: {
              x: { beginAtZero: true, grid: { display: false } },
              y: { grid: { display: false } },
            },
          },
        });
      }

      /* Top Pages table */
      var tbody = document.getElementById('ga4-top-pages');
      if (tbody && d.top_pages.length) {
        tbody.innerHTML = d.top_pages.map(function (p) {
          return '<tr>' +
            '<td class="sa-table__page">' + p.page + '</td>' +
            '<td>' + fmt(p.pageviews) + '</td>' +
            '<td>' + fmt(p.sessions) + '</td>' +
            '</tr>';
        }).join('');
      }
    }
  })();
</script>

<script is:inline nonce={nonce} define:vars={{ dauTrend, mauTrend, personaDist, learningTrend, commentTrend }}>
  (function () {
    if (typeof Chart === 'undefined') return;
    var textColor = '#94a3b8';
    var gridColor = 'rgba(148,163,184,0.1)';

    /* ── DAU/MAU Trend Chart ── */
    var dauCanvas = document.getElementById('ua-dau-mau-chart');
    if (dauCanvas && dauTrend.length > 0) {
      var labels = dauTrend.map(function(d) { return d.label; });
      var dauData = dauTrend.map(function(d) { return d.dau; });
      new Chart(dauCanvas, {
        type: 'line',
        data: {
          labels: labels,
          datasets: [
            {
              label: 'DAU',
              data: dauData,
              borderColor: '#10b981',
              backgroundColor: 'rgba(16,185,129,0.1)',
              fill: true, tension: 0.3, pointRadius: 3,
            },
            {
              label: 'MAU',
              data: mauTrend,
              borderColor: '#6366f1',
              backgroundColor: 'rgba(99,102,241,0.08)',
              fill: true, tension: 0.3, pointRadius: 2, borderDash: [4, 2],
            },
          ],
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: { legend: { labels: { color: textColor, boxWidth: 10, font: { size: 11 } } } },
          scales: {
            x: { ticks: { color: textColor, font: { size: 10 } }, grid: { color: gridColor } },
            y: { beginAtZero: true, ticks: { color: textColor, stepSize: 1 }, grid: { color: gridColor } },
          },
        },
      });
    }

    /* ── Persona Distribution (Doughnut) ── */
    var personaCanvas = document.getElementById('ua-persona-chart');
    if (personaCanvas) {
      var pLabels = []; var pData = []; var pColors = [];
      var colorMap = { beginner: '#10b981', learner: '#6366f1', expert: '#f59e0b', unset: '#64748b' };
      var nameMap = { beginner: 'Beginner', learner: 'Learner', expert: 'Expert', unset: 'Not set' };
      for (var key in personaDist) {
        if (personaDist[key] > 0) {
          pLabels.push(nameMap[key] || key);
          pData.push(personaDist[key]);
          pColors.push(colorMap[key] || '#94a3b8');
        }
      }
      if (pData.length > 0) {
        new Chart(personaCanvas, {
          type: 'doughnut',
          data: {
            labels: pLabels,
            datasets: [{ data: pData, backgroundColor: pColors, borderWidth: 0 }],
          },
          options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { position: 'bottom', labels: { color: textColor, font: { size: 11 }, boxWidth: 10 } } },
          },
        });
      }
    }

    /* ── Learning Activity (Stacked Bar — read vs learned per day) ── */
    var learnCanvas = document.getElementById('ua-learning-chart');
    if (learnCanvas && learningTrend.length > 0) {
      new Chart(learnCanvas, {
        type: 'bar',
        data: {
          labels: learningTrend.map(function(d) { return d.label; }),
          datasets: [
            {
              label: 'Read',
              data: learningTrend.map(function(d) { return d.read; }),
              backgroundColor: '#64748b',
              borderRadius: 2,
            },
            {
              label: 'Learned',
              data: learningTrend.map(function(d) { return d.learned; }),
              backgroundColor: '#10b981',
              borderRadius: 2,
            },
          ],
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: { legend: { labels: { color: textColor, boxWidth: 10, font: { size: 10 } } } },
          scales: {
            x: { stacked: true, ticks: { color: textColor, font: { size: 9 } }, grid: { display: false } },
            y: { stacked: true, beginAtZero: true, ticks: { color: textColor, stepSize: 1 }, grid: { color: gridColor } },
          },
        },
      });
    }

    /* ── Comment Activity (Bar) ── */
    var commentCanvas = document.getElementById('ua-comment-chart');
    if (commentCanvas && commentTrend.length > 0) {
      new Chart(commentCanvas, {
        type: 'bar',
        data: {
          labels: commentTrend.map(function(d) { return d.label; }),
          datasets: [{
            label: 'Comments',
            data: commentTrend.map(function(d) { return d.count; }),
            backgroundColor: 'rgba(99,102,241,0.5)',
            borderRadius: 3,
          }],
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            x: { ticks: { color: textColor, font: { size: 10 } }, grid: { display: false } },
            y: { beginAtZero: true, ticks: { color: textColor, stepSize: 1 }, grid: { color: gridColor } },
          },
        },
      });
    }
  })();
</script>

<style>
  @keyframes saSlideUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .admin-main--site-analytics {
    max-width: 1200px;
  }

  .sa-eyebrow {
    margin: 0 0 0.35rem;
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .sa-subtitle {
    margin: 0.4rem 0 0;
    max-width: 52rem;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  /* ─── Brief Cards ───────────────────────────── */
  .sa-briefs {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .sa-brief-card {
    position: relative;
    display: block;
    padding: 1.1rem 1.2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 0.5rem);
    border-top: 3px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg-secondary) 86%, var(--color-bg-primary));
    cursor: pointer;
    text-align: left;
    font-family: inherit;
    color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
    animation: saSlideUp 0.4s ease both;
    min-width: 0;
    overflow: hidden;
  }

  .sa-brief-card:nth-child(2) { animation-delay: 0.06s; }
  .sa-brief-card:nth-child(3) { animation-delay: 0.12s; }

  .sa-brief-card:hover {
    border-color: color-mix(in srgb, var(--color-accent) 45%, var(--color-border));
    box-shadow: 0 2px 12px var(--color-shadow);
    transform: translateY(-1px);
  }

  .sa-brief-card--users { border-top-color: #eab308; }
  .sa-brief-card--news { border-top-color: #ef4444; }
  .sa-brief-card--handbook { border-top-color: #10b981; }
  .sa-brief-card--blog { border-top-color: #ec4899; }
  .sa-brief-card--products { border-top-color: #8b5cf6; }

  .sa-brief-card--selected.sa-brief-card--users { box-shadow: 0 1px 10px color-mix(in srgb, #eab308 15%, transparent); }
  .sa-brief-card--selected.sa-brief-card--news { box-shadow: 0 1px 10px color-mix(in srgb, #ef4444 15%, transparent); }
  .sa-brief-card--selected.sa-brief-card--handbook { box-shadow: 0 1px 10px color-mix(in srgb, #10b981 15%, transparent); }
  .sa-brief-card--selected.sa-brief-card--blog { box-shadow: 0 1px 10px color-mix(in srgb, #ec4899 15%, transparent); }
  .sa-brief-card--selected.sa-brief-card--products { box-shadow: 0 1px 10px color-mix(in srgb, #8b5cf6 15%, transparent); }

  .sa-brief-card__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.85rem;
  }

  .sa-brief-card__icon { color: var(--color-text-muted); flex-shrink: 0; opacity: 0.7; }

  .sa-brief-card__title {
    margin: 0;
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .sa-brief-card__stats { display: flex; flex-direction: column; gap: 0.55rem; }
  .sa-brief-stat { display: flex; flex-direction: column; }

  .sa-brief-stat__value {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 600;
    line-height: 1;
    color: var(--color-text-primary);
  }

  .sa-brief-stat__label {
    display: block;
    margin-top: 0.3rem;
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  /* ─── Tab Bar ───────────────────────────────── */
  .sa-tab-bar {
    display: flex;
    gap: 0.2rem;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    flex-wrap: nowrap;
