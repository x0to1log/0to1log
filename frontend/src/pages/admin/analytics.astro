---
export const prerender = false;

import MainLayout from '../../layouts/MainLayout.astro';
import AdminSidebar from '../../components/admin/AdminSidebar.astro';
import { createClient } from '@supabase/supabase-js';
import { getHandbookCategoryLabel } from '../../lib/handbookCategories';

const accessToken = Astro.locals.accessToken;
const sb = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
);

// ─── Types ───────────────────────────────────────────────────
type HandbookRow = {
  id: string;
  term: string;
  slug: string;
  status: string;
  source: string | null;
  categories: string[] | null;
  is_favourite: boolean | null;
  updated_at: string;
};

type BlogRow = {
  id: string;
  title: string;
  slug: string;
  status: string;
  locale: string | null;
  category: string | null;
  source: string | null;
  updated_at: string;
};

type NewsRow = {
  id: string;
  title: string;
  slug: string;
  category: string | null;
  locale: string | null;
  status: string;
  post_type: string | null;
  updated_at: string;
};

// ─── Types ─ Products ──────────────────────────────────────
type ProductRow = {
  id: string;
  name: string;
  slug: string;
  is_published: boolean;
  primary_category: string | null;
  pricing: string | null;
  featured: boolean;
  view_count: number;
  like_count: number;
};

// ─── Queries ─────────────────────────────────────────────────
const [
  // Handbook: distribution data (minimal columns) + counts
  { data: rawHandbook },
  { count: handbookTotalCount },
  { count: handbookPublishedCount },
  { count: handbookDraftCount },
  { data: recentHandbookRows },
  // Blog: distribution data + counts
  { data: rawBlog },
  { count: blogTotalCount },
  { count: blogPublishedCount },
  { count: blogDraftCount },
  { data: recentBlogRows },
  // News: distribution data + counts
  { data: rawNews },
  { count: newsTotalCount },
  { count: newsPublishedCount },
  { count: newsDraftCount },
  { data: recentNewsRows },
  // Products (already specific columns)
  { data: rawProducts },
  // User counts
  { count: userCount },
  { count: bookmarkCount },
  { count: readingCount },
  { count: learningCount },
  { count: activeUserCount },
  // Popular content
  { data: rawReadingItems },
  { data: rawBookmarkItems },
  // Quiz, Feedback, Likes
  { data: rawQuizResponses },
  { data: rawFeedback },
  { count: newsLikeCount },
  { count: blogLikeCount },
  { count: productLikeCount },
  // UA data
  { data: rawLastSeenData },
  { data: rawPersonaData },
  { data: rawLearningStatusData },
  { data: rawNewsComments },
  { data: rawBlogComments },
] = await Promise.all([
  // Handbook: only columns needed for source/category/favourite distribution
  sb.from('handbook_terms').select('status, source, categories, is_favourite'),
  sb.from('handbook_terms').select('id', { count: 'exact', head: true }),
  sb.from('handbook_terms').select('id', { count: 'exact', head: true }).eq('status', 'published'),
  sb.from('handbook_terms').select('id', { count: 'exact', head: true }).eq('status', 'draft'),
  sb.from('handbook_terms').select('term, slug, status, source, updated_at').order('updated_at', { ascending: false }).limit(5),
  // Blog: only columns needed for locale/category/source distribution
  sb.from('blog_posts').select('status, locale, category, source'),
  sb.from('blog_posts').select('id', { count: 'exact', head: true }),
  sb.from('blog_posts').select('id', { count: 'exact', head: true }).eq('status', 'published'),
  sb.from('blog_posts').select('id', { count: 'exact', head: true }).eq('status', 'draft'),
  sb.from('blog_posts').select('title, slug, status, locale, source, updated_at').order('updated_at', { ascending: false }).limit(5),
  // News: only columns needed for category/locale/post_type distribution
  sb.from('news_posts').select('status, category, locale, post_type'),
  sb.from('news_posts').select('id', { count: 'exact', head: true }),
  sb.from('news_posts').select('id', { count: 'exact', head: true }).eq('status', 'published'),
  sb.from('news_posts').select('id', { count: 'exact', head: true }).eq('status', 'draft'),
  sb.from('news_posts').select('title, slug, status, category, locale, updated_at').order('updated_at', { ascending: false }).limit(5),
  // Products (already using specific columns)
  sb.from('ai_products')
    .select('id, name, slug, is_published, primary_category, pricing, featured, view_count, like_count')
    .order('view_count', { ascending: false }),
  // User engagement counts
  sb.from('profiles').select('id', { count: 'exact', head: true }),
  sb.from('user_bookmarks').select('id', { count: 'exact', head: true }),
  sb.from('reading_history').select('id', { count: 'exact', head: true }),
  sb.from('learning_progress').select('id', { count: 'exact', head: true }),
  sb.from('profiles').select('id', { count: 'exact', head: true })
    .gte('updated_at', new Date(Date.now() - 7 * 86400000).toISOString()),
  // Popular content (reading_history aggregation)
  sb.from('reading_history').select('item_type, item_id'),
  sb.from('user_bookmarks').select('item_type, item_id'),
  // Quiz analytics
  sb.from('quiz_responses').select('is_correct, persona, created_at'),
  // Content feedback
  sb.from('content_feedback').select('reaction, source_type, created_at'),
  // Likes
  sb.from('news_likes').select('id', { count: 'exact', head: true }),
  sb.from('blog_likes').select('id', { count: 'exact', head: true }),
  sb.from('ai_product_likes').select('id', { count: 'exact', head: true }),
  // UA: DAU/MAU + persona + learning status + comments
  sb.from('profiles').select('last_seen_at').not('last_seen_at', 'is', null).order('last_seen_at', { ascending: true }),
  sb.from('profiles').select('persona'),
  sb.from('learning_progress').select('status, created_at'),
  sb.from('news_comments').select('created_at'),
  sb.from('blog_comments').select('created_at'),
]);

// ─── Handbook Data ───────────────────────────────────────────
const handbookTerms = (rawHandbook ?? []) as HandbookRow[];
const handbookTotal = handbookTotalCount ?? 0;
const handbookPublished = handbookPublishedCount ?? 0;
const handbookDraft = handbookDraftCount ?? 0;
const handbookFavourites = handbookTerms.filter((t) => t.is_favourite).length;

const handbookBySource: Record<string, number> = {};
for (const t of handbookTerms) {
  const src = t.source || 'manual';
  handbookBySource[src] = (handbookBySource[src] || 0) + 1;
}

const handbookCategoryMap = new Map<string, number>();
for (const t of handbookTerms) {
  for (const cat of t.categories ?? []) {
    handbookCategoryMap.set(cat, (handbookCategoryMap.get(cat) || 0) + 1);
  }
}
const handbookCategories = Array.from(handbookCategoryMap.entries())
  .sort((a, b) => b[1] - a[1]);

const recentHandbook = (recentHandbookRows ?? []) as { term: string; slug: string; status: string; source: string | null; updated_at: string }[];

// ─── Blog Data ───────────────────────────────────────────────
const blogPosts = (rawBlog ?? []) as BlogRow[];
const blogTotal = blogTotalCount ?? 0;
const blogPublished = blogPublishedCount ?? 0;
const blogDraft = blogDraftCount ?? 0;

const blogByLocale: Record<string, number> = {};
for (const p of blogPosts) {
  const loc = p.locale || 'unknown';
  blogByLocale[loc] = (blogByLocale[loc] || 0) + 1;
}

const blogByCategory: Record<string, number> = {};
for (const p of blogPosts) {
  const cat = p.category || 'uncategorized';
  blogByCategory[cat] = (blogByCategory[cat] || 0) + 1;
}

const blogBySource: Record<string, number> = {};
for (const p of blogPosts) {
  const src = p.source || 'manual';
  blogBySource[src] = (blogBySource[src] || 0) + 1;
}

const recentBlog = (recentBlogRows ?? []) as { title: string; slug: string; status: string; locale: string | null; source: string | null; updated_at: string }[];

// ─── News Data ──────────────────────────────────────────────
const newsPosts = (rawNews ?? []) as NewsRow[];
const newsTotal = newsTotalCount ?? 0;
const newsPublished = newsPublishedCount ?? 0;
const newsDraft = newsDraftCount ?? 0;

const newsByCategory: Record<string, number> = {};
for (const p of newsPosts) {
  const cat = p.category || 'uncategorized';
  newsByCategory[cat] = (newsByCategory[cat] || 0) + 1;
}

const newsByLocale: Record<string, number> = {};
for (const p of newsPosts) {
  const loc = p.locale || 'unknown';
  newsByLocale[loc] = (newsByLocale[loc] || 0) + 1;
}

const newsByType: Record<string, number> = {};
for (const p of newsPosts) {
  const t = p.post_type || 'article';
  newsByType[t] = (newsByType[t] || 0) + 1;
}

const recentNews = (recentNewsRows ?? []) as { title: string; slug: string; status: string; category: string | null; locale: string | null; updated_at: string }[];

// ─── Products Data ──────────────────────────────────────────
const products = (rawProducts ?? []) as ProductRow[];
const productsTotal = products.length;
const productsPublished = products.filter((p) => p.is_published).length;
const productsDraft = products.filter((p) => !p.is_published).length;
const productsFeatured = products.filter((p) => p.featured).length;

const productsByCategory: Record<string, number> = {};
for (const p of products) {
  const cat = p.primary_category || 'uncategorized';
  productsByCategory[cat] = (productsByCategory[cat] || 0) + 1;
}

const productsByPricing: Record<string, number> = {};
for (const p of products) {
  const pr = p.pricing || 'unknown';
  productsByPricing[pr] = (productsByPricing[pr] || 0) + 1;
}

const topProducts = products.slice(0, 5);

// ─── Quiz Analytics ─────────────────────────────────────────
type QuizRow = { is_correct: boolean; persona: string | null; created_at: string };
const quizResponses = (rawQuizResponses ?? []) as QuizRow[];
const quizTotal = quizResponses.length;
const quizCorrect = quizResponses.filter((q) => q.is_correct).length;
const quizAccuracy = quizTotal > 0 ? Math.round((quizCorrect / quizTotal) * 100) : 0;

const quizByPersona: Record<string, { total: number; correct: number }> = {};
for (const q of quizResponses) {
  const p = q.persona || 'unknown';
  if (!quizByPersona[p]) quizByPersona[p] = { total: 0, correct: 0 };
  quizByPersona[p].total += 1;
  if (q.is_correct) quizByPersona[p].correct += 1;
}

const quizLast7d = quizResponses.filter(
  (q) => new Date(q.created_at) >= new Date(Date.now() - 7 * 86400000),
).length;

// ─── Content Feedback ───────────────────────────────────────
type FeedbackRow = { reaction: string | null; source_type: string | null; created_at: string };
const feedbackRows = (rawFeedback ?? []) as FeedbackRow[];
const feedbackTotal = feedbackRows.length;
const feedbackPositive = feedbackRows.filter((f) => f.reaction === 'positive').length;
const feedbackNegative = feedbackRows.filter((f) => f.reaction === 'negative').length;

const feedbackBySource: Record<string, { positive: number; negative: number }> = {};
for (const f of feedbackRows) {
  const src = f.source_type || 'unknown';
  if (!feedbackBySource[src]) feedbackBySource[src] = { positive: 0, negative: 0 };
  if (f.reaction === 'positive') feedbackBySource[src].positive += 1;
  else if (f.reaction === 'negative') feedbackBySource[src].negative += 1;
}

// ─── Likes Summary ──────────────────────────────────────────
const totalLikes = (newsLikeCount ?? 0) + (blogLikeCount ?? 0) + (productLikeCount ?? 0);

// ─── User Analytics (UA) ────────────────────────────────────
// DAU/MAU trend: group last_seen_at by date, count unique users per day
const dauTrend: { label: string; dau: number; _date: string }[] = [];
const dauMap = new Map<string, number>();
for (const row of (rawLastSeenData ?? []) as { last_seen_at: string }[]) {
  if (!row.last_seen_at) continue;
  const d = row.last_seen_at.slice(0, 10); // YYYY-MM-DD
  dauMap.set(d, (dauMap.get(d) || 0) + 1);
}
for (const [dateStr, count] of Array.from(dauMap.entries()).sort()) {
  const d = new Date(dateStr + 'T00:00:00');
  dauTrend.push({ label: `${d.getMonth() + 1}/${d.getDate()}`, dau: count, _date: dateStr });
}

// MAU for each day: count users with last_seen_at >= (date - 30 days)
// Compute cumulative MAU per day using sorted last_seen entries
const allSeenDates = (rawLastSeenData ?? []).map((r: any) => r.last_seen_at?.slice(0, 10)).filter(Boolean) as string[];
const mauTrend: number[] = dauTrend.map(({ _date }) => {
  const cutoff = new Date(new Date(_date + 'T00:00:00').getTime() - 30 * 86400000).toISOString().slice(0, 10);
  return allSeenDates.filter(d => d >= cutoff && d <= _date).length;
});

// Current DAU/MAU numbers
const today = new Date().toISOString().slice(0, 10);
const dauToday = dauMap.get(today) || 0;
const mauCutoff = new Date(Date.now() - 30 * 86400000).toISOString().slice(0, 10);
const mauToday = allSeenDates.filter(d => d >= mauCutoff).length;

// Persona distribution
const personaDist: Record<string, number> = { beginner: 0, learner: 0, expert: 0, unset: 0 };
for (const row of (rawPersonaData ?? []) as { persona: string | null }[]) {
  const p = row.persona || 'unset';
  personaDist[p] = (personaDist[p] || 0) + 1;
}

// Learning status breakdown + time series
const learningStatus = { read: 0, learned: 0 };
const learningByDate = new Map<string, { read: number; learned: number }>();
for (const row of (rawLearningStatusData ?? []) as { status: string; created_at: string }[]) {
  if (row.status === 'learned') learningStatus.learned += 1;
  else learningStatus.read += 1;
  const d = row.created_at?.slice(0, 10);
  if (d) {
    if (!learningByDate.has(d)) learningByDate.set(d, { read: 0, learned: 0 });
    const entry = learningByDate.get(d)!;
    if (row.status === 'learned') entry.learned += 1;
    else entry.read += 1;
  }
}
const learningTrend = Array.from(learningByDate.entries()).sort().map(([dateStr, counts]) => {
  const d = new Date(dateStr + 'T00:00:00');
  return { label: `${d.getMonth() + 1}/${d.getDate()}`, ...counts };
});
const learningTotal = learningStatus.read + learningStatus.learned;
const learningConversion = learningTotal > 0 ? Math.round((learningStatus.learned / learningTotal) * 100) : 0;

// Comment activity: merge news + blog comments, group by date
const commentMap = new Map<string, number>();
for (const row of [...(rawNewsComments ?? []), ...(rawBlogComments ?? [])] as { created_at: string }[]) {
  const d = row.created_at?.slice(0, 10);
  if (d) commentMap.set(d, (commentMap.get(d) || 0) + 1);
}
const commentTrend = Array.from(commentMap.entries()).sort().map(([dateStr, count]) => {
  const d = new Date(dateStr + 'T00:00:00');
  return { label: `${d.getMonth() + 1}/${d.getDate()}`, count };
});
const totalComments = (rawNewsComments ?? []).length + (rawBlogComments ?? []).length;

// ─── Popular Content ────────────────────────────────────────
type PopItem = { item_type: string; item_id: string };
const readingItems = (rawReadingItems ?? []) as PopItem[];
const bookmarkItems = (rawBookmarkItems ?? []) as PopItem[];

// Count reads + bookmarks per item (bookmarks count double as stronger signal)
const popularityMap = new Map<string, { type: string; id: string; reads: number; bookmarks: number; score: number }>();
for (const r of readingItems) {
  const key = `${r.item_type}:${r.item_id}`;
  if (!popularityMap.has(key)) popularityMap.set(key, { type: r.item_type, id: r.item_id, reads: 0, bookmarks: 0, score: 0 });
  const entry = popularityMap.get(key)!;
  entry.reads += 1;
  entry.score += 1;
}
for (const b of bookmarkItems) {
  const key = `${b.item_type}:${b.item_id}`;
  if (!popularityMap.has(key)) popularityMap.set(key, { type: b.item_type, id: b.item_id, reads: 0, bookmarks: 0, score: 0 });
  const entry = popularityMap.get(key)!;
  entry.bookmarks += 1;
  entry.score += 2;
}

const topPopular = Array.from(popularityMap.values()).sort((a, b) => b.score - a.score).slice(0, 5);

// Resolve titles for popular items
const titleMap = new Map<string, { title: string; slug: string }>();
if (topPopular.length > 0) {
  const postIds = topPopular.filter((p) => p.type === 'post').map((p) => p.id);
  const termIds = topPopular.filter((p) => p.type === 'term').map((p) => p.id);

  const [postsRes, termsRes] = await Promise.all([
    postIds.length > 0 ? sb.from('news_posts').select('id, title, slug').in('id', postIds) : { data: [] },
    termIds.length > 0 ? sb.from('handbook_terms').select('id, term, slug').in('id', termIds) : { data: [] },
  ]);
  for (const p of (postsRes.data ?? []) as { id: string; title: string; slug: string }[]) {
    titleMap.set(`post:${p.id}`, { title: p.title, slug: `/admin/news/edit/${p.slug}` });
  }
  for (const t of (termsRes.data ?? []) as { id: string; term: string; slug: string }[]) {
    titleMap.set(`term:${t.id}`, { title: t.term, slug: `/admin/handbook/edit/${t.slug}` });
  }
}

const clarityId = import.meta.env.PUBLIC_CLARITY_ID || '';
const ga4PropertyId = import.meta.env.GA4_PROPERTY_ID || '';
const nonce = Astro.locals.cspNonce || '';
---

<MainLayout title="Site Analytics" locale="en">
  <AdminSidebar activeSection="site-analytics" />
  <div class="admin-dashboard">
    <div class="admin-main admin-main--site-analytics">
      <div class="admin-main-header">
        <div class="admin-main-header-top">
          <button class="admin-mobile-menu-btn" id="mobile-menu-btn" type="button" aria-label="Menu">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 5h14M3 10h14M3 15h14" />
            </svg>
          </button>
          <div>
            <p class="sa-eyebrow">Content & Traffic</p>
            <h1 class="admin-main-title">Site Analytics</h1>
            <p class="sa-subtitle">
              Content statistics, visitor analytics, and external tool integrations.
            </p>
          </div>
        </div>
      </div>

      <!-- Brief Cards -->
      <section class="sa-briefs">
        <button class="sa-brief-card sa-brief-card--users" type="button" data-tab-target="traffic" aria-label="View User stats">
          <div class="sa-brief-card__header">
            <svg class="sa-brief-card__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" />
              <path d="M23 21v-2a4 4 0 0 0-3-3.87 M16 3.13a4 4 0 0 1 0 7.75" />
            </svg>
            <h3 class="sa-brief-card__title">Users</h3>
          </div>
          <div class="sa-brief-card__stats">
            <div class="sa-brief-stat">
              <span class="sa-brief-stat__value">{userCount ?? 0}</span>
              <span class="sa-brief-stat__label">Registered</span>
            </div>
            <div class="sa-brief-stat">
              <span class="sa-brief-stat__value">{bookmarkCount ?? 0}</span>
              <span class="sa-brief-stat__label">Bookmarks</span>
            </div>
            <div class="sa-brief-stat">
              <span class="sa-brief-stat__value">{activeUserCount ?? 0}</span>
              <span class="sa-brief-stat__label">Active 7d</span>
            </div>
          </div>
        </button>
        <button class="sa-brief-card sa-brief-card--news" type="button" data-tab-target="news" aria-label="View News details">
          <div class="sa-brief-card__header">
            <svg class="sa-brief-card__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2" />
              <path d="M18 14h-8 M15 18h-5 M10 6h8v4h-8V6Z" />
            </svg>
            <h3 class="sa-brief-card__title">Paper</h3>
          </div>
          <div class="sa-brief-card__stats">
            <div class="sa-brief-stat">
              <span class="sa-brief-stat__value">{newsTotal}</span>
              <span class="sa-brief-stat__label">Posts</span>
            </div>
            <div class="sa-brief-stat">
              <span class="sa-brief-stat__value">{newsPublished}</span>
              <span class="sa-brief-stat__label">Published</span>
            </div>
            <div class="sa-brief-stat">
              <span class="sa-brief-stat__value">{Object.keys(newsByCategory).length}</span>
              <span class="sa-brief-stat__label">Categories</span>
            </div>
          </div>
        </button>
        <button class="sa-brief-card sa-brief-card--handbook" type="button" data-tab-target="handbook" aria-label="View Handbook details">
          <div class="sa-brief-card__header">
            <svg class="sa-brief-card__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20" />
            </svg>
            <h3 class="sa-brief-card__title">Handbook</h3>
          </div>
          <div class="sa-brief-card__stats">
            <div class="sa-brief-stat">
              <span class="sa-brief-stat__value">{handbookTotal}</span>
              <span class="sa-brief-stat__label">Terms</span>
            </div>
            <div class="sa-brief-stat">
              <span class="sa-brief-stat__value">{handbookPublished}</span>
              <span class="sa-brief-stat__label">Published</span>
            </div>
            <div class="sa-brief-stat">
              <span class="sa-brief-stat__value">{handbookFavourites}</span>
              <span class="sa-brief-stat__label">Starred</span>
            </div>
          </div>
        </button>
        <button class="sa-brief-card sa-brief-card--blog" type="button" data-tab-target="blog" aria-label="View Blog details">
          <div class="sa-brief-card__header">
            <svg class="sa-brief-card__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 20h9 M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z" />
            </svg>
            <h3 class="sa-brief-card__title">Blog</h3>
          </div>
          <div class="sa-brief-card__stats">
            <div class="sa-brief-stat">
              <span class="sa-brief-stat__value">{blogTotal}</span>
              <span class="sa-brief-stat__label">Posts</span>
            </div>
            <div class="sa-brief-stat">
              <span class="sa-brief-stat__value">{blogPublished}</span>
              <span class="sa-brief-stat__label">Published</span>
            </div>
            <div class="sa-brief-stat">
              <span class="sa-brief-stat__value">{Object.keys(blogByLocale).length}</span>
              <span class="sa-brief-stat__label">Locales</span>
            </div>
          </div>
        </button>
        <button class="sa-brief-card sa-brief-card--products" type="button" data-tab-target="products" aria-label="View Products details">
          <div class="sa-brief-card__header">
            <svg class="sa-brief-card__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
