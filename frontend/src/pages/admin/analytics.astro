  .sa-tab__dot--news { background: var(--color-accent); }
  .sa-tab__dot--handbook { background: var(--color-success); }
  .sa-tab__dot--blog { background: var(--color-warning); }

  /* ─── Tab Panels ────────────────────────────── */
  .sa-tab-panel { animation: saSlideUp 0.3s ease both; }

  /* ─── Stats Grid ────────────────────────────── */
  .sa-stats-grid {
