    .sa-stats-grid--5 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .sa-brief-card__stats { flex-wrap: wrap; }
    .sa-tab { padding: 0.5rem 0.8rem; font-size: 0.74rem; }
  }

  @media (max-width: 520px) {
    .sa-stats-grid--4,
    .sa-stats-grid--3,
    .sa-stats-grid--5 {
      grid-template-columns: 1fr;
    }
    .sa-section { padding: 0.9rem; }
    .sa-tab__dot { display: none; }
  }
</style>
