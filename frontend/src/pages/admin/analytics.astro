  .sa-tab__dot--traffic { background: #eab308; }
  .sa-tab__dot--news { background: #ef4444; }
  .sa-tab__dot--handbook { background: #10b981; }
  .sa-tab__dot--blog { background: #ec4899; }
  .sa-tab__dot--products { background: #8b5cf6; }

