---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import AdminSidebar from '../../../components/admin/AdminSidebar.astro';
import AdminAiConfig from '../../../components/admin/AdminAiConfig.astro';
import NewsprintShell from '../../../components/newsprint/NewsprintShell.astro';
import NewsprintArticleLayout from '../../../components/newsprint/NewsprintArticleLayout.astro';
import NewsprintSideRail from '../../../components/newsprint/NewsprintSideRail.astro';
import NewsprintNotice from '../../../components/newsprint/NewsprintNotice.astro';
import { getCategoryLabel, getCategoryColorVar, getDefaultCategories, normalizeCategorySlug } from '../../../lib/categories';
import { getArticleFocusItems } from '../../../lib/articleRail';
import { renderMarkdown } from '../../../lib/markdown';
import { createClient } from '@supabase/supabase-js';

const { slug } = Astro.params;
const pageSlug = slug ?? '';
const isNew = pageSlug === 'new';
const startInPreview = Astro.url.searchParams.get('mode') === 'preview';

const accessToken = Astro.locals.accessToken;
let post: any = null;
let fetchError: string | null = null;

if (!accessToken) {
  return Astro.redirect('/admin/login');
}

if (!isNew) {
  try {
    const supabase = createClient(
      import.meta.env.PUBLIC_SUPABASE_URL,
      import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
      { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
    );
    const { data, error } = await supabase
      .from('news_posts')
      .select('*')
      .eq('slug', pageSlug)
      .single();

    if (error && error.code === 'PGRST116') {
      fetchError = '404';
    } else if (error) {
      fetchError = error.message;
    } else {
      post = data;
    }
  } catch (err) {
    fetchError = err instanceof Error ? err.message : 'Unknown error';
  }

  if (!fetchError && !post) {
    fetchError = '404';
  }
}

// Content setup: posts with persona content use 2 editors (v4), others use single editor
const contentLearner = post?.content_learner || '';
const contentExpert = post?.content_expert || '';
const hasPersonaContent = !!(contentLearner || contentExpert);
const editableContent = hasPersonaContent
  ? ''
  : (post?.content_original || '');

const categories = getDefaultCategories();

// Edition label map (same as published page)
const editionMap: Record<string, string> = {
  'ai-news': 'Daily Dispatch',
  study: 'Study Notes',
  career: 'Career Notes',
  project: 'Build Log',
};

// Pre-render initial content and compute derived data for preview
const initialStatus = post?.status || 'draft';
const initialCategory = normalizeCategorySlug(post?.category) || 'ai-news';
const initialEditionLabel = editionMap[initialCategory] || 'Daily Dispatch';
const initialFocusItems = getArticleFocusItems('en', initialCategory);
const initialTitle = post?.title || '';
const initialTags = post?.tags || [];
const previewContent = hasPersonaContent ? (contentLearner || contentExpert) : editableContent;
const initialHtmlContent = post ? await renderMarkdown(previewContent) : '';
const initialWordCount = post ? previewContent.split(/\s+/).length : 0;
const initialReadingTime = Math.max(1, Math.round(initialWordCount / 200));
---

<MainLayout title={isNew ? 'New Post' : (post ? `Edit: ${post.title}` : 'Editor')} locale="en">
  {fetchError === '403' ? (
    <div style="max-width: 800px; margin: 0 auto; padding: 2rem;">
      <NewsprintNotice
        variant="unauthorized"
        message="You do not have permission to access this page."
        linkHref="/"
        linkLabel="Go home"
      />
    </div>
  ) : fetchError === '404' ? (
    <div style="max-width: 800px; margin: 0 auto; padding: 2rem;">
      <NewsprintNotice
        variant="notfound"
        message="This draft does not exist or has been deleted."
        linkHref="/admin"
        linkLabel="Back to Posts"
      />
    </div>
  ) : fetchError ? (
    <div style="max-width: 800px; margin: 0 auto; padding: 2rem;">
      <NewsprintNotice
        variant="notfound"
        message={`Error loading draft: ${fetchError}`}
        linkHref="/admin"
        linkLabel="Back to Posts"
      />
    </div>
  ) : (post || isNew) ? (
    <>
      <AdminSidebar activeSection="posts" />
      <!-- Draft Mode -->
      <div class="admin-editor-layout" id="draft-mode" style={startInPreview ? 'display: none;' : undefined}>
        <div class="admin-editor-topbar">
          <div class="admin-editor-topbar-left">
            <button class="admin-mobile-menu-btn" id="mobile-menu-btn" type="button" aria-label="Menu">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 5h14M3 10h14M3 15h14" />
              </svg>
            </button>
            <a href="/admin/news/" class="admin-editor-back">&larr; Back</a>
            <span class={`admin-status-badge admin-status-badge--${initialStatus}`}>{initialStatus}</span>
          </div>
          <div class="admin-editor-topbar-right">
            <span id="last-saved-time" class="admin-last-saved"></span>
            <button id="btn-ai-toggle" class="admin-ai-panel-toggle" type="button">AI</button>
            <button id="btn-clear" class="admin-btn" type="button">Clear</button>
            <button id="btn-save" class="admin-btn" type="button">Save</button>
            <button id="btn-preview" class="admin-btn" type="button">Preview</button>
            <button id="btn-publish-draft" class="admin-btn admin-btn-primary" type="button">Publish</button>
          </div>
        </div>

        <div class="admin-editor-content">
          <textarea
            id="edit-title"
            class="admin-editor-title"
            rows="1"
            placeholder="Untitled"
          >{post?.title || ''}</textarea>

          <div class="admin-editor-meta">
            <select id="edit-category" class="admin-select" style="width: auto; min-width: 120px;">
              {categories.map((cat) => (
                <option value={cat} selected={cat === post?.category}>
                  {getCategoryLabel('en', cat)}
                </option>
              ))}
            </select>
            <input
              id="edit-tags"
              class="admin-input"
              type="text"
              value={(post?.tags || []).join(', ')}
              placeholder="Tags: tag1, tag2, tag3..."
              style="flex: 1;"
            />
          </div>

          <div style="display:flex;gap:0.75rem;margin-bottom:0.75rem">
            <div style="flex:1">
              <label class="admin-label" for="edit-locale">Locale</label>
              <select id="edit-locale" class="admin-select" style="width:100%;">
                <option value="en" selected={!post?.locale || post?.locale === 'en'}>EN</option>
                <option value="ko" selected={post?.locale === 'ko'}>KO</option>
              </select>
            </div>
            <div style="flex:1">
              <label class="admin-label" for="edit-post-type">Post Type</label>
              <select id="edit-post-type" class="admin-select" style="width:100%;">
                <option value="" selected={!post?.post_type}>—</option>
                <option value="research" selected={post?.post_type === 'research'}>Research</option>
                <option value="business" selected={post?.post_type === 'business'}>Business</option>
              </select>
            </div>
          </div>

          <details class="admin-details">
            <summary>More fields (Slug, Excerpt...)</summary>
            <div class="admin-details-body">
              <div class="admin-editor-meta-row">
                <label class="admin-field-label" for="edit-slug">Slug</label>
                <input id="edit-slug" class="admin-input" type="text" style="flex:1;"
                  value={post?.slug || ''} placeholder="auto-generated-from-title" />
              </div>
              <div class="admin-editor-meta-row">
                <label class="admin-field-label" for="edit-excerpt">Excerpt</label>
                <textarea id="edit-excerpt" class="admin-input" rows="2" style="flex:1;"
                  placeholder="Brief summary for list pages and SEO...">{post?.excerpt || ''}</textarea>
              </div>
              <div class="admin-editor-meta-row">
                <label class="admin-field-label" for="edit-focus-items">Focus Items</label>
                <input id="edit-focus-items" class="admin-input" type="text" style="flex:1;"
                  value={(post?.focus_items || []).join(', ')} placeholder="item1, item2, item3..." />
              </div>
              <div class="admin-editor-meta-row">
                <label class="admin-field-label" for="edit-og-image">OG Image</label>
                <input id="edit-og-image" class="admin-input" type="text" style="flex:1;"
                  value={post?.og_image_url || ''} placeholder="https://..." />
              </div>
            </div>
          </details>

          {hasPersonaContent ? (
            <>
              <div class="admin-lang-tabs">
                <button type="button" class="admin-lang-tab admin-lang-tab--active" data-persona-tab="learner">Learner</button>
                <button type="button" class="admin-lang-tab" data-persona-tab="expert">Expert</button>
              </div>
              <div id="persona-learner" class="admin-editor-wrapper" data-content={contentLearner}></div>
              <div id="persona-expert" class="admin-editor-wrapper" style="display:none;" data-content={contentExpert}></div>
            </>
          ) : (
            <div id="milkdown-editor" class="admin-editor-wrapper" data-content={editableContent}></div>
          )}
          <div id="editor-char-count" class="admin-char-count"></div>

          {!isNew && (
            <div class="admin-danger-zone">
              <div class="admin-danger-zone__label">
                <strong>Danger Zone</strong>
                이 글을 영구 삭제합니다. 복구할 수 없습니다.
              </div>
              <button id="btn-delete" class="admin-btn-danger" type="button">Delete</button>
            </div>
          )}
        </div>

        <div id="admin-feedback" class="admin-feedback admin-feedback--toast" hidden></div>

        <div class="admin-ai-backdrop" id="ai-backdrop"></div>
        <div class="admin-ai-panel" id="ai-panel">
          <div class="admin-ai-panel-header">
            <span class="admin-ai-panel-title">AI Advisor</span>
            <button id="btn-ai-close" class="admin-ai-panel-toggle" type="button">&times;</button>
          </div>
          <div class="admin-ai-actions" id="ai-actions-container">
            <!-- Populated dynamically by JS based on category -->
          </div>
          <div id="ai-loading" class="admin-ai-loading" hidden>
            <span class="ai-spinner"></span>
            <span id="ai-loading-text">Analyzing...</span>
          </div>
          <div id="ai-result" class="admin-ai-result"></div>
        </div>
      </div>

      <!-- Preview Mode (matches published page layout exactly) -->
      <div id="preview-mode" style={startInPreview ? undefined : 'display: none;'}>
        <div class="admin-preview-bar">
          <div class="admin-toolbar-left">
            <a href="/admin/news/" class="admin-editor-back">&larr; Back</a>
          </div>
          <div class="admin-toolbar-right">
            <button id="btn-edit-back" class="admin-btn" type="button">Edit</button>
            <button id="btn-publish-preview" class="admin-btn admin-btn-primary" type="button">Publish</button>
          </div>
        </div>

        <div class="admin-preview-frame-shell" data-preview-shell>
          <div class="admin-preview-frame-loading" data-preview-loading role="status" aria-live="polite" hidden>
            <span class="admin-preview-frame-spinner" aria-hidden="true"></span>
            <span data-preview-loading-text>Loading live preview...</span>
          </div>
          <iframe
            id="preview-iframe"
            class="admin-preview-iframe"
            title="News preview"
            loading="lazy"
          ></iframe>
        </div>
        <div style="display: none;">
        <NewsprintShell
          locale="en"
          masthead="Latest AI News"
          editionLabel={initialEditionLabel}
          subkicker={['AI · Papers', 'Daily Curation', 'Open Access']}
        >
          <div id="preview-content">
            <NewsprintArticleLayout
              locale="en"
              slug={pageSlug}
              showSlug={false}
              title={initialTitle}
              category={initialCategory}
              publishedAt={new Date().toISOString()}
              readingTimeMin={initialReadingTime}
              tags={initialTags}
              htmlContent={initialHtmlContent}
              backLabel="Back to List"
            />
          </div>

          <Fragment slot="rail">
            <NewsprintSideRail locale="en" focusItems={initialFocusItems} />
          </Fragment>
        </NewsprintShell>
        </div>
      </div>
    </>
  ) : (
    <div style="max-width: 800px; margin: 0 auto;">
      <NewsprintNotice
        variant="notfound"
        message="This draft does not exist or has been deleted."
        linkHref="/admin"
        linkLabel="Back to Posts"
      />
    </div>
  )}
  <div id="admin-data" hidden data-post-id={post?.id || ''} data-slug={pageSlug} data-is-new={isNew ? 'true' : 'false'}></div>
  <AdminAiConfig />
</MainLayout>

<script>
  import { Crepe } from '@milkdown/crepe';
  import { replaceAll } from '@milkdown/utils';
  import '@milkdown/crepe/theme/common/style.css';
  import { esc, showFeedback, createButtonManager } from '../../../scripts/adminEditorUtils';
  import { createPreviewManager } from '../../../scripts/adminEditorPreview';

  let crepe: Crepe | null = null;
  const personaEditors: Record<string, Crepe | null> = { learner: null, expert: null };
  let activePersonaTab = 'learner';

  document.addEventListener('DOMContentLoaded', () => {
    // Cleanup previous editor instance(s) (View Transitions re-entry)
    if (crepe) {
      crepe.destroy();
      crepe = null;
    }
    // Cleanup persona editors from previous page
    for (const key of Object.keys(personaEditors)) {
      if (personaEditors[key]) {
        personaEditors[key]!.destroy();
        personaEditors[key] = null;
      }
    }

    const editorEl = document.getElementById('milkdown-editor');
    const personaTabs = document.querySelectorAll<HTMLButtonElement>('[data-persona-tab]');
    const isBusinessEditor = personaTabs.length > 0;
    if (!editorEl && !isBusinessEditor) return; // Not the editor page

    const draftMode = document.getElementById('draft-mode');
    const previewMode = document.getElementById('preview-mode');
    const btnPreview = document.getElementById('btn-preview') as HTMLButtonElement | null;
    const btnEdit = document.getElementById('btn-edit-back') as HTMLButtonElement | null;
    const btnPublish = document.getElementById('btn-publish-preview') as HTMLButtonElement | null;
    const btnSave = document.getElementById('btn-save') as HTMLButtonElement | null;
    const btnDelete = document.getElementById('btn-delete') as HTMLButtonElement | null;
    const btnPublishDraft = document.getElementById('btn-publish-draft') as HTMLButtonElement | null;
    const titleInput = document.getElementById('edit-title') as HTMLTextAreaElement;
    const categorySelect = document.getElementById('edit-category') as HTMLSelectElement;
    const tagsInput = document.getElementById('edit-tags') as HTMLInputElement;
    const slugInput = document.getElementById('edit-slug') as HTMLInputElement;
    const excerptInput = document.getElementById('edit-excerpt') as HTMLTextAreaElement;
    const postTypeSelect = document.getElementById('edit-post-type') as HTMLSelectElement;
    const localeSelect = document.getElementById('edit-locale') as HTMLSelectElement;
    const focusItemsInput = document.getElementById('edit-focus-items') as HTMLInputElement;
    const ogImageInput = document.getElementById('edit-og-image') as HTMLInputElement;
    const adminData = document.getElementById('admin-data');
    const lastSavedEl = document.getElementById('last-saved-time');
    const previewShell = document.querySelector<HTMLElement>('[data-preview-shell]');
    const previewLoading = document.querySelector<HTMLElement>('[data-preview-loading]');
    const previewLoadingText = document.querySelector<HTMLElement>('[data-preview-loading-text]');
    const previewFrame = document.getElementById('preview-iframe') as HTMLIFrameElement | null;
    let postId = adminData?.dataset.postId || '';
    let isNewPost = adminData?.dataset.isNew === 'true';
    let currentSlug = slugInput?.value || adminData?.dataset.slug || '';
    const btnManager = createButtonManager(
      [btnSave, btnPreview, btnPublish, btnPublishDraft, btnDelete, btnEdit]
        .filter((b): b is HTMLButtonElement => b instanceof HTMLButtonElement),
    );
    const preview = createPreviewManager({
      editorPath: '/admin/edit/',
      getSlug: () => currentSlug || adminData?.dataset.slug || '',
      buildPreviewUrl,
      btnManager,
      draftModeEl: draftMode,
      previewModeEl: previewMode,
      previewShell,
      previewLoading,
      previewLoadingText,
      previewFrame,
    });

    // Clear all fields except title and slug
    document.getElementById('btn-clear')?.addEventListener('click', () => {
      if (!confirm('제목을 제외한 모든 필드를 비웁니다. 계속하시겠습니까?')) return;
      if (categorySelect) categorySelect.selectedIndex = 0;
      if (tagsInput) tagsInput.value = '';
      if (localeSelect) localeSelect.selectedIndex = 0;
      if (postTypeSelect) postTypeSelect.selectedIndex = 0;
      if (excerptInput) excerptInput.value = '';
      if (focusItemsInput) focusItemsInput.value = '';
      if (ogImageInput) ogImageInput.value = '';
      if (crepe) crepe.editor.action(replaceAll(''));
      for (const key of Object.keys(personaEditors)) {
        personaEditors[key]?.editor.action(replaceAll(''));
      }
      showFeedback('모든 필드를 비웠습니다.');
    });

    // Auto-resize title textarea
    function autoResizeTitle() {
      if (!titleInput) return;
      titleInput.style.height = 'auto';
      titleInput.style.height = titleInput.scrollHeight + 'px';
    }
    titleInput?.addEventListener('input', autoResizeTitle);
    autoResizeTitle();



    // --- Diff / Undo helpers ---
    const previousValues = new Map<string, string>();

    function getInputForField(field: string): HTMLInputElement | HTMLTextAreaElement | null {
      if (field === 'title') return titleInput;
      if (field === 'excerpt') return excerptInput;
      if (field === 'slug') return slugInput;
      if (field === 'tags') return tagsInput;
      if (field === 'focus_items') return focusItemsInput;
      return null;
    }

    function showDiff(btn: HTMLButtonElement, field: string, newValue: string) {
      const input = getInputForField(field);
      if (!input) return;
      const currentValue = input.value;

      // Replace button with diff UI
      const container = btn.closest('.admin-ai-suggestion') as HTMLElement | null;
      if (!container) return;
      const diffId = `diff-${field}-${Date.now()}`;
      const diffHtml = `<div class="admin-ai-diff" id="${diffId}">` +
        `<div class="admin-ai-diff--del">${esc(currentValue || '(empty)')}</div>` +
        `<div class="admin-ai-diff--add">${esc(newValue)}</div>` +
        `<div class="admin-ai-diff-actions">` +
        `<button class="admin-ai-diff-confirm" type="button">Apply</button>` +
        `<button class="admin-ai-diff-cancel" type="button">Cancel</button>` +
        `</div></div>`;

      btn.hidden = true;
      container.insertAdjacentHTML('beforeend', diffHtml);

      const diffEl = document.getElementById(diffId);
      diffEl?.querySelector('.admin-ai-diff-confirm')?.addEventListener('click', () => {
        previousValues.set(field, currentValue);
        input.value = newValue;
        diffEl.remove();
        btn.hidden = false;
        btn.textContent = 'Undo';
        btn.classList.add('admin-ai-undo-btn');
        btn.onclick = () => {
          const prev = previousValues.get(field);
          if (prev !== undefined) { input.value = prev; previousValues.delete(field); }
          btn.textContent = 'Use';
          btn.classList.remove('admin-ai-undo-btn');
          btn.onclick = null;
          showFeedback(`${field} reverted.`);
        };
        showFeedback(`${field} applied.`);
      });

      diffEl?.querySelector('.admin-ai-diff-cancel')?.addEventListener('click', () => {
        diffEl.remove();
        btn.hidden = false;
      });
    }

    // Initialize Milkdown Crepe (single editor for research posts)
    async function initEditor() {
      if (!editorEl) return;
      const initialContent = editorEl.dataset.content || '';

      crepe = new Crepe({
        root: editorEl,
        defaultValue: initialContent,
        featureConfigs: {
          [Crepe.Feature.Placeholder]: {
            text: 'Start writing your post...',
            mode: 'block',
          },
        },
      });

      await crepe.create();
    }

    // Persona editors (business posts)
    async function initPersonaEditor(persona: string) {
      const el = document.getElementById(`persona-${persona}`);
      if (!el || personaEditors[persona]) return;
      const c = new Crepe({
        root: el,
        defaultValue: el.dataset.content || '',
        featureConfigs: {
          [Crepe.Feature.Placeholder]: {
            text: `${persona.charAt(0).toUpperCase() + persona.slice(1)} content...`,
            mode: 'block',
          },
        },
      });
      await c.create();
      personaEditors[persona] = c;
    }

    function setupPersonaTabs() {
      personaTabs.forEach(btn => {
        btn.addEventListener('click', async () => {
          const p = btn.dataset.personaTab!;
          personaTabs.forEach(b => b.classList.remove('admin-lang-tab--active'));
          btn.classList.add('admin-lang-tab--active');
          (['learner', 'expert'] as const).forEach(k => {
            const el = document.getElementById(`persona-${k}`);
            if (el) el.style.display = k === p ? '' : 'none';
          });
          activePersonaTab = p;
          await initPersonaEditor(p);
        });
      });
    }

    function syncSavedState(saved: { id?: string; slug?: string } | null) {
      if (!saved) return;
      if (saved.id) {
        postId = saved.id;
        if (adminData) adminData.dataset.postId = saved.id;
      }
      if (saved.slug) {
        currentSlug = saved.slug;
        if (slugInput) slugInput.value = saved.slug;
        if (adminData) adminData.dataset.slug = saved.slug;
      }
      if (saved.id || saved.slug) {
        isNewPost = false;
        if (adminData) adminData.dataset.isNew = 'false';
      }
      if (saved.slug) {
        window.history.replaceState(window.history.state, '', preview.getEditorUrl(preview.isPreviewLocation() ? 'preview' : 'draft', saved.slug));
      }
    }

    function buildPreviewUrl() {
      const locale = localeSelect?.value || 'en';
      const slug = (slugInput?.value || currentSlug || '').trim();
      if (!slug) return '';
      const params = new URLSearchParams({
        preview: '1',
        ts: `${Date.now()}`,
      });
      if ((postTypeSelect?.value || '') === 'business') {
        params.set('previewPersona', activePersonaTab);
      }
      return `/${locale}/news/${slug}/?${params.toString()}`;
    }

    // Save draft
    async function handleSave(options: { showFeedback?: boolean; redirectOnCreate?: boolean } = {}) {
      const { showFeedback: shouldShowFeedback = true, redirectOnCreate = true } = options;
      const title = titleInput?.value || '';
      if (!title.trim()) {
        if (shouldShowFeedback) showFeedback('Save failed: title is required.', true);
        return null;
      }
      const category = categorySelect?.value || '';
      const tagsRaw = tagsInput?.value || '';
      const tags = [...new Set(tagsRaw.split(',').map(t => t.trim().toLowerCase()).filter(Boolean))];
      const slug = slugInput?.value || '';
      const excerpt = excerptInput?.value || '';
      const postType = postTypeSelect?.value || '';
      const locale = localeSelect?.value || 'en';
      const focusRaw = focusItemsInput?.value || '';
      const focusItems = focusRaw.split(',').map((s: string) => s.trim()).filter(Boolean);
      const ogImageUrl = ogImageInput?.value || '';

      const saveBody: Record<string, any> = {
        id: isNewPost ? undefined : postId,
        title, slug, category, tags,
        excerpt, post_type: postType, locale, focus_items: focusItems, og_image_url: ogImageUrl,
      };

      if (isBusinessEditor) {
        saveBody.content_learner = personaEditors.learner?.getMarkdown() || '';
        saveBody.content_expert = personaEditors.expert?.getMarkdown() || '';
      } else {
        saveBody.content_original = crepe ? crepe.getMarkdown() : '';
      }

      try {
        const res = await fetch('/api/admin/posts/save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(saveBody),
        });
        if (!res.ok) {
          const err = await res.json();
          throw new Error(err.error || `${res.status}`);
        }
        const saved = await res.json();
        syncSavedState(saved);
        if (shouldShowFeedback) {
          showFeedback(res.status === 201 ? 'Post created.' : 'Draft saved.');
        }
        // Update last-saved timestamp
        if (lastSavedEl) {
          const now = new Date();
          lastSavedEl.textContent = `Last saved: ${now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' })}`;
        }
        if (res.status === 201 && redirectOnCreate && saved?.slug) {
          window.location.href = `/admin/edit/${saved.slug}`;
        }
        return saved;
      } catch (err) {
        if (shouldShowFeedback) {
          showFeedback(`Save failed: ${err instanceof Error ? err.message : 'unknown error'}`, true);
        }
        return null;
      }
    }

    // Auto-save + switch to Preview
    async function switchToPreview() {
      if (btnManager.isPending) return;
      btnManager.begin(btnPreview, 'Saving...');
      const saved = await handleSave({ showFeedback: false, redirectOnCreate: false });
      if (!saved) {
        btnManager.restore();
        showFeedback('Preview failed: save the draft first.', true);
        return;
      }
      const previewUrl = buildPreviewUrl();
      if (!previewUrl) {
        btnManager.restore();
        showFeedback('Preview failed: save a valid slug first.', true);
        return;
      }
      btnManager.setLabel(btnPreview, 'Loading preview...');
      preview.loadFrame(previewUrl, { announce: true, pushHistory: true });
    }

    // Switch back to Draft
    function switchToDraft() {
      if (btnManager.isPending) return;
      if (preview.isPreviewLocation() && preview.enteredFromEditor) {
        history.back();
        return;
      }
      preview.showDraft(true);
    }

    // Publish
    async function handlePublish() {
      const title = titleInput?.value || '';
      if (!title.trim()) {
        showFeedback('Publish failed: title is required.', true);
        return false;
      }
      try {
        const res = await fetch('/api/admin/posts/status', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: postId, action: 'publish' }),
        });
        if (!res.ok) {
          const err = await res.json();
          throw new Error(err.error || `${res.status}`);
        }
        showFeedback('Published! Redirecting...');
        const locale = localeSelect?.value || 'en';
        const slugEl = currentSlug || adminData?.dataset.slug || '';
        setTimeout(() => { window.location.href = `/${locale}/news/${slugEl}/`; }, 1500);
        return true;
      } catch (err) {
        showFeedback(`Publish failed: ${err instanceof Error ? err.message : 'unknown error'}`, true);
        return false;
      }
    }

    // Delete
    async function handleDelete() {
      const title = titleInput?.value || 'this post';
      if (!confirm(`Delete "${title}"? This cannot be undone.`)) return;
      try {
        const res = await fetch('/api/admin/posts/delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: postId }),
        });
        if (res.ok) {
          window.location.href = '/admin';
        } else {
          const err = await res.json();
          showFeedback(`Delete failed: ${err.error}`, true);
        }
      } catch (err) {
        showFeedback(`Delete failed: ${err instanceof Error ? err.message : 'unknown error'}`, true);
      }
    }

    // Publish from draft mode (save first, then publish)
    async function handlePublishFromDraft() {
      const saved = await handleSave({ redirectOnCreate: false });
      if (!saved && !postId) return;
      await handlePublish();
    }

    // AI panel toggle
    const aiToggleBtn = document.getElementById('btn-ai-toggle');
    const aiCloseBtn = document.getElementById('btn-ai-close');
    const editorLayout = document.querySelector('.admin-editor-layout');
    const aiBackdrop = document.getElementById('ai-backdrop');

    function toggleAiPanel() {
      const isMobile = window.innerWidth < 768;
      if (isMobile) {
        const panel = document.getElementById('ai-panel');
        const isOpen = panel?.classList.contains('admin-ai-panel--open');
        panel?.classList.toggle('admin-ai-panel--open', !isOpen);
        aiBackdrop?.classList.toggle('admin-ai-backdrop--visible', !isOpen);
      } else {
        editorLayout?.classList.toggle('admin-editor-layout--collapsed');
      }
    }

    aiToggleBtn?.addEventListener('click', toggleAiPanel);
    aiCloseBtn?.addEventListener('click', toggleAiPanel);
    aiBackdrop?.addEventListener('click', toggleAiPanel);

    // --- AI Advisor ---
    const aiLoadingEl = document.getElementById('ai-loading');
    const aiLoadingText = document.getElementById('ai-loading-text');
    const aiResultEl = document.getElementById('ai-result');
    const aiActionsContainer = document.getElementById('ai-actions-container');

    const CATEGORY_ACTIONS: Record<string, { action: string; label: string; model: string; wide?: boolean }[]> = {
      'ai-news': [
        { action: 'generate', label: 'Generate', model: 'gpt-5' },
        { action: 'seo', label: 'SEO', model: 'gpt-5-nano' },
        { action: 'review', label: 'Review', model: 'gpt-5-nano' },
        { action: 'factcheck', label: 'Fact-check', model: 'gpt-5-mini' },
        { action: 'deepverify', label: 'Deep Verify', model: 'gpt-5-mini + Tavily', wide: true },
      ],
      'study': [
        { action: 'generate', label: 'Generate', model: 'gpt-5' },
        { action: 'seo', label: 'SEO', model: 'gpt-5-nano' },
        { action: 'review', label: 'Review', model: 'gpt-5-nano' },
        { action: 'conceptcheck', label: 'Concept Check', model: 'gpt-5-mini', wide: true },
      ],
      'career': [
        { action: 'generate', label: 'Generate', model: 'gpt-5' },
        { action: 'seo', label: 'SEO', model: 'gpt-5-nano' },
        { action: 'review', label: 'Review', model: 'gpt-5-nano' },
        { action: 'voicecheck', label: 'Voice Check', model: 'gpt-5-nano', wide: true },
      ],
      'project': [
        { action: 'generate', label: 'Generate', model: 'gpt-5' },
        { action: 'seo', label: 'SEO', model: 'gpt-5-nano' },
        { action: 'review', label: 'Review', model: 'gpt-5-nano' },
        { action: 'retrocheck', label: 'Retro Check', model: 'gpt-5-nano', wide: true },
      ],
    };

    let currentAiButtons: HTMLButtonElement[] = [];
    const aiActionLabels = new Map<string, string>();

    function renderAiButtons(category: string) {
      if (!aiActionsContainer) return;
      const actions = CATEGORY_ACTIONS[category] || CATEGORY_ACTIONS['ai-news'];
      aiActionsContainer.innerHTML = '';
      currentAiButtons = [];
      aiActionLabels.clear();

      // Define groups
      const contentActionNames = ['generate', 'seo'];
      const qualityActionNames = ['review', 'factcheck', 'deepverify', 'conceptcheck', 'voicecheck', 'retrocheck'];

      const groups: { label: string; items: typeof actions }[] = [
        { label: 'Content', items: actions.filter(a => contentActionNames.includes(a.action)) },
        { label: 'Quality', items: actions.filter(a => qualityActionNames.includes(a.action)) },
      ];

      for (const group of groups) {
        if (group.items.length === 0) continue;
        const groupEl = document.createElement('div');
        groupEl.className = 'admin-ai-group';
        const labelEl = document.createElement('span');
        labelEl.className = 'admin-ai-group__label';
        labelEl.textContent = group.label;
        groupEl.appendChild(labelEl);

        for (const a of group.items) {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'admin-ai-action-btn' + (a.wide ? ' admin-ai-action-btn--wide' : '');
          btn.dataset.aiAction = a.action;
          btn.textContent = a.label;
          const modelSpan = document.createElement('span');
          modelSpan.className = 'ai-btn-model';
          modelSpan.textContent = a.model;
          btn.appendChild(modelSpan);
          btn.addEventListener('click', () => runAiAction(a.action));
          groupEl.appendChild(btn);
          currentAiButtons.push(btn);
          aiActionLabels.set(a.action, a.label);
        }

        aiActionsContainer.appendChild(groupEl);
      }
    }

    // Render initial buttons based on current category
    renderAiButtons(categorySelect?.value || 'ai-news');

    // Re-render buttons when category changes
    categorySelect?.addEventListener('change', () => {
      renderAiButtons(categorySelect.value);
      if (aiResultEl) aiResultEl.innerHTML = '';
    });

    function setAiLoading(loading: boolean, action?: string) {
      if (aiLoadingEl) aiLoadingEl.hidden = !loading;
      const actionLabel = action ? (aiActionLabels.get(action) || action) : '';
      if (aiLoadingText) aiLoadingText.textContent = loading ? `Running ${actionLabel}...` : '';
      if (aiResultEl && loading) aiResultEl.innerHTML = '';
      currentAiButtons.forEach(btn => {
        btn.disabled = loading;
        const a = btn.dataset.aiAction || '';
        if (loading && a === action) {
          btn.classList.add('admin-ai-action-btn--loading');
          const orig = aiActionLabels.get(a) || a;
          btn.childNodes[0].textContent = `${orig}...`;
          const spinner = document.createElement('span');
          spinner.className = 'ai-btn-spinner';
          btn.prepend(spinner);
        } else {
          btn.classList.remove('admin-ai-action-btn--loading');
          btn.querySelector('.ai-btn-spinner')?.remove();
          const orig = aiActionLabels.get(a);
          if (orig && btn.childNodes[0]) btn.childNodes[0].textContent = orig;
        }
      });
    }

    async function runAiAction(action: string) {
      const title = titleInput?.value || '';
      const content = isBusinessEditor
        ? (personaEditors[activePersonaTab]?.getMarkdown() || '')
        : (crepe ? crepe.getMarkdown() : '');
      if (!title.trim() && !content.trim()) {
        showFeedback('Write some content before using AI Advisor.', true);
        return;
      }

      setAiLoading(true, action);

      const label = aiActionLabels.get(action) || action;
      let elapsed = 0;
      const elapsedTimer = setInterval(() => {
        elapsed++;
        if (aiLoadingText) aiLoadingText.textContent = `Running ${label}... (${elapsed}s)`;
      }, 1000);

      try {
        const _ac = (window as any).__adminAiConfig;
        const _aiUrl = _ac?.fastApiUrl ? `${_ac.fastApiUrl}/api/admin/ai/advise` : '/api/admin/ai/advise';
        const _aiH: Record<string, string> = { 'Content-Type': 'application/json' };
        if (_ac?.accessToken) _aiH['Authorization'] = `Bearer ${_ac.accessToken}`;

        const res = await fetch(_aiUrl, {
          method: 'POST',
          headers: _aiH,
          body: JSON.stringify({
            action,
            post_id: postId || 'new',
            title,
            content,
            category: categorySelect?.value || '',
            tags: [...new Set((tagsInput?.value || '').split(',').map((t: string) => t.trim().toLowerCase()).filter(Boolean))],
            excerpt: excerptInput?.value || '',
            slug: slugInput?.value || '',
            post_type: postTypeSelect?.value || '',
          }),
          signal: AbortSignal.timeout(180_000), // 3min
        });

        if (!res.ok) {
          const err = await res.json().catch(() => ({ detail: res.statusText }));
          const rawMsg = err.detail || err.error || `Error ${res.status}`;
          const msg = typeof rawMsg === 'string' ? rawMsg : JSON.stringify(rawMsg);
          if (res.status === 429) showFeedback('Too many requests. Wait a minute.', true);
          else if (res.status === 504) showFeedback('AI request timed out.', true);
          else if (res.status === 502) showFeedback('AI service unavailable.', true);
          else showFeedback(msg, true);
          setAiLoading(false);
          return;
        }

        const data = await res.json();
        setAiLoading(false);
        renderAiResult(action, data.result);
      } catch (err) {
        setAiLoading(false);
        showFeedback('AI request failed.', true);
      } finally {
        clearInterval(elapsedTimer);
      }
    }

    function renderAiResult(action: string, result: any) {
      if (!aiResultEl) return;
      if (action === 'generate') renderGenerate(result);
      else if (action === 'seo') renderSeo(result);
      else if (action === 'review') renderReview(result);
      else if (action === 'factcheck') renderFactcheck(result);
      else if (action === 'deepverify') renderDeepverify(result);
      else if (action === 'conceptcheck') renderConceptcheck(result);
      else if (action === 'voicecheck') renderVoicecheck(result);
      else if (action === 'retrocheck') renderRetrocheck(result);
    }

    // --- Generate Result ---
    function renderGenerate(r: any) {
      if (!aiResultEl) return;
      let html = '<h4>Generated Metadata</h4>';

      if (r.excerpt) {
        html += `<div class="admin-ai-suggestion"><span class="admin-ai-suggestion-text"><strong>Excerpt:</strong> ${esc(r.excerpt)}</span><button class="admin-ai-apply-btn" data-apply="excerpt">Use</button></div>`;
      }
      if (r.slug) {
        html += `<div class="admin-ai-suggestion"><span class="admin-ai-suggestion-text"><strong>Slug:</strong> ${esc(r.slug)}</span><button class="admin-ai-apply-btn" data-apply="slug">Use</button></div>`;
      }
      if (r.tags?.length) {
        html += `<div class="admin-ai-suggestion"><span class="admin-ai-suggestion-text"><strong>Tags:</strong> ${r.tags.map(esc).join(', ')}</span><button class="admin-ai-apply-btn" data-apply="tags" data-value="${esc(r.tags.join(', '))}">Use</button></div>`;
      }
      if (r.focus_items?.length) {
        html += `<div class="admin-ai-suggestion"><span class="admin-ai-suggestion-text"><strong>Focus Items:</strong> ${r.focus_items.map(esc).join(' · ')}</span><button class="admin-ai-apply-btn" data-apply="focus_items" data-value="${esc(r.focus_items.join(', '))}">Use</button></div>`;
      }
      if (r.guide_items) {
        html += '<h4>Guide Items</h4>';
        const gi = r.guide_items;
        for (const [key, val] of Object.entries(gi)) {
          if (key === 'quiz_poll') continue;
          html += `<div class="admin-ai-suggestion"><span class="admin-ai-suggestion-text"><strong>${esc(key)}:</strong> ${esc(String(val))}</span></div>`;
        }
        if (gi.quiz_poll) {
          const q = gi.quiz_poll;
          html += `<div class="admin-ai-suggestion"><span class="admin-ai-suggestion-text"><strong>Quiz:</strong> ${esc(q.question)} (Answer: ${esc(q.answer)})</span></div>`;
        }
      }

      html += `<button class="admin-ai-apply-all-btn" id="ai-apply-all-generate">Apply All</button>`;
      aiResultEl.innerHTML = html;

      // Bind apply buttons (with diff preview)
      aiResultEl.querySelectorAll<HTMLButtonElement>('.admin-ai-apply-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const field = btn.dataset.apply;
          if (!field) return;
          let newVal = '';
          if (field === 'excerpt') newVal = r.excerpt;
          else if (field === 'slug') newVal = r.slug;
          else if (field === 'tags') newVal = btn.dataset.value || r.tags.join(', ');
          showDiff(btn, field, newVal);
        });
      });

      document.getElementById('ai-apply-all-generate')?.addEventListener('click', () => {
        if (r.excerpt && excerptInput) { previousValues.set('excerpt', excerptInput.value); excerptInput.value = r.excerpt; }
        if (r.slug && slugInput) { previousValues.set('slug', slugInput.value); slugInput.value = r.slug; }
        if (r.tags?.length && tagsInput) { previousValues.set('tags', tagsInput.value); tagsInput.value = r.tags.join(', '); }
        if (r.focus_items?.length && focusItemsInput) { previousValues.set('focus_items', focusItemsInput.value); focusItemsInput.value = r.focus_items.join(', '); }
        showFeedback('All fields applied.');
      });
    }

    // --- SEO Result ---
    function renderSeo(r: any) {
      if (!aiResultEl) return;
      let html = '';

      if (r.title_suggestions?.length) {
        html += '<h4>Title Suggestions</h4>';
        r.title_suggestions.forEach((t: string) => {
          html += `<div class="admin-ai-suggestion"><span class="admin-ai-suggestion-text">${esc(t)}</span><button class="admin-ai-apply-btn" data-apply="title" data-value="${esc(t)}">Use</button></div>`;
        });
      }

      if (r.excerpt_suggestion) {
        html += '<h4>Excerpt</h4>';
        html += `<div class="admin-ai-suggestion"><span class="admin-ai-suggestion-text">${esc(r.excerpt_suggestion)}</span><button class="admin-ai-apply-btn" data-apply="excerpt" data-value="${esc(r.excerpt_suggestion)}">Use</button></div>`;
      }

      if (r.tag_recommendations?.length) {
        html += '<h4>Tag Recommendations</h4>';
        html += `<div class="admin-ai-suggestion"><span class="admin-ai-suggestion-text">${r.tag_recommendations.map(esc).join(', ')}</span><button class="admin-ai-apply-btn" data-apply="tags" data-value="${esc(r.tag_recommendations.join(', '))}">Use</button></div>`;
      }

