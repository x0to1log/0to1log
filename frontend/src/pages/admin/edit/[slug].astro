---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import NewsprintShell from '../../../components/newsprint/NewsprintShell.astro';
import NewsprintArticleLayout from '../../../components/newsprint/NewsprintArticleLayout.astro';
import NewsprintSideRail from '../../../components/newsprint/NewsprintSideRail.astro';
import NewsprintNotice from '../../../components/newsprint/NewsprintNotice.astro';
import { getCategoryLabel, getCategoryColorVar, getDefaultCategories, normalizeCategorySlug } from '../../../lib/categories';
import { getArticleFocusItems } from '../../../lib/articleRail';
import { renderMarkdown } from '../../../lib/markdown';
import { apiFetch } from '../../../lib/api';

const { slug } = Astro.params;
const pageSlug = slug ?? '';

const accessToken = Astro.locals.accessToken;
let draft: any = null;
let fetchError: string | null = null;

try {
  draft = await apiFetch<any>(`/api/admin/drafts/${pageSlug}`, {
    headers: { Authorization: `Bearer ${accessToken}` },
  });
} catch (err) {
  const msg = err instanceof Error ? err.message : 'Unknown error';
  if (msg.includes('401')) {
    return Astro.redirect('/admin/login');
  }
  if (msg.includes('404')) {
    fetchError = '404';
  } else if (msg.includes('403')) {
    fetchError = '403';
  } else {
    fetchError = msg;
  }
}

if (!fetchError && !draft) {
  return Astro.redirect('/admin');
}

const categories = getDefaultCategories();

// Edition label map (same as published page)
const editionMap: Record<string, string> = {
  'ai-news': 'Daily Dispatch',
  study: 'Study Notes',
  career: 'Career Notes',
  project: 'Build Log',
};

// Pre-render initial content and compute derived data for preview
const initialCategory = draft ? (normalizeCategorySlug(draft.category) || '') : '';
const initialEditionLabel = editionMap[initialCategory] || 'Deep Dive';
const initialFocusItems = draft ? getArticleFocusItems('en', draft.category) : [];
const initialHtmlContent = draft ? await renderMarkdown(draft.content_original || '') : '';
const initialWordCount = draft ? (draft.content_original || '').split(/\s+/).length : 0;
const initialReadingTime = Math.max(1, Math.round(initialWordCount / 200));
---

<MainLayout title={draft ? `Edit: ${draft.title}` : 'Editor'} locale="en">
  <div id="fastapi-url-holder" hidden data-url={import.meta.env.FASTAPI_URL || ''}></div>
  {fetchError === '403' ? (
    <div style="max-width: 800px; margin: 0 auto;">
      <NewsprintNotice
        variant="unauthorized"
        message="You do not have permission to access this page."
        linkHref="/"
        linkLabel="Go home"
      />
    </div>
  ) : fetchError === '404' ? (
    <div style="max-width: 800px; margin: 0 auto;">
      <NewsprintNotice
        variant="notfound"
        message="This draft does not exist or has been deleted."
        linkHref="/admin"
        linkLabel="Back to Drafts"
      />
    </div>
  ) : fetchError ? (
    <div style="max-width: 800px; margin: 0 auto;">
      <NewsprintNotice
        variant="notfound"
        message={`Error loading draft: ${fetchError}`}
        linkHref="/admin"
        linkLabel="Back to Drafts"
      />
    </div>
  ) : draft ? (
    <>
      <!-- Draft Mode -->
      <div id="draft-mode">
        <div class="admin-toolbar">
          <div class="admin-toolbar-left">
            <a href="/admin" class="admin-back">&larr; Back to Drafts</a>
          </div>
          <div class="admin-toolbar-right">
            <button id="btn-save" class="admin-btn" type="button">Save Draft</button>
            <button id="btn-preview" class="admin-btn" type="button">Preview</button>
            <form method="POST" action="/api/auth/logout" style="display: inline;">
              <button type="submit" class="admin-btn" style="font-size: 0.85rem;">Logout</button>
            </form>
          </div>
        </div>

        <div id="admin-feedback" class="admin-feedback" hidden>
          <span id="admin-feedback-msg"></span>
          <button class="admin-feedback-dismiss" type="button" aria-label="Dismiss">&times;</button>
        </div>

        <div class="admin-split">
          <div>
            <div class="admin-field">
              <label for="edit-title">Title</label>
              <input
                id="edit-title"
                class="admin-input"
                type="text"
                value={draft.title}
                placeholder="Post title..."
              />
            </div>

            <div style="display: flex; gap: 1rem;">
              <div class="admin-field" style="flex: 1;">
                <label for="edit-category">Category</label>
                <select id="edit-category" class="admin-select">
                  {categories.map((cat) => (
                    <option value={cat} selected={cat === draft.category}>
                      {getCategoryLabel('en', cat)}
                    </option>
                  ))}
                </select>
              </div>
              <div class="admin-field" style="flex: 2;">
                <label for="edit-tags">Tags</label>
                <input
                  id="edit-tags"
                  class="admin-input"
                  type="text"
                  value={(draft.tags || []).join(', ')}
                  placeholder="tag1, tag2, tag3..."
                />
              </div>
            </div>

            <div class="admin-field">
              <label>Content</label>
              <div id="milkdown-editor" class="admin-editor-wrapper" data-content={draft.content_original}></div>
            </div>
          </div>

          <div>
            <div class="admin-panel">
              <div class="admin-panel-title">AI Suggestions</div>
              <p class="admin-panel-placeholder">
                AI suggestion panel will be connected in a future update.
                This panel will show editorial verdicts, accuracy scores,
                and actionable suggestions with one-click apply.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Preview Mode (matches published page layout exactly) -->
      <div id="preview-mode" style="display: none;">
        <div class="admin-preview-bar">
          <div class="admin-toolbar-left">
            <a href="/admin" class="admin-back">&larr; Back to Drafts</a>
          </div>
          <div class="admin-toolbar-right">
            <button id="btn-edit" class="admin-btn" type="button">Edit</button>
            <button id="btn-publish" class="admin-btn admin-btn-primary" type="button">Publish</button>
            <form method="POST" action="/api/auth/logout" style="display: inline;">
              <button type="submit" class="admin-btn" style="font-size: 0.85rem;">Logout</button>
            </form>
          </div>
        </div>

        <NewsprintShell
          locale="en"
          masthead="All About AI"
          editionLabel={initialEditionLabel}
          subkicker={['AI · Papers · Projects', 'Daily Curation', 'Open Access']}
        >
          <div id="preview-content">
            <NewsprintArticleLayout
              locale="en"
              slug={pageSlug}
              showSlug={false}
              title={draft.title}
              category={draft.category}
              publishedAt={new Date().toISOString()}
              readingTimeMin={initialReadingTime}
              tags={draft.tags}
              htmlContent={initialHtmlContent}
              backLabel="Back to List"
            />
          </div>

          <Fragment slot="rail">
            <NewsprintSideRail locale="en" posts={[]} focusItems={initialFocusItems} />
          </Fragment>
        </NewsprintShell>
      </div>
    </>
  ) : (
    <div style="max-width: 800px; margin: 0 auto;">
      <NewsprintNotice
        variant="notfound"
        message="This draft does not exist or has been deleted."
        linkHref="/admin"
        linkLabel="Back to Drafts"
      />
    </div>
  )}
  <div id="admin-data" hidden data-access-token={accessToken} data-post-id={draft?.id} data-slug={pageSlug}></div>
</MainLayout>

<script>
  import { Crepe } from '@milkdown/crepe';
  import '@milkdown/crepe/theme/common/style.css';
  import { marked } from 'marked';

  let crepe: Crepe | null = null;
  let feedbackTimer = 0;

  const editorEl = document.getElementById('milkdown-editor');
  const draftMode = document.getElementById('draft-mode');
  const previewMode = document.getElementById('preview-mode');
  const btnPreview = document.getElementById('btn-preview');
  const btnEdit = document.getElementById('btn-edit');
  const btnPublish = document.getElementById('btn-publish');
  const btnSave = document.getElementById('btn-save');
  const titleInput = document.getElementById('edit-title') as HTMLInputElement;
  const categorySelect = document.getElementById('edit-category') as HTMLSelectElement;
  const tagsInput = document.getElementById('edit-tags') as HTMLInputElement;

  // Maps (must match server-side values)
  const CATEGORY_LABELS: Record<string, string> = {
    'ai-news': 'AI News',
    study: 'Study',
    career: 'Career',
    project: 'Project',
  };

  const EDITION_MAP: Record<string, string> = {
    'ai-news': 'Daily Dispatch',
    study: 'Study Notes',
    career: 'Career Notes',
    project: 'Build Log',
  };

  const FOCUS_MAP: Record<string, string[]> = {
    'ai-news': ['What changed today', 'Why it matters right now', 'What to watch next'],
    study: ['What concept to understand', 'What to remember from this note', 'What to try after reading'],
    career: ['What decision matters here', 'What signal is worth noticing', 'What to apply in actual work'],
    project: ['What was built in this step', 'What tradeoff appeared', 'What to improve next'],
  };

  const DEFAULT_FOCUS = ['Key shift', 'Practical impact', 'Next point to watch'];

  // Feedback banner
  function showFeedback(type: 'success' | 'error', message: string) {
    const el = document.getElementById('admin-feedback');
    const msgEl = document.getElementById('admin-feedback-msg');
    if (!el || !msgEl) return;
    el.classList.remove('admin-feedback--success', 'admin-feedback--error');
    el.classList.add(`admin-feedback--${type}`);
    msgEl.textContent = message;
    el.hidden = false;
    clearTimeout(feedbackTimer);
    feedbackTimer = window.setTimeout(() => { el.hidden = true; }, 3000);
  }

  document.querySelector('.admin-feedback-dismiss')?.addEventListener('click', () => {
    const el = document.getElementById('admin-feedback');
    if (el) el.hidden = true;
    clearTimeout(feedbackTimer);
  });

  // Initialize Milkdown Crepe
  async function initEditor() {
    if (!editorEl) return;

    const initialContent = editorEl.dataset.content || '';

    crepe = new Crepe({
      root: editorEl,
      defaultValue: initialContent,
      featureConfigs: {
        [Crepe.Feature.Placeholder]: {
          text: 'Start writing your post...',
          mode: 'block',
        },
      },
    });

    await crepe.create();
  }

  // Admin data from server
  const adminData = document.getElementById('admin-data');
  const accessToken = adminData?.dataset.accessToken || '';
  const postId = adminData?.dataset.postId || '';

  // Save draft
  async function handleSave() {
    const title = titleInput?.value || '';
    if (!title.trim()) {
      showFeedback('error', 'Save failed: title is required.');
      return;
    }
    const category = categorySelect?.value || '';
    const tagsRaw = tagsInput?.value || '';
    const tags = tagsRaw.split(',').map(t => t.trim()).filter(Boolean);
    const content = crepe ? crepe.getMarkdown() : '';

    try {
      const FASTAPI_URL = document.getElementById('fastapi-url-holder')?.dataset.url || '';
      const res = await fetch(`${FASTAPI_URL}/api/admin/posts/${postId}/update`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${accessToken}`,
        },
        body: JSON.stringify({ title, category, tags, content_original: content }),
      });
      if (!res.ok) throw new Error(`${res.status}`);
      showFeedback('success', 'Draft saved.');
    } catch (err) {
      showFeedback('error', `Save failed: ${err instanceof Error ? err.message : 'unknown error'}`);
    }
  }

  // Auto-save + switch to Preview
  function switchToPreview() {
    if (!crepe) return;

    const markdown = crepe.getMarkdown();
    const title = titleInput?.value || '';
    const category = categorySelect?.value || '';
    const tagsRaw = tagsInput?.value || '';
    const tags = tagsRaw.split(',').map(t => t.trim()).filter(Boolean);

    console.log('Auto-saved draft:', { title, category, tags, content: markdown });
    showFeedback('success', 'Draft auto-saved.');

    // Estimate reading time
    const wordCount = markdown.split(/\s+/).length;
    const readingTime = Math.max(1, Math.round(wordCount / 200));

    const previewContent = document.getElementById('preview-content');
    if (previewContent) {
      // Update title
      const previewTitle = previewContent.querySelector('.newsprint-lead-title');
      if (previewTitle) previewTitle.textContent = title;

      // Update category label (not raw slug)
      const previewCategory = previewContent.querySelector('.newsprint-category');
      if (previewCategory) previewCategory.textContent = CATEGORY_LABELS[category] || category;

      // Update tags
      const headerLeft = previewContent.querySelector('.newsprint-article-header-left');
      if (headerLeft) {
        // Remove existing tags
        headerLeft.querySelectorAll('.newsprint-tag').forEach(el => el.remove());
        // Add new tags
        tags.slice(0, 6).forEach(tag => {
          const span = document.createElement('span');
          span.className = 'newsprint-tag';
          span.textContent = tag;
          headerLeft.appendChild(span);
        });
      }

      // Update reading time and date
      const headerRight = previewContent.querySelector('.newsprint-article-header-right');
      if (headerRight) {
        headerRight.innerHTML = '';
        const readSpan = document.createElement('span');
        readSpan.textContent = `${readingTime} min read`;
        headerRight.appendChild(readSpan);
        const timeEl = document.createElement('time');
        timeEl.dateTime = new Date().toISOString();
        timeEl.textContent = new Date().toLocaleDateString('en-US');
        headerRight.appendChild(timeEl);
      }

      // Update prose content with proper markdown rendering
      const previewProse = previewContent.querySelector('.newsprint-prose');
      if (previewProse) {
        previewProse.innerHTML = marked.parse(markdown) as string;
      }
    }

    // Update edition label in shell header
    const editionEl = previewMode?.querySelector('.newsprint-kicker span:nth-child(2)');
    if (editionEl) {
      editionEl.textContent = EDITION_MAP[category] || 'Deep Dive';
    }

    // Update focus items in side rail
    const focusSection = previewMode?.querySelector('.newsprint-rail section:first-child');
    if (focusSection) {
      const focusTitle = focusSection.querySelector('.newsprint-section-title');
      const focusItems = FOCUS_MAP[category] || DEFAULT_FOCUS;
      // Replace content after the title
      const existingList = focusSection.querySelector('.newsprint-rail-list');
      const existingEmpty = focusSection.querySelector('.newsprint-empty');
      if (existingList) existingList.remove();
      if (existingEmpty) existingEmpty.remove();
      const ul = document.createElement('ul');
      ul.className = 'newsprint-rail-list';
      focusItems.forEach(item => {
        const li = document.createElement('li');
        li.textContent = item;
        ul.appendChild(li);
      });
      focusSection.appendChild(ul);
    }

    if (draftMode) draftMode.style.display = 'none';
    if (previewMode) previewMode.style.display = 'block';
  }

  // Switch back to Draft
  function switchToDraft() {
    if (draftMode) draftMode.style.display = 'block';
    if (previewMode) previewMode.style.display = 'none';
  }

  // Publish
  async function handlePublish() {
    const title = titleInput?.value || '';
    if (!title.trim()) {
      showFeedback('error', 'Publish failed: title is required.');
      return;
    }
    try {
      const FASTAPI_URL = document.getElementById('fastapi-url-holder')?.dataset.url || '';
      const res = await fetch(`${FASTAPI_URL}/api/admin/posts/${postId}/publish`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${accessToken}`,
        },
      });
      if (!res.ok) throw new Error(`${res.status}`);
      const data = await res.json();
      showFeedback('success', 'Published! Redirecting...');
      setTimeout(() => { window.location.href = `/en/log/${data.slug}/`; }, 1500);
    } catch (err) {
      showFeedback('error', `Publish failed: ${err instanceof Error ? err.message : 'unknown error'}`);
    }
  }

  // Event listeners
  btnSave?.addEventListener('click', handleSave);
  btnPreview?.addEventListener('click', switchToPreview);
  btnEdit?.addEventListener('click', switchToDraft);
  btnPublish?.addEventListener('click', handlePublish);

  // Init
  initEditor();
</script>
