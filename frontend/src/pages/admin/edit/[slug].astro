      if (r.missing_labels?.length) {
        html += '<h4>Missing "Unverified" Labels</h4>';
        r.missing_labels.forEach((label: string) => {
          html += `<div class="admin-ai-suggestion"><span class="admin-ai-suggestion-text">${esc(label)}</span></div>`;
        });
      }

      aiResultEl.innerHTML = html;
    }

    // --- Deep Verify Result ---
    function renderDeepverify(r: any) {
      if (!aiResultEl) return;
      let html = '';

      if (r.overall_confidence) {
        html += `<span class="admin-ai-confidence admin-ai-confidence--${r.overall_confidence}">Confidence: ${r.overall_confidence}</span>`;
      }
      if (r.confidence_reason) {
        html += `<p class="admin-ai-confidence-reason">${esc(r.confidence_reason)}</p>`;
      }

      if (r.claims?.length) {
        html += '<h4>Verified Claims</h4>';
        r.claims.forEach((c: any) => {
          html += `<div class="admin-ai-claim"><div class="admin-ai-claim-text">"${esc(c.claim)}"</div><div class="admin-ai-claim-meta"><span class="admin-ai-verdict admin-ai-verdict--${c.verdict}">${c.verdict}</span>`;
          if (c.note) html += `<span>${esc(c.note)}</span>`;
          html += `</div>`;
          if (c.sources?.length) {
            html += `<div class="admin-ai-claim-sources">`;
            c.sources.forEach((src: string) => {
              html += `<a href="${esc(src)}" target="_blank" rel="noopener" class="admin-ai-source-link">${esc(new URL(src).hostname)}</a>`;
            });
            html += `</div>`;
          }
          html += `</div>`;
        });
      }

      if (r.broken_links?.length) {
        html += '<h4>Broken Links</h4>';
        r.broken_links.forEach((bl: any) => {
          const status = bl.status_code ? ` (${bl.status_code})` : '';
          html += `<div class="admin-ai-suggestion"><span class="admin-ai-suggestion-text">${esc(bl.url)}${status} — ${esc(bl.error)}</span></div>`;
        });
      }

      aiResultEl.innerHTML = html;
    }

    // --- Concept Check Result (Study) ---
    function renderConceptcheck(r: any) {
      if (!aiResultEl) return;
      let html = '';

      if (r.overall_accuracy) {
        html += `<span class="admin-ai-confidence admin-ai-confidence--${r.overall_accuracy}">Accuracy: ${r.overall_accuracy}</span>`;
      }
      if (r.depth_assessment) {
        html += `<span class="admin-ai-depth-badge">${r.depth_assessment}</span>`;
      }

      if (r.concepts?.length) {
        html += '<h4>Concepts</h4>';
        const verdictMap: Record<string, string> = { accurate: 'verified', unclear: 'unverified', incorrect: 'no_source' };
        r.concepts.forEach((c: any) => {
          const cssVerdict = verdictMap[c.verdict] || c.verdict;
          html += `<div class="admin-ai-claim"><div class="admin-ai-claim-text">${esc(c.concept)}</div><div class="admin-ai-claim-meta"><span class="admin-ai-verdict admin-ai-verdict--${cssVerdict}">${c.verdict}</span>`;
          if (c.note) html += `<span>${esc(c.note)}</span>`;
          html += `</div>`;
          if (c.suggestion) {
            html += `<div class="admin-ai-checklist-suggestion">${esc(c.suggestion)}</div>`;
          }
          html += `</div>`;
        });
      }

      if (r.missing_concepts?.length) {
        html += '<h4>Missing Concepts</h4>';
        r.missing_concepts.forEach((mc: string) => {
          html += `<div class="admin-ai-suggestion"><span class="admin-ai-suggestion-text">${esc(mc)}</span></div>`;
        });
      }

      aiResultEl.innerHTML = html;
    }

    // --- Voice Check Result (Career) ---
    function renderVoicecheck(r: any) {
      if (!aiResultEl) return;
      let html = '';

      if (r.overall_voice) {
        const voiceMap: Record<string, string> = { authentic: 'high', mixed: 'medium', generic: 'low' };
        html += `<span class="admin-ai-confidence admin-ai-confidence--${voiceMap[r.overall_voice] || 'medium'}">Voice: ${r.overall_voice}</span>`;
      }

      if (r.tone_profile) {
        const tp = r.tone_profile;
        html += '<h4>Tone Profile</h4><div class="admin-ai-tone-profile">';
        for (const [key, val] of Object.entries(tp)) {
          const v = val as number;
          html += `<div class="admin-ai-score-row"><span class="admin-ai-score-label">${esc(key)}</span><div class="admin-ai-score-bar"><div class="admin-ai-score-fill" style="width: ${v}%;"></div></div><span class="admin-ai-score-value">${v}</span></div>`;
        }
        html += '</div>';
      }

      if (r.sections?.length) {
        html += '<h4>Section Analysis</h4>';
        r.sections.forEach((s: any) => {
          const hasIssue = s.issue && s.issue.length > 0;
          const statusClass = hasIssue ? 'warn' : 'pass';
          html += `<div class="admin-ai-checklist-item"><span class="admin-ai-status-badge admin-ai-status-badge--${statusClass}">${hasIssue ? 'warn' : 'pass'}</span><span><strong>${esc(s.section)}</strong>: ${esc(s.assessment)}</span></div>`;
          if (s.suggestion) {
            html += `<div class="admin-ai-checklist-suggestion">${esc(s.suggestion)}</div>`;
          }
        });
      }

      if (r.generic_phrases?.length) {
        html += '<h4>Generic Phrases to Replace</h4>';
        r.generic_phrases.forEach((p: string) => {
          html += `<div class="admin-ai-suggestion"><span class="admin-ai-suggestion-text admin-ai-generic-phrase">"${esc(p)}"</span></div>`;
        });
      }

      aiResultEl.innerHTML = html;
    }

    // --- Retro Check Result (Project) ---
    function renderRetrocheck(r: any) {
      if (!aiResultEl) return;
      let html = '';

      if (r.overall_quality) {
        const qualityMap: Record<string, string> = { 'publication-ready': 'high', 'needs-work': 'medium', 'incomplete': 'low' };
        html += `<span class="admin-ai-confidence admin-ai-confidence--${qualityMap[r.overall_quality] || 'medium'}">Quality: ${r.overall_quality}</span>`;
      }

      // Stats
      html += '<div class="admin-ai-retro-stats">';
      html += `<div class="admin-ai-stat"><span class="admin-ai-stat-value">${r.decisions_documented ?? 0}</span><span class="admin-ai-stat-label">Decisions</span></div>`;
      html += `<div class="admin-ai-stat"><span class="admin-ai-stat-value">${r.lessons_extracted ?? 0}</span><span class="admin-ai-stat-label">Lessons</span></div>`;
      html += `<div class="admin-ai-stat"><span class="admin-ai-stat-value">${r.metrics_included ? 'Yes' : 'No'}</span><span class="admin-ai-stat-label">Metrics</span></div>`;
      html += '</div>';

      if (r.sections?.length) {
        html += '<h4>Section Quality</h4>';
        const statusMap: Record<string, string> = { present: 'pass', weak: 'warn', missing: 'fail' };
        r.sections.forEach((s: any) => {
          const css = statusMap[s.status] || s.status;
          html += `<div class="admin-ai-checklist-item"><span class="admin-ai-status-badge admin-ai-status-badge--${css}">${s.status}</span><span><strong>${esc(s.section)}</strong>: ${esc(s.note)}</span></div>`;
          if (s.suggestion) {
            html += `<div class="admin-ai-checklist-suggestion">${esc(s.suggestion)}</div>`;
          }
        });
      }

      aiResultEl.innerHTML = html;
    }

    previewFrame?.addEventListener('load', () => {
      preview.attachAutoResize();
      preview.setShellLoading(false);
      btnManager.restore();
      if (preview.announceReady) {
        showFeedback('Preview updated.');
        preview.announceReady = false;
      }
    });

    window.addEventListener('popstate', () => preview.syncFromLocation());

    // AI action buttons are bound dynamically in renderAiButtons()

    // Event listeners
    btnSave?.addEventListener('click', async () => {
      if (btnManager.isPending) return;
      btnManager.begin(btnSave, 'Saving...');
      await handleSave();
      btnManager.restore();
    });
    btnPreview?.addEventListener('click', switchToPreview);
    btnEdit?.addEventListener('click', switchToDraft);
    btnPublish?.addEventListener('click', async () => {
      if (btnManager.isPending) return;
      btnManager.begin(btnPublish, 'Publishing...');
      const published = await handlePublish();
      if (!published) btnManager.restore();
    });
    btnDelete?.addEventListener('click', handleDelete);
    btnPublishDraft?.addEventListener('click', async () => {
      if (btnManager.isPending) return;
      btnManager.begin(btnPublishDraft, 'Publishing...');
      const saved = await handleSave({ showFeedback: false, redirectOnCreate: false });
      if (!saved) {
        btnManager.restore();
        showFeedback('Publish failed: save the draft first.', true);
        return;
      }
      const published = await handlePublish();
      if (!published) btnManager.restore();
    });

    // --- Character / word count ---
    const charCountEl = document.getElementById('editor-char-count');
    function updateCharCount() {
      if (!charCountEl) return;
      let md = '';
      if (isBusinessEditor) {
        const activeEditor = personaEditors[activePersonaTab];
        md = activeEditor ? activeEditor.getMarkdown() : '';
      } else {
        md = crepe ? crepe.getMarkdown() : '';
      }
      if (!md || !md.trim()) {
        charCountEl.textContent = '';
        return;
      }
      const chars = md.length;
      const words = md.trim().split(/\s+/).filter(Boolean).length;
      charCountEl.textContent = `${chars} chars / ${words} words`;
    }
    setInterval(updateCharCount, 3000);

    // Init editor(s)
    if (isBusinessEditor) {
      setupPersonaTabs();
      initPersonaEditor('learner'); // init first tab immediately
    } else {
      initEditor();
    }
    preview.syncFromLocation();
  });
</script>
