---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import AdminSidebar from '../../../components/admin/AdminSidebar.astro';
import { createClient } from '@supabase/supabase-js';

const accessToken = Astro.locals.accessToken;
if (!accessToken || !Astro.locals.isAdmin) {
  return Astro.redirect('/admin/');
}

const sb = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
);

const { data: webhooks } = await sb
  .from('webhooks')
  .select('*')
  .order('created_at', { ascending: false });

const hooks = webhooks ?? [];
const nonce = Astro.locals.cspNonce || '';
---

<MainLayout title="Webhooks" locale="en">
  <AdminSidebar activeSection="webhooks" />

  <div class="admin-dashboard">
    <div class="admin-main">
      <div class="admin-main-header">
        <div class="admin-main-header-top">
          <button class="admin-mobile-menu-btn" id="mobile-menu-btn" type="button" aria-label="Menu">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 5h14M3 10h14M3 15h14" />
            </svg>
          </button>
          <div>
            <h1 class="admin-main-title">Webhooks</h1>
            <p style="color: var(--color-text-muted); font-size: 0.82rem; margin: 0.2rem 0 0;">
              Notify Discord, Slack, or custom endpoints when news is published.
            </p>
          </div>
          <button class="admin-btn admin-btn-primary" id="btn-add" type="button" style="margin-left: auto;">+ Add</button>
        </div>
      </div>

      <!-- Setup Guide -->
      <details class="wh-guide" id="webhook-guide">
        <summary class="wh-guide-toggle">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;">
            <circle cx="12" cy="12" r="10" /><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" /><line x1="12" y1="17" x2="12.01" y2="17" />
          </svg>
          Setup Guide
        </summary>
        <div class="wh-guide-body">
          <div class="wh-guide-section">
            <h4 class="wh-guide-heading">Discord</h4>
            <ol class="wh-guide-steps">
              <li>Open the channel you want notifications in</li>
              <li>Click the <strong>gear icon</strong> (Edit Channel)</li>
              <li>Go to <strong>Integrations → Webhooks → New Webhook</strong></li>
              <li>Set name to <code>0to1log</code> (optional)</li>
              <li><strong>Copy Webhook URL</strong></li>
              <li>Paste it here with Platform = <strong>Discord</strong></li>
            </ol>
          </div>
          <div class="wh-guide-section">
            <h4 class="wh-guide-heading">Slack</h4>
            <ol class="wh-guide-steps">
              <li>Go to <strong>api.slack.com/apps</strong> → Create New App</li>
              <li>Enable <strong>Incoming Webhooks</strong></li>
              <li>Click <strong>Add New Webhook to Workspace</strong></li>
              <li>Select the channel → <strong>Allow</strong></li>
              <li>Copy the <strong>Webhook URL</strong></li>
              <li>Paste it here with Platform = <strong>Slack</strong></li>
            </ol>
          </div>
          <div class="wh-guide-section">
            <h4 class="wh-guide-heading">How it works</h4>
            <ul class="wh-guide-steps" style="list-style: none; padding-left: 0;">
              <li>When you <strong>publish</strong> a news post → all active webhooks receive a notification</li>
              <li>Backfill posts (older than 24h) are <strong>skipped automatically</strong></li>
              <li>After <strong>5 consecutive failures</strong>, a webhook is auto-deactivated</li>
              <li>Use the <strong>Test</strong> button to verify your URL works before publishing</li>
            </ul>
          </div>
        </div>
      </details>

      <!-- Filter -->
      <div class="admin-filter-tabs" style="margin-bottom: 1rem;">
        <button class="admin-filter-btn admin-filter-btn--active" data-filter="all">All ({hooks.length})</button>
        <button class="admin-filter-btn" data-filter="active">Active ({hooks.filter(h => h.is_active).length})</button>
        <button class="admin-filter-btn" data-filter="inactive">Inactive ({hooks.filter(h => !h.is_active).length})</button>
      </div>

      <!-- List -->
      {hooks.length === 0 ? (
        <p style="color: var(--color-text-muted); text-align: center; padding: 3rem 0;">
          No webhooks configured. Click "+ Add" to create one.
        </p>
      ) : (
        <ul class="admin-list" id="webhook-list">
          {hooks.map((h) => (
            <li class="admin-list-item" data-id={h.id} data-active={h.is_active ? 'true' : 'false'}
                data-label={h.label} data-url={h.url} data-platform={h.platform}>
              <div class="admin-list-info">
                <h3 class="admin-list-title">
                  <span class={`admin-status-badge ${h.is_active ? 'admin-status-badge--published' : 'admin-status-badge--draft'}`}>
                    {h.is_active ? 'Active' : 'Inactive'}
                  </span>
                  {h.label}
                </h3>
                <div class="admin-list-meta">
                  <span class="admin-source-badge">{h.platform}</span>
                  <span style="opacity: 0.6; font-size: 0.75rem; word-break: break-all;">{h.url.slice(0, 60)}{h.url.length > 60 ? '...' : ''}</span>
                </div>
                {h.fail_count > 0 && (
                  <div class="admin-list-meta" style="margin-top: 0.2rem;">
                    <span style="color: var(--color-error); font-size: 0.75rem;">
                      {h.fail_count} failure{h.fail_count > 1 ? 's' : ''}
                      {h.last_error ? ` — ${h.last_error.slice(0, 80)}` : ''}
                    </span>
                  </div>
                )}
                {h.last_fired_at && (
                  <div class="admin-list-meta" style="margin-top: 0.15rem;">
                    <span style="font-size: 0.72rem; opacity: 0.5;">Last fired: {new Date(h.last_fired_at).toLocaleString()}</span>
                  </div>
                )}
              </div>
              <div class="admin-list-actions" style="display: flex; gap: 0.4rem; flex-wrap: wrap; align-items: center;">
                <button
                  class={`admin-btn admin-btn--sm ${h.is_active ? '' : 'admin-btn-success'}`}
                  data-action="toggle"
                  data-id={h.id}
                  title={h.is_active ? 'Deactivate this webhook' : 'Activate this webhook'}
                >{h.is_active ? 'Deactivate' : 'Activate'}</button>
                <button class="admin-btn admin-btn--sm admin-btn-success" data-action="test" data-id={h.id}>Test</button>
                <button class="admin-btn admin-btn--sm" data-action="edit" data-id={h.id}>Edit</button>
                <button class="admin-btn admin-btn--sm admin-btn-danger" data-action="delete" data-id={h.id}>Delete</button>
              </div>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>

  <!-- Add/Edit Modal -->
  <div class="admin-modal-overlay" id="modal-overlay" hidden>
    <div class="admin-modal admin-modal--sm">
      <div class="admin-modal-header">
        <h2 class="admin-modal-title" id="modal-title">Add Webhook</h2>
        <button class="admin-modal-close" data-action="close-modal">&times;</button>
      </div>
      <div class="admin-modal-body">
        <label class="admin-field-label">Label</label>
        <input class="admin-input" id="field-label" placeholder="e.g. Discord #news" />

        <label class="admin-field-label" style="margin-top: 0.6rem;">Platform</label>
        <select class="admin-input" id="field-platform">
          <option value="discord">Discord</option>
          <option value="slack">Slack</option>
          <option value="custom">Custom</option>
        </select>

        <label class="admin-field-label" style="margin-top: 0.6rem;">Webhook URL</label>
        <input class="admin-input" id="field-url" placeholder="https://discord.com/api/webhooks/..." />
      </div>
      <div class="admin-modal-footer">
        <button class="admin-btn" data-action="close-modal">Cancel</button>
        <button class="admin-btn admin-btn-primary" id="btn-save">Save</button>
      </div>
    </div>
  </div>
</MainLayout>

<script is:inline nonce={nonce}>
(function () {
  var overlay = document.getElementById('modal-overlay');
  var editingId = null;

  // Modal open/close
  document.getElementById('btn-add')?.addEventListener('click', function () {
    editingId = null;
    document.getElementById('modal-title').textContent = 'Add Webhook';
    document.getElementById('field-label').value = '';
    document.getElementById('field-platform').value = 'discord';
    document.getElementById('field-url').value = '';
    overlay.hidden = false;
  });

  document.querySelectorAll('[data-action="close-modal"]').forEach(function (btn) {
    btn.addEventListener('click', function () { overlay.hidden = true; });
  });

  // Save
  document.getElementById('btn-save')?.addEventListener('click', async function () {
    var label = document.getElementById('field-label').value.trim();
    var platform = document.getElementById('field-platform').value;
    var url = document.getElementById('field-url').value.trim();
    if (!label || !url) return alert('Label and URL are required.');

    var body = { label: label, platform: platform, url: url };
    if (editingId) body.id = editingId;

    var res = await fetch('/api/admin/webhooks/save', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });

    if (res.ok) {
      location.reload();
    } else {
      var data = await res.json().catch(function () { return {}; });
      alert(data.error || 'Failed to save webhook.');
    }
  });

  // List actions (delegate)
  document.getElementById('webhook-list')?.addEventListener('click', async function (e) {
    var btn = e.target.closest('[data-action]');
    if (!btn) return;

    var action = btn.dataset.action;
    var id = btn.dataset.id;
    var item = btn.closest('.admin-list-item');

    if (action === 'test') {
      btn.disabled = true;
      btn.textContent = 'Sending...';
      var res = await fetch('/api/admin/webhooks/test', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: id }),
      });
      var data = await res.json().catch(function () { return {}; });
      btn.disabled = false;
      btn.textContent = data.success ? 'Sent!' : 'Failed';
      if (!data.success && data.error) alert('Test failed: ' + data.error);
      setTimeout(function () { btn.textContent = 'Test'; }, 2000);
    }

    if (action === 'edit') {
      editingId = id;
      document.getElementById('modal-title').textContent = 'Edit Webhook';
      document.getElementById('field-label').value = item.dataset.label || '';
      document.getElementById('field-platform').value = item.dataset.platform || 'discord';
      document.getElementById('field-url').value = item.dataset.url || '';
      overlay.hidden = false;
    }

    if (action === 'delete') {
      if (!confirm('Delete this webhook?')) return;
      var res = await fetch('/api/admin/webhooks/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: id }),
      });
      if (res.ok) location.reload();
    }

    if (action === 'toggle') {
      var isActive = item.dataset.active === 'true';
      btn.disabled = true;
      btn.textContent = isActive ? 'Deactivating...' : 'Activating...';
      var res = await fetch('/api/admin/webhooks/save', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: id, label: item.dataset.label, url: item.dataset.url, platform: item.dataset.platform, is_active: !isActive }),
      });
      if (res.ok) location.reload();
      else { btn.disabled = false; btn.textContent = isActive ? 'Deactivate' : 'Activate'; }
    }
  });

  // Filters
  document.querySelectorAll('[data-filter]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var filter = btn.dataset.filter;
      document.querySelectorAll('[data-filter]').forEach(function (b) {
        b.classList.toggle('admin-filter-btn--active', b === btn);
      });
      document.querySelectorAll('#webhook-list .admin-list-item').forEach(function (item) {
        if (filter === 'all') { item.style.display = ''; return; }
        var isActive = item.dataset.active === 'true';
        item.style.display = (filter === 'active') === isActive ? '' : 'none';
      });
    });
  });
})();
</script>

<style>
  .wh-guide {
    margin-bottom: 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-bg-secondary) 60%, transparent);
  }

  .wh-guide-toggle {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.65rem 0.9rem;
    font-family: var(--font-ui);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    cursor: pointer;
    list-style: none;
  }
  .wh-guide-toggle::-webkit-details-marker { display: none; }
  .wh-guide-toggle::after {
    content: '▸';
    margin-left: auto;
    font-size: 0.7rem;
    transition: transform 0.15s;
  }
  .wh-guide[open] .wh-guide-toggle::after { transform: rotate(90deg); }
  .wh-guide-toggle:hover { color: var(--color-text-primary); }

  .wh-guide-body {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
    padding: 0 0.9rem 0.9rem;
  }

  .wh-guide-section {
    padding: 0.7rem;
    border: 1px solid color-mix(in srgb, var(--color-border) 50%, transparent);
    border-radius: var(--radius-md);
  }

  .wh-guide-heading {
    margin: 0 0 0.45rem;
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .wh-guide-steps {
    margin: 0;
    padding-left: 1.3rem;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }
  .wh-guide-steps code {
    font-size: 0.72rem;
    padding: 0.1rem 0.3rem;
    background: var(--color-bg-primary);
    border: 1px solid var(--color-border);
    border-radius: 3px;
  }
  .wh-guide-steps strong {
    color: var(--color-text-primary);
  }

  @media (max-width: 768px) {
    .wh-guide-body { grid-template-columns: 1fr; }
  }
</style>
