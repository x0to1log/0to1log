<script>
  function initDashboardActions(): void {
    const pipelineBtn = document.getElementById('run-pipeline-btn');
    const pipelineFeedback = document.getElementById('run-pipeline-feedback');
    const setPipelineFeedback = (message: string, state?: 'error' | 'success'): void => {
      if (!pipelineFeedback) return;
      pipelineFeedback.textContent = message;
      if (state) {
        pipelineFeedback.dataset.state = state;
      } else {
        delete pipelineFeedback.dataset.state;
      }
    };
    const dateInput = document.getElementById('pipeline-target-date') as HTMLInputElement | null;

    const handbookCheckbox = document.getElementById('include-handbook') as HTMLInputElement | null;

    async function firePipelineRequest(
      mode: string,
      targetDate: string | null,
      force: boolean,
    ): Promise<{ res: Response; payload: any }> {
      const reqBody: Record<string, unknown> = { mode };
      if (targetDate) reqBody.target_date = targetDate;
      if (force) reqBody.force = true;
      if (handbookCheckbox && !handbookCheckbox.checked) reqBody.skip_handbook = true;
      const res = await fetch('/api/admin/run-pipeline', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(reqBody),
      });
      const payload = await res.json().catch(() => null);
      return { res, payload };
    }

    const bindPipelineButton = (
      button: HTMLElement | null,
      idleLabel: string,
      mode: 'resume',
    ): void => {
      if (!button || button.dataset.init === '1') return;
      button.dataset.init = '1';
      button.addEventListener('click', async () => {
        if (pipelineBtn) pipelineBtn.setAttribute('disabled', 'true');
        button.textContent = 'Running...';
        setPipelineFeedback('');
        const targetDate = dateInput?.value || null;
        try {
          let { res, payload } = await firePipelineRequest(mode, targetDate, false);

          // Handle duplicate batch — ask user to confirm overwrite
          if (res.status === 409) {
            const detail = payload?.data?.detail || payload?.detail || payload;
            const existing = detail?.existing || {};
            const msg = `${detail?.batch_id || targetDate || 'today'} already has data:\n`
              + `${existing.post_count ?? '?'} posts, ${existing.run_count ?? '?'} pipeline runs.\n\n`
              + `Overwrite existing data?`;
            if (!window.confirm(msg)) {
              button.textContent = idleLabel;
              setPipelineFeedback('Cancelled — existing data kept.', 'error');
              return;
            }
            // Retry with force=true
            ({ res, payload } = await firePipelineRequest(mode, targetDate, true));
          }

          // Handle published protection
          if (res.status === 422) {
            const detail = payload?.data?.detail || payload?.detail || payload;
            throw new Error(detail?.message || 'Cannot overwrite: published posts exist.');
          }

          if (!res.ok) {
            let message = payload?.error || `HTTP ${res.status}`;
            if (res.status === 401) message = payload?.error || 'Unauthorized';
            else if (res.status === 403) message = payload?.error || 'Admin access required';
            else if (res.status === 500) message = 'Missing pipeline configuration';
            else if (res.status === 503) {
              message = payload?.message || payload?.error || 'Admin verification unavailable';
            }
            else if (res.status === 502) {
              message = payload?.message || payload?.data?.message || 'Backend trigger failed';
            }
            throw new Error(message);
          }
          button.textContent = 'Started';
          const dateLabel = targetDate || 'today';
          setPipelineFeedback(payload?.data?.message || `Pipeline queued for ${dateLabel}.`, 'success');
          setTimeout(() => window.location.reload(), 2000);
        } catch (error) {
          button.textContent = 'Failed';
          const message = error instanceof Error ? error.message : 'Failed to trigger pipeline';
          setPipelineFeedback(message, 'error');
          setTimeout(() => {
            button.textContent = idleLabel;
          }, 3000);
        } finally {
          if (pipelineBtn) pipelineBtn.removeAttribute('disabled');
        }
      });
    };

    bindPipelineButton(pipelineBtn, 'Run Pipeline', 'resume');

    // Retry Handbook button handler
    const retryHandbookBtn = document.getElementById('retry-handbook-btn');
    if (retryHandbookBtn) {
      retryHandbookBtn.addEventListener('click', async () => {
        const batchId = (retryHandbookBtn as HTMLElement & { dataset: DOMStringMap }).dataset.batchId;
        if (!batchId) return;
        retryHandbookBtn.textContent = 'Retrying...';
        retryHandbookBtn.setAttribute('disabled', 'true');
        try {
          const res = await fetch('/api/admin/run-pipeline', {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ mode: 'handbook-extract', target_date: batchId }),
          });
          if (!res.ok) {
            const payload = await res.json().catch(() => null);
            throw new Error(payload?.error || `HTTP ${res.status}`);
          }
          retryHandbookBtn.textContent = 'Started';
          setPipelineFeedback(`Handbook extraction retrying for ${batchId}`, 'success');
          setTimeout(() => window.location.reload(), 2000);
        } catch (error) {
          retryHandbookBtn.textContent = 'Failed';
          const message = error instanceof Error ? error.message : 'Failed to retry handbook';
          setPipelineFeedback(message, 'error');
          setTimeout(() => { retryHandbookBtn.textContent = 'Retry Handbook'; }, 3000);
        }
      });
    }

    // Cancel pipeline button handler
    const cancelBtn = document.getElementById('cancel-pipeline-btn');
    if (cancelBtn) {
      cancelBtn.addEventListener('click', async () => {
        const runId = (cancelBtn as HTMLElement).dataset.runId;
        if (!runId) return;
        cancelBtn.textContent = 'Cancelling...';
        cancelBtn.setAttribute('disabled', 'true');
        try {
          const res = await fetch('/api/admin/pipeline-cancel', {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ run_id: runId }),
          });
          if (!res.ok) throw new Error('Cancel failed');
          setPipelineFeedback('Pipeline cancelled.', 'success');
          setTimeout(() => window.location.reload(), 1500);
        } catch {
          cancelBtn.textContent = 'Failed';
          setTimeout(() => { cancelBtn.textContent = 'Cancel'; }, 2000);
        }
      });
    }

    const markReadBtn = document.getElementById('mark-all-read-btn');
    if (markReadBtn && !markReadBtn.dataset.init) {
      markReadBtn.dataset.init = '1';
      markReadBtn.addEventListener('click', async () => {
        markReadBtn.textContent = 'Updating…';
        try {
          const res = await fetch('/api/admin/notifications-read', {
            method: 'POST',
            credentials: 'same-origin',
          });
          if (!res.ok) throw new Error('Failed');
          markReadBtn.closest('.dashboard-section')?.remove();
        } catch {
          markReadBtn.textContent = 'Failed';
          setTimeout(() => { markReadBtn.textContent = 'Mark all read'; }, 2000);
        }
      });
    }

    // Handbook auto-extract toggle — persists to admin_settings via Supabase REST API
    const autoExtractCheckbox = document.getElementById('handbook-auto-extract') as HTMLInputElement | null;
    if (autoExtractCheckbox && !autoExtractCheckbox.dataset.init) {
      autoExtractCheckbox.dataset.init = '1';
      autoExtractCheckbox.addEventListener('change', async () => {
        const enabled = autoExtractCheckbox.checked;
        try {
          const res = await fetch('/api/admin/settings', {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ key: 'handbook_auto_extract', value: enabled }),
          });
          if (!res.ok) throw new Error('Save failed');
          setPipelineFeedback(`Handbook auto-extract ${enabled ? 'enabled' : 'disabled'} for cron runs.`, 'success');
        } catch {
          autoExtractCheckbox.checked = !enabled; // revert
          setPipelineFeedback('Failed to save setting.', 'error');
        }
      });
    }

    // Weekly Recap button
    const weeklyBtn = document.getElementById('run-weekly-btn') as HTMLButtonElement | null;
    const weekInput = document.getElementById('weekly-target-week') as HTMLInputElement | null;
    const weeklyFeedback = document.getElementById('weekly-pipeline-feedback');
    function setWeeklyFeedback(msg: string, tone: 'success' | 'error') {
      if (weeklyFeedback) {
        weeklyFeedback.textContent = msg;
        weeklyFeedback.className = 'dashboard-pipeline-feedback dashboard-pipeline-feedback--' + tone;
      }
    }
    if (weeklyBtn && !weeklyBtn.dataset.init) {
      weeklyBtn.dataset.init = '1';
      weeklyBtn.addEventListener('click', async () => {
        const weeklyCheckbox = document.getElementById('weekly-enabled') as HTMLInputElement | null;
        if (!weeklyCheckbox?.checked) {
          setWeeklyFeedback('Weekly recap is disabled. Enable it first with the checkbox.', 'error');
          return;
        }
        const weekId = weekInput?.value || null;
        const label = weekId || 'last week';
        if (!confirm(`Generate weekly recap for ${label}?`)) return;
        weeklyBtn.disabled = true;
        weeklyBtn.textContent = 'Generating...';
        try {
          const res = await fetch('/api/admin/run-pipeline', {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ mode: 'weekly', week_id: weekId }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data?.error || 'Failed');
          weeklyBtn.textContent = 'Started';
          setWeeklyFeedback(`Weekly recap started for ${label}.`, 'success');
          setTimeout(() => window.location.reload(), 2000);
        } catch (e) {
          weeklyBtn.textContent = 'Failed';
          setWeeklyFeedback(e instanceof Error ? e.message : 'Failed', 'error');
          setTimeout(() => { weeklyBtn.textContent = 'Generate Weekly'; weeklyBtn.disabled = false; }, 3000);
        }
      });
    }

    // Weekly Recap toggle
    const weeklyCheckbox = document.getElementById('weekly-enabled') as HTMLInputElement | null;
    if (weeklyCheckbox && !weeklyCheckbox.dataset.init) {
      weeklyCheckbox.dataset.init = '1';
      weeklyCheckbox.addEventListener('change', async () => {
        const enabled = weeklyCheckbox.checked;
        try {
          const res = await fetch('/api/admin/settings', {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ key: 'weekly_enabled', value: enabled }),
          });
          if (!res.ok) throw new Error('Save failed');
          if (weeklyBtn) weeklyBtn.disabled = !enabled;
          setWeeklyFeedback(`Weekly Recap ${enabled ? 'enabled' : 'disabled'}.`, 'success');
        } catch {
          weeklyCheckbox.checked = !enabled;
          setWeeklyFeedback('Failed to save setting.', 'error');
        }
      });
    }
  }

  document.addEventListener('astro:page-load', initDashboardActions);
  initDashboardActions();
</script>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js" nonce={nonce}></script>
<script is:inline nonce={nonce} define:vars={{ newsQualityData, hbQualityData }}>
  (function() {
    if (typeof Chart === 'undefined') return;

    var rootStyle = getComputedStyle(document.documentElement);
    var textColor = rootStyle.getPropertyValue('--color-text-muted').trim() || '#888';
    var gridColor = rootStyle.getPropertyValue('--color-border').trim() || '#e5e5e5';

    // ─── News Quality Line Chart ───
    var newsCanvas = document.getElementById('dash-chart-news-quality');
    if (newsCanvas) {
      var research = newsQualityData.filter(function(d) { return d.type === 'research'; });
      var business = newsQualityData.filter(function(d) { return d.type === 'business'; });
      var weekly = newsQualityData.filter(function(d) { return d.type === 'weekly'; });

      if (research.length === 0 && business.length === 0 && weekly.length === 0) {
        newsCanvas.parentElement.innerHTML = '<p style="color:' + textColor + ';font-size:0.82rem;text-align:center;padding:2rem 0">No data yet</p>';
      } else {
        // Unified x-axis: union of all sort keys, sorted chronologically
        var keyMap = {};
        newsQualityData.forEach(function(d) { keyMap[d._sortKey] = d.label; });
        var sortKeys = Object.keys(keyMap).sort();
        var labels = sortKeys.map(function(k) { return keyMap[k]; });

        // Align each series against the unified axis — missing points become null (chart skips)
        function alignSeries(series) {
          var byKey = {};
          series.forEach(function(d) { byKey[d._sortKey] = d.score; });
          return sortKeys.map(function(k) { return byKey[k] != null ? byKey[k] : null; });
        }

        var datasets = [];
        if (research.length > 0) {
          datasets.push({
            label: 'Research', data: alignSeries(research),
            borderColor: '#10b981', backgroundColor: 'rgba(16, 185, 129, 0.1)',
            fill: false, tension: 0.3, pointRadius: 3, spanGaps: true,
          });
        }
        if (business.length > 0) {
          datasets.push({
            label: 'Business', data: alignSeries(business),
            borderColor: '#8b5cf6', backgroundColor: 'rgba(139, 92, 246, 0.1)',
            fill: false, tension: 0.3, pointRadius: 3, spanGaps: true,
          });
        }
        if (weekly.length > 0) {
          datasets.push({
            label: 'Weekly', data: alignSeries(weekly),
            borderColor: '#f59e0b', backgroundColor: 'rgba(245, 158, 11, 0.15)',
            fill: false, tension: 0, pointRadius: 6, pointStyle: 'rectRot',
            borderDash: [4, 4], spanGaps: true,
          });
        }

        var allScores = newsQualityData.map(function(d) { return d.score; });
        var minScore = allScores.length ? Math.max(50, Math.floor((Math.min.apply(null, allScores) - 10) / 10) * 10) : 50;

        new Chart(newsCanvas, {
          type: 'line',
          data: { labels: labels, datasets: datasets },
          options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { labels: { color: textColor, boxWidth: 10, font: { size: 11 } } } },
            scales: {
              x: { ticks: { color: textColor, font: { size: 10 } }, grid: { color: gridColor } },
              y: { min: minScore, max: 100, ticks: { color: textColor, stepSize: 10 }, grid: { color: gridColor } },
            },
          },
        });
      }
    }

    // ─── Handbook Quality Bar Chart ───
    var hbCanvas = document.getElementById('dash-chart-hb-quality');
    if (hbCanvas) {
      var hbData = hbQualityData.slice(-50);

      if (hbData.length === 0) {
        hbCanvas.parentElement.innerHTML = '<p style="color:' + textColor + ';font-size:0.82rem;text-align:center;padding:2rem 0">No data yet</p>';
      } else {
        var hbLabels = hbData.map(function(d) { return d.label; });
        var hbScores = hbData.map(function(d) { return d.score; });
        var hbPointColors = hbScores.map(function(s) {
          return s >= 80 ? 'rgba(90, 142, 93, 0.85)' : s >= 60 ? 'rgba(200, 170, 60, 0.85)' : 'rgba(200, 80, 80, 0.85)';
        });

        // Moving average (window=5)
        var window = 5;
        var movingAvg = hbScores.map(function(_, i) {
          var start = Math.max(0, i - window + 1);
          var slice = hbScores.slice(start, i + 1);
          return Math.round(slice.reduce(function(a, b) { return a + b; }, 0) / slice.length);
        });

        var minScore = Math.max(0, Math.floor((Math.min.apply(null, hbScores) - 10) / 10) * 10);

        new Chart(hbCanvas, {
          type: 'scatter',
          data: {
            labels: hbLabels,
            datasets: [
              {
                label: 'Score',
                data: hbScores.map(function(s, i) { return { x: i, y: s }; }),
                backgroundColor: hbPointColors,
                pointRadius: 5,
                pointHoverRadius: 7,
              },
              {
                label: 'Avg (5)',
                data: movingAvg.map(function(s, i) { return { x: i, y: s }; }),
                type: 'line',
                borderColor: 'rgba(99, 102, 241, 0.7)',
                borderWidth: 2,
                pointRadius: 0,
                tension: 0.4,
                fill: false,
              },
            ],
          },
          options: {
            responsive: true, maintainAspectRatio: false,
            plugins: {
              legend: { labels: { color: textColor, boxWidth: 10, font: { size: 10 } } },
              tooltip: { callbacks: {
                title: function(items) {
                  var idx = items[0].dataIndex;
                  return hbData[idx] ? hbData[idx].term : '';
                },
                label: function(ctx) {
                  return ctx.dataset.label + ': ' + ctx.parsed.y;
                },
              }},
            },
            scales: {
              x: {
                type: 'linear', min: 0, max: hbScores.length - 1,
                ticks: {
                  color: textColor, font: { size: 9 },
                  callback: function(v) { return hbLabels[v] || ''; },
                  maxTicksLimit: 10,
                },
                grid: { color: gridColor },
              },
              y: { min: minScore, max: 100, ticks: { color: textColor, stepSize: 10 }, grid: { color: gridColor } },
            },
          },
        });
      }
    }
  })();
</script>
