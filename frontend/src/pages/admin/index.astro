---
export const prerender = false;
import MainLayout from '../../layouts/MainLayout.astro';
import NewsprintNotice from '../../components/newsprint/NewsprintNotice.astro';
import { apiFetch } from '../../lib/api';

const accessToken = Astro.locals.accessToken;
let drafts: any[] = [];
let fetchError: string | null = null;

try {
  drafts = await apiFetch<any[]>('/api/admin/drafts', {
    headers: { Authorization: `Bearer ${accessToken}` },
  });
} catch (err) {
  const msg = err instanceof Error ? err.message : 'Unknown error';
  if (msg.includes('401')) {
    return Astro.redirect('/admin/login');
  }
  if (msg.includes('403')) {
    fetchError = '403';
  } else {
    fetchError = msg;
  }
}
---

<MainLayout title="Admin Dashboard" locale="en">
  <div style="max-width: 800px; margin: 0 auto;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
      <h1 class="newsprint-masthead" style="font-size: 2rem; text-align: left; margin-bottom: 0;">
        Admin Dashboard
      </h1>
      <form method="POST" action="/api/auth/logout" style="display: inline;">
        <button type="submit" class="admin-btn" style="font-size: 0.85rem;">Logout</button>
      </form>
    </div>

    {fetchError === '403' ? (
      <NewsprintNotice
        variant="unauthorized"
        message="You do not have permission to access this page."
        linkHref="/"
        linkLabel="Go home"
      />
    ) : fetchError ? (
      <NewsprintNotice
        variant="unauthorized"
        message={`Failed to load drafts: ${fetchError}`}
        linkHref="/admin"
        linkLabel="Retry"
      />
    ) : drafts.length === 0 ? (
      <NewsprintNotice
        variant="empty"
        message="No drafts pending. Create a new post to get started."
      />
    ) : (
      <>
        <p class="admin-draft-meta" style="margin-bottom: 1.5rem;">
          {drafts.length} draft{drafts.length !== 1 ? 's' : ''} pending
        </p>

        <ul class="admin-draft-list">
          {drafts.map((draft) => (
            <li class="admin-draft-item">
              <div class="admin-draft-info">
                <div class="admin-draft-title">{draft.title}</div>
                <div class="admin-draft-meta">
                  {draft.category} &middot; {new Date(draft.updated_at).toLocaleDateString('en-US')}
                </div>
              </div>
              <a href={`/admin/edit/${draft.slug}`} class="admin-btn">Edit</a>
            </li>
          ))}
        </ul>
      </>
    )}
  </div>
</MainLayout>
