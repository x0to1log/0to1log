---
export const prerender = false;

import MainLayout from '../../layouts/MainLayout.astro';
import AdminSidebar from '../../components/admin/AdminSidebar.astro';
import { createClient } from '@supabase/supabase-js';
import { formatPipelineError } from '../../lib/admin/pipelineError.js';

const accessToken = Astro.locals.accessToken;
const sb = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
);

let totalPosts = 0;
let totalTerms = 0;
let newsDrafts = 0;
let handbookDrafts = 0;
let totalUsers = 0;
let totalLikes = 0;
let aiPendingCount = 0;
let termsBySource = { manual: 0, pipeline: 0, 'ai-suggested': 0 };
let aiSuggestedTerms: ActivityItem[] = [];

type PipelineRun = {
  id: string;
  run_key: string;
  status: string;
  started_at: string;
  finished_at: string | null;
  last_error: string | null;
};
let lastRun: PipelineRun | null = null;
let lastRunError = '';
let pipelineCost = 0;
let pipelineTokens = 0;
let candidatesTotal = 0;
let candidatesSelected = 0;
let totalBlogPosts = 0;
let blogDrafts = 0;
let monthlyCost = 0;
let monthlyTokens = 0;
let lastHandbookRun: { id: string; run_key: string; status: string; started_at: string; last_error: string | null } | null = null;

type Notification = {
  id: string;
  type: string;
  title: string;
  message: string | null;
  created_at: string;
};
let notifications: Notification[] = [];

type ActivityItem = {
  title: string;
  slug: string;
  type: 'post' | 'term';
  status: string;
  updated_at: string;
  source?: string;
};

let recentActivity: ActivityItem[] = [];
let staleDrafts: ActivityItem[] = [];

try {
  const thirtyDaysAgo = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000).toISOString();
  const [postsRes, termsRes, profilesRes, likesRes, pipelineRes, notifsRes, blogRes, monthlyLogsRes, handbookRunRes] = await Promise.all([
    sb.from('news_posts').select('title, slug, status, updated_at').order('updated_at', { ascending: false }),
    sb.from('handbook_terms').select('term, slug, status, updated_at, source').order('updated_at', { ascending: false }),
    sb.from('profiles').select('id', { count: 'exact', head: true }),
    sb.from('news_likes').select('id', { count: 'exact', head: true }),
    sb.from('pipeline_runs').select('*').order('started_at', { ascending: false }).limit(1),
    sb.from('admin_notifications').select('id, type, title, message, created_at').eq('is_read', false).order('created_at', { ascending: false }).limit(5),
    sb.from('blog_posts').select('id, status'),
    sb.from('pipeline_logs').select('cost_usd, tokens_used').gte('created_at', thirtyDaysAgo),
    sb.from('pipeline_runs')
      .select('id, run_key, status, started_at, last_error')
      .like('run_key', 'handbook-extract-%')
      .order('started_at', { ascending: false })
      .limit(1)
      .maybeSingle(),
  ]);

  const posts = postsRes.data ?? [];
  const terms = termsRes.data ?? [];

  totalPosts = posts.length;
  totalTerms = terms.length;

  newsDrafts = posts.filter((p) => p.status === 'draft').length;
  handbookDrafts = terms.filter((t) => t.status === 'draft').length;
  aiPendingCount = terms.filter((t) => (t.source === 'ai-suggested' || t.source === 'pipeline') && t.status === 'draft').length;

  terms.forEach((t) => {
    const src = (t.source || 'manual') as keyof typeof termsBySource;
    if (src in termsBySource) termsBySource[src] += 1;
    else termsBySource.manual += 1;
  });

  aiSuggestedTerms = terms
    .filter((t) => t.source === 'ai-suggested' && t.status === 'draft')
    .slice(0, 5)
    .map((t) => ({ title: t.term, slug: t.slug, type: 'term' as const, status: t.status, updated_at: t.updated_at, source: t.source }));

  const allItems: ActivityItem[] = [
    ...posts.map((p) => ({ title: p.title, slug: p.slug, type: 'post' as const, status: p.status, updated_at: p.updated_at })),
    ...terms.map((t) => ({ title: t.term, slug: t.slug, type: 'term' as const, status: t.status, updated_at: t.updated_at, source: t.source })),
  ];
  allItems.sort((a, b) => new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime());
  recentActivity = allItems.slice(0, 8);

  const sevenDaysAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString();
  staleDrafts = allItems.filter((item) => item.status === 'draft' && item.updated_at < sevenDaysAgo).slice(0, 5);

  totalUsers = profilesRes.count ?? 0;
  totalLikes = likesRes.count ?? 0;
  const blogs = blogRes.data ?? [];
  totalBlogPosts = blogs.length;
  blogDrafts = blogs.filter((b: any) => b.status === 'draft').length;

  const monthlyLogs = monthlyLogsRes.data ?? [];
  monthlyCost = monthlyLogs.reduce((sum: number, l: any) => sum + (parseFloat(l.cost_usd) || 0), 0);
  monthlyTokens = monthlyLogs.reduce((sum: number, l: any) => sum + (l.tokens_used || 0), 0);

  // Handbook retry
  lastHandbookRun = handbookRunRes.data ?? null;

  // Pipeline
  const runData = pipelineRes.data?.[0] ?? null;
  if (runData) {
    lastRun = runData as PipelineRun;
    lastRunError = formatPipelineError(lastRun.last_error);
    const [logsRes, candidatesRes] = await Promise.all([
      sb.from('pipeline_logs').select('cost_usd, tokens_used').eq('run_id', lastRun.id),
      sb.from('news_candidates').select('status').eq('batch_id', lastRun.run_key),
    ]);
    const logs = logsRes.data ?? [];
    pipelineCost = logs.reduce((sum: number, l: any) => sum + (parseFloat(l.cost_usd) || 0), 0);
    pipelineTokens = logs.reduce((sum: number, l: any) => sum + (l.tokens_used || 0), 0);
    const cands = candidatesRes.data ?? [];
    candidatesTotal = cands.length;
    candidatesSelected = cands.filter((c: any) => c.status === 'selected' || c.status === 'published').length;
  }

  // Notifications
  notifications = (notifsRes.data ?? []) as Notification[];
} catch {}

const showRetryHandbook = lastHandbookRun?.status === 'failed';
const retryBatchId = lastHandbookRun?.run_key?.replace('handbook-extract-', '') ?? '';

function relativeTime(dateStr: string): string {
  const diff = Date.now() - new Date(dateStr).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return `${mins}m ago`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return `${hrs}h ago`;
  const days = Math.floor(hrs / 24);
  if (days < 7) return `${days}d ago`;
  return new Date(dateStr).toLocaleDateString('en-US');
}
---

<MainLayout title="Admin Dashboard" locale="en">
  <AdminSidebar activeSection="dashboard" />

  <div class="admin-dashboard">
    <div class="admin-main">
      <div class="admin-main-header">
        <div class="admin-main-header-top">
          <button class="admin-mobile-menu-btn" id="mobile-menu-btn" type="button" aria-label="Menu">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 5h14M3 10h14M3 15h14" />
            </svg>
          </button>
          <div>
            <h1 class="admin-main-title">Dashboard</h1>
          </div>
        </div>
        <div class="admin-quick-actions">
          <a href="/admin/posts/" class="admin-btn admin-btn-primary">Check News</a>
          <a href="/admin/handbook/edit/new" class="admin-btn">New Term</a>
          <a href="/admin/edit/new" class="admin-btn">New Post</a>
        </div>
      </div>

      <!-- Zone A: 콘텐츠 현황 -->
      <div class="dashboard-stats-zone-a">
        <a href="/admin/posts/" class="dashboard-stat-card">
          <div class="dashboard-stat-label">News</div>
          <div class="dashboard-stat-value">
            {totalPosts}
            {newsDrafts > 0 && <span class="dashboard-stat-draft">/ {newsDrafts}</span>}
          </div>
        </a>
        <a href="/admin/handbook/" class="dashboard-stat-card">
          <div class="dashboard-stat-label">Handbook</div>
          <div class="dashboard-stat-value">
            {totalTerms}
            {handbookDrafts > 0 && <span class="dashboard-stat-draft">/ {handbookDrafts}</span>}
          </div>
        </a>
        <a href="/admin/blog/" class="dashboard-stat-card">
          <div class="dashboard-stat-label">Blog</div>
          <div class="dashboard-stat-value">
            {totalBlogPosts}
            {blogDrafts > 0 && <span class="dashboard-stat-draft">/ {blogDrafts}</span>}
          </div>
        </a>
      </div>

      <!-- Zone B: AI 운영 비용 -->
      <a href="/admin/pipeline-analytics" class="dashboard-ai-cost-card">
        <div class="dashboard-ai-cost-label">AI Cost (this month)</div>
        <div class="dashboard-ai-cost-body">
          <span class="dashboard-ai-cost-main">${monthlyCost.toFixed(2)}</span>
          <span class="dashboard-ai-cost-tokens">{monthlyTokens.toLocaleString()} tokens</span>
        </div>
      </a>

      <!-- Zone C: 사이트 성과 -->
      <div class="dashboard-stats-zone-c">
        <a href="/admin/handbook/" class="dashboard-stat-card dashboard-stat-card--highlight">
          <div class="dashboard-stat-label">AI Review</div>
          <div class="dashboard-stat-value">{aiPendingCount}</div>
        </a>
        <a href="/admin/analytics#traffic" class="dashboard-stat-card dashboard-stat-card--link">
          <div class="dashboard-stat-label">Users</div>
          <div class="dashboard-stat-value">{totalUsers}</div>
        </a>
        <a href="/admin/analytics#traffic" class="dashboard-stat-card dashboard-stat-card--link">
          <div class="dashboard-stat-label">Likes</div>
          <div class="dashboard-stat-value">{totalLikes}</div>
        </a>
      </div>

      <section class="dashboard-section">
        <h2 class="dashboard-section-title">Site Analytics</h2>
        <div class="dashboard-source-row">
          <a href="/admin/handbook/" class="dashboard-source-chip">
            <span class="dashboard-source-label">Manual</span>
            <span class="dashboard-source-count">{termsBySource.manual}</span>
          </a>
          <a href="/admin/handbook/" class="dashboard-source-chip dashboard-source-chip--pipeline">
            <span class="dashboard-source-label">Pipeline</span>
            <span class="dashboard-source-count">{termsBySource.pipeline}</span>
          </a>
          <a href="/admin/handbook/" class="dashboard-source-chip dashboard-source-chip--ai">
            <span class="dashboard-source-label">AI Suggested</span>
            <span class="dashboard-source-count">{termsBySource['ai-suggested']}</span>
          </a>
        </div>
      </section>

      <section class="dashboard-section">
        <h2 class="dashboard-section-title">Pipeline Status</h2>
        {lastRun ? (
          <div class={`dashboard-pipeline dashboard-pipeline--${lastRun.status}`}>
            <div class="dashboard-pipeline-header">
              <span class="dashboard-pipeline-status">
                {lastRun.status === 'success' ? '✓' : lastRun.status === 'failed' ? '✗' : '●'} {lastRun.status}
              </span>
              <span class="dashboard-pipeline-time">{relativeTime(lastRun.started_at)}</span>
            </div>
            <div class="dashboard-pipeline-details">
              {lastRun.finished_at && (
                <span>Duration: {Math.round((new Date(lastRun.finished_at).getTime() - new Date(lastRun.started_at).getTime()) / 1000)}s</span>
              )}
              {candidatesTotal > 0 && (
                <span>Candidates: {candidatesTotal} collected → {candidatesSelected} selected</span>
              )}
              {pipelineCost > 0 && (
                <span>Cost: ${pipelineCost.toFixed(2)} · {pipelineTokens.toLocaleString()} tokens</span>
              )}
            </div>
            {lastRun.status === 'failed' && lastRunError && (
              <div class="dashboard-pipeline-error">{lastRunError}</div>
            )}
            <div class="dashboard-pipeline-actions">
              <input type="date" id="pipeline-target-date" class="admin-input admin-input--date"
                     max={new Date().toISOString().slice(0,10)}
                     title="Leave empty for today" />
              <button type="button" class="admin-btn admin-btn-primary" id="run-pipeline-btn">Run Pipeline</button>
              {showRetryHandbook && (
                <button type="button" class="admin-btn" id="retry-handbook-btn"
                        data-batch-id={retryBatchId}
                        title={`Retry handbook extraction for ${retryBatchId}`}>
                  Retry Handbook
                </button>
              )}
              <a href="/admin/pipeline-runs" class="admin-btn">View pipeline runs</a>
              <span class="dashboard-pipeline-helper">Run Pipeline collects and generates AI news.</span>
              <p class="dashboard-pipeline-feedback" id="run-pipeline-feedback" aria-live="polite"></p>
            </div>
          </div>
        ) : (
          <div class="dashboard-pipeline dashboard-pipeline--none">
            <p class="dashboard-empty">No pipeline runs yet.</p>
            <div class="dashboard-pipeline-actions">
              <input type="date" id="pipeline-target-date" class="admin-input admin-input--date"
                     max={new Date().toISOString().slice(0,10)}
                     title="Leave empty for today" />
              <button type="button" class="admin-btn admin-btn-primary" id="run-pipeline-btn">Run Pipeline</button>
              {showRetryHandbook && (
                <button type="button" class="admin-btn" id="retry-handbook-btn"
                        data-batch-id={retryBatchId}
                        title={`Retry handbook extraction for ${retryBatchId}`}>
                  Retry Handbook
                </button>
              )}
              <a href="/admin/pipeline-runs" class="admin-btn">View pipeline runs</a>
              <span class="dashboard-pipeline-helper">Run Pipeline collects and generates AI news.</span>
              <p class="dashboard-pipeline-feedback" id="run-pipeline-feedback" aria-live="polite"></p>
            </div>
          </div>
        )}
      </section>

      {aiSuggestedTerms.length > 0 && (
        <section class="dashboard-section">
          <h2 class="dashboard-section-title">AI-Suggested Drafts</h2>
          <p class="dashboard-section-hint">Terms created via AI advisor, awaiting review.</p>
          <ul class="dashboard-activity-list">
            {aiSuggestedTerms.map((item) => (
              <li class="dashboard-activity-item">
                <a href={`/admin/handbook/edit/${item.slug}`} class="dashboard-activity-link">
                  <span class="dashboard-activity-type">Term</span>
                  <span class="dashboard-activity-title">{item.title}</span>
                  <span class="admin-source-badge admin-source-badge--ai-suggested">AI</span>
                  <span class="dashboard-activity-time">{relativeTime(item.updated_at)}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {notifications.length > 0 && (
        <section class="dashboard-section">
          <div class="dashboard-section-header">
            <h2 class="dashboard-section-title">Notifications</h2>
            <button type="button" class="admin-btn-text" id="mark-all-read-btn">Mark all read</button>
          </div>
          <ul class="dashboard-activity-list">
            {notifications.map((n) => (
              <li class="dashboard-activity-item">
                <div class="dashboard-notification">
                  <span class="dashboard-notification-icon">
                    {n.type === 'error' ? '⚠' : n.type === 'pipeline' ? '⚙' : '🔔'}
                  </span>
                  <span class="dashboard-notification-title">{n.title}</span>
                  <span class="dashboard-activity-time">{relativeTime(n.created_at)}</span>
                </div>
              </li>
            ))}
          </ul>
        </section>
      )}

      <section class="dashboard-section">
        <h2 class="dashboard-section-title">Recent Activity</h2>
        {recentActivity.length === 0 ? (
          <p class="dashboard-empty">No activity yet. Create your first post or term.</p>
        ) : (
          <ul class="dashboard-activity-list">
            {recentActivity.map((item) => (
              <li class="dashboard-activity-item">
                <a
                  href={item.type === 'post' ? `/admin/edit/${item.slug}` : `/admin/handbook/edit/${item.slug}`}
                  class="dashboard-activity-link"
                >
                  <span class="dashboard-activity-type">{item.type === 'post' ? 'Post' : 'Term'}</span>
                  <span class="dashboard-activity-title">{item.title}</span>
                  <span class={`admin-status-badge admin-status-badge--${item.status}`}>{item.status}</span>
                  {item.source && item.source !== 'manual' && (
                    <span class={`admin-source-badge admin-source-badge--${item.source}`}>
                      {item.source === 'pipeline' ? 'Pipeline' : 'AI'}
                    </span>
                  )}
                  <span class="dashboard-activity-time">{relativeTime(item.updated_at)}</span>
                </a>
              </li>
            ))}
          </ul>
        )}
      </section>

      {staleDrafts.length > 0 && (
        <section class="dashboard-section">
          <h2 class="dashboard-section-title">Drafts Needing Attention</h2>
          <p class="dashboard-section-hint">These drafts haven't been updated in over 7 days.</p>
          <ul class="dashboard-activity-list">
            {staleDrafts.map((item) => (
              <li class="dashboard-activity-item">
                <a
                  href={item.type === 'post' ? `/admin/edit/${item.slug}` : `/admin/handbook/edit/${item.slug}`}
                  class="dashboard-activity-link"
                >
                  <span class="dashboard-activity-type">{item.type === 'post' ? 'Post' : 'Term'}</span>
                  <span class="dashboard-activity-title">{item.title}</span>
                  <span class="dashboard-activity-time">{relativeTime(item.updated_at)}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </div>
  </div>
</MainLayout>

<style>
  .admin-quick-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  /* Zone A — 콘텐츠 현황 */
  .dashboard-stats-zone-a {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .dashboard-stats-zone-a .dashboard-stat-card {
    padding: 1.25rem 1rem;
  }

  .dashboard-stats-zone-a .dashboard-stat-value {
    font-size: 2rem;
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
  }

  .dashboard-stat-draft {
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-text-muted);
  }

  /* Zone B — AI 운영 비용 */
  .dashboard-ai-cost-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
    padding: 0.875rem 1rem;
    text-decoration: none;
    color: inherit;
    margin-bottom: 0.75rem;
    transition: border-color 0.15s;
  }

  .dashboard-ai-cost-card:hover {
    border-color: var(--color-text-muted);
  }

  .dashboard-ai-cost-label {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .dashboard-ai-cost-body {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .dashboard-ai-cost-main {
    font-size: 1.25rem;
    font-weight: 700;
  }

  .dashboard-ai-cost-tokens {
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }

  /* Zone C — 사이트 성과 */
  .dashboard-stats-zone-c {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .dashboard-stat-card {
    border: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
    padding: 1rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
  }

  .dashboard-stat-card:hover {
    border-color: var(--color-text-muted);
  }

  .dashboard-stat-card--link {
    cursor: pointer;
  }

  .dashboard-stat-card--link:hover {
    border-color: var(--color-accent);
    box-shadow: 0 1px 6px var(--color-shadow);
  }

  .dashboard-stat-card--highlight {
    border-color: var(--color-accent, var(--color-border));
  }

  .dashboard-stat-label {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }

  .dashboard-stat-value {
    font-size: 1.5rem;
    font-weight: 700;
  }

  .dashboard-section {
    margin-bottom: 1.5rem;
  }

  .dashboard-section-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .dashboard-section-hint {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .dashboard-empty {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    padding: 1rem 0;
  }

  .dashboard-activity-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .dashboard-activity-item {
    border-bottom: 1px solid var(--color-border);
  }

  .dashboard-activity-item:last-child {
    border-bottom: none;
  }

  .dashboard-activity-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.25rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.1s;
  }

  .dashboard-activity-link:hover {
    background: var(--color-bg-secondary);
  }

  .dashboard-activity-type {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    min-width: 3rem;
  }

  .dashboard-activity-title {
    flex: 1;
    font-size: 0.9rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .dashboard-activity-time {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .dashboard-section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .dashboard-section-header .dashboard-section-title {
    margin-bottom: 0;
  }

  .admin-btn-text {
    background: none;
    border: none;
    color: var(--color-text-muted);
    font-size: 0.78rem;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    text-decoration: underline;
    font-family: inherit;
  }

  .admin-btn-text:hover {
    color: var(--color-text);
  }

  .dashboard-pipeline {
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-border);
    background: var(--color-bg-secondary);
    padding: 1rem;
  }

  .dashboard-pipeline--success {
    border-left-color: var(--color-success);
  }

  .dashboard-pipeline--failed {
    border-left-color: var(--color-error, #c44);
  }

  .dashboard-pipeline--running {
    border-left-color: var(--color-accent, #e90);
  }

  .dashboard-pipeline-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .dashboard-pipeline-status {
    font-weight: 600;
    font-size: 0.9rem;
    text-transform: capitalize;
  }

  .dashboard-pipeline-time {
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  .dashboard-pipeline-details {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .dashboard-pipeline-error {
    font-size: 0.8rem;
    color: var(--color-error, #c44);
    background: var(--color-bg);
    padding: 0.5rem;
    border: 1px solid var(--color-error, #c44);
    margin-bottom: 0.75rem;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .dashboard-pipeline-actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .dashboard-pipeline-feedback {
    margin: 0;
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }

  .dashboard-pipeline-helper {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .admin-input--date {
    font-family: inherit;
    font-size: 0.82rem;
    padding: 0.35rem 0.5rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
  }

  .dashboard-pipeline-feedback[data-state='error'] {
    color: #b42318;
  }

  .dashboard-notification {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.25rem;
  }

  .dashboard-notification-icon {
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  .dashboard-notification-title {
    flex: 1;
    font-size: 0.9rem;
  }

  .dashboard-source-row {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .dashboard-source-chip {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.85rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
    text-decoration: none;
    color: inherit;
    font-size: 0.85rem;
    transition: border-color 0.15s;
  }

  .dashboard-source-chip:hover {
    border-color: var(--color-text-muted);
  }

  .dashboard-source-chip--pipeline {
    border-left: 3px solid var(--color-accent, #0ea5e9);
  }

  .dashboard-source-chip--ai {
    border-left: 3px solid #7c3aed;
  }

  .dashboard-source-label {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  .dashboard-source-count {
    font-weight: 700;
    font-size: 1.1rem;
  }

  @media (max-width: 640px) {
    .dashboard-stats-zone-a .dashboard-stat-card {
      padding: 0.75rem 0.5rem;
    }

    .dashboard-stats-zone-a .dashboard-stat-value {
      font-size: 1.5rem;
    }

    .dashboard-ai-cost-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.35rem;
    }

    .admin-quick-actions {
      flex-direction: row;
    }

    .admin-quick-actions .admin-btn {
      flex: 1;
      justify-content: center;
    }

    .dashboard-activity-link {
      display: grid;
      grid-template-columns: auto 1fr auto;
      grid-template-rows: auto auto;
      gap: 0.2rem 0.5rem;
      padding: 0.65rem 0.25rem;
    }

    .dashboard-activity-type {
      min-width: auto;
      grid-row: 1;
      grid-column: 1;
    }

    .dashboard-activity-title {
      grid-row: 1;
      grid-column: 2 / -1;
    }

    .dashboard-activity-time {
      grid-row: 2;
      grid-column: 2;
    }

    .dashboard-activity-link .admin-status-badge {
      grid-row: 2;
      grid-column: 1;
    }
  }
</style>

<script>
  function initDashboardActions(): void {
    const pipelineBtn = document.getElementById('run-pipeline-btn');
    const pipelineFeedback = document.getElementById('run-pipeline-feedback');
    const setPipelineFeedback = (message: string, state?: 'error' | 'success'): void => {
      if (!pipelineFeedback) return;
      pipelineFeedback.textContent = message;
      if (state) {
        pipelineFeedback.dataset.state = state;
      } else {
        delete pipelineFeedback.dataset.state;
      }
    };
    const dateInput = document.getElementById('pipeline-target-date') as HTMLInputElement | null;

    async function firePipelineRequest(
      mode: string,
      targetDate: string | null,
      force: boolean,
    ): Promise<{ res: Response; payload: any }> {
      const reqBody: Record<string, unknown> = { mode };
      if (targetDate) reqBody.target_date = targetDate;
      if (force) reqBody.force = true;
      const res = await fetch('/api/admin/run-pipeline', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(reqBody),
      });
      const payload = await res.json().catch(() => null);
      return { res, payload };
    }

    const bindPipelineButton = (
      button: HTMLElement | null,
      idleLabel: string,
      mode: 'resume',
    ): void => {
      if (!button || button.dataset.init === '1') return;
      button.dataset.init = '1';
      button.addEventListener('click', async () => {
        if (pipelineBtn) pipelineBtn.setAttribute('disabled', 'true');
        button.textContent = 'Running...';
        setPipelineFeedback('');
        const targetDate = dateInput?.value || null;
        try {
          let { res, payload } = await firePipelineRequest(mode, targetDate, false);

          // Handle duplicate batch — ask user to confirm overwrite
          if (res.status === 409) {
            const detail = payload?.data?.detail || payload?.detail || payload;
            const existing = detail?.existing || {};
            const msg = `${detail?.batch_id || targetDate || 'today'} already has data:\n`
              + `${existing.post_count ?? '?'} posts, ${existing.run_count ?? '?'} pipeline runs.\n\n`
              + `Overwrite existing data?`;
            if (!window.confirm(msg)) {
              button.textContent = idleLabel;
              setPipelineFeedback('Cancelled — existing data kept.', 'error');
              return;
            }
            // Retry with force=true
            ({ res, payload } = await firePipelineRequest(mode, targetDate, true));
          }

          // Handle published protection
          if (res.status === 422) {
            const detail = payload?.data?.detail || payload?.detail || payload;
            throw new Error(detail?.message || 'Cannot overwrite: published posts exist.');
          }

          if (!res.ok) {
            let message = payload?.error || `HTTP ${res.status}`;
            if (res.status === 401) message = payload?.error || 'Unauthorized';
            else if (res.status === 403) message = payload?.error || 'Admin access required';
            else if (res.status === 500) message = 'Missing pipeline configuration';
            else if (res.status === 503) {
              message = payload?.message || payload?.error || 'Admin verification unavailable';
            }
            else if (res.status === 502) {
              message = payload?.message || payload?.data?.message || 'Backend trigger failed';
            }
            throw new Error(message);
          }
          button.textContent = 'Started';
          const dateLabel = targetDate || 'today';
          setPipelineFeedback(payload?.data?.message || `Pipeline queued for ${dateLabel}.`, 'success');
          setTimeout(() => window.location.reload(), 2000);
        } catch (error) {
          button.textContent = 'Failed';
          const message = error instanceof Error ? error.message : 'Failed to trigger pipeline';
          setPipelineFeedback(message, 'error');
          setTimeout(() => {
            button.textContent = idleLabel;
          }, 3000);
        } finally {
          if (pipelineBtn) pipelineBtn.removeAttribute('disabled');
        }
      });
    };

    bindPipelineButton(pipelineBtn, 'Run Pipeline', 'resume');

    // Retry Handbook button handler
    const retryHandbookBtn = document.getElementById('retry-handbook-btn');
    if (retryHandbookBtn) {
      retryHandbookBtn.addEventListener('click', async () => {
        const batchId = (retryHandbookBtn as HTMLElement & { dataset: DOMStringMap }).dataset.batchId;
        if (!batchId) return;
        retryHandbookBtn.textContent = 'Retrying...';
        retryHandbookBtn.setAttribute('disabled', 'true');
        try {
          const res = await fetch('/api/admin/run-pipeline', {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ mode: 'handbook-extract', target_date: batchId }),
          });
          if (!res.ok) {
            const payload = await res.json().catch(() => null);
            throw new Error(payload?.error || `HTTP ${res.status}`);
          }
          retryHandbookBtn.textContent = 'Started';
          setPipelineFeedback(`Handbook extraction retrying for ${batchId}`, 'success');
          setTimeout(() => window.location.reload(), 2000);
        } catch (error) {
          retryHandbookBtn.textContent = 'Failed';
          const message = error instanceof Error ? error.message : 'Failed to retry handbook';
          setPipelineFeedback(message, 'error');
          setTimeout(() => { retryHandbookBtn.textContent = 'Retry Handbook'; }, 3000);
        }
      });
    }

    const markReadBtn = document.getElementById('mark-all-read-btn');
    if (markReadBtn && !markReadBtn.dataset.init) {
      markReadBtn.dataset.init = '1';
      markReadBtn.addEventListener('click', async () => {
        markReadBtn.textContent = 'Updating…';
        try {
          const { createClient } = await import('@supabase/supabase-js');
          const sb = createClient(
            (import.meta as any).env.PUBLIC_SUPABASE_URL,
            (import.meta as any).env.PUBLIC_SUPABASE_ANON_KEY,
          );
          const { data: { session } } = await sb.auth.getSession();
          if (session) {
            await sb.from('admin_notifications').update({ is_read: true }).eq('is_read', false);
          }
          markReadBtn.closest('.dashboard-section')?.remove();
        } catch {
          markReadBtn.textContent = 'Failed';
          setTimeout(() => { markReadBtn.textContent = 'Mark all read'; }, 2000);
        }
      });
    }
  }

  document.addEventListener('astro:page-load', initDashboardActions);
  initDashboardActions();
</script>
