---
export const prerender = false;

import MainLayout from '../../layouts/MainLayout.astro';
import AdminSidebar from '../../components/admin/AdminSidebar.astro';
import { createClient } from '@supabase/supabase-js';
import { formatPipelineError } from '../../lib/admin/pipelineError.js';

const accessToken = Astro.locals.accessToken;
const sb = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
);

let totalPosts = 0;
let totalTerms = 0;
let newsDrafts = 0;
let handbookDrafts = 0;
let totalUsers = 0;
let dau = 0;
let mau = 0;
let totalLikes = 0;
let aiPendingCount = 0;
let termsBySource = { manual: 0, pipeline: 0, 'ai-suggested': 0 };
let aiSuggestedTerms: ActivityItem[] = [];

type PipelineRun = {
  id: string;
  run_key: string;
  status: string;
  started_at: string;
  finished_at: string | null;
  last_error: string | null;
};
let lastRun: PipelineRun | null = null;
let lastRunError = '';
let pipelineCost = 0;
let pipelineTokens = 0;
let candidatesTotal = 0;
let candidatesSelected = 0;
let totalBlogPosts = 0;
let blogDrafts = 0;
let totalProducts = 0;
let monthlyCost = 0;
let monthlyTokens = 0;
let lastHandbookRun: { id: string; run_key: string; status: string; started_at: string; last_error: string | null } | null = null;

type Notification = {
  id: string;
  type: string;
  title: string;
  message: string | null;
  created_at: string;
};
let notifications: Notification[] = [];

type ActivityItem = {
  title: string;
  slug: string;
  type: 'post' | 'term';
  status: string;
  updated_at: string;
  source?: string;
  quality_score?: number | null;
};

let recentActivity: ActivityItem[] = [];
let staleDrafts: ActivityItem[] = [];
let handbookAutoExtract = true;
let weeklyEnabled = false;
let newsQualityData: { label: string; score: number; type: string; _sortKey: string }[] = [];
let hbQualityData: { term: string; score: number; label: string }[] = [];

try {
  const thirtyDaysAgo = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000).toISOString();
  // All queries in a single parallel batch (eliminates waterfall)
  const [postsRes, termsRes, profilesRes, likesRes, pipelineRes, notifsRes,
         blogTotalRes, blogDraftRes, monthlyLogsRes, handbookRunRes,
         pipelineLogsRes, candidatesRes, settingsRes, weeklySettingsRes, productsRes,
         newsQualityRes, hbQualityRes, dauRes, mauRes] = await Promise.all([
    sb.from('news_posts').select('title, slug, status, updated_at, quality_score, locale').order('updated_at', { ascending: false }),
    sb.from('handbook_terms').select('term, slug, status, updated_at, source').order('updated_at', { ascending: false }),
    sb.from('profiles').select('id', { count: 'exact', head: true }),
    sb.from('news_likes').select('id', { count: 'exact', head: true }),
    sb.from('pipeline_runs').select('*').order('started_at', { ascending: false }).limit(1),
    sb.from('admin_notifications').select('id, type, title, message, created_at').eq('is_read', false).order('created_at', { ascending: false }).limit(5),
    // Blog: count queries instead of full fetch
    sb.from('blog_posts').select('id', { count: 'exact', head: true }),
    sb.from('blog_posts').select('id', { count: 'exact', head: true }).eq('status', 'draft'),
    sb.from('pipeline_logs').select('cost_usd, tokens_used').gte('created_at', thirtyDaysAgo),
    sb.from('pipeline_runs')
      .select('id, run_key, status, started_at, last_error')
      .like('run_key', 'handbook-extract-%')
      .order('started_at', { ascending: false })
      .limit(1)
      .maybeSingle(),
    // Pipeline detail: eagerly fetch (filter client-side by run_id)
    sb.from('pipeline_logs').select('cost_usd, tokens_used, run_id').order('created_at', { ascending: false }).limit(100),
    sb.from('news_candidates').select('status, batch_id').order('created_at', { ascending: false }).limit(200),
    sb.from('admin_settings').select('value').eq('key', 'handbook_auto_extract').maybeSingle(),
    sb.from('admin_settings').select('value').eq('key', 'weekly_enabled').maybeSingle(),
    sb.from('ai_products').select('id', { count: 'exact', head: true }),
    // Quality score data for dashboard charts
    sb.from('pipeline_logs')
      .select('debug_meta, pipeline_type, pipeline_runs!inner(run_key, started_at)')
      .gte('pipeline_runs.started_at', thirtyDaysAgo)
      .in('pipeline_type', ['quality:research', 'quality:business', 'quality:weekly'])
      .order('created_at', { ascending: true })
      .limit(150),
    sb.from('pipeline_logs')
      .select('debug_meta, pipeline_type, created_at')
      .eq('pipeline_type', 'handbook.quality_check')
      .gte('created_at', thirtyDaysAgo)
      .order('created_at', { ascending: true })
      .limit(100),
    // DAU/MAU
    sb.from('profiles').select('id', { count: 'exact', head: true })
      .gte('last_seen_at', new Date(new Date().setUTCHours(0,0,0,0)).toISOString()),
    sb.from('profiles').select('id', { count: 'exact', head: true })
      .gte('last_seen_at', new Date(Date.now() - 30 * 24 * 60 * 60 * 1000).toISOString()),
  ]);

  const posts = postsRes.data ?? [];
  const terms = termsRes.data ?? [];

  totalPosts = posts.length;
  totalTerms = terms.length;

  newsDrafts = posts.filter((p) => p.status === 'draft').length;
  handbookDrafts = terms.filter((t) => t.status === 'draft').length;
  aiPendingCount = terms.filter((t) => (t.source === 'ai-suggested' || t.source === 'pipeline') && t.status === 'draft').length;

  terms.forEach((t) => {
    const src = (t.source || 'manual') as keyof typeof termsBySource;
    if (src in termsBySource) termsBySource[src] += 1;
    else termsBySource.manual += 1;
  });

  aiSuggestedTerms = terms
    .filter((t) => t.source === 'ai-suggested' && t.status === 'draft')
    .slice(0, 5)
    .map((t) => ({ title: t.term, slug: t.slug, type: 'term' as const, status: t.status, updated_at: t.updated_at, source: t.source }));

  // Admin settings
  if (settingsRes.data) {
    handbookAutoExtract = settingsRes.data.value !== false;
  }
  if (weeklySettingsRes.data) {
    weeklyEnabled = weeklySettingsRes.data.value === true;
  }

  totalProducts = productsRes.count ?? 0;

  // Convert ISO week (e.g. 2026-W15) to the Monday of that week
  function isoWeekToMonday(year: number, week: number): Date {
    const jan4 = new Date(Date.UTC(year, 0, 4));
    const jan4Dow = jan4.getUTCDay() || 7;
    const firstMonday = new Date(jan4.getTime() - (jan4Dow - 1) * 86400000);
    return new Date(firstMonday.getTime() + (week - 1) * 7 * 86400000);
  }

  // News quality chart data (research / business / weekly)
  for (const q of (newsQualityRes.data ?? []) as any[]) {
    const meta = (q.debug_meta ?? {}) as Record<string, unknown>;
    const score = typeof meta.quality_score === 'number' ? meta.quality_score : typeof meta.score === 'number' ? meta.score : null;
    if (score === null) continue;
    // Use run_key date (news target date), not started_at (pipeline execution time)
    const runKey = q.pipeline_runs.run_key || '';
    const dateMatch = runKey.match(/(\d{4}-\d{2}-\d{2})/);
    const weekMatch = runKey.match(/^weekly-(\d{4})-W(\d{1,2})$/);
    let d: Date;
    let sortKey: string;
    let label: string;
    if (dateMatch) {
      d = new Date(dateMatch[1] + 'T00:00:00');
      sortKey = dateMatch[1];
      label = `${d.getMonth() + 1}/${d.getDate()}`;
    } else if (weekMatch) {
      d = isoWeekToMonday(parseInt(weekMatch[1], 10), parseInt(weekMatch[2], 10));
      sortKey = d.toISOString().slice(0, 10);
      label = `W${weekMatch[2]}`;
    } else {
      d = new Date(q.pipeline_runs.started_at);
      sortKey = q.pipeline_runs.started_at;
      label = `${d.getMonth() + 1}/${d.getDate()}`;
    }
    newsQualityData.push({
      label,
      score,
      type: q.pipeline_type.replace('quality:', ''),
      _sortKey: sortKey,
    });
  }
  newsQualityData.sort((a, b) => a._sortKey.localeCompare(b._sortKey));

  // Handbook quality chart data
  for (const q of (hbQualityRes.data ?? []) as any[]) {
    const meta = (q.debug_meta ?? {}) as Record<string, unknown>;
    const score = typeof meta.quality_score === 'number' ? meta.quality_score : null;
    if (score === null) continue;
    const dt = new Date(q.created_at);
    hbQualityData.push({
      term: (meta.term as string) || 'unknown',
      score,
      label: `${dt.getMonth() + 1}/${dt.getDate()}`,
    });
  }

  const allItems: ActivityItem[] = [
    ...posts.filter((p) => p.locale !== 'ko').map((p) => ({ title: p.title, slug: p.slug, type: 'post' as const, status: p.status, updated_at: p.updated_at, quality_score: p.quality_score })),
    ...terms.map((t) => ({ title: t.term, slug: t.slug, type: 'term' as const, status: t.status, updated_at: t.updated_at, source: t.source })),
  ];
  allItems.sort((a, b) => new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime());
  recentActivity = allItems.slice(0, 8);

  const sevenDaysAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString();
  staleDrafts = allItems.filter((item) => item.status === 'draft' && item.updated_at < sevenDaysAgo).slice(0, 5);

  totalUsers = profilesRes.count ?? 0;
  dau = dauRes.count ?? 0;
  mau = mauRes.count ?? 0;
  totalLikes = likesRes.count ?? 0;
  totalBlogPosts = blogTotalRes.count ?? 0;
  blogDrafts = blogDraftRes.count ?? 0;

  const monthlyLogs = monthlyLogsRes.data ?? [];
  monthlyCost = monthlyLogs.reduce((sum: number, l: any) => sum + (parseFloat(l.cost_usd) || 0), 0);
  monthlyTokens = monthlyLogs.reduce((sum: number, l: any) => sum + (l.tokens_used || 0), 0);

  // Handbook retry
  lastHandbookRun = handbookRunRes.data ?? null;

  // Pipeline: filter eagerly-fetched data by run_id
  const runData = pipelineRes.data?.[0] ?? null;
  if (runData) {
    lastRun = runData as PipelineRun;
    lastRunError = formatPipelineError(lastRun.last_error);
    const logs = (pipelineLogsRes.data ?? []).filter((l: any) => l.run_id === lastRun!.id);
    pipelineCost = logs.reduce((sum: number, l: any) => sum + (parseFloat(l.cost_usd) || 0), 0);
    pipelineTokens = logs.reduce((sum: number, l: any) => sum + (l.tokens_used || 0), 0);
    const cands = (candidatesRes.data ?? []).filter((c: any) => c.batch_id === lastRun!.run_key);
    candidatesTotal = cands.length;
    candidatesSelected = cands.filter((c: any) => c.status === 'selected' || c.status === 'published').length;
  }

  // Notifications
  notifications = (notifsRes.data ?? []) as Notification[];
} catch {}

const nonce = Astro.locals.cspNonce || '';

// Detect stuck pipeline runs — news: 30min, handbook: 60min
const NEWS_TIMEOUT_MS = 30 * 60 * 1000;
const HANDBOOK_TIMEOUT_MS = 60 * 60 * 1000;

function checkStuck(run: any) {
  if (run?.status !== 'running' || !run?.started_at) return false;
  const elapsed = Date.now() - new Date(run.started_at).getTime();
  const isHandbook = run.run_key?.startsWith('handbook-');
  return elapsed > (isHandbook ? HANDBOOK_TIMEOUT_MS : NEWS_TIMEOUT_MS);
}

const isStuck = checkStuck(lastRun);
if (isStuck && lastRun) {
  const isHandbook = lastRun.run_key?.startsWith('handbook-');
  const timeoutMin = isHandbook ? 60 : 30;
  try {
    await sb.from('pipeline_runs').update({
      status: 'failed',
      finished_at: new Date().toISOString(),
      last_error: `Pipeline timed out (>${timeoutMin} minutes)`,
    }).eq('id', lastRun.id).eq('status', 'running');
    lastRun.status = 'failed';
    lastRunError = `Pipeline timed out (>${timeoutMin} minutes)`;
  } catch {}
}

// Show Retry Handbook when:
// 1. Last handbook-extract run failed or stuck running, OR
// 2. News run exists but no handbook-extract run for that batch
const lastNewsBatchId = lastRun?.run_key?.replace('news-', '') ?? '';
const handbookNeedsRetry = lastHandbookRun?.status === 'failed' || lastHandbookRun?.status === 'running';
const newsExistsNoHandbook = !!lastNewsBatchId && !lastHandbookRun;
const showRetryHandbook = handbookNeedsRetry || newsExistsNoHandbook;
const retryBatchId = handbookNeedsRetry
  ? (lastHandbookRun?.run_key?.replace('handbook-extract-', '') ?? '')
  : lastNewsBatchId;

function relativeTime(dateStr: string): string {
  const diff = Date.now() - new Date(dateStr).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return `${mins}m ago`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return `${hrs}h ago`;
  const days = Math.floor(hrs / 24);
  if (days < 7) return `${days}d ago`;
  return new Date(dateStr).toLocaleDateString('en-US');
}
---

<MainLayout title="Admin Dashboard" locale="en">
  <AdminSidebar activeSection="dashboard" />

  <div class="admin-dashboard">
    <div class="admin-main">
      <div class="admin-main-header">
        <div class="admin-main-header-top">
          <button class="admin-mobile-menu-btn" id="mobile-menu-btn" type="button" aria-label="Menu">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 5h14M3 10h14M3 15h14" />
            </svg>
          </button>
          <div>
            <h1 class="admin-main-title">Dashboard</h1>
          </div>
        </div>
        <div class="admin-quick-actions">
          <a href="/admin/news/" class="admin-btn admin-btn-primary">Check News</a>
          <a href="/admin/handbook/edit/new" class="admin-btn">New Term</a>
          <a href="/admin/blog/edit/new" class="admin-btn">New Post</a>
        </div>
      </div>

      <!-- Stats Grid: Content + Operations -->
      <div class="dashboard-stats-grid">
        <a href="/admin/news/" class="dashboard-stat-card">
          <div class="dashboard-stat-label">Paper</div>
          <div class="dashboard-stat-value">
            {totalPosts}
            {newsDrafts > 0 && <span class="dashboard-stat-draft">/ {newsDrafts}</span>}
          </div>
        </a>
        <a href="/admin/handbook/" class="dashboard-stat-card">
          <div class="dashboard-stat-label">Handbook</div>
          <div class="dashboard-stat-value">
            {totalTerms}
            {handbookDrafts > 0 && <span class="dashboard-stat-draft">/ {handbookDrafts}</span>}
          </div>
        </a>
        <a href="/admin/blog/" class="dashboard-stat-card">
          <div class="dashboard-stat-label">Blog</div>
          <div class="dashboard-stat-value">
            {totalBlogPosts}
            {blogDrafts > 0 && <span class="dashboard-stat-draft">/ {blogDrafts}</span>}
          </div>
        </a>
        <a href="/admin/products/" class="dashboard-stat-card">
          <div class="dashboard-stat-label">Products</div>
          <div class="dashboard-stat-value">{totalProducts}</div>
        </a>
        <a href="/admin/analytics#traffic" class="dashboard-stat-card">
          <div class="dashboard-stat-label">Users</div>
          <div class="dashboard-stat-value">{totalUsers}</div>
          <div class="dashboard-stat-sub">DAU {dau} · MAU {mau}</div>
        </a>
        <a href="/admin/analytics#traffic" class="dashboard-stat-card">
          <div class="dashboard-stat-label">Likes</div>
          <div class="dashboard-stat-value">{totalLikes}</div>
        </a>
        <a href="/admin/handbook/" class="dashboard-stat-card dashboard-stat-card--highlight">
          <div class="dashboard-stat-label">AI Review</div>
          <div class="dashboard-stat-value">{aiPendingCount}</div>
        </a>
        <a href="/admin/pipeline-analytics" class="dashboard-stat-card">
          <div class="dashboard-stat-label">AI Cost</div>
          <div class="dashboard-stat-value">${monthlyCost.toFixed(2)}</div>
          <div class="dashboard-stat-sub">{monthlyTokens.toLocaleString()} tokens</div>
        </a>
      </div>

      <!-- Pipeline Status (most actionable — check daily) -->
      <section class="dashboard-section">
        <h2 class="dashboard-section-title">Pipeline Status</h2>
        {lastRun ? (
          <div class={`dashboard-pipeline dashboard-pipeline--${lastRun.status}`}>
            <div class="dashboard-pipeline-header">
              <span class="dashboard-pipeline-status">
                <span class="dashboard-pipeline-dot"></span> {lastRun.status}
              </span>
              <span class="dashboard-pipeline-time">{relativeTime(lastRun.started_at)}</span>
            </div>
            <div class="dashboard-pipeline-details">
              {lastRun.finished_at && (
                <span>Duration: {Math.round((new Date(lastRun.finished_at).getTime() - new Date(lastRun.started_at).getTime()) / 1000)}s</span>
              )}
              {candidatesTotal > 0 && (
                <span>Candidates: {candidatesTotal} collected → {candidatesSelected} selected</span>
              )}
              {pipelineCost > 0 && (
                <span>Cost: ${pipelineCost.toFixed(2)} · {pipelineTokens.toLocaleString()} tokens</span>
              )}
            </div>
            {lastRun.status === 'failed' && lastRunError && (
              <div class="dashboard-pipeline-error">{lastRunError}</div>
            )}
            <div class="pipeline-control-groups">
              <div class="pipeline-control-group">
                <h4 class="pipeline-control-label">Daily Pipeline</h4>
                <div class="pipeline-control-row">
                  <input type="date" id="pipeline-target-date" class="admin-input admin-input--date"
                         max={new Date().toISOString().slice(0,10)}
                         title="Leave empty for today" />
                  <button type="button" class="admin-btn admin-btn-primary" id="run-pipeline-btn">Run Pipeline</button>
                  {lastRun?.status === 'running' && (
                    <button type="button" class="admin-btn-danger" id="cancel-pipeline-btn"
                            data-run-id={lastRun.id}>
                      Cancel
                    </button>
                  )}
                  {showRetryHandbook && (
                    <button type="button" class="admin-btn" id="retry-handbook-btn"
                            data-batch-id={retryBatchId}
                            title={`Retry handbook extraction for ${retryBatchId}`}>
                      Retry Handbook
                    </button>
                  )}
                </div>
                <div class="pipeline-control-toggles">
                  <label class="dashboard-pipeline-toggle">
                    <input type="checkbox" id="include-handbook" checked />
                    Include handbook
                  </label>
                  <label class="dashboard-pipeline-toggle" title="Controls whether the scheduled cron pipeline auto-extracts handbook terms">
                    <input type="checkbox" id="handbook-auto-extract" checked={handbookAutoExtract} />
                    Auto-extract (cron)
                  </label>
                </div>
                <p class="dashboard-pipeline-feedback" id="run-pipeline-feedback" aria-live="polite"></p>
              </div>

              <div class="pipeline-control-group">
                <h4 class="pipeline-control-label">Weekly Recap</h4>
                <div class="pipeline-control-row">
                  <input type="week" id="weekly-target-week" class="admin-input admin-input--date"
                         title="Leave empty for last week" />
                  <button type="button" class="admin-btn" id="run-weekly-btn">Generate Weekly</button>
                </div>
                <div class="pipeline-control-toggles">
                  <label class="dashboard-pipeline-toggle" title="Enable weekly recap generation">
                    <input type="checkbox" id="weekly-enabled" checked={weeklyEnabled} />
                    Enabled
                  </label>
                </div>
                <p class="dashboard-pipeline-feedback" id="weekly-pipeline-feedback" aria-live="polite"></p>
              </div>
            </div>
          </div>
        ) : (
          <div class="dashboard-pipeline dashboard-pipeline--none">
            <p class="dashboard-empty">No pipeline runs yet.</p>
            <div class="pipeline-control-groups">
              <div class="pipeline-control-group">
                <h4 class="pipeline-control-label">Daily Pipeline</h4>
                <div class="pipeline-control-row">
                  <input type="date" id="pipeline-target-date" class="admin-input admin-input--date"
                         max={new Date().toISOString().slice(0,10)}
                         title="Leave empty for today" />
                  <button type="button" class="admin-btn admin-btn-primary" id="run-pipeline-btn">Run Pipeline</button>
                </div>
                <div class="pipeline-control-toggles">
                  <label class="dashboard-pipeline-toggle">
                    <input type="checkbox" id="include-handbook" checked />
                    Include handbook
                  </label>
                  <label class="dashboard-pipeline-toggle" title="Controls whether the scheduled cron pipeline auto-extracts handbook terms">
                    <input type="checkbox" id="handbook-auto-extract" checked={handbookAutoExtract} />
                    Auto-extract (cron)
                  </label>
                </div>
                <p class="dashboard-pipeline-feedback" id="run-pipeline-feedback" aria-live="polite"></p>
              </div>

              <div class="pipeline-control-group">
                <h4 class="pipeline-control-label">Weekly Recap</h4>
                <div class="pipeline-control-row">
                  <input type="week" id="weekly-target-week" class="admin-input admin-input--date"
                         title="Leave empty for last week" />
                  <button type="button" class="admin-btn" id="run-weekly-btn">Generate Weekly</button>
                </div>
                <div class="pipeline-control-toggles">
                  <label class="dashboard-pipeline-toggle" title="Enable weekly recap generation">
                    <input type="checkbox" id="weekly-enabled" checked={weeklyEnabled} />
                    Enabled
                  </label>
                </div>
                <p class="dashboard-pipeline-feedback" id="weekly-pipeline-feedback" aria-live="polite"></p>
              </div>
            </div>
          </div>
        )}
      </section>

      <!-- Quality Score Charts -->
      <section class="dashboard-section">
        <h2 class="dashboard-section-title">Quality Score Trend</h2>
        <div class="dashboard-charts-row">
          <div class="dashboard-chart-card">
            <h3 class="dashboard-chart-label">Paper</h3>
            <div class="dashboard-chart-wrap">
              <canvas id="dash-chart-news-quality"></canvas>
            </div>
          </div>
          <div class="dashboard-chart-card">
            <h3 class="dashboard-chart-label">Handbook</h3>
            <div class="dashboard-chart-wrap">
              <canvas id="dash-chart-hb-quality"></canvas>
            </div>
          </div>
        </div>
      </section>

      {notifications.length > 0 && (
        <section class="dashboard-section">
          <div class="dashboard-section-header">
            <h2 class="dashboard-section-title">Notifications</h2>
            <button type="button" class="admin-btn-text" id="mark-all-read-btn">Mark all read</button>
          </div>
          <ul class="dashboard-activity-list">
            {notifications.map((n) => (
              <li class="dashboard-activity-item">
                <div class="dashboard-notification">
                  <span class={`dashboard-notification-badge dashboard-notification-badge--${n.type}`}>
                    {n.type === 'error' ? 'ERR' : n.type === 'pipeline' ? 'SYS' : 'INFO'}
                  </span>
                  <span class="dashboard-notification-title">{n.title}</span>
                  <span class="dashboard-activity-time">{relativeTime(n.created_at)}</span>
                </div>
              </li>
            ))}
          </ul>
        </section>
      )}

      <section class="dashboard-section">
        <h2 class="dashboard-section-title">Handbook Sources</h2>
        <div class="dashboard-source-row">
          <a href="/admin/handbook/" class="dashboard-source-chip">
            <span class="dashboard-source-label">Manual</span>
            <span class="dashboard-source-count">{termsBySource.manual}</span>
          </a>
          <a href="/admin/handbook/" class="dashboard-source-chip dashboard-source-chip--pipeline">
            <span class="dashboard-source-label">Pipeline</span>
            <span class="dashboard-source-count">{termsBySource.pipeline}</span>
          </a>
          <a href="/admin/handbook/" class="dashboard-source-chip dashboard-source-chip--ai">
            <span class="dashboard-source-label">AI Suggested</span>
            <span class="dashboard-source-count">{termsBySource['ai-suggested']}</span>
          </a>
        </div>
      </section>

      {aiSuggestedTerms.length > 0 && (
        <section class="dashboard-section">
          <h2 class="dashboard-section-title">AI-Suggested Drafts</h2>
          <p class="dashboard-section-hint">Terms created via AI advisor, awaiting review.</p>
          <ul class="dashboard-activity-list">
            {aiSuggestedTerms.map((item) => (
              <li class="dashboard-activity-item">
                <a href={`/admin/handbook/edit/${item.slug}`} class="dashboard-activity-link">
                  <span class="dashboard-activity-type">Term</span>
                  <span class="dashboard-activity-title">{item.title}</span>
                  <span class="admin-source-badge admin-source-badge--ai-suggested">AI</span>
                  <span class="dashboard-activity-time">{relativeTime(item.updated_at)}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      <section class="dashboard-section">
        <h2 class="dashboard-section-title">Recent Activity</h2>
        {recentActivity.length === 0 ? (
          <p class="dashboard-empty">No activity yet. Create your first post or term.</p>
        ) : (
          <ul class="dashboard-activity-list">
            {recentActivity.map((item) => (
              <li class="dashboard-activity-item">
                <a
                  href={item.type === 'post' ? `/admin/news/edit/${item.slug}` : `/admin/handbook/edit/${item.slug}`}
                  class="dashboard-activity-link"
                >
                  <span class="dashboard-activity-type">{item.type === 'post' ? 'Post' : 'Term'}</span>
                  <span class="dashboard-activity-title">{item.title}</span>
                  <span class={`admin-status-badge admin-status-badge--${item.status}`}>{item.status}</span>
                  {item.quality_score != null && (
                    <span class={`admin-quality-badge ${item.quality_score >= 80 ? 'admin-quality-badge--high' : item.quality_score >= 60 ? 'admin-quality-badge--mid' : 'admin-quality-badge--low'}`}>
                      Q{item.quality_score}
                    </span>
                  )}
                  {item.source && item.source !== 'manual' && (
                    <span class={`admin-source-badge admin-source-badge--${item.source}`}>
                      {item.source === 'pipeline' ? 'Pipeline' : 'AI'}
                    </span>
                  )}
                  <span class="dashboard-activity-time">{relativeTime(item.updated_at)}</span>
                </a>
              </li>
            ))}
          </ul>
        )}
      </section>

      {staleDrafts.length > 0 && (
        <section class="dashboard-section">
          <h2 class="dashboard-section-title">Drafts Needing Attention</h2>
          <p class="dashboard-section-hint">These drafts haven't been updated in over 7 days.</p>
          <ul class="dashboard-activity-list">
            {staleDrafts.map((item) => (
              <li class="dashboard-activity-item">
                <a
                  href={item.type === 'post' ? `/admin/news/edit/${item.slug}` : `/admin/handbook/edit/${item.slug}`}
                  class="dashboard-activity-link"
                >
                  <span class="dashboard-activity-type">{item.type === 'post' ? 'Post' : 'Term'}</span>
                  <span class="dashboard-activity-title">{item.title}</span>
                  <span class="dashboard-activity-time">{relativeTime(item.updated_at)}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </div>
  </div>
</MainLayout>

