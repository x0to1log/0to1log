---
export const prerender = false;
import MainLayout from '../../layouts/MainLayout.astro';
import AdminHeader from '../../components/admin/AdminHeader.astro';
import NewsprintNotice from '../../components/newsprint/NewsprintNotice.astro';
import { createClient } from '@supabase/supabase-js';

const accessToken = Astro.locals.accessToken;
const sb = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
);

// --- Handbook stats ---
let handbookDraft = 0;
let handbookPublished = 0;
let handbookTotal = 0;
try {
  const { data: terms } = await sb
    .from('handbook_terms')
    .select('status');
  if (terms) {
    handbookTotal = terms.length;
    handbookDraft = terms.filter((t) => t.status === 'draft').length;
    handbookPublished = terms.filter((t) => t.status === 'published').length;
  }
} catch {}

// --- Post stats (Supabase direct) ---
let logDraft = 0;
let logPublished = 0;
let logTotal = 0;
let drafts: any[] = [];
let fetchError: string | null = null;
try {
  const { data: posts, error } = await sb
    .from('posts')
    .select('id, title, slug, category, status, updated_at')
    .order('updated_at', { ascending: false });
  if (error) {
    fetchError = error.message;
  } else if (posts) {
    logTotal = posts.length;
    logDraft = posts.filter((p) => p.status === 'draft').length;
    logPublished = posts.filter((p) => p.status === 'published').length;
    drafts = posts.filter((p) => p.status === 'draft');
  }
} catch (err) {
  fetchError = err instanceof Error ? err.message : 'Unknown error';
}
---

<MainLayout title="Admin Dashboard" locale="en">
  <div style="max-width: 800px; margin: 0 auto;">
    <AdminHeader activeTab="posts" />

    {/* --- Summary Cards --- */}
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 2rem;">
      <a href="/admin/handbook/" style="text-decoration: none; color: inherit; border: 1px solid var(--color-border); padding: 1.25rem; display: block;">
        <div style="font-family: var(--font-ui); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-secondary); margin-bottom: 0.5rem;">
          Handbook
        </div>
        <div style="font-family: var(--font-heading); font-size: 1.75rem; font-weight: 700;">
          {handbookTotal}
        </div>
        <div style="font-family: var(--font-ui); font-size: 0.8rem; color: var(--color-text-secondary); margin-top: 0.25rem;">
          {handbookDraft > 0 && <span class="admin-status-badge admin-status-badge--draft" style="margin-right: 0.5rem;">{handbookDraft} draft</span>}
          {handbookPublished > 0 && <span class="admin-status-badge admin-status-badge--published">{handbookPublished} published</span>}
        </div>
      </a>
      <div style="border: 1px solid var(--color-border); padding: 1.25rem;">
        <div style="font-family: var(--font-ui); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-secondary); margin-bottom: 0.5rem;">
          Posts
        </div>
        <div style="font-family: var(--font-heading); font-size: 1.75rem; font-weight: 700;">
          {fetchError ? '—' : logTotal}
        </div>
        <div style="font-family: var(--font-ui); font-size: 0.8rem; color: var(--color-text-secondary); margin-top: 0.25rem;">
          {fetchError ? 'DB error' : (
            <>
              {logDraft > 0 && <span class="admin-status-badge admin-status-badge--draft" style="margin-right: 0.5rem;">{logDraft} draft</span>}
              {logPublished > 0 && <span class="admin-status-badge admin-status-badge--published">{logPublished} published</span>}
            </>
          )}
        </div>
      </div>
    </div>

    {/* --- Post Drafts List --- */}
    <h2 style="font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--color-border);">
      Post Drafts
    </h2>

    {fetchError ? (
      <NewsprintNotice
        variant="unauthorized"
        message={`Failed to load posts: ${fetchError}`}
        linkHref="/admin"
        linkLabel="Retry"
      />
    ) : drafts.length === 0 ? (
      <NewsprintNotice
        variant="empty"
        message="No drafts pending."
      />
    ) : (
      <ul class="admin-draft-list">
        {drafts.map((draft) => (
          <li class="admin-draft-item">
            <div class="admin-draft-info">
              <div class="admin-draft-title">{draft.title}</div>
              <div class="admin-draft-meta">
                {draft.category} &middot; {new Date(draft.updated_at).toLocaleDateString('en-US')}
              </div>
            </div>
            <a href={`/admin/edit/${draft.slug}`} class="admin-btn">Edit</a>
          </li>
        ))}
      </ul>
    )}
  </div>
</MainLayout>
