---
export const prerender = false;
import MainLayout from '../../layouts/MainLayout.astro';
import AdminSidebar from '../../components/admin/AdminSidebar.astro';
import NewsprintNotice from '../../components/newsprint/NewsprintNotice.astro';
import { createClient } from '@supabase/supabase-js';

const accessToken = Astro.locals.accessToken;
const sb = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
);

// --- Handbook stats ---
let handbookDraft = 0;
let handbookPublished = 0;
let handbookTotal = 0;
try {
  const { data: terms } = await sb
    .from('handbook_terms')
    .select('id, term, slug, status, updated_at');
  if (terms) {
    handbookTotal = terms.length;
    handbookDraft = terms.filter((t) => t.status === 'draft').length;
    handbookPublished = terms.filter((t) => t.status === 'published').length;
  }
} catch {}

// --- Post stats (Supabase direct) ---
let logDraft = 0;
let logPublished = 0;
let logTotal = 0;
let allPosts: any[] = [];
let fetchError: string | null = null;
try {
  const { data: posts, error } = await sb
    .from('posts')
    .select('id, title, slug, category, status, updated_at, published_at')
    .order('updated_at', { ascending: false });
  if (error) {
    fetchError = error.message;
  } else if (posts) {
    allPosts = posts.sort((a, b) => {
      if (a.status === 'draft' && b.status !== 'draft') return -1;
      if (a.status !== 'draft' && b.status === 'draft') return 1;
      if (a.status === 'draft' && b.status === 'draft') {
        return new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime();
      }
      return new Date(b.published_at || b.updated_at).getTime() - new Date(a.published_at || a.updated_at).getTime();
    });
    logTotal = posts.length;
    logDraft = posts.filter((p) => p.status === 'draft').length;
    logPublished = posts.filter((p) => p.status === 'published').length;
  }
} catch (err) {
  fetchError = err instanceof Error ? err.message : 'Unknown error';
}

// --- Recent items for sidebar ---
const recentItems: Array<{ title: string; slug: string; type: 'post' | 'term' }> = [];
// Add recent posts
allPosts.slice(0, 3).forEach((p) => recentItems.push({ title: p.title, slug: p.slug, type: 'post' }));
// Add recent handbook terms (already fetched above)
try {
  const { data: recentTerms } = await sb
    .from('handbook_terms')
    .select('term, slug')
    .order('updated_at', { ascending: false })
    .limit(2);
  (recentTerms || []).forEach((t) => recentItems.push({ title: t.term, slug: t.slug, type: 'term' }));
} catch {}
---

<MainLayout title="Admin Dashboard" locale="en">
  <AdminSidebar
    activeSection="posts"
    recentPosts={recentItems}
    stats={{ posts: logTotal, terms: handbookTotal, drafts: logDraft + handbookDraft }}
  />

  <div class="admin-dashboard">
    <div class="admin-main">
      <div class="admin-main-header">
        <div class="admin-main-header-top">
          <button class="admin-mobile-menu-btn" id="mobile-menu-btn" type="button" aria-label="Menu">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 5h14M3 10h14M3 15h14" />
            </svg>
          </button>
          <h1 class="admin-main-title">Posts</h1>
        </div>
        <div class="admin-header-controls">
          <div class="admin-filter-tabs">
            <button class="admin-filter-btn admin-filter-btn--active" data-filter="draft">
              Draft ({logDraft})
            </button>
            <button class="admin-filter-btn" data-filter="published">
              Published ({logPublished})
            </button>
            <button class="admin-filter-btn" data-filter="all">
              All ({logTotal})
            </button>
          </div>
          <a href="/admin/edit/new" class="admin-btn admin-btn-primary">+ New Post</a>
        </div>
      </div>

      <!-- Overview Dashboard -->
      <div class="admin-overview">
        <div class="admin-stat-card">
          <div class="admin-stat-card-label">Posts</div>
          <div class="admin-stat-card-value">{fetchError ? '—' : logTotal}</div>
          <div class="admin-stat-card-detail">
            {logDraft > 0 && <span class="admin-status-badge admin-status-badge--draft">{logDraft} draft</span>}
            {logPublished > 0 && <span class="admin-status-badge admin-status-badge--published">{logPublished} published</span>}
          </div>
        </div>
        <div class="admin-stat-card">
          <div class="admin-stat-card-label">Handbook</div>
          <div class="admin-stat-card-value">{handbookTotal}</div>
          <div class="admin-stat-card-detail">
            {handbookDraft > 0 && <span class="admin-status-badge admin-status-badge--draft">{handbookDraft} draft</span>}
            {handbookPublished > 0 && <span class="admin-status-badge admin-status-badge--published">{handbookPublished} published</span>}
          </div>
        </div>
      </div>

      <input type="search" class="admin-input admin-search-input" id="admin-search" placeholder="Search by title..." />

      {fetchError ? (
        <NewsprintNotice
          variant="unauthorized"
          message={`Failed to load posts: ${fetchError}`}
          linkHref="/admin"
          linkLabel="Retry"
        />
      ) : allPosts.length === 0 ? (
        <NewsprintNotice variant="empty" message="No posts yet." />
      ) : (
        <ul class="admin-list" id="post-list">
          {allPosts.map((post) => (
            <li class="admin-list-item" data-status={post.status}>
              <div class="admin-list-info">
                <div class="admin-list-title">
                  <a href={`/admin/edit/${post.slug}`}>{post.title}</a>
                </div>
                <div class="admin-list-meta">
                  <span class={`admin-status-badge admin-status-badge--${post.status}`}>
                    {post.status}
                  </span>
                  {post.category && <span>{post.category}</span>}
                  <span>{new Date(post.updated_at).toLocaleDateString('en-US')}</span>
                </div>
              </div>
              <div class="admin-list-actions">
                {post.status === 'draft' ? (
                  <button class="admin-btn" data-action="publish" data-id={post.id}>Publish</button>
                ) : post.status === 'published' ? (
                  <button class="admin-btn" data-action="unpublish" data-id={post.id}>Unpublish</button>
                ) : null}
                <a href={`/admin/edit/${post.slug}`} class="admin-btn">Edit</a>
                <button class="admin-btn-danger" data-action="delete" data-id={post.id} data-title={post.title}>Delete</button>
              </div>
            </li>
          ))}
        </ul>
        <p id="admin-no-results" class="admin-no-results" hidden>No matching items.</p>
      )}
    </div>

  </div>
</MainLayout>

<script>
  function initAdminDashboard() {
    let currentFilter = 'draft';
    const searchInput = document.getElementById('admin-search') as HTMLInputElement;

    function applyFilter(filter: string) {
      currentFilter = filter;
      const query = searchInput?.value.toLowerCase().trim() || '';
      let visibleCount = 0;
      document.querySelectorAll<HTMLElement>('#post-list [data-status]').forEach((item) => {
        const matchesStatus = filter === 'all' || item.dataset.status === filter;
        const title = item.querySelector('.admin-list-title a')?.textContent?.toLowerCase() || '';
        const matchesSearch = !query || title.includes(query);
        item.style.display = (matchesStatus && matchesSearch) ? '' : 'none';
        if (matchesStatus && matchesSearch) visibleCount++;
      });
      const noResults = document.getElementById('admin-no-results');
      if (noResults) noResults.hidden = visibleCount > 0;
    }

    document.querySelectorAll<HTMLButtonElement>('[data-filter]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter!;
        document.querySelectorAll<HTMLButtonElement>('[data-filter]').forEach((b) =>
          b.classList.remove('admin-filter-btn--active')
        );
        btn.classList.add('admin-filter-btn--active');
        applyFilter(filter);
      });
    });

    searchInput?.addEventListener('input', () => applyFilter(currentFilter));

    applyFilter('draft');

    document.querySelectorAll<HTMLButtonElement>('[data-action]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const action = btn.dataset.action!;
        const id = btn.dataset.id!;

        if (action === 'delete') {
          const title = btn.dataset.title || 'this post';
          if (!confirm(`Delete "${title}"? This cannot be undone.`)) return;
          const res = await fetch('/api/admin/posts/delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id }),
          });
          if (res.ok) { window.location.reload(); }
          else { const err = await res.json(); alert(`Delete failed: ${err.error}`); }
          return;
        }

        const res = await fetch('/api/admin/posts/status', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, action }),
        });
        if (res.ok) { window.location.reload(); }
        else { const err = await res.json(); alert(`${action} failed: ${err.error}`); }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initAdminDashboard);
  initAdminDashboard();
</script>
