---
export const prerender = false;

import MainLayout from '../../layouts/MainLayout.astro';
import AdminSidebar from '../../components/admin/AdminSidebar.astro';
import { createClient } from '@supabase/supabase-js';

const accessToken = Astro.locals.accessToken;
const sb = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
);

let totalPosts = 0;
let publishedPosts = 0;
let totalTerms = 0;
let totalDrafts = 0;

type ActivityItem = {
  title: string;
  slug: string;
  type: 'post' | 'term';
  status: string;
  updated_at: string;
};

let recentActivity: ActivityItem[] = [];
let staleDrafts: ActivityItem[] = [];

try {
  const [postsRes, termsRes] = await Promise.all([
    sb.from('posts').select('title, slug, status, updated_at').order('updated_at', { ascending: false }),
    sb.from('handbook_terms').select('term, slug, status, updated_at').order('updated_at', { ascending: false }),
  ]);

  const posts = postsRes.data ?? [];
  const terms = termsRes.data ?? [];

  totalPosts = posts.length;
  publishedPosts = posts.filter((p) => p.status === 'published').length;
  totalTerms = terms.length;

  const postDrafts = posts.filter((p) => p.status === 'draft').length;
  const termDrafts = terms.filter((t) => t.status === 'draft').length;
  totalDrafts = postDrafts + termDrafts;

  const allItems: ActivityItem[] = [
    ...posts.map((p) => ({ title: p.title, slug: p.slug, type: 'post' as const, status: p.status, updated_at: p.updated_at })),
    ...terms.map((t) => ({ title: t.term, slug: t.slug, type: 'term' as const, status: t.status, updated_at: t.updated_at })),
  ];
  allItems.sort((a, b) => new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime());
  recentActivity = allItems.slice(0, 8);

  const sevenDaysAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString();
  staleDrafts = allItems.filter((item) => item.status === 'draft' && item.updated_at < sevenDaysAgo).slice(0, 5);
} catch {}

function relativeTime(dateStr: string): string {
  const diff = Date.now() - new Date(dateStr).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return `${mins}m ago`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return `${hrs}h ago`;
  const days = Math.floor(hrs / 24);
  if (days < 7) return `${days}d ago`;
  return new Date(dateStr).toLocaleDateString('en-US');
}
---

<MainLayout title="Admin Dashboard" locale="en">
  <AdminSidebar activeSection="dashboard" />

  <div class="admin-dashboard">
    <div class="admin-main">
      <div class="admin-main-header">
        <div class="admin-main-header-top">
          <button class="admin-mobile-menu-btn" id="mobile-menu-btn" type="button" aria-label="Menu">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 5h14M3 10h14M3 15h14" />
            </svg>
          </button>
          <div>
            <h1 class="admin-main-title">Dashboard</h1>
          </div>
        </div>
        <div class="admin-quick-actions">
          <a href="/admin/edit/new" class="admin-btn admin-btn-primary">New Post</a>
          <a href="/admin/handbook/edit/new" class="admin-btn">New Term</a>
        </div>
      </div>

      <div class="dashboard-stats">
        <a href="/admin/posts/" class="dashboard-stat-card">
          <div class="dashboard-stat-label">Posts</div>
          <div class="dashboard-stat-value">{totalPosts}</div>
        </a>
        <a href="/admin/posts/" class="dashboard-stat-card">
          <div class="dashboard-stat-label">Published</div>
          <div class="dashboard-stat-value">{publishedPosts}</div>
        </a>
        <a href="/admin/handbook/" class="dashboard-stat-card">
          <div class="dashboard-stat-label">Terms</div>
          <div class="dashboard-stat-value">{totalTerms}</div>
        </a>
        <div class="dashboard-stat-card dashboard-stat-card--highlight">
          <div class="dashboard-stat-label">Drafts</div>
          <div class="dashboard-stat-value">{totalDrafts}</div>
        </div>
      </div>

      <section class="dashboard-section">
        <h2 class="dashboard-section-title">Recent Activity</h2>
        {recentActivity.length === 0 ? (
          <p class="dashboard-empty">No activity yet. Create your first post or term.</p>
        ) : (
          <ul class="dashboard-activity-list">
            {recentActivity.map((item) => (
              <li class="dashboard-activity-item">
                <a
                  href={item.type === 'post' ? `/admin/edit/${item.slug}` : `/admin/handbook/edit/${item.slug}`}
                  class="dashboard-activity-link"
                >
                  <span class="dashboard-activity-type">{item.type === 'post' ? 'Post' : 'Term'}</span>
                  <span class="dashboard-activity-title">{item.title}</span>
                  <span class={`admin-status-badge admin-status-badge--${item.status}`}>{item.status}</span>
                  <span class="dashboard-activity-time">{relativeTime(item.updated_at)}</span>
                </a>
              </li>
            ))}
          </ul>
        )}
      </section>

      {staleDrafts.length > 0 && (
        <section class="dashboard-section">
          <h2 class="dashboard-section-title">Drafts Needing Attention</h2>
          <p class="dashboard-section-hint">These drafts haven't been updated in over 7 days.</p>
          <ul class="dashboard-activity-list">
            {staleDrafts.map((item) => (
              <li class="dashboard-activity-item">
                <a
                  href={item.type === 'post' ? `/admin/edit/${item.slug}` : `/admin/handbook/edit/${item.slug}`}
                  class="dashboard-activity-link"
                >
                  <span class="dashboard-activity-type">{item.type === 'post' ? 'Post' : 'Term'}</span>
                  <span class="dashboard-activity-title">{item.title}</span>
                  <span class="dashboard-activity-time">{relativeTime(item.updated_at)}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </div>
  </div>
</MainLayout>

<style>
  .admin-quick-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .dashboard-stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .dashboard-stat-card {
    border: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
    padding: 1rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
  }

  .dashboard-stat-card:hover {
    border-color: var(--color-text-muted);
  }

  .dashboard-stat-card--highlight {
    border-color: var(--color-accent, var(--color-border));
  }

  .dashboard-stat-label {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }

  .dashboard-stat-value {
    font-size: 1.5rem;
    font-weight: 700;
  }

  .dashboard-section {
    margin-bottom: 1.5rem;
  }

  .dashboard-section-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .dashboard-section-hint {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .dashboard-empty {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    padding: 1rem 0;
  }

  .dashboard-activity-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .dashboard-activity-item {
    border-bottom: 1px solid var(--color-border);
  }

  .dashboard-activity-item:last-child {
    border-bottom: none;
  }

  .dashboard-activity-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.25rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.1s;
  }

  .dashboard-activity-link:hover {
    background: var(--color-bg-secondary);
  }

  .dashboard-activity-type {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    min-width: 3rem;
  }

  .dashboard-activity-title {
    flex: 1;
    font-size: 0.9rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .dashboard-activity-time {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  @media (max-width: 960px) {
    .dashboard-stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .dashboard-stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .admin-quick-actions {
      flex-direction: row;
    }

    .admin-quick-actions .admin-btn {
      flex: 1;
      justify-content: center;
    }

    .dashboard-activity-link {
      display: grid;
      grid-template-columns: auto 1fr auto;
      grid-template-rows: auto auto;
      gap: 0.2rem 0.5rem;
      padding: 0.65rem 0.25rem;
    }

    .dashboard-activity-type {
      min-width: auto;
      grid-row: 1;
      grid-column: 1;
    }

    .dashboard-activity-title {
      grid-row: 1;
      grid-column: 2 / -1;
    }

    .dashboard-activity-time {
      grid-row: 2;
      grid-column: 2;
    }

    .dashboard-activity-link .admin-status-badge {
      grid-row: 2;
      grid-column: 1;
    }
  }
</style>
