---
export const prerender = false;

import MainLayout from '../../../../layouts/MainLayout.astro';
import AdminSidebar from '../../../../components/admin/AdminSidebar.astro';
import NewsprintShell from '../../../../components/newsprint/NewsprintShell.astro';
import NewsprintArticleLayout from '../../../../components/newsprint/NewsprintArticleLayout.astro';
import NewsprintSideRail from '../../../../components/newsprint/NewsprintSideRail.astro';
import NewsprintNotice from '../../../../components/newsprint/NewsprintNotice.astro';
import { getCategoryLabel, getCategoryColorVar, normalizeCategorySlug, BLOG_CATEGORIES } from '../../../../lib/categories';
import { getArticleFocusItems } from '../../../../lib/articleRail';
import { renderMarkdown } from '../../../../lib/markdown';
import { createClient } from '@supabase/supabase-js';

const { slug } = Astro.params;
const pageSlug = slug ?? '';
const isNew = pageSlug === 'new';
const startInPreview = Astro.url.searchParams.get('mode') === 'preview';

const accessToken = Astro.locals.accessToken;
let post: any = null;
let fetchError: string | null = null;

if (!accessToken) {
  return Astro.redirect('/admin/login');
}

if (!isNew) {
  try {
    const supabase = createClient(
      import.meta.env.PUBLIC_SUPABASE_URL,
      import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
      { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
    );
    const { data, error } = await supabase
      .from('blog_posts')
      .select('*')
      .eq('slug', pageSlug)
      .single();

    if (error && error.code === 'PGRST116') {
      fetchError = '404';
    } else if (error) {
      fetchError = error.message;
    } else {
      post = data;
    }
  } catch (err) {
    fetchError = err instanceof Error ? err.message : 'Unknown error';
  }

  if (!fetchError && !post) {
    fetchError = '404';
  }
}

const editableContent = post?.content || '';
const categories = BLOG_CATEGORIES;

const editionMap: Record<string, string> = {
  study: 'Study Notes',
  career: 'Career Notes',
  project: 'Build Log',
  'work-note': 'Work Notes',
  daily: 'Daily Life',
};

const initialStatus = post?.status || 'draft';
const initialCategory = normalizeCategorySlug(post?.category) || 'study';
const initialEditionLabel = editionMap[initialCategory] || 'Deep Dive';
const initialFocusItems = getArticleFocusItems('en', initialCategory);
const initialTitle = post?.title || '';
const initialTags = post?.tags || [];
const previewContent = editableContent;
const initialHtmlContent = post ? await renderMarkdown(previewContent) : '';
const initialWordCount = post ? previewContent.split(/\s+/).length : 0;
const initialReadingTime = Math.max(1, Math.round(initialWordCount / 200));
---

<MainLayout title={isNew ? 'New Blog Post' : (post ? `Edit: ${post.title}` : 'Blog Editor')} locale="en">
  {fetchError === '403' ? (
    <div style="max-width: 800px; margin: 0 auto; padding: 2rem;">
      <NewsprintNotice
        variant="unauthorized"
        message="You do not have permission to access this page."
        linkHref="/"
        linkLabel="Go home"
      />
    </div>
  ) : fetchError === '404' ? (
    <div style="max-width: 800px; margin: 0 auto; padding: 2rem;">
      <NewsprintNotice
        variant="notfound"
        message="This blog post does not exist or has been deleted."
        linkHref="/admin/blog/"
        linkLabel="Back to Blog"
      />
    </div>
  ) : fetchError ? (
    <div style="max-width: 800px; margin: 0 auto; padding: 2rem;">
      <NewsprintNotice
        variant="notfound"
        message={`Error loading post: ${fetchError}`}
        linkHref="/admin/blog/"
        linkLabel="Back to Blog"
      />
    </div>
  ) : (post || isNew) ? (
    <>
      <AdminSidebar activeSection="blog" />
      <!-- Draft Mode -->
      <div class="admin-editor-layout" id="draft-mode" style={startInPreview ? 'display: none;' : undefined}>
        <div class="admin-editor-topbar">
          <div class="admin-editor-topbar-left">
            <button class="admin-mobile-menu-btn" id="mobile-menu-btn" type="button" aria-label="Menu">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 5h14M3 10h14M3 15h14" />
              </svg>
            </button>
            <a href="/admin/blog/" class="admin-editor-back">&larr; Back</a>
            <span class={`admin-status-badge admin-status-badge--${initialStatus}`}>{initialStatus}</span>
          </div>
          <div class="admin-editor-topbar-right">
            <button id="btn-save" class="admin-btn" type="button">Save</button>
            <button id="btn-preview" class="admin-btn" type="button">Preview</button>
            <button id="btn-publish-draft" class="admin-btn admin-btn-primary" type="button">Publish</button>
            <button id="btn-ai-toggle" class="admin-ai-panel-toggle" type="button">AI</button>
            {!isNew && <button id="btn-delete" class="admin-btn-danger" type="button">Delete</button>}
          </div>
        </div>

        <div class="admin-editor-content">
          <textarea
            id="edit-title"
            class="admin-editor-title"
            rows="1"
            placeholder="Untitled"
          >{post?.title || ''}</textarea>

          <div class="admin-editor-meta">
            <select id="edit-category" class="admin-select" style="width: auto; min-width: 120px;">
              {categories.map((cat) => (
                <option value={cat} selected={cat === post?.category}>
                  {getCategoryLabel('en', cat)}
                </option>
              ))}
            </select>
            <input
              id="edit-tags"
              class="admin-input"
              type="text"
              value={(post?.tags || []).join(', ')}
              placeholder="Tags: tag1, tag2, tag3..."
              style="flex: 1;"
            />
          </div>

          <details class="admin-details">
            <summary>More fields (Slug, Excerpt...)</summary>
            <div class="admin-details-body">
              <div class="admin-editor-meta-row">
                <label class="admin-field-label" for="edit-slug">Slug</label>
                <input id="edit-slug" class="admin-input" type="text" style="flex:1;"
                  value={post?.slug || ''} placeholder="auto-generated-from-title" />
              </div>
              <div class="admin-editor-meta-row">
                <label class="admin-field-label" for="edit-excerpt">Excerpt</label>
                <textarea id="edit-excerpt" class="admin-input" rows="2" style="flex:1;"
                  placeholder="Brief summary for list pages and SEO...">{post?.excerpt || ''}</textarea>
              </div>
              <div class="admin-editor-meta-row">
                <label class="admin-field-label" for="edit-locale">Locale</label>
                <select id="edit-locale" class="admin-select" style="width:auto;">
                  <option value="en" selected={!post?.locale || post?.locale === 'en'}>EN</option>
                  <option value="ko" selected={post?.locale === 'ko'}>KO</option>
                </select>
              </div>
              <div class="admin-editor-meta-row">
                <label class="admin-field-label" for="edit-focus-items">Focus Items</label>
                <input id="edit-focus-items" class="admin-input" type="text" style="flex:1;"
                  value={(post?.focus_items || []).join(', ')} placeholder="item1, item2, item3..." />
              </div>
              <div class="admin-editor-meta-row">
                <label class="admin-field-label" for="edit-og-image">OG Image</label>
                <input id="edit-og-image" class="admin-input" type="text" style="flex:1;"
                  value={post?.og_image_url || ''} placeholder="https://..." />
              </div>
            </div>
          </details>

          <div id="milkdown-editor" class="admin-editor-wrapper" data-content={editableContent}></div>
        </div>

        <div id="admin-feedback" class="admin-feedback admin-feedback--toast" hidden>
          <span id="admin-feedback-msg"></span>
        </div>

        <div class="admin-ai-backdrop" id="ai-backdrop"></div>
        <div class="admin-ai-panel" id="ai-panel">
          <div class="admin-ai-panel-header">
            <span class="admin-ai-panel-title">AI Advisor</span>
            <button id="btn-ai-close" class="admin-ai-panel-toggle" type="button">&times;</button>
          </div>
          <div class="admin-ai-actions" id="ai-actions-container"></div>
          <div id="ai-loading" class="admin-ai-loading" hidden>
            <span class="ai-spinner"></span>
            <span id="ai-loading-text">Analyzing...</span>
          </div>
          <div id="ai-result" class="admin-ai-result"></div>
        </div>
      </div>

      <!-- Preview Mode -->
      <div id="preview-mode" style={startInPreview ? undefined : 'display: none;'}>
        <div class="admin-preview-bar">
          <div class="admin-toolbar-left">
            <a href="/admin/blog/" class="admin-editor-back">&larr; Back</a>
          </div>
          <div class="admin-toolbar-right">
            <button id="btn-edit-back" class="admin-btn" type="button">Edit</button>
            <button id="btn-publish-preview" class="admin-btn admin-btn-primary" type="button">Publish</button>
          </div>
        </div>

        <NewsprintShell
          locale="en"
          masthead="IT Blog"
          editionLabel={initialEditionLabel}
          subkicker={['Study · Project · Career · Work Notes · Daily Life', 'Deep Dive', 'Personal Notes']}
        >
          <div id="preview-content">
            <NewsprintArticleLayout
              locale="en"
              slug={pageSlug}
              showSlug={false}
              title={initialTitle}
              category={initialCategory}
              publishedAt={new Date().toISOString()}
              readingTimeMin={initialReadingTime}
              tags={initialTags}
              htmlContent={initialHtmlContent}
              backLabel="Back to Blog"
            />
          </div>

          <Fragment slot="rail">
            <NewsprintSideRail locale="en" posts={[]} focusItems={initialFocusItems} />
          </Fragment>
        </NewsprintShell>
      </div>
    </>
  ) : (
    <div style="max-width: 800px; margin: 0 auto;">
      <NewsprintNotice
        variant="notfound"
        message="This blog post does not exist or has been deleted."
        linkHref="/admin/blog/"
        linkLabel="Back to Blog"
      />
    </div>
  )}
  <div id="admin-data" hidden data-post-id={post?.id || ''} data-slug={pageSlug} data-is-new={isNew ? 'true' : 'false'} data-post-locale={post?.locale || 'en'}></div>
</MainLayout>

<script>
  import { Crepe } from '@milkdown/crepe';
  import { replaceAll } from '@milkdown/utils';
  import '@milkdown/crepe/theme/common/style.css';
  import { marked } from 'marked';

  let crepe: Crepe | null = null;

  /** Milkdown Crepe v7.19 has no setMarkdown(). Use editor.action(replaceAll()) instead. */
  function setEditorContent(md: string) {
    if (crepe) crepe.editor.action(replaceAll(md));
  }
  let feedbackTimer = 0;

  const CATEGORY_LABELS: Record<string, string> = {
    study: 'Study',
    career: 'Career',
    project: 'Project',
    'work-note': 'Work Notes',
    daily: 'Daily',
  };

  const EDITION_MAP: Record<string, string> = {
    study: 'Study Notes',
    career: 'Career Notes',
    project: 'Build Log',
    'work-note': 'Work Notes',
    daily: 'Daily Life',
  };

  const FOCUS_MAP: Record<string, string[]> = {
    study: ['What concept to understand', 'What to remember from this note', 'What to try after reading'],
    career: ['What decision matters here', 'What signal is worth noticing', 'What to apply in actual work'],
    project: ['What was built in this step', 'What tradeoff appeared', 'What to improve next'],
    'work-note': ['What moved in this work session', 'What blocker or decision matters', 'What to do next'],
    daily: ['What stood out today', 'What it made me notice', 'What I want to carry forward'],
  };

  const DEFAULT_FOCUS = ['Key insight', 'Practical takeaway', 'Next step'];

  document.addEventListener('DOMContentLoaded', () => {
    if (crepe) {
      crepe.destroy();
      crepe = null;
    }
    clearTimeout(feedbackTimer);

    const editorEl = document.getElementById('milkdown-editor');
    if (!editorEl) return;

    const draftMode = document.getElementById('draft-mode');
    const previewMode = document.getElementById('preview-mode');
    const btnPreview = document.getElementById('btn-preview');
    const btnEdit = document.getElementById('btn-edit-back');
    const btnPublish = document.getElementById('btn-publish-preview');
    const btnSave = document.getElementById('btn-save');
    const btnDelete = document.getElementById('btn-delete');
    const btnPublishDraft = document.getElementById('btn-publish-draft');
    const titleInput = document.getElementById('edit-title') as HTMLTextAreaElement;
    const categorySelect = document.getElementById('edit-category') as HTMLSelectElement;
    const tagsInput = document.getElementById('edit-tags') as HTMLInputElement;
    const slugInput = document.getElementById('edit-slug') as HTMLInputElement;
    const excerptInput = document.getElementById('edit-excerpt') as HTMLTextAreaElement;
    const localeSelect = document.getElementById('edit-locale') as HTMLSelectElement;
    const focusItemsInput = document.getElementById('edit-focus-items') as HTMLInputElement;
    const ogImageInput = document.getElementById('edit-og-image') as HTMLInputElement;
    const adminData = document.getElementById('admin-data');
    const postId = adminData?.dataset.postId || '';
    const isNewPost = adminData?.dataset.isNew === 'true';
    const postLocale = adminData?.dataset.postLocale || 'en';

    function autoResizeTitle() {
      if (!titleInput) return;
      titleInput.style.height = 'auto';
      titleInput.style.height = titleInput.scrollHeight + 'px';
    }
    titleInput?.addEventListener('input', autoResizeTitle);
    autoResizeTitle();

    function showFeedback(type: 'success' | 'error', message: string) {
      const el = document.getElementById('admin-feedback');
      const msgEl = document.getElementById('admin-feedback-msg');
      if (!el || !msgEl) return;
      el.classList.remove('admin-feedback--success', 'admin-feedback--error');
      el.classList.add(`admin-feedback--${type}`);
      msgEl.textContent = message;
      el.hidden = false;
      clearTimeout(feedbackTimer);
      feedbackTimer = window.setTimeout(() => { el.hidden = true; }, 3000);
    }

    const previousValues = new Map<string, string>();

    function getInputForField(field: string): HTMLInputElement | HTMLTextAreaElement | null {
      if (field === 'title') return titleInput;
      if (field === 'excerpt') return excerptInput;
      if (field === 'slug') return slugInput;
      if (field === 'tags') return tagsInput;
      if (field === 'focus_items') return focusItemsInput;
      return null;
    }

    function showDiff(btn: HTMLButtonElement, field: string, newValue: string) {
      const input = getInputForField(field);
      if (!input) return;
      const currentValue = input.value;

      const container = btn.closest('.admin-ai-suggestion') as HTMLElement | null;
      if (!container) return;
      const diffId = `diff-${field}-${Date.now()}`;
      const diffHtml = `<div class="admin-ai-diff" id="${diffId}">` +
        `<div class="admin-ai-diff--del">${esc(currentValue || '(empty)')}</div>` +
        `<div class="admin-ai-diff--add">${esc(newValue)}</div>` +
        `<div class="admin-ai-diff-actions">` +
        `<button class="admin-ai-diff-confirm" type="button">Apply</button>` +
        `<button class="admin-ai-diff-cancel" type="button">Cancel</button>` +
        `</div></div>`;

      btn.hidden = true;
      container.insertAdjacentHTML('beforeend', diffHtml);

      const diffEl = document.getElementById(diffId);
      diffEl?.querySelector('.admin-ai-diff-confirm')?.addEventListener('click', () => {
        previousValues.set(field, currentValue);
        input.value = newValue;
        diffEl.remove();
        btn.hidden = false;
        btn.textContent = 'Undo';
        btn.classList.add('admin-ai-undo-btn');
        btn.onclick = () => {
          const prev = previousValues.get(field);
          if (prev !== undefined) { input.value = prev; previousValues.delete(field); }
          btn.textContent = 'Use';
          btn.classList.remove('admin-ai-undo-btn');
          btn.onclick = null;
          showFeedback('success', `${field} reverted.`);
        };
        showFeedback('success', `${field} applied.`);
      });

      diffEl?.querySelector('.admin-ai-diff-cancel')?.addEventListener('click', () => {
        diffEl.remove();
        btn.hidden = false;
      });
    }

    async function initEditor() {
      if (!editorEl) return;
      const initialContent = editorEl.dataset.content || '';

      crepe = new Crepe({
        root: editorEl,
        defaultValue: initialContent,
        featureConfigs: {
          [Crepe.Feature.Placeholder]: {
            text: 'Start writing your blog post...',
            mode: 'block',
          },
        },
      });

      await crepe.create();
    }

    async function handleSave() {
      const title = titleInput?.value || '';
      if (!title.trim()) {
        showFeedback('error', 'Save failed: title is required.');
        return;
      }
      const category = categorySelect?.value || 'study';
      const tagsRaw = tagsInput?.value || '';
      const tags = tagsRaw.split(',').map(t => t.trim()).filter(Boolean);
      const slug = slugInput?.value || '';
      const excerpt = excerptInput?.value || '';
      const locale = localeSelect?.value || 'en';
      const focusRaw = focusItemsInput?.value || '';
      const focusItems = focusRaw.split(',').map((s: string) => s.trim()).filter(Boolean);
      const ogImageUrl = ogImageInput?.value || '';

      const saveBody: Record<string, any> = {
        id: isNewPost ? undefined : postId,
        title, slug, category, tags,
        content: crepe ? crepe.getMarkdown() : '',
        excerpt, locale, focus_items: focusItems, og_image_url: ogImageUrl,
      };

      try {
        const res = await fetch('/api/admin/blog/save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(saveBody),
        });
        if (!res.ok) {
          const err = await res.json();
          throw new Error(err.error || `${res.status}`);
        }
        if (res.status === 201) {
          const created = await res.json();
          showFeedback('success', 'Post created! Redirecting...');
          window.location.href = `/admin/blog/edit/${created.slug}`;
          return;
        }
        showFeedback('success', 'Draft saved.');
      } catch (err) {
        showFeedback('error', `Save failed: ${err instanceof Error ? err.message : 'unknown error'}`);
      }
    }

    function switchToPreview() {
      const markdown = crepe ? crepe.getMarkdown() : '';
      const title = titleInput?.value || '';
      const category = categorySelect?.value || 'study';
      const tagsRaw = tagsInput?.value || '';
      const tags = tagsRaw.split(',').map(t => t.trim()).filter(Boolean);

      showFeedback('success', 'Draft auto-saved.');

      const wordCount = markdown.split(/\s+/).length;
      const readingTime = Math.max(1, Math.round(wordCount / 200));

      const previewContent = document.getElementById('preview-content');
      if (previewContent) {
        const previewTitle = previewContent.querySelector('.newsprint-lead-title');
        if (previewTitle) previewTitle.textContent = title;

        const previewCategory = previewContent.querySelector('.newsprint-category');
        if (previewCategory) previewCategory.textContent = CATEGORY_LABELS[category] || category;

        const headerLeft = previewContent.querySelector('.newsprint-article-header-left');
        if (headerLeft) {
          headerLeft.querySelectorAll('.newsprint-tag').forEach(el => el.remove());
          tags.slice(0, 6).forEach(tag => {
            const span = document.createElement('span');
            span.className = 'newsprint-tag';
            span.textContent = tag;
            headerLeft.appendChild(span);
          });
        }

        const headerRight = previewContent.querySelector('.newsprint-article-header-right');
        if (headerRight) {
          headerRight.innerHTML = '';
          const readSpan = document.createElement('span');
          readSpan.textContent = `${readingTime} min read`;
          headerRight.appendChild(readSpan);
          const timeEl = document.createElement('time');
          timeEl.dateTime = new Date().toISOString();
          timeEl.textContent = new Date().toLocaleDateString('en-US');
          headerRight.appendChild(timeEl);
        }

        const previewProse = previewContent.querySelector('.newsprint-prose');
        if (previewProse) {
          previewProse.innerHTML = marked.parse(markdown) as string;
        }
      }

      const editionEl = previewMode?.querySelector('.newsprint-kicker span:nth-child(2)');
      if (editionEl) {
        editionEl.textContent = EDITION_MAP[category] || 'Deep Dive';
      }

      const focusSection = previewMode?.querySelector('.newsprint-rail section:first-child');
      if (focusSection) {
        const focusItems = FOCUS_MAP[category] || DEFAULT_FOCUS;
        const existingList = focusSection.querySelector('.newsprint-rail-list');
        const existingEmpty = focusSection.querySelector('.newsprint-empty');
        if (existingList) existingList.remove();
        if (existingEmpty) existingEmpty.remove();
        const ul = document.createElement('ul');
        ul.className = 'newsprint-rail-list';
        focusItems.forEach(item => {
          const li = document.createElement('li');
          li.textContent = item;
          ul.appendChild(li);
        });
        focusSection.appendChild(ul);
      }

      if (draftMode) draftMode.style.display = 'none';
      if (previewMode) previewMode.style.display = 'block';
    }

    function switchToDraft() {
      if (draftMode) draftMode.style.display = '';
      if (previewMode) previewMode.style.display = 'none';
    }

    async function handlePublish() {
      const title = titleInput?.value || '';
      if (!title.trim()) {
        showFeedback('error', 'Publish failed: title is required.');
        return;
      }
      try {
        const res = await fetch('/api/admin/blog/status', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: postId, action: 'publish' }),
        });
        if (!res.ok) {
          const err = await res.json();
          throw new Error(err.error || `${res.status}`);
        }
        showFeedback('success', 'Published! Redirecting...');
        const locale = localeSelect?.value || postLocale || 'en';
        const slugEl = adminData?.dataset.slug || '';
        setTimeout(() => { window.location.href = `/${locale}/blog/${slugEl}/`; }, 1500);
      } catch (err) {
        showFeedback('error', `Publish failed: ${err instanceof Error ? err.message : 'unknown error'}`);
      }
    }

    async function handleDelete() {
      const title = titleInput?.value || 'this post';
      if (!confirm(`Delete "${title}"? This cannot be undone.`)) return;
      try {
        const res = await fetch('/api/admin/blog/delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: postId }),
        });
        if (res.ok) {
          window.location.href = '/admin/blog/';
        } else {
          const err = await res.json();
          showFeedback('error', `Delete failed: ${err.error}`);
        }
      } catch (err) {
        showFeedback('error', `Delete failed: ${err instanceof Error ? err.message : 'unknown error'}`);
      }
    }

    async function handlePublishFromDraft() {
      await handleSave();
      await handlePublish();
    }

    // AI panel toggle
    const aiToggleBtn = document.getElementById('btn-ai-toggle');
    const aiCloseBtn = document.getElementById('btn-ai-close');
    const editorLayout = document.querySelector('.admin-editor-layout');
    const aiBackdrop = document.getElementById('ai-backdrop');

    function toggleAiPanel() {
      const isMobile = window.innerWidth < 768;
      if (isMobile) {
        const panel = document.getElementById('ai-panel');
        const isOpen = panel?.classList.contains('admin-ai-panel--open');
        panel?.classList.toggle('admin-ai-panel--open', !isOpen);
        aiBackdrop?.classList.toggle('admin-ai-backdrop--visible', !isOpen);
      } else {
        editorLayout?.classList.toggle('admin-editor-layout--collapsed');
      }
    }

    aiToggleBtn?.addEventListener('click', toggleAiPanel);
    aiCloseBtn?.addEventListener('click', toggleAiPanel);
    aiBackdrop?.addEventListener('click', toggleAiPanel);

    // --- AI Advisor ---
    const aiLoadingEl = document.getElementById('ai-loading');
    const aiLoadingText = document.getElementById('ai-loading-text');
    const aiResultEl = document.getElementById('ai-result');
    const aiActionsContainer = document.getElementById('ai-actions-container');

    const COMMON_ACTIONS: { action: string; label: string; model: string; wide?: boolean }[] = [
      { action: 'outline', label: 'Outline', model: 'gpt-4o' },
      { action: 'draft', label: 'Draft', model: 'gpt-4o' },
      { action: 'rewrite', label: 'Rewrite', model: 'gpt-4o' },
      { action: 'suggest', label: 'Suggest', model: 'gpt-4o-mini' },
      { action: 'review', label: 'Review', model: 'gpt-4o-mini' },
      { action: 'generate', label: 'Generate', model: 'gpt-4o' },
    ];

    const CATEGORY_SPECIAL: Record<string, { action: string; label: string; model: string; wide?: boolean }> = {
      'study': { action: 'conceptcheck', label: 'Concept Check', model: 'gpt-4o-mini', wide: true },
      'career': { action: 'voicecheck', label: 'Voice Check', model: 'gpt-4o-mini', wide: true },
      'project': { action: 'retrocheck', label: 'Retro Check', model: 'gpt-4o-mini', wide: true },
      'work-note': { action: 'retrocheck', label: 'Retro Check', model: 'gpt-4o-mini', wide: true },
      'daily': { action: 'voicecheck', label: 'Voice Check', model: 'gpt-4o-mini', wide: true },
    };

    const TRANSLATE_ACTION = { action: 'translate', label: 'Translate', model: 'gpt-4o', wide: true };

    function getActionsForCategory(category: string) {
      const special = CATEGORY_SPECIAL[category] || CATEGORY_SPECIAL['study'];
      return [...COMMON_ACTIONS, special, TRANSLATE_ACTION];
    }

    let currentAiButtons: HTMLButtonElement[] = [];
    const aiActionLabels = new Map<string, string>();
    const aiResultCache = new Map<string, { html: string; result: any }>();

    function renderAiButtons(category: string) {
      if (!aiActionsContainer) return;
      const actions = getActionsForCategory(category);
      aiActionsContainer.innerHTML = '';
      currentAiButtons = [];
      aiActionLabels.clear();

      for (const a of actions) {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'admin-ai-action-btn' + (a.wide ? ' admin-ai-action-btn--wide' : '');
        btn.dataset.aiAction = a.action;
        btn.textContent = a.label;
        const modelSpan = document.createElement('span');
        modelSpan.className = 'ai-btn-model';
        modelSpan.textContent = a.model;
        btn.appendChild(modelSpan);
        btn.addEventListener('click', () => runAiAction(a.action));
        if (aiResultCache.has(a.action)) {
          const dot = document.createElement('span');
          dot.className = 'ai-btn-cached-dot';
          btn.appendChild(dot);
        }
        aiActionsContainer.appendChild(btn);
        currentAiButtons.push(btn);
        aiActionLabels.set(a.action, a.label);
      }
    }

    renderAiButtons(categorySelect?.value || 'study');

    categorySelect?.addEventListener('change', () => {
      aiResultCache.clear();
      renderAiButtons(categorySelect.value);
      if (aiResultEl) aiResultEl.innerHTML = '';
    });

    function setAiLoading(loading: boolean, action?: string) {
      if (aiLoadingEl) aiLoadingEl.hidden = !loading;
      if (aiLoadingText) aiLoadingText.textContent = loading ? `Running ${action || ''}...` : '';
      if (aiResultEl && loading) aiResultEl.innerHTML = '';
      currentAiButtons.forEach(btn => {
        btn.disabled = loading;
        const a = btn.dataset.aiAction || '';
        if (loading && a === action) {
          btn.classList.add('admin-ai-action-btn--loading');
          const orig = aiActionLabels.get(a) || a;
          btn.childNodes[0].textContent = `${orig}...`;
          const spinner = document.createElement('span');
          spinner.className = 'ai-btn-spinner';
          btn.prepend(spinner);
        } else {
          btn.classList.remove('admin-ai-action-btn--loading');
          btn.querySelector('.ai-btn-spinner')?.remove();
          const orig = aiActionLabels.get(a);
          if (orig && btn.childNodes[0]) btn.childNodes[0].textContent = orig;
        }
      });
    }

    async function runAiAction(action: string, forceRerun = false) {
      if (action === 'translate') {
        runTranslate();
        return;
      }

      // Show cached result if available (unless force re-run)
      const cached = aiResultCache.get(action);
      if (cached && !forceRerun && aiResultEl) {
        aiResultEl.innerHTML = cached.html;
        // Prepend re-run banner
        const banner = document.createElement('div');
        banner.className = 'admin-ai-cached-banner';
        banner.innerHTML = `<span>Cached result</span><button type="button" class="admin-ai-rerun-btn">Re-run</button>`;
        aiResultEl.prepend(banner);
        banner.querySelector('.admin-ai-rerun-btn')?.addEventListener('click', () => runAiAction(action, true));
        return;
      }

      const title = titleInput?.value || '';
      const content = crepe ? crepe.getMarkdown() : '';

      if (action === 'outline' && !title.trim()) {
        showFeedback('error', 'Add a title before generating an outline.');
        return;
      }
      if (action === 'draft') {
        const hasHeadings = /^#{2,3}\s+/m.test(content);
        if (!hasHeadings) {
          showFeedback('error', 'Draft needs an outline with H2/H3 headings first. Try Outline.');
          return;
        }
      }
      if (!title.trim() && !content.trim()) {
        showFeedback('error', 'Write some content before using AI Advisor.');
        return;
      }

      setAiLoading(true, action);

      try {
        const res = await fetch('/api/admin/blog/ai/advise', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            action,
            post_id: postId || 'new',
            title,
            content,
            category: categorySelect?.value || '',
            tags: (tagsInput?.value || '').split(',').map((t: string) => t.trim()).filter(Boolean),
            excerpt: excerptInput?.value || '',
            slug: slugInput?.value || '',
            locale: localeSelect?.value || 'en',
          }),
        });

        if (!res.ok) {
          const err = await res.json().catch(() => ({ detail: res.statusText }));
          const rawMsg = err.detail || err.error || `Error ${res.status}`;
          const msg = typeof rawMsg === 'string' ? rawMsg : JSON.stringify(rawMsg);
          if (res.status === 429) showFeedback('error', 'Too many requests. Wait a minute.');
          else if (res.status === 504) showFeedback('error', 'AI request timed out.');
          else if (res.status === 502) showFeedback('error', 'AI service unavailable.');
          else showFeedback('error', msg);
          setAiLoading(false);
          return;
        }

        const data = await res.json();
        setAiLoading(false);
        renderAiResult(action, data.result);
      } catch (err) {
        setAiLoading(false);
        showFeedback('error', 'AI request failed.');
      }
    }

    function renderAiResult(action: string, result: any) {
      if (!aiResultEl) return;
      if (action === 'outline') renderOutline(result);
      else if (action === 'draft') renderDraft(result);
      else if (action === 'rewrite') renderRewrite(result);
      else if (action === 'suggest') renderSuggest(result);
      else if (action === 'generate') renderGenerate(result);
      else if (action === 'review') renderReview(result);
      else if (action === 'conceptcheck') renderConceptcheck(result);
      else if (action === 'voicecheck') renderVoicecheck(result);
      else if (action === 'retrocheck') renderRetrocheck(result);

      // Cache rendered result
      aiResultCache.set(action, { html: aiResultEl.innerHTML, result });
      // Update dot indicators on buttons
      currentAiButtons.forEach(btn => {
        const a = btn.dataset.aiAction || '';
        if (a === action && !btn.querySelector('.ai-btn-cached-dot')) {
          const dot = document.createElement('span');
          dot.className = 'ai-btn-cached-dot';
          btn.appendChild(dot);
        }
      });
    }

    function renderGenerate(r: any) {
      if (!aiResultEl) return;
      let html = '<h4>Generated Metadata</h4>';
      if (r.title_suggestions?.length) {
        html += '<h4>Title Suggestions</h4>';
        r.title_suggestions.forEach((t: string) => {
          html += `<div class="admin-ai-suggestion"><span class="admin-ai-suggestion-text">${esc(t)}</span><button class="admin-ai-apply-btn" data-apply="title" data-value="${esc(t)}">Use</button></div>`;
        });
      }
      if (r.excerpt) html += `<div class="admin-ai-suggestion"><span class="admin-ai-suggestion-text"><strong>Excerpt:</strong> ${esc(r.excerpt)}</span><button class="admin-ai-apply-btn" data-apply="excerpt">Use</button></div>`;
      if (r.slug) html += `<div class="admin-ai-suggestion"><span class="admin-ai-suggestion-text"><strong>Slug:</strong> ${esc(r.slug)}</span><button class="admin-ai-apply-btn" data-apply="slug">Use</button></div>`;
      if (r.tags?.length) html += `<div class="admin-ai-suggestion"><span class="admin-ai-suggestion-text"><strong>Tags:</strong> ${r.tags.map(esc).join(', ')}</span><button class="admin-ai-apply-btn" data-apply="tags" data-value="${esc(r.tags.join(', '))}">Use</button></div>`;
      if (r.focus_items?.length) html += `<div class="admin-ai-suggestion"><span class="admin-ai-suggestion-text"><strong>Focus Items:</strong> ${r.focus_items.map(esc).join(' · ')}</span><button class="admin-ai-apply-btn" data-apply="focus_items" data-value="${esc(r.focus_items.join(', '))}">Use</button></div>`;
      html += `<button class="admin-ai-apply-all-btn" id="ai-apply-all-generate">Apply All</button>`;
      aiResultEl.innerHTML = html;

      aiResultEl.querySelectorAll<HTMLButtonElement>('.admin-ai-apply-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const field = btn.dataset.apply;
          if (!field) return;
          let newVal = '';
          if (field === 'title') newVal = btn.dataset.value || '';
          else if (field === 'excerpt') newVal = r.excerpt;
          else if (field === 'slug') newVal = r.slug;
          else if (field === 'tags') newVal = btn.dataset.value || r.tags.join(', ');
          else if (field === 'focus_items') newVal = btn.dataset.value || r.focus_items.join(', ');
          showDiff(btn, field, newVal);
        });
      });

      document.getElementById('ai-apply-all-generate')?.addEventListener('click', () => {
        if (r.excerpt && excerptInput) { previousValues.set('excerpt', excerptInput.value); excerptInput.value = r.excerpt; }
        if (r.slug && slugInput) { previousValues.set('slug', slugInput.value); slugInput.value = r.slug; }
        if (r.tags?.length && tagsInput) { previousValues.set('tags', tagsInput.value); tagsInput.value = r.tags.join(', '); }
        if (r.focus_items?.length && focusItemsInput) { previousValues.set('focus_items', focusItemsInput.value); focusItemsInput.value = r.focus_items.join(', '); }
        showFeedback('success', 'All fields applied.');
      });
    }

    function renderOutline(r: any) {
      if (!aiResultEl) return;
      let html = '<h4>Outline</h4>';
      if (r.sections?.length) {
        r.sections.forEach((s: any, i: number) => {
          html += `<div class="admin-ai-claim"><div class="admin-ai-claim-text"><strong>${esc(s.heading)}</strong></div>`;
          if (s.description) html += `<div class="admin-ai-checklist-suggestion">${esc(s.description)}</div>`;
          if (s.subsections?.length) {
            html += '<ul style="margin:0.25rem 0 0.5rem 1rem;padding:0;">';
            s.subsections.forEach((sub: string) => { html += `<li>${esc(sub)}</li>`; });
            html += '</ul>';
          }
          html += '</div>';
        });
      }
      html += `<button class="admin-ai-apply-all-btn" id="ai-apply-outline">Apply to Editor</button>`;
      aiResultEl.innerHTML = html;

      document.getElementById('ai-apply-outline')?.addEventListener('click', () => {
        if (!crepe || !r.sections?.length) return;
        let md = '';
        r.sections.forEach((s: any) => {
          md += `## ${s.heading}\n\n`;
          if (s.subsections?.length) {
            s.subsections.forEach((sub: string) => { md += `### ${sub}\n\n`; });
          }
        });
        setEditorContent(md.trim());
        showFeedback('success', 'Outline applied to editor.');
      });
    }

    function renderDraft(r: any) {
      if (!aiResultEl) return;
      let html = '<h4>Draft</h4>';
      if (r.content) {
        const preview = r.content.length > 500 ? r.content.slice(0, 500) + '…' : r.content;
        html += `<div class="admin-ai-claim"><div class="admin-ai-claim-text" style="white-space:pre-wrap;font-size:0.85rem;">${esc(preview)}</div></div>`;
      }
      html += `<button class="admin-ai-apply-all-btn" id="ai-apply-draft">Apply to Editor</button>`;
      aiResultEl.innerHTML = html;

      document.getElementById('ai-apply-draft')?.addEventListener('click', () => {
        if (!crepe || !r.content) return;
        setEditorContent(r.content);
        showFeedback('success', 'Draft applied to editor.');
      });
    }

    function renderRewrite(r: any) {
      if (!aiResultEl) return;
      let html = '<h4>Rewrite Suggestions</h4>';
      if (r.changes?.length) {
        r.changes.forEach((c: any, i: number) => {
          html += `<div class="admin-ai-claim">`;
          html += `<div class="admin-ai-claim-text"><strong>${esc(c.section)}</strong></div>`;
          html += `<div class="admin-ai-claim-meta"><span class="admin-ai-verdict admin-ai-verdict--no_source">Before</span></div>`;
          html += `<div class="admin-ai-checklist-suggestion" style="text-decoration:line-through;opacity:0.6;">${esc(c.before)}</div>`;
          html += `<div class="admin-ai-claim-meta"><span class="admin-ai-verdict admin-ai-verdict--verified">After</span></div>`;
          html += `<div class="admin-ai-checklist-suggestion">${esc(c.after)}</div>`;
          if (c.reason) html += `<div class="admin-ai-checklist-suggestion" style="font-style:italic;">${esc(c.reason)}</div>`;
          html += `<button class="admin-ai-apply-btn ai-rewrite-apply" data-idx="${i}">Apply</button>`;
          html += `</div>`;
        });
      }
      aiResultEl.innerHTML = html;

      aiResultEl.querySelectorAll<HTMLButtonElement>('.ai-rewrite-apply').forEach(btn => {
        btn.addEventListener('click', () => {
          const idx = parseInt(btn.dataset.idx || '0', 10);
          const change = r.changes?.[idx];
          if (!crepe || !change) return;
          const md = crepe.getMarkdown();
          if (md.includes(change.before)) {
            setEditorContent(md.replace(change.before, change.after));
            btn.textContent = 'Applied';
            btn.disabled = true;
            showFeedback('success', `Applied rewrite for "${change.section}".`);
          } else {
            showFeedback('error', 'Could not find the original text in editor.');
          }
        });
      });
    }

    function renderSuggest(r: any) {
      if (!aiResultEl) return;
      let html = '<h4>Suggestions</h4>';
      if (r.suggestions?.length) {
        const sorted = [...r.suggestions].sort((a: any, b: any) => {
          const prio: Record<string, number> = { high: 0, medium: 1, low: 2 };
          return (prio[a.priority] ?? 1) - (prio[b.priority] ?? 1);
        });
        sorted.forEach((s: any) => {
          const prioClass = s.priority === 'high' ? 'fail' : s.priority === 'low' ? 'pass' : 'warn';
          html += `<div class="admin-ai-checklist-item">`;
          html += `<span class="admin-ai-status-badge admin-ai-status-badge--${prioClass}">${esc(s.priority)}</span>`;
          html += `<span><strong>[${esc(s.type)}]</strong> ${esc(s.section)}: ${esc(s.message)}</span>`;
          html += `</div>`;
        });
      }
      aiResultEl.innerHTML = html;
    }

    async function runTranslate() {
      const title = titleInput?.value || '';
      const content = crepe ? crepe.getMarkdown() : '';
      if (!title.trim() || !content.trim()) {
        showFeedback('error', 'Title and content are required for translation.');
        return;
      }

      setAiLoading(true, 'translate');

      try {
        const res = await fetch('/api/admin/blog/ai/translate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            title,
            content,
            excerpt: excerptInput?.value || '',
            tags: (tagsInput?.value || '').split(',').map((t: string) => t.trim()).filter(Boolean),
            category: categorySelect?.value || '',
            locale: document.documentElement.lang === 'ko' ? 'ko' : 'en',
            source_post_id: postId || '',
          }),
        });

        if (!res.ok) {
          const err = await res.json().catch(() => ({ detail: res.statusText }));
          const rawMsg = err.detail || err.error || `Error ${res.status}`;
          const msg = typeof rawMsg === 'string' ? rawMsg : JSON.stringify(rawMsg);
          if (res.status === 429) showFeedback('error', 'Too many requests. Wait a minute.');
          else showFeedback('error', msg);
          setAiLoading(false);
          return;
        }

        const data = await res.json();
        setAiLoading(false);

        if (!data.success && data.translated_slug) {
          if (aiResultEl) {
            aiResultEl.innerHTML = `<h4>Translation Exists</h4><p>A translation already exists.</p><a href="/admin/blog/edit/${esc(data.translated_slug)}" class="admin-ai-apply-all-btn" style="display:inline-block;text-decoration:none;text-align:center;">Open Translation</a>`;
          }
          return;
        }

        if (data.success && data.translated_slug) {
          showFeedback('success', 'Translation created!');
          window.location.href = `/admin/blog/edit/${data.translated_slug}`;
        }
      } catch (err) {
        setAiLoading(false);
        showFeedback('error', 'Translation request failed.');
      }
    }

    function renderReview(r: any) {
      if (!aiResultEl) return;
      let html = '';
      if (typeof r.score === 'number') html += `<div class="admin-ai-score">${r.score}/100</div>`;
      if (r.summary) html += `<p>${esc(r.summary)}</p>`;
      if (r.checklist?.length) {
        html += '<h4>Checklist</h4>';
        r.checklist.forEach((item: any) => {
          html += `<div class="admin-ai-checklist-item"><span class="admin-ai-status-badge admin-ai-status-badge--${item.status}">${item.status}</span><span><strong>${esc(item.category)}</strong>: ${esc(item.message)}</span></div>`;
          if (item.suggestion && item.status !== 'pass') html += `<div class="admin-ai-checklist-suggestion">${esc(item.suggestion)}</div>`;
        });
      }
      aiResultEl.innerHTML = html;
    }

    function renderConceptcheck(r: any) {
      if (!aiResultEl) return;
      let html = '';
      if (r.overall_accuracy) html += `<span class="admin-ai-confidence admin-ai-confidence--${r.overall_accuracy}">Accuracy: ${r.overall_accuracy}</span>`;
      if (r.depth_assessment) html += `<span class="admin-ai-depth-badge">${r.depth_assessment}</span>`;
      if (r.concepts?.length) {
        html += '<h4>Concepts</h4>';
        const verdictMap: Record<string, string> = { accurate: 'verified', unclear: 'unverified', incorrect: 'no_source' };
        r.concepts.forEach((c: any) => {
          const cssVerdict = verdictMap[c.verdict] || c.verdict;
          html += `<div class="admin-ai-claim"><div class="admin-ai-claim-text">${esc(c.concept)}</div><div class="admin-ai-claim-meta"><span class="admin-ai-verdict admin-ai-verdict--${cssVerdict}">${c.verdict}</span>`;
          if (c.note) html += `<span>${esc(c.note)}</span>`;
          html += `</div>`;
          if (c.suggestion) html += `<div class="admin-ai-checklist-suggestion">${esc(c.suggestion)}</div>`;
          html += `</div>`;
        });
      }
      if (r.missing_concepts?.length) {
        html += '<h4>Missing Concepts</h4>';
        r.missing_concepts.forEach((mc: string) => { html += `<div class="admin-ai-suggestion"><span class="admin-ai-suggestion-text">${esc(mc)}</span></div>`; });
      }
      aiResultEl.innerHTML = html;
    }

    function renderVoicecheck(r: any) {
      if (!aiResultEl) return;
      let html = '';
      if (r.overall_voice) {
        const voiceMap: Record<string, string> = { authentic: 'high', mixed: 'medium', generic: 'low' };
        html += `<span class="admin-ai-confidence admin-ai-confidence--${voiceMap[r.overall_voice] || 'medium'}">Voice: ${r.overall_voice}</span>`;
      }
      if (r.tone_profile) {
        const tp = r.tone_profile;
        html += '<h4>Tone Profile</h4><div class="admin-ai-tone-profile">';
        for (const [key, val] of Object.entries(tp)) {
          const v = val as number;
          html += `<div class="admin-ai-score-row"><span class="admin-ai-score-label">${esc(key)}</span><div class="admin-ai-score-bar"><div class="admin-ai-score-fill" style="width: ${v}%;"></div></div><span class="admin-ai-score-value">${v}</span></div>`;
        }
        html += '</div>';
      }
      if (r.sections?.length) {
        html += '<h4>Section Analysis</h4>';
        r.sections.forEach((s: any) => {
          const hasIssue = s.issue && s.issue.length > 0;
          const statusClass = hasIssue ? 'warn' : 'pass';
          html += `<div class="admin-ai-checklist-item"><span class="admin-ai-status-badge admin-ai-status-badge--${statusClass}">${hasIssue ? 'warn' : 'pass'}</span><span><strong>${esc(s.section)}</strong>: ${esc(s.assessment)}</span></div>`;
          if (s.suggestion) html += `<div class="admin-ai-checklist-suggestion">${esc(s.suggestion)}</div>`;
        });
      }
      if (r.generic_phrases?.length) {
        html += '<h4>Generic Phrases to Replace</h4>';
        r.generic_phrases.forEach((p: string) => { html += `<div class="admin-ai-suggestion"><span class="admin-ai-suggestion-text admin-ai-generic-phrase">"${esc(p)}"</span></div>`; });
      }
      aiResultEl.innerHTML = html;
    }

    function renderRetrocheck(r: any) {
      if (!aiResultEl) return;
      let html = '';
      if (r.overall_quality) {
        const qualityMap: Record<string, string> = { 'publication-ready': 'high', 'needs-work': 'medium', 'incomplete': 'low' };
        html += `<span class="admin-ai-confidence admin-ai-confidence--${qualityMap[r.overall_quality] || 'medium'}">Quality: ${r.overall_quality}</span>`;
      }
      html += '<div class="admin-ai-retro-stats">';
      html += `<div class="admin-ai-stat"><span class="admin-ai-stat-value">${r.decisions_documented ?? 0}</span><span class="admin-ai-stat-label">Decisions</span></div>`;
      html += `<div class="admin-ai-stat"><span class="admin-ai-stat-value">${r.lessons_extracted ?? 0}</span><span class="admin-ai-stat-label">Lessons</span></div>`;
      html += `<div class="admin-ai-stat"><span class="admin-ai-stat-value">${r.metrics_included ? 'Yes' : 'No'}</span><span class="admin-ai-stat-label">Metrics</span></div>`;
      html += '</div>';
      if (r.sections?.length) {
        html += '<h4>Section Quality</h4>';
        const statusMap: Record<string, string> = { present: 'pass', weak: 'warn', missing: 'fail' };
        r.sections.forEach((s: any) => {
          const css = statusMap[s.status] || s.status;
          html += `<div class="admin-ai-checklist-item"><span class="admin-ai-status-badge admin-ai-status-badge--${css}">${s.status}</span><span><strong>${esc(s.section)}</strong>: ${esc(s.note)}</span></div>`;
          if (s.suggestion) html += `<div class="admin-ai-checklist-suggestion">${esc(s.suggestion)}</div>`;
        });
      }
      aiResultEl.innerHTML = html;
    }

    function esc(s: string): string {
      const d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML.replace(/"/g, '&quot;');
    }

    // Event listeners
    btnSave?.addEventListener('click', handleSave);
    btnPreview?.addEventListener('click', switchToPreview);
    btnEdit?.addEventListener('click', switchToDraft);
    btnPublish?.addEventListener('click', handlePublish);
    btnDelete?.addEventListener('click', handleDelete);
    btnPublishDraft?.addEventListener('click', handlePublishFromDraft);

    initEditor();
  });
</script>
