<script is:inline nonce={Astro.locals.cspNonce || ''}>
  (function() {
    var tabs = document.querySelectorAll('.pcosts-tab');
    var panels = {
      news: document.getElementById('tab-news'),
      handbook: document.getElementById('tab-handbook'),
    };
    tabs.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var target = btn.getAttribute('data-tab');
        tabs.forEach(function(t) { t.classList.remove('pcosts-tab--active'); });
        btn.classList.add('pcosts-tab--active');
        Object.keys(panels).forEach(function(key) {
          if (panels[key]) panels[key].style.display = key === target ? '' : 'none';
        });
      });
    });
  })();
</script>

<script is:inline nonce={Astro.locals.cspNonce || ''}>
  (function() {
    var pipelineBtn = document.getElementById('run-pipeline-btn');
    var pipelineFeedback = document.getElementById('run-pipeline-feedback');
    var dateInput = document.getElementById('pipeline-target-date');
    var handbookCheckbox = document.getElementById('include-handbook');

    function setPipelineFeedback(message, state) {
      if (!pipelineFeedback) return;
      pipelineFeedback.textContent = message;
      if (state) {
        pipelineFeedback.dataset.state = state;
      } else {
        delete pipelineFeedback.dataset.state;
      }
    }

    function firePipelineRequest(mode, targetDate, force) {
      var reqBody = { mode: mode };
      if (targetDate) reqBody.target_date = targetDate;
      if (force) reqBody.force = true;
      if (handbookCheckbox && !handbookCheckbox.checked) reqBody.skip_handbook = true;
      return fetch('/api/admin/run-pipeline', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(reqBody),
      }).then(function(res) {
        return res.json().catch(function() { return null; }).then(function(payload) {
          return { res: res, payload: payload };
        });
      });
    }

    if (pipelineBtn && !pipelineBtn.dataset.init) {
      pipelineBtn.dataset.init = '1';
      pipelineBtn.addEventListener('click', function() {
        pipelineBtn.setAttribute('disabled', 'true');
        pipelineBtn.textContent = 'Running...';
        setPipelineFeedback('');
        var targetDate = dateInput ? dateInput.value || null : null;

        firePipelineRequest('resume', targetDate, false).then(function(result) {
          var res = result.res;
          var payload = result.payload;

          // Handle duplicate batch
          if (res.status === 409) {
            var detail = (payload && payload.data && payload.data.detail) || (payload && payload.detail) || payload;
            var existing = (detail && detail.existing) || {};
            var msg = (detail && detail.batch_id || targetDate || 'today') + ' already has data:\n'
              + (existing.post_count != null ? existing.post_count : '?') + ' posts, '
              + (existing.run_count != null ? existing.run_count : '?') + ' pipeline runs.\n\n'
              + 'Overwrite existing data?';
            if (!window.confirm(msg)) {
              pipelineBtn.textContent = 'Run Pipeline';
              pipelineBtn.removeAttribute('disabled');
              setPipelineFeedback('Cancelled — existing data kept.', 'error');
              return;
            }
            return firePipelineRequest('resume', targetDate, true).then(function(r2) {
              return handleResponse(r2.res, r2.payload);
            });
          }

          return handleResponse(res, payload);
        }).catch(function(error) {
          pipelineBtn.textContent = 'Failed';
          var message = error instanceof Error ? error.message : 'Failed to trigger pipeline';
          setPipelineFeedback(message, 'error');
          setTimeout(function() { pipelineBtn.textContent = 'Run Pipeline'; }, 3000);
          pipelineBtn.removeAttribute('disabled');
        });

        function handleResponse(res, payload) {
          if (res.status === 422) {
            var detail = (payload && payload.data && payload.data.detail) || (payload && payload.detail) || payload;
            throw new Error((detail && detail.message) || 'Cannot overwrite: published posts exist.');
          }
          if (!res.ok) {
            var message = (payload && payload.error) || 'HTTP ' + res.status;
            if (res.status === 401) message = (payload && payload.error) || 'Unauthorized';
            else if (res.status === 403) message = (payload && payload.error) || 'Admin access required';
            else if (res.status === 500) message = 'Missing pipeline configuration';
            else if (res.status === 503) message = (payload && (payload.message || payload.error)) || 'Admin verification unavailable';
            else if (res.status === 502) message = (payload && (payload.message || (payload.data && payload.data.message))) || 'Backend trigger failed';
            throw new Error(message);
          }
          pipelineBtn.textContent = 'Started';
          var dateLabel = (dateInput && dateInput.value) || 'today';
          setPipelineFeedback((payload && payload.data && payload.data.message) || 'Pipeline queued for ' + dateLabel + '.', 'success');
          setTimeout(function() { window.location.reload(); }, 2000);
        }
      });
    }

    // Retry Handbook button handler
    var retryHandbookBtn = document.getElementById('retry-handbook-btn');
    if (retryHandbookBtn) {
      retryHandbookBtn.addEventListener('click', function() {
        var batchId = retryHandbookBtn.dataset.batchId;
        if (!batchId) return;
        retryHandbookBtn.textContent = 'Retrying...';
        retryHandbookBtn.setAttribute('disabled', 'true');
        fetch('/api/admin/run-pipeline', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ mode: 'handbook-extract', target_date: batchId }),
        }).then(function(res) {
          if (!res.ok) {
            return res.json().catch(function() { return null; }).then(function(payload) {
              throw new Error((payload && payload.error) || 'HTTP ' + res.status);
            });
          }
          retryHandbookBtn.textContent = 'Started';
          setPipelineFeedback('Handbook extraction retrying for ' + batchId, 'success');
          setTimeout(function() { window.location.reload(); }, 2000);
        }).catch(function(error) {
          retryHandbookBtn.textContent = 'Failed';
          var message = error instanceof Error ? error.message : 'Failed to retry handbook';
          setPipelineFeedback(message, 'error');
          setTimeout(function() { retryHandbookBtn.textContent = 'Retry Handbook'; }, 3000);
        });
      });
    }

    // Cancel pipeline button handler
    var cancelBtn = document.getElementById('cancel-pipeline-btn');
    if (cancelBtn) {
      cancelBtn.addEventListener('click', function() {
        var runId = cancelBtn.dataset.runId;
        if (!runId) return;
        cancelBtn.textContent = 'Cancelling...';
        cancelBtn.setAttribute('disabled', 'true');
        fetch('/api/admin/pipeline-cancel', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ run_id: runId }),
        }).then(function(res) {
          if (!res.ok) throw new Error('Cancel failed');
          setPipelineFeedback('Pipeline cancelled.', 'success');
          setTimeout(function() { window.location.reload(); }, 1500);
        }).catch(function() {
          cancelBtn.textContent = 'Failed';
          setTimeout(function() { cancelBtn.textContent = 'Cancel'; }, 2000);
        });
      });
    }

    // Handbook auto-extract toggle
    var autoExtractCheckbox = document.getElementById('handbook-auto-extract');
    if (autoExtractCheckbox && !autoExtractCheckbox.dataset.init) {
      autoExtractCheckbox.dataset.init = '1';
      autoExtractCheckbox.addEventListener('change', function() {
        var enabled = autoExtractCheckbox.checked;
        fetch('/api/admin/settings', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ key: 'handbook_auto_extract', value: enabled }),
        }).then(function(res) {
          if (!res.ok) throw new Error('Save failed');
          setPipelineFeedback('Handbook auto-extract ' + (enabled ? 'enabled' : 'disabled') + ' for cron runs.', 'success');
        }).catch(function() {
          autoExtractCheckbox.checked = !enabled;
          setPipelineFeedback('Failed to save setting.', 'error');
        });
      });
    }
  })();
</script>
