---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import AdminSidebar from '../../../components/admin/AdminSidebar.astro';
import { createClient } from '@supabase/supabase-js';
import { formatPipelineError } from '../../../lib/admin/pipelineError.js';

const accessToken = Astro.locals.accessToken;
const sb = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
);

type PipelineRun = {
  id: string;
  run_key: string;
  status: string;
  started_at: string;
  finished_at: string | null;
  last_error: string | null;
};

type PipelineLog = {
  run_id: string;
  cost_usd: number | string | null;
  tokens_used: number | null;
};

type RunCard = PipelineRun & {
  totalCost: number | null;
  totalTokens: number | null;
  stageCount: number | null;
  hasUsageMetrics: boolean;
  errorSummary: string;
  durationSeconds: number | null;
  statusTone: 'success' | 'failed' | 'running' | 'idle';
};

const runs: RunCard[] = [];

// Pipeline Status box data
let lastRun: PipelineRun | null = null;
let lastRunError = '';
let pipelineCost = 0;
let pipelineTokens = 0;
let candidatesTotal = 0;
let candidatesSelected = 0;
let lastHandbookRun: { id: string; run_key: string; status: string; started_at: string; last_error: string | null } | null = null;
let handbookAutoExtract = true;

function statusTone(status: string | null | undefined): RunCard['statusTone'] {
  if (status === 'success') return 'success';
  if (status === 'failed') return 'failed';
  if (status === 'running') return 'running';
  return 'idle';
}

function relativeTime(dateStr: string): string {
  const diff = Date.now() - new Date(dateStr).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return `${mins}m ago`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return `${hrs}h ago`;
  const days = Math.floor(hrs / 24);
  return `${days}d ago`;
}

function formatDateTime(dateStr: string | null): string {
  if (!dateStr) return 'In progress';
  return new Date(dateStr).toLocaleString('en-US', {
    month: 'short',
    day: 'numeric',
    hour: 'numeric',
    minute: '2-digit',
  });
}

function durationSeconds(startedAt: string, finishedAt: string | null): number | null {
  if (!finishedAt) return null;
  return Math.max(0, Math.round((new Date(finishedAt).getTime() - new Date(startedAt).getTime()) / 1000));
}

function metricText(value: number | null, formatter?: (num: number) => string): string {
  if (value === null) return '—';
  return formatter ? formatter(value) : String(value);
}

function parseCost(value: number | string | null): number | null {
  if (value === null || value === undefined || value === '') return null;
  const parsed = Number.parseFloat(String(value));
  return Number.isFinite(parsed) ? parsed : null;
}

try {
  const { data: runRows } = await sb
    .from('pipeline_runs')
    .select('*')
    .order('started_at', { ascending: false })
    .limit(30);
  const pipelineRuns = (runRows ?? []) as PipelineRun[];
  const runIds = pipelineRuns.map((run) => run.id);
  const { data: logs } = runIds.length
    ? await sb.from('pipeline_logs').select('run_id, cost_usd, tokens_used').in('run_id', runIds)
    : { data: [] };

  const totals = new Map<
    string,
    {
      totalCost: number | null;
      totalTokens: number | null;
      stageCount: number;
      hasUsageMetrics: boolean;
    }
  >();
  for (const log of (logs ?? []) as PipelineLog[]) {
    const current = totals.get(log.run_id) ?? {
      totalCost: null,
      totalTokens: null,
      stageCount: 0,
      hasUsageMetrics: false,
    };
    const parsedCost = parseCost(log.cost_usd);
    if (parsedCost !== null) {
      current.totalCost = (current.totalCost ?? 0) + parsedCost;
      current.hasUsageMetrics = true;
    }
    if (typeof log.tokens_used === 'number') {
      current.totalTokens = (current.totalTokens ?? 0) + log.tokens_used;
      current.hasUsageMetrics = true;
    }
    current.stageCount += 1;
    totals.set(log.run_id, current);
  }

  for (const run of pipelineRuns) {
    const metric = totals.get(run.id);
    runs.push({
      ...run,
      totalCost: metric?.totalCost ?? null,
      totalTokens: metric?.totalTokens ?? null,
      stageCount: metric?.stageCount ?? null,
      hasUsageMetrics: metric?.hasUsageMetrics ?? false,
      errorSummary: formatPipelineError(run.last_error),
      durationSeconds: durationSeconds(run.started_at, run.finished_at),
      statusTone: statusTone(run.status),
    });
  }

  // Pipeline Status box: derive from first run
  if (pipelineRuns.length > 0) {
    lastRun = pipelineRuns[0];
    lastRunError = formatPipelineError(lastRun.last_error);
    const statusMetric = totals.get(lastRun.id);
    pipelineCost = statusMetric?.totalCost ?? 0;
    pipelineTokens = statusMetric?.totalTokens ?? 0;

    const { data: cands } = await sb
      .from('news_candidates')
      .select('status')
      .eq('batch_id', lastRun.run_key);
    const candidates = cands ?? [];
    candidatesTotal = candidates.length;
    candidatesSelected = candidates.filter((c: any) => c.status === 'selected' || c.status === 'published').length;
  }

  // Last handbook run for Retry Handbook button
  const { data: hbRunData } = await sb
    .from('pipeline_runs')
    .select('id, run_key, status, started_at, last_error')
    .like('run_key', 'handbook-extract-%')
    .order('started_at', { ascending: false })
    .limit(1)
    .maybeSingle();
  lastHandbookRun = hbRunData ?? null;

  const { data: settingsData } = await sb
    .from('admin_settings').select('value').eq('key', 'handbook_auto_extract').maybeSingle();
  if (settingsData) handbookAutoExtract = settingsData.value !== false;
} catch {}

// Detect stuck pipeline runs — news: 30min, handbook: 60min
const NEWS_TIMEOUT_MS = 30 * 60 * 1000;
const HANDBOOK_TIMEOUT_MS = 60 * 60 * 1000;

function checkStuck(run: any) {
  if (run?.status !== 'running' || !run?.started_at) return false;
  const elapsed = Date.now() - new Date(run.started_at).getTime();
  const isHandbook = run.run_key?.startsWith('handbook-');
  return elapsed > (isHandbook ? HANDBOOK_TIMEOUT_MS : NEWS_TIMEOUT_MS);
}

const isStuck = checkStuck(lastRun);
if (isStuck && lastRun) {
  const isHandbook = lastRun.run_key?.startsWith('handbook-');
  const timeoutMin = isHandbook ? 60 : 30;
  try {
    await sb.from('pipeline_runs').update({
      status: 'failed',
      finished_at: new Date().toISOString(),
      last_error: `Pipeline timed out (>${timeoutMin} minutes)`,
    }).eq('id', lastRun.id).eq('status', 'running');
    lastRun.status = 'failed';
    lastRunError = `Pipeline timed out (>${timeoutMin} minutes)`;
  } catch {}
}

// Show Retry Handbook when:
// 1. Last handbook-extract run failed or stuck running, OR
// 2. News run exists but no handbook-extract run for that batch
const lastNewsBatchId = lastRun?.run_key?.replace('news-', '') ?? '';
const handbookNeedsRetry = lastHandbookRun?.status === 'failed' || lastHandbookRun?.status === 'running';
const newsExistsNoHandbook = !!lastNewsBatchId && !lastHandbookRun;
const showRetryHandbook = handbookNeedsRetry || newsExistsNoHandbook;
const retryBatchId = handbookNeedsRetry
  ? (lastHandbookRun?.run_key?.replace('handbook-extract-', '') ?? '')
  : lastNewsBatchId;

const newsRuns = runs.filter((r) => r.run_key?.startsWith('news-'));
const handbookRuns = runs.filter((r) => r.run_key?.startsWith('handbook-extract-'));

function buildSummary(subset: RunCard[]) {
  const withCost = subset.filter((r) => r.totalCost !== null);
  const withDuration = subset.filter((r) => r.durationSeconds !== null);
  return {
    total: subset.length,
    success: subset.filter((r) => r.status === 'success').length,
    failed: subset.filter((r) => r.status === 'failed').length,
    running: subset.filter((r) => r.status === 'running').length,
    avgCost: withCost.length
      ? withCost.reduce((sum, r) => sum + (r.totalCost ?? 0), 0) / withCost.length
      : null,
    avgDuration: withDuration.length
      ? Math.round(withDuration.reduce((sum, r) => sum + (r.durationSeconds ?? 0), 0) / withDuration.length)
      : 0,
  };
}

const summary = buildSummary(newsRuns);
const handbookSummary = buildSummary(handbookRuns);
---

<MainLayout title="Pipeline Runs" locale="en">
  <AdminSidebar activeSection="pipeline" />
  <div class="admin-dashboard">
    <div class="admin-main admin-main--pipeline-runs">
      <div class="admin-main-header">
        <div class="admin-main-header-top">
          <button class="admin-mobile-menu-btn" id="mobile-menu-btn" type="button" aria-label="Menu">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 5h14M3 10h14M3 15h14" />
            </svg>
          </button>
          <div>
            <p class="pipeline-runs-eyebrow">Monitoring</p>
            <h1 class="admin-main-title">Pipeline Runs</h1>
            <p class="pipeline-runs-subtitle">
              Watch collection, generation, translation, and validation runs without leaving the admin console.
            </p>
          </div>
        </div>
      </div>

      <section class="dashboard-section" style="margin-bottom:1.25rem">
        <h2 class="dashboard-section-title">Pipeline Status</h2>
        {lastRun ? (
          <div class={`dashboard-pipeline dashboard-pipeline--${lastRun.status}`}>
            <div class="dashboard-pipeline-header">
              <span class="dashboard-pipeline-status">
                {lastRun.status === 'success' ? '✓' : lastRun.status === 'failed' ? '✗' : '●'} {lastRun.status}
              </span>
              <span class="dashboard-pipeline-time">{relativeTime(lastRun.started_at)}</span>
            </div>
            <div class="dashboard-pipeline-details">
              {lastRun.finished_at && (
                <span>Duration: {Math.round((new Date(lastRun.finished_at).getTime() - new Date(lastRun.started_at).getTime()) / 1000)}s</span>
              )}
              {candidatesTotal > 0 && (
                <span>Candidates: {candidatesTotal} collected → {candidatesSelected} selected</span>
              )}
              {pipelineCost > 0 && (
                <span>Cost: ${pipelineCost.toFixed(2)} · {pipelineTokens.toLocaleString()} tokens</span>
              )}
            </div>
            {lastRun.status === 'failed' && lastRunError && (
              <div class="dashboard-pipeline-error">{lastRunError}</div>
            )}
            <div class="dashboard-pipeline-actions">
              <input type="date" id="pipeline-target-date" class="admin-input admin-input--date"
                     max={new Date().toISOString().slice(0,10)}
                     title="Leave empty for today" />
              <button type="button" class="admin-btn admin-btn-primary" id="run-pipeline-btn">Run Pipeline</button>
              {lastRun?.status === 'running' && (
                <button type="button" class="admin-btn-danger" id="cancel-pipeline-btn"
                        data-run-id={lastRun.id}>
                  Cancel
                </button>
              )}
              {showRetryHandbook && (
                <button type="button" class="admin-btn" id="retry-handbook-btn"
                        data-batch-id={retryBatchId}
                        title={`Retry handbook extraction for ${retryBatchId}`}>
                  Retry Handbook
                </button>
              )}
              <p class="dashboard-pipeline-feedback" id="run-pipeline-feedback" aria-live="polite"></p>
            </div>
            <div class="dashboard-pipeline-settings">
              <label class="dashboard-pipeline-toggle">
                <input type="checkbox" id="include-handbook" checked />
                Include handbook (manual run)
              </label>
              <label class="dashboard-pipeline-toggle" title="Controls whether the scheduled cron pipeline auto-extracts handbook terms">
                <input type="checkbox" id="handbook-auto-extract" checked={handbookAutoExtract} />
                Auto-extract terms (cron)
              </label>
            </div>
          </div>
        ) : (
          <div class="dashboard-pipeline dashboard-pipeline--none">
            <p class="dashboard-empty">No pipeline runs yet.</p>
            <div class="dashboard-pipeline-actions">
              <input type="date" id="pipeline-target-date" class="admin-input admin-input--date"
                     max={new Date().toISOString().slice(0,10)}
                     title="Leave empty for today" />
              <button type="button" class="admin-btn admin-btn-primary" id="run-pipeline-btn">Run Pipeline</button>
              {showRetryHandbook && (
                <button type="button" class="admin-btn" id="retry-handbook-btn"
                        data-batch-id={retryBatchId}
                        title={`Retry handbook extraction for ${retryBatchId}`}>
                  Retry Handbook
                </button>
              )}
              <p class="dashboard-pipeline-feedback" id="run-pipeline-feedback" aria-live="polite"></p>
            </div>
            <div class="dashboard-pipeline-settings">
              <label class="dashboard-pipeline-toggle">
                <input type="checkbox" id="include-handbook" checked />
                Include handbook (manual run)
              </label>
              <label class="dashboard-pipeline-toggle" title="Controls whether the scheduled cron pipeline auto-extracts handbook terms">
                <input type="checkbox" id="handbook-auto-extract" checked={handbookAutoExtract} />
                Auto-extract terms (cron)
              </label>
            </div>
          </div>
        )}
      </section>

      <div class="pcosts-tabs">
        <button class="pcosts-tab pcosts-tab--active" data-tab="news" type="button">News</button>
        <button class="pcosts-tab" data-tab="handbook" type="button">Handbook</button>
      </div>

      <div id="tab-news">
      <section class="pipeline-runs-summary">
        <div class="pipeline-runs-stat pipeline-runs-stat--neutral">
          <span class="pipeline-runs-stat__label">Recent Runs</span>
          <strong class="pipeline-runs-stat__value">{summary.total}</strong>
          <span class="pipeline-runs-stat__detail">Last 30 executions</span>
        </div>
        <div class="pipeline-runs-stat pipeline-runs-stat--success">
          <span class="pipeline-runs-stat__label">Successful</span>
          <strong class="pipeline-runs-stat__value">{summary.success}</strong>
          <span class="pipeline-runs-stat__detail">Healthy completions</span>
        </div>
        <div class="pipeline-runs-stat pipeline-runs-stat--failed">
          <span class="pipeline-runs-stat__label">Failed</span>
          <strong class="pipeline-runs-stat__value">{summary.failed}</strong>
          <span class="pipeline-runs-stat__detail">Need inspection</span>
        </div>
        <div class="pipeline-runs-stat pipeline-runs-stat--running">
          <span class="pipeline-runs-stat__label">Running</span>
          <strong class="pipeline-runs-stat__value">{summary.running}</strong>
          <span class="pipeline-runs-stat__detail">Active right now</span>
        </div>
        <div class="pipeline-runs-stat pipeline-runs-stat--neutral">
          <span class="pipeline-runs-stat__label">Avg Cost</span>
          <strong class="pipeline-runs-stat__value">
            {summary.avgCost === null ? '—' : `$${summary.avgCost.toFixed(2)}`}
          </strong>
          <span class="pipeline-runs-stat__detail">
            {summary.avgCost === null ? 'No stage cost recorded yet' : 'Per logged run'}
          </span>
        </div>
        <div class="pipeline-runs-stat pipeline-runs-stat--neutral">
          <span class="pipeline-runs-stat__label">Avg Duration</span>
          <strong class="pipeline-runs-stat__value">{summary.avgDuration}s</strong>
          <span class="pipeline-runs-stat__detail">Finished runs only</span>
        </div>
      </section>

      <section class="pipeline-runs-section">
        <div class="pipeline-runs-section__header">
          <div>
            <h2 class="pipeline-runs-section__title">Execution Feed</h2>
            <p class="pipeline-runs-section__hint">
              Each card shows the run key, current status, stage count, token usage, and the latest normalized error.
            </p>
          </div>
        </div>

        {newsRuns.length === 0 ? (
          <p class="dashboard-empty">No news pipeline runs yet.</p>
        ) : (
          <div class="pipeline-run-card-list">
            {newsRuns.map((run) => (
              <a href={`/admin/pipeline-runs/${run.id}`} class={`pipeline-run-card pipeline-run-card--${run.statusTone}`}>
                <div class="pipeline-run-card__top">
                  <div class="pipeline-run-card__identity">
                    <span class={`pipeline-run-status pipeline-run-status--${run.statusTone}`}>{run.status}</span>
                    <strong class="pipeline-run-card__title">{run.run_key}</strong>
                  </div>
                  <div class="pipeline-run-card__time">
                    <span>{relativeTime(run.started_at)}</span>
                    <span>{formatDateTime(run.started_at)}</span>
                  </div>
                </div>

                <div class="pipeline-run-card__metrics">
                  <div class="pipeline-run-chip">
                    <span class="pipeline-run-chip__label">Stages</span>
                    <span class="pipeline-run-chip__value">{metricText(run.stageCount)}</span>
                  </div>
                  <div class="pipeline-run-chip">
                    <span class="pipeline-run-chip__label">Tokens</span>
                    <span class="pipeline-run-chip__value">
                      {metricText(run.totalTokens, (value) => value.toLocaleString())}
                    </span>
                  </div>
                  <div class="pipeline-run-chip">
                    <span class="pipeline-run-chip__label">Cost</span>
                    <span class="pipeline-run-chip__value">
                      {metricText(run.totalCost, (value) => `$${value.toFixed(2)}`)}
                    </span>
                  </div>
                  <div class="pipeline-run-chip">
                    <span class="pipeline-run-chip__label">Duration</span>
                    <span class="pipeline-run-chip__value">
                      {run.durationSeconds === null ? 'Running' : `${run.durationSeconds}s`}
                    </span>
                  </div>
                </div>

                <div class="pipeline-run-card__footer">
                  {run.errorSummary ? (
                    <p class="pipeline-run-card__error">{run.errorSummary}</p>
                  ) : (
                    <p class="pipeline-run-card__ok">No blocking error recorded.</p>
                  )}
                  <span class="pipeline-run-card__cta">Open details</span>
                </div>
              </a>
            ))}
          </div>
        )}
      </section>
      </div>

      <div id="tab-handbook" style="display:none">
      <section class="pipeline-runs-summary">
        <div class="pipeline-runs-stat pipeline-runs-stat--neutral">
          <span class="pipeline-runs-stat__label">Recent Runs</span>
          <strong class="pipeline-runs-stat__value">{handbookSummary.total}</strong>
          <span class="pipeline-runs-stat__detail">Last 30 executions</span>
        </div>
        <div class="pipeline-runs-stat pipeline-runs-stat--success">
          <span class="pipeline-runs-stat__label">Successful</span>
          <strong class="pipeline-runs-stat__value">{handbookSummary.success}</strong>
          <span class="pipeline-runs-stat__detail">Healthy completions</span>
        </div>
        <div class="pipeline-runs-stat pipeline-runs-stat--failed">
          <span class="pipeline-runs-stat__label">Failed</span>
          <strong class="pipeline-runs-stat__value">{handbookSummary.failed}</strong>
          <span class="pipeline-runs-stat__detail">Need inspection</span>
        </div>
        <div class="pipeline-runs-stat pipeline-runs-stat--running">
          <span class="pipeline-runs-stat__label">Running</span>
          <strong class="pipeline-runs-stat__value">{handbookSummary.running}</strong>
          <span class="pipeline-runs-stat__detail">Active right now</span>
        </div>
        <div class="pipeline-runs-stat pipeline-runs-stat--neutral">
          <span class="pipeline-runs-stat__label">Avg Cost</span>
          <strong class="pipeline-runs-stat__value">
            {handbookSummary.avgCost === null ? '—' : `$${handbookSummary.avgCost.toFixed(2)}`}
          </strong>
          <span class="pipeline-runs-stat__detail">
            {handbookSummary.avgCost === null ? 'No stage cost recorded yet' : 'Per logged run'}
          </span>
        </div>
        <div class="pipeline-runs-stat pipeline-runs-stat--neutral">
          <span class="pipeline-runs-stat__label">Avg Duration</span>
          <strong class="pipeline-runs-stat__value">{handbookSummary.avgDuration}s</strong>
          <span class="pipeline-runs-stat__detail">Finished runs only</span>
        </div>
      </section>

      <section class="pipeline-runs-section">
        <div class="pipeline-runs-section__header">
          <div>
            <h2 class="pipeline-runs-section__title">Execution Feed</h2>
            <p class="pipeline-runs-section__hint">
              Each card shows the run key, current status, stage count, token usage, and the latest normalized error.
            </p>
          </div>
        </div>

        {handbookRuns.length === 0 ? (
          <p class="dashboard-empty">No handbook pipeline runs yet.</p>
        ) : (
          <div class="pipeline-run-card-list">
            {handbookRuns.map((run) => (
              <a href={`/admin/pipeline-runs/${run.id}`} class={`pipeline-run-card pipeline-run-card--${run.statusTone}`}>
                <div class="pipeline-run-card__top">
                  <div class="pipeline-run-card__identity">
                    <span class={`pipeline-run-status pipeline-run-status--${run.statusTone}`}>{run.status}</span>
                    <strong class="pipeline-run-card__title">{run.run_key}</strong>
                  </div>
                  <div class="pipeline-run-card__time">
                    <span>{relativeTime(run.started_at)}</span>
                    <span>{formatDateTime(run.started_at)}</span>
                  </div>
                </div>

                <div class="pipeline-run-card__metrics">
                  <div class="pipeline-run-chip">
                    <span class="pipeline-run-chip__label">Stages</span>
                    <span class="pipeline-run-chip__value">{metricText(run.stageCount)}</span>
                  </div>
                  <div class="pipeline-run-chip">
                    <span class="pipeline-run-chip__label">Tokens</span>
                    <span class="pipeline-run-chip__value">
                      {metricText(run.totalTokens, (value) => value.toLocaleString())}
                    </span>
                  </div>
                  <div class="pipeline-run-chip">
                    <span class="pipeline-run-chip__label">Cost</span>
                    <span class="pipeline-run-chip__value">
                      {metricText(run.totalCost, (value) => `$${value.toFixed(2)}`)}
                    </span>
                  </div>
                  <div class="pipeline-run-chip">
                    <span class="pipeline-run-chip__label">Duration</span>
                    <span class="pipeline-run-chip__value">
                      {run.durationSeconds === null ? 'Running' : `${run.durationSeconds}s`}
                    </span>
                  </div>
                </div>

                <div class="pipeline-run-card__footer">
                  {run.errorSummary ? (
                    <p class="pipeline-run-card__error">{run.errorSummary}</p>
                  ) : (
                    <p class="pipeline-run-card__ok">No blocking error recorded.</p>
                  )}
                  <span class="pipeline-run-card__cta">Open details</span>
                </div>
              </a>
            ))}
          </div>
        )}
      </section>
      </div>
    </div>
  </div>
</MainLayout>

<style>
  .admin-main--pipeline-runs {
    max-width: 1120px;
  }

  .pipeline-runs-eyebrow {
    margin: 0 0 0.35rem;
    font-family: var(--font-ui);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .pipeline-runs-subtitle {
    margin: 0.4rem 0 0;
    max-width: 56rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
  }

  .pcosts-tabs {
    display: flex;
    gap: 0;
    border-bottom: 2px solid var(--color-border);
    margin-bottom: 1.25rem;
  }

  .pcosts-tab {
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-muted);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    cursor: pointer;
    transition: color 150ms, border-color 150ms;
  }

  .pcosts-tab:hover {
