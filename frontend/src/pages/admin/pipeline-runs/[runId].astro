---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import AdminSidebar from '../../../components/admin/AdminSidebar.astro';
import { createClient } from '@supabase/supabase-js';
import { formatPipelineError } from '../../../lib/admin/pipelineError.js';

type StatusTone = 'success' | 'failed' | 'running' | 'idle';

type PipelineRun = {
  id: string;
  run_key: string;
  status: string | null;
  started_at: string;
  finished_at: string | null;
  last_error: string | null;
};

type PipelineLog = {
  id: string;
  pipeline_type: string;
  status: string | null;
  created_at: string;
  post_type: string | null;
  locale: string | null;
  attempt: number | null;
  tokens_used: number | null;
  cost_usd: number | string | null;
  error_message: string | null;
  debug_meta: Record<string, unknown> | null;
};

const runId = Astro.params.runId ?? '';
const accessToken = Astro.locals.accessToken;
const sb = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
);

function statusTone(status: string | null | undefined): StatusTone {
  if (status === 'success') return 'success';
  if (status === 'failed') return 'failed';
  if (status === 'running') return 'running';
  return 'idle';
}

function formatDateTime(dateStr: string | null): string {
  if (!dateStr) return 'In progress';
  return new Date(dateStr).toLocaleString('en-US', {
    month: 'short',
    day: 'numeric',
    hour: 'numeric',
    minute: '2-digit',
  });
}

function relativeTime(dateStr: string | null): string {
  if (!dateStr) return 'In progress';
  const diff = Date.now() - new Date(dateStr).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return `${mins}m ago`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return `${hrs}h ago`;
  const days = Math.floor(hrs / 24);
  return `${days}d ago`;
}

function durationSeconds(startedAt: string | null, finishedAt: string | null): number | null {
  if (!startedAt || !finishedAt) return null;
  return Math.max(0, Math.round((new Date(finishedAt).getTime() - new Date(startedAt).getTime()) / 1000));
}

function formatCurrency(value: number): string {
  return `$${value.toFixed(2)}`;
}

function metricText(value: number | null, formatter?: (num: number) => string): string {
  if (value === null) return '—';
  return formatter ? formatter(value) : String(value);
}

function parseCost(value: number | string | null): number | null {
  if (value === null || value === undefined || value === '') return null;
  const parsed = Number.parseFloat(String(value));
  return Number.isFinite(parsed) ? parsed : null;
}

function formatDebugMeta(meta: unknown): string {
  if (!meta || (typeof meta === 'object' && Object.keys(meta as Record<string, unknown>).length === 0)) {
    return '';
  }
  try {
    return JSON.stringify(meta, null, 2);
  } catch {
    return String(meta);
  }
}

function debugMetaObject(log: PipelineLog | null): Record<string, unknown> {
  return log?.debug_meta && typeof log.debug_meta === 'object'
    ? (log.debug_meta as Record<string, unknown>)
    : {};
}

function firstTruthyDebugValue(logs: PipelineLog[], key: string): unknown {
  for (const log of logs) {
    const value = debugMetaObject(log)[key];
    if (value !== undefined && value !== null && value !== false && value !== '') {
      return value;
    }
  }
  return null;
}

function hasTruthyDebugFlag(logs: PipelineLog[], key: string): boolean {
  return logs.some((log) => debugMetaObject(log)[key] === true);
}

let run: PipelineRun | null = null;
let logs: PipelineLog[] = [];

try {
  const [{ data: runRow }, { data: logRows }] = await Promise.all([
    sb.from('pipeline_runs').select('*').eq('id', runId).single(),
    sb.from('pipeline_logs').select('*').eq('run_id', runId).order('created_at', { ascending: true }),
  ]);
  run = (runRow as PipelineRun | null) ?? null;
  logs = ((logRows ?? []) as PipelineLog[]).map((log) => ({
    ...log,
    debug_meta: log.debug_meta ?? null,
  }));
} catch {}

const raw_error = run?.last_error || '';
const normalizedError = formatPipelineError(raw_error);
const tone = statusTone(run?.status);
const hasStageLogs = logs.length > 0;
const hasTokenMetrics = logs.some((log) => typeof log.tokens_used === 'number');
const hasCostMetrics = logs.some((log) => parseCost(log.cost_usd) !== null);
const totalTokens = hasTokenMetrics ? logs.reduce((sum, log) => sum + (log.tokens_used ?? 0), 0) : null;
const totalCost = hasCostMetrics
  ? logs.reduce((sum, log) => sum + (parseCost(log.cost_usd) ?? 0), 0)
  : null;
const failedStages = hasStageLogs ? logs.filter((log) => log.status === 'failed').length : null;
const duration = durationSeconds(run?.started_at ?? null, run?.finished_at ?? null);
const latestLog = logs.at(-1) ?? null;

// Cost breakdown: group by pipeline_type for the Cost Breakdown table
type CostBreakdownRow = {
  stage: string;
  inputTokens: number;
  outputTokens: number;
  totalTokens: number;
  costUsd: number;
  attempts: number | null;
};
const costBreakdown: CostBreakdownRow[] = logs
  .filter((log) => log.status === 'success' && (log.tokens_used || parseCost(log.cost_usd)))
  .map((log) => {
    const meta = debugMetaObject(log);
    return {
      stage: log.pipeline_type,
      inputTokens: (meta.input_tokens as number) ?? 0,
      outputTokens: (meta.output_tokens as number) ?? 0,
      totalTokens: log.tokens_used ?? 0,
      costUsd: parseCost(log.cost_usd) ?? 0,
      attempts: (meta.attempts as number) ?? null,
    };
  });
const hasCostBreakdown = costBreakdown.length > 0;

const runMode = String(firstTruthyDebugValue(logs, 'mode') ?? 'resume');
const reusedCandidates = hasTruthyDebugFlag(logs, 'reused_candidates');
const reusedRanking = hasTruthyDebugFlag(logs, 'reused_ranking');
const resumedFromSavedEn = hasTruthyDebugFlag(logs, 'resumed_from_saved_en');
---

<MainLayout title="Pipeline Run Detail" locale="en">
  <AdminSidebar activeSection="pipeline" />
  <div class="admin-dashboard">
    <div class="admin-main admin-main--pipeline-run-detail">
      <div class="admin-main-header">
        <div class="admin-main-header-top">
          <button class="admin-mobile-menu-btn" id="mobile-menu-btn" type="button" aria-label="Menu">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 5h14M3 10h14M3 15h14" />
            </svg>
          </button>
          <div>
            <p class="pipeline-run-detail-eyebrow">Run Snapshot</p>
            <h1 class="admin-main-title">Pipeline Run Detail</h1>
            <p class="pipeline-run-detail-subtitle">
              Review stage timing, validation failures, cost, token usage, and the debugging context attached to each
              step.
            </p>
          </div>
        </div>
      </div>

      <section class={`pipeline-run-hero pipeline-run-hero--${tone}`}>
        <div class="pipeline-run-hero__content">
          <div class="pipeline-run-hero__top">
            <div class="pipeline-run-hero__identity">
              <span class={`pipeline-run-status pipeline-run-status--${tone}`}>{run?.status ?? 'unknown'}</span>
              <strong class="pipeline-run-hero__key">{run?.run_key ?? runId}</strong>
            </div>
            <a href="/admin/pipeline-runs" class="pipeline-run-hero__back">Back to runs</a>
          </div>
          <div class="pipeline-run-hero__meta">
            <span>Started {relativeTime(run?.started_at ?? null)}</span>
            <span>{formatDateTime(run?.started_at ?? null)}</span>
            <span>{run?.finished_at ? `Finished ${formatDateTime(run.finished_at)}` : 'Still running'}</span>
            <span>{latestLog ? `Latest stage: ${latestLog.pipeline_type}` : 'No stage logs yet'}</span>
          </div>
          {normalizedError && (
            <div class="pipeline-run-hero__alert">
              <span class="pipeline-run-hero__alert-label">Latest error</span>
              <p>{normalizedError}</p>
            </div>
          )}
        </div>
      </section>

      <section class="pipeline-run-summary-grid">
        <div class="pipeline-run-stat">
          <span class="pipeline-run-stat__label">Stage Count</span>
          <strong class="pipeline-run-stat__value">{metricText(hasStageLogs ? logs.length : null)}</strong>
          <span class="pipeline-run-stat__detail">
            {hasStageLogs ? 'Tracked log entries for this run' : 'No stage logs recorded for this run'}
          </span>
        </div>
        <div class="pipeline-run-stat">
          <span class="pipeline-run-stat__label">Failed Stages</span>
          <strong class="pipeline-run-stat__value">{metricText(failedStages)}</strong>
          <span class="pipeline-run-stat__detail">
            {hasStageLogs ? 'Entries marked failed' : 'No stage failure data recorded'}
          </span>
        </div>
        <div class="pipeline-run-stat">
          <span class="pipeline-run-stat__label">Total Tokens</span>
          <strong class="pipeline-run-stat__value">
            {metricText(totalTokens, (value) => value.toLocaleString())}
          </strong>
          <span class="pipeline-run-stat__detail">
            {hasTokenMetrics ? 'Across all recorded stages' : 'No token usage recorded for this run'}
          </span>
        </div>
        <div class="pipeline-run-stat">
          <span class="pipeline-run-stat__label">Total Cost</span>
          <strong class="pipeline-run-stat__value">
            {metricText(totalCost, (value) => formatCurrency(value))}
          </strong>
          <span class="pipeline-run-stat__detail">
            {hasCostMetrics ? 'Accumulated stage spend' : 'No cost estimate recorded for this run'}
          </span>
        </div>
        <div class="pipeline-run-stat">
          <span class="pipeline-run-stat__label">Duration</span>
          <strong class="pipeline-run-stat__value">{duration === null ? 'Running' : `${duration}s`}</strong>
          <span class="pipeline-run-stat__detail">From start to finish</span>
        </div>
      </section>

      {hasCostBreakdown && (
        <section class="pipeline-run-section">
          <div class="pipeline-run-section__header">
            <div>
              <h2 class="pipeline-run-section__title">Cost Breakdown</h2>
              <p class="pipeline-run-section__hint">
                Per-stage token usage and estimated cost. Only successful stages with token data are shown.
              </p>
            </div>
          </div>
          <div class="pipeline-cost-table-wrap">
            <table class="pipeline-cost-table">
              <thead>
                <tr>
                  <th>Stage</th>
                  <th>Input</th>
                  <th>Output</th>
                  <th>Total</th>
                  <th>Cost</th>
                  <th>Attempts</th>
                </tr>
              </thead>
              <tbody>
                {costBreakdown.map((row) => (
                  <tr>
                    <td class="pipeline-cost-table__stage">{row.stage}</td>
                    <td>{row.inputTokens ? row.inputTokens.toLocaleString() : '—'}</td>
                    <td>{row.outputTokens ? row.outputTokens.toLocaleString() : '—'}</td>
                    <td>{row.totalTokens ? row.totalTokens.toLocaleString() : '—'}</td>
                    <td>{row.costUsd ? `$${row.costUsd.toFixed(4)}` : '—'}</td>
                    <td>{row.attempts ?? '—'}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      )}

      <section class="pipeline-run-section">
        <div class="pipeline-run-section__header">
          <div>
            <h2 class="pipeline-run-section__title">Reuse Signals</h2>
            <p class="pipeline-run-section__hint">
              These indicators show whether the rerun reused saved snapshots or EN drafts.
            </p>
          </div>
        </div>
        <div class="pipeline-run-summary-grid pipeline-run-summary-grid--reuse">
          <div class="pipeline-run-stat">
            <span class="pipeline-run-stat__label">Run mode</span>
            <strong class="pipeline-run-stat__value">{runMode}</strong>
            <span class="pipeline-run-stat__detail">`resume` reuses saved state when possible.</span>
          </div>
          <div class="pipeline-run-stat">
            <span class="pipeline-run-stat__label">Reused candidates</span>
            <strong class="pipeline-run-stat__value">{reusedCandidates ? 'Yes' : 'No'}</strong>
            <span class="pipeline-run-stat__detail">Saved `news_candidates` snapshot reused.</span>
          </div>
          <div class="pipeline-run-stat">
            <span class="pipeline-run-stat__label">Reused ranking</span>
            <strong class="pipeline-run-stat__value">{reusedRanking ? 'Yes' : 'No'}</strong>
            <span class="pipeline-run-stat__detail">Ranking reconstructed from the saved batch snapshot.</span>
          </div>
          <div class="pipeline-run-stat">
            <span class="pipeline-run-stat__label">Resumed saved EN</span>
            <strong class="pipeline-run-stat__value">{resumedFromSavedEn ? 'Yes' : 'No'}</strong>
            <span class="pipeline-run-stat__detail">Skipped EN regeneration because only KO was missing.</span>
          </div>
        </div>
      </section>

      <section class="pipeline-run-section">
        <div class="pipeline-run-section__header">
          <div>
            <h2 class="pipeline-run-section__title">Stage Timeline</h2>
            <p class="pipeline-run-section__hint">
              This timeline shows exactly which stage ran, how many tokens it used, and the debugging payload saved
              with it.
            </p>
          </div>
        </div>

        {logs.length === 0 ? (
          <p class="dashboard-empty">No pipeline logs recorded for this run yet.</p>
        ) : (
          <div class="pipeline-stage-list">
            {logs.map((log) => {
              const logTone = statusTone(log.status);
              const debugMetaText = formatDebugMeta(log.debug_meta);
              return (
                <article class={`pipeline-stage-card pipeline-stage-card--${logTone}`}>
                  <div class="pipeline-stage-card__rail" aria-hidden="true"></div>
                  <div class="pipeline-stage-card__body">
                    <div class="pipeline-stage-card__header">
                      <div class="pipeline-stage-card__identity">
                        <span class={`pipeline-run-status pipeline-run-status--${logTone}`}>{log.status ?? 'idle'}</span>
                        <strong class="pipeline-stage-card__title">{log.pipeline_type}</strong>
                      </div>
                      <div class="pipeline-stage-card__time">
                        <span>{relativeTime(log.created_at)}</span>
                        <span>{formatDateTime(log.created_at)}</span>
                      </div>
                    </div>

                    <div class="pipeline-stage-card__chips">
                      {log.post_type && (
                        <span class="pipeline-stage-chip">
                          <span class="pipeline-stage-chip__label">Post</span>
                          <span class="pipeline-stage-chip__value">{log.post_type}</span>
                        </span>
                      )}
                      {log.locale && (
                        <span class="pipeline-stage-chip">
                          <span class="pipeline-stage-chip__label">Locale</span>
                          <span class="pipeline-stage-chip__value">{log.locale}</span>
                        </span>
                      )}
                      {typeof log.attempt === 'number' && (
                        <span class="pipeline-stage-chip">
                          <span class="pipeline-stage-chip__label">Attempt</span>
                          <span class="pipeline-stage-chip__value">{log.attempt}</span>
                        </span>
                      )}
                      <span class="pipeline-stage-chip">
                        <span class="pipeline-stage-chip__label">Tokens</span>
                        <span class="pipeline-stage-chip__value">
                          {metricText(log.tokens_used, (value) => value.toLocaleString())}
                        </span>
                      </span>
                      {typeof debugMetaObject(log).input_tokens === 'number' && (
                        <span class="pipeline-stage-chip">
                          <span class="pipeline-stage-chip__label">In</span>
                          <span class="pipeline-stage-chip__value">
                            {(debugMetaObject(log).input_tokens as number).toLocaleString()}
                          </span>
                        </span>
                      )}
                      {typeof debugMetaObject(log).output_tokens === 'number' && (
                        <span class="pipeline-stage-chip">
                          <span class="pipeline-stage-chip__label">Out</span>
                          <span class="pipeline-stage-chip__value">
                            {(debugMetaObject(log).output_tokens as number).toLocaleString()}
                          </span>
                        </span>
                      )}
                      <span class="pipeline-stage-chip">
                        <span class="pipeline-stage-chip__label">Cost</span>
                        <span class="pipeline-stage-chip__value">
                          {metricText(parseCost(log.cost_usd), (value) => formatCurrency(value))}
                        </span>
                      </span>
                      {typeof debugMetaObject(log).attempts === 'number' && (debugMetaObject(log).attempts as number) > 1 && (
                        <span class="pipeline-stage-chip pipeline-stage-chip--warn">
                          <span class="pipeline-stage-chip__label">Retries</span>
                          <span class="pipeline-stage-chip__value">
                            {(debugMetaObject(log).attempts as number) - 1}
                          </span>
                        </span>
                      )}
                      {typeof debugMetaObject(log).quality_score === 'number' && (
                        <span class="pipeline-stage-chip">
                          <span class="pipeline-stage-chip__label">Quality</span>
                          <span class="pipeline-stage-chip__value">
                            {debugMetaObject(log).quality_score}/4
                          </span>
                        </span>
                      )}
                    </div>

                    {log.error_message && <p class="pipeline-stage-card__error">{log.error_message}</p>}

                    {(debugMetaText || log.error_message) && (
                      <div class="pipeline-stage-card__panels">
                        {debugMetaText && (
                          <details class="pipeline-stage-panel">
                            <summary>debug_meta</summary>
                            <pre>{debugMetaText}</pre>
                          </details>
                        )}
                        {log.error_message && (
                          <details class="pipeline-stage-panel">
                            <summary>stage_error</summary>
                            <pre>{log.error_message}</pre>
                          </details>
                        )}
                      </div>
                    )}
                  </div>
                </article>
              );
            })}
          </div>
        )}
      </section>

      {(raw_error || normalizedError) && (
        <section class="pipeline-run-section">
          <div class="pipeline-run-section__header">
            <div>
              <h2 class="pipeline-run-section__title">Failure Capture</h2>
              <p class="pipeline-run-section__hint">
                The dashboard uses the normalized message. The raw payload stays available for deeper debugging.
              </p>
            </div>
          </div>
          {normalizedError && (
            <div class="pipeline-run-error-card">
              <span class="pipeline-run-error-card__label">Normalized error</span>
              <p>{normalizedError}</p>
            </div>
          )}
          {raw_error && (
            <details class="pipeline-stage-panel pipeline-stage-panel--raw">
              <summary>raw_error</summary>
              <pre>{raw_error}</pre>
            </details>
          )}
        </section>
      )}
    </div>
  </div>
</MainLayout>

<style>
  .admin-main--pipeline-run-detail {
    max-width: 1120px;
  }

  .pipeline-run-detail-eyebrow {
    margin: 0 0 0.35rem;
    font-family: var(--font-ui);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .pipeline-run-detail-subtitle {
    margin: 0.4rem 0 0;
    max-width: 58rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
  }

  .pipeline-run-hero {
    margin-bottom: 1rem;
    padding: 1.1rem 1.15rem;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg-secondary) 90%, var(--color-bg-primary));
    box-shadow: 0 18px 32px -26px var(--color-shadow);
  }

  .pipeline-run-hero--success {
    border-color: color-mix(in srgb, var(--color-success) 66%, var(--color-border));
    background: color-mix(in srgb, var(--color-success) 10%, var(--color-bg-secondary));
  }

  .pipeline-run-hero--failed {
    border-color: color-mix(in srgb, var(--color-error) 74%, var(--color-border));
    background: color-mix(in srgb, var(--color-error) 12%, var(--color-bg-secondary));
  }

  .pipeline-run-hero--running {
    border-color: color-mix(in srgb, var(--color-accent) 74%, var(--color-border));
    background: color-mix(in srgb, var(--color-accent) 12%, var(--color-bg-secondary));
  }

  .pipeline-run-hero__top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-start;
  }

  .pipeline-run-hero__identity {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 0;
  }

  .pipeline-run-hero__key {
    font-family: var(--font-code);
    font-size: 1.05rem;
    word-break: break-word;
  }

  .pipeline-run-hero__back {
    align-self: center;
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: 0.86rem;
    font-weight: 700;
  }

  .pipeline-run-hero__back:hover {
    color: var(--color-text-primary);
  }

  .pipeline-run-hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 1rem;
    margin-top: 0.9rem;
    color: var(--color-text-secondary);
    font-size: 0.86rem;
  }

  .pipeline-run-hero__alert {
    margin-top: 0.95rem;
    padding: 0.85rem 0.95rem;
    border: 1px solid color-mix(in srgb, var(--color-error) 40%, var(--color-border));
    background: color-mix(in srgb, var(--color-error) 9%, var(--color-bg-primary));
  }

  .pipeline-run-hero__alert-label {
    display: block;
    margin-bottom: 0.35rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-error);
  }

  .pipeline-run-hero__alert p {
    margin: 0;
    color: var(--color-error);
    line-height: 1.55;
  }

  .pipeline-run-summary-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0.85rem;
    margin-bottom: 1.1rem;
  }

  .pipeline-run-summary-grid--reuse {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .pipeline-run-stat {
    padding: 1rem 1.05rem;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg-secondary) 86%, var(--color-bg-primary));
  }

  .pipeline-run-stat__label {
    display: block;
    margin-bottom: 0.45rem;
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .pipeline-run-stat__value {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.45rem;
    line-height: 1;
    color: var(--color-text-primary);
  }

  .pipeline-run-stat__detail {
    display: block;
    margin-top: 0.45rem;
    color: var(--color-text-secondary);
    font-size: 0.82rem;
    line-height: 1.5;
  }

  .pipeline-run-section {
    margin-bottom: 1rem;
    padding: 1rem;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg-secondary) 74%, transparent);
  }

  .pipeline-run-section__header {
    margin-bottom: 1rem;
  }

  .pipeline-run-section__title {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
  }

  .pipeline-run-section__hint {
    margin: 0.35rem 0 0;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .pipeline-stage-list {
    display: grid;
