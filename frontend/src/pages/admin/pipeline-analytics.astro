---
export const prerender = false;

import MainLayout from '../../layouts/MainLayout.astro';
import AdminSidebar from '../../components/admin/AdminSidebar.astro';
import { createClient } from '@supabase/supabase-js';

const accessToken = Astro.locals.accessToken;
const sb = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
);

// ─── Types ───────────────────────────────────────────────────
type AnalyticsLog = {
  pipeline_type: string;
  status: string | null;
  tokens_used: number | null;
  cost_usd: number | string | null;
  debug_meta: Record<string, unknown> | null;
  created_at: string;
  pipeline_runs: {
    id: string;
    run_key: string;
    status: string | null;
    started_at: string;
  };
};

// ─── Date Filter ────────────────────────────────────────────
const daysParam = Astro.url.searchParams.get('days');
const filterDays = daysParam ? parseInt(daysParam, 10) : 14;
const filterDate = new Date(Date.now() - filterDays * 24 * 60 * 60 * 1000).toISOString();

// ─── Queries ─────────────────────────────────────────────────

const excludeStages = [
  'pipeline', 'research.novelty_gate', 'candidates.save',
  'save.research.en', 'save.research.ko', 'save.business.en', 'save.business.ko',
  'save:research', 'save:business', 'summary',
  'quality.research', 'quality.business',
  'quality:research', 'quality:business',
];

const [{ data: rawLogs }, { data: qualityLogs }, { data: handbookLogs }, { data: hbQualityRows }, { data: runsRaw }] = await Promise.all([
  sb.from('pipeline_logs')
    .select('pipeline_type, status, tokens_used, cost_usd, debug_meta, created_at, pipeline_runs!inner(id, run_key, status, started_at)')
    .gte('pipeline_runs.started_at', filterDate)
    .not('pipeline_type', 'in', `(${excludeStages.map((s) => `"${s}"`).join(',')})`)
    .not('pipeline_type', 'like', 'handbook.%')
    .order('created_at', { ascending: true }),
  sb.from('pipeline_logs')
    .select('debug_meta, pipeline_type, cost_usd, tokens_used, pipeline_runs!inner(id, run_key, started_at)')
    .gte('pipeline_runs.started_at', filterDate)
    .in('pipeline_type', ['quality:research', 'quality:business'])
    .order('created_at', { ascending: true }),
  sb.from('pipeline_logs')
    .select('pipeline_type, status, tokens_used, cost_usd, debug_meta, created_at, run_id')
    .like('pipeline_type', 'handbook.%')
    .gte('created_at', filterDate)
    .order('created_at', { ascending: true }),
  sb.from('handbook_quality_scores')
    .select('term_slug, score, term_type, source, created_at')
    .gte('created_at', filterDate)
    .order('created_at', { ascending: false })
    .limit(50),
  sb.from('pipeline_runs')
    .select('run_key, status, started_at, finished_at')
    .gte('started_at', filterDate)
    .not('run_key', 'like', 'handbook-%')
    .order('started_at', { ascending: true }),
]);

// ─── Helpers ─────────────────────────────────────────────────
function parseCost(value: number | string | null): number {
  if (value === null || value === undefined || value === '') return 0;
  const parsed = Number.parseFloat(String(value));
  return Number.isFinite(parsed) ? parsed : 0;
}

// ─── News Pipeline Data ──────────────────────────────────────
const logs: AnalyticsLog[] = (rawLogs ?? []) as unknown as AnalyticsLog[];

type RunGroup = {
  runKey: string;
  startedAt: string;
  stages: AnalyticsLog[];
  totalCost: number;
  totalTokens: number;
  totalInputTokens: number;
  totalOutputTokens: number;
};

const runMap = new Map<string, RunGroup>();
for (const log of logs) {
  const runId = log.pipeline_runs.id;
  if (!runMap.has(runId)) {
    runMap.set(runId, {
      runKey: log.pipeline_runs.run_key,
      startedAt: log.pipeline_runs.started_at,
      stages: [],
      totalCost: 0,
      totalTokens: 0,
      totalInputTokens: 0,
      totalOutputTokens: 0,
    });
  }
  const group = runMap.get(runId)!;
  group.stages.push(log);
  group.totalCost += parseCost(log.cost_usd);
  group.totalTokens += log.tokens_used ?? 0;
  const meta = (log.debug_meta ?? {}) as Record<string, unknown>;
  group.totalInputTokens += (meta.input_tokens as number) ?? 0;
  group.totalOutputTokens += (meta.output_tokens as number) ?? 0;
}

const runs = Array.from(runMap.values()).sort(
  (a, b) => new Date(a.startedAt).getTime() - new Date(b.startedAt).getTime(),
);

// Group runs by date for chart display
type DateGroup = {
  date: string;
  stages: AnalyticsLog[];
  totalCost: number;
  totalTokens: number;
};

const dateMap = new Map<string, DateGroup>();
for (const run of runs) {
  // Use batch date from run_key (news target date), not execution date
  const batchMatch = run.runKey.match(/\d{4}-\d{2}-\d{2}/);
  const dateKey = batchMatch ? batchMatch[0] : run.startedAt.slice(0, 10);
  if (!dateMap.has(dateKey)) {
    dateMap.set(dateKey, { date: dateKey, stages: [], totalCost: 0, totalTokens: 0 });
  }
  const group = dateMap.get(dateKey)!;
  group.stages.push(...run.stages);
  group.totalCost += run.totalCost;
  group.totalTokens += run.totalTokens;
}

const dateGroups = Array.from(dateMap.values()).sort(
  (a, b) => a.date.localeCompare(b.date),
);

type QualityEntry = { runKey: string; startedAt: string; type: string; score: number };
const qualityEntries: QualityEntry[] = [];
for (const q of (qualityLogs ?? []) as unknown as AnalyticsLog[]) {
  const meta = (q.debug_meta ?? {}) as Record<string, unknown>;
  const score = (typeof meta.quality_score === 'number' ? meta.quality_score : typeof meta.score === 'number' ? meta.score : null) as number | null;
  if (score !== null) {
    qualityEntries.push({
      runKey: q.pipeline_runs.run_key,
      startedAt: q.pipeline_runs.started_at,
      type: q.pipeline_type.replace('quality:', '').replace('quality.', ''),
      score,
    });
  }
}

const stageNames = [
  'collect', 'classify',
  'digest:research:expert', 'digest:research:learner',
  'digest:business:expert', 'digest:business:learner',
  // legacy (for old runs)
  'digest:research:beginner', 'digest:business:beginner',
  'rank', 'research.generate.en', 'research.translate.ko', 'business.generate.en', 'business.translate.ko',
];
const stageLabels: Record<string, string> = {
  'collect': 'Collect', 'classify': 'Classify',
  'digest:research:expert': 'Research Expert', 'digest:research:learner': 'Research Learner',
  'digest:business:expert': 'Business Expert', 'digest:business:learner': 'Business Learner',
  'digest:research:beginner': 'Research Beginner (legacy)', 'digest:business:beginner': 'Business Beginner (legacy)',
  // v2 legacy
  'rank': 'Rank', 'research.generate.en': 'Research EN', 'research.translate.ko': 'Research KO',
  'business.generate.en': 'Business EN', 'business.translate.ko': 'Business KO',
  'quality.research': 'QC Research (legacy)', 'quality.business': 'QC Business (legacy)',
};

type StackedCostData = { label: string; costs: number[]; tokens: number[] };
const stackedData: StackedCostData[] = stageNames.map((stage) => ({
  label: stageLabels[stage] || stage,
  costs: dateGroups.map((dg) => {
    const stageLogs = dg.stages.filter((s) => s.pipeline_type === stage);
    return stageLogs.reduce((sum, s) => sum + parseCost(s.cost_usd), 0);
  }),
  tokens: dateGroups.map((dg) => {
    const stageLogs = dg.stages.filter((s) => s.pipeline_type === stage);
    return stageLogs.reduce((sum, s) => sum + (s.tokens_used ?? 0), 0);
  }),
}));

const totalRunCount = runs.length;
const totalCostAll = runs.reduce((sum, r) => sum + r.totalCost, 0);
const avgCostPerRun = totalRunCount > 0 ? totalCostAll / totalRunCount : 0;
const totalTokensAll = runs.reduce((sum, r) => sum + r.totalTokens, 0);
const avgQuality = qualityEntries.length > 0
  ? qualityEntries.reduce((sum, q) => sum + q.score, 0) / qualityEntries.length
  : null;

// QC cost from quality logs
const qcLogs = (qualityLogs ?? []) as unknown as { cost_usd: number | string | null; tokens_used: number | null }[];
const qcTotalCost = qcLogs.reduce((sum, l) => sum + (Number.parseFloat(String(l.cost_usd ?? 0)) || 0), 0);
const qcTotalTokens = qcLogs.reduce((sum, l) => sum + (l.tokens_used ?? 0), 0);
const qcRunCount = qcLogs.length;

// Pipeline runs: duration + success rate
type PipelineRunEntry = { run_key: string; status: string; started_at: string; finished_at: string | null };
const pipelineRuns = (runsRaw ?? []) as PipelineRunEntry[];
const successCount = pipelineRuns.filter((r) => r.status === 'success').length;
const failCount = pipelineRuns.filter((r) => r.status === 'failed').length;
const totalPipelineRuns = pipelineRuns.length;
const successRate = totalPipelineRuns > 0 ? Math.round((successCount / totalPipelineRuns) * 100) : null;

const durationData = pipelineRuns
  .filter((r) => r.finished_at && r.started_at)
  .map((r) => {
    const dur = Math.round((new Date(r.finished_at!).getTime() - new Date(r.started_at).getTime()) / 1000);
    // Use batch date from run_key (target/publish date), not started_at (execution date)
    const batchMatch = r.run_key.match(/\d{4}-\d{2}-\d{2}/);
    const d = batchMatch ? new Date(batchMatch[0] + 'T00:00:00') : new Date(r.started_at);
    return { label: `${d.getMonth() + 1}/${d.getDate()}`, seconds: dur > 0 ? dur : 0 };
  })
  .sort((a, b) => a.label.localeCompare(b.label));

// Token totals per stage for donut chart
const tokenTotals = stackedData
  .map((s) => ({ label: s.label, total: s.tokens.reduce((sum, t) => sum + t, 0) }))
  .filter((s) => s.total > 0)
  .sort((a, b) => b.total - a.total);

const chartData = {
  runLabels: dateGroups.map((dg) => {
    const d = new Date(dg.date);
    return `${d.getMonth() + 1}/${d.getDate()}`;
  }),
  totalCosts: dateGroups.map((dg) => Number(dg.totalCost.toFixed(4))),
  stacked: stackedData.map((s) => ({
    label: s.label,
    costs: s.costs.map((c) => Number(c.toFixed(6))),
    tokens: s.tokens,
  })),
  tokenDonut: {
    labels: tokenTotals.map((s) => s.label),
    values: tokenTotals.map((s) => s.total),
  },
  quality: {
    research: qualityEntries.filter((q) => q.type === 'research').map((q) => q.score),
    business: qualityEntries.filter((q) => q.type === 'business').map((q) => q.score),
    researchLabels: qualityEntries.filter((q) => q.type === 'research').map((q) => {
      const d = new Date(q.startedAt); return `${d.getMonth() + 1}/${d.getDate()}`;
    }),
    businessLabels: qualityEntries.filter((q) => q.type === 'business').map((q) => {
      const d = new Date(q.startedAt); return `${d.getMonth() + 1}/${d.getDate()}`;
    }),
  },
  duration: {
    labels: durationData.map((d) => d.label),
    values: durationData.map((d) => d.seconds),
  },
};

type StageStats = { stage: string; avgTokens: number; avgCost: number; avgAttempts: number; count: number };
const stageStatsMap = new Map<string, { totalTokens: number; totalCost: number; totalAttempts: number; count: number }>();
for (const run of runs) {
  for (const log of run.stages) {
    const key = log.pipeline_type;
    const existing = stageStatsMap.get(key) ?? { totalTokens: 0, totalCost: 0, totalAttempts: 0, count: 0 };
    existing.totalTokens += log.tokens_used ?? 0;
    existing.totalCost += parseCost(log.cost_usd);
    const meta = (log.debug_meta ?? {}) as Record<string, unknown>;
    existing.totalAttempts += (meta.attempts as number) ?? (meta.attempt as number) ?? 1;
    existing.count += 1;
    stageStatsMap.set(key, existing);
  }
}
const stageStats: StageStats[] = Array.from(stageStatsMap.entries())
  .map(([stage, s]) => ({
    stage,
    avgTokens: Math.round(s.totalTokens / s.count),
    avgCost: s.totalCost / s.count,
    avgAttempts: s.totalAttempts / s.count,
    count: s.count,
  }))
  .sort((a, b) => b.avgCost - a.avgCost);

// ─── Handbook Data ──────────────────────────────────────────
type HandbookLog = {
  pipeline_type: string;
  status: string | null;
  tokens_used: number | null;
  cost_usd: number | string | null;
  debug_meta: Record<string, unknown> | null;
  created_at: string;
  run_id: string | null;
};

const hbLogs: HandbookLog[] = (handbookLogs ?? []) as unknown as HandbookLog[];
const hbTotalCalls = hbLogs.length;
const hbTotalCost = hbLogs.reduce((sum, l) => sum + parseCost(l.cost_usd), 0);
const hbTotalTokens = hbLogs.reduce((sum, l) => sum + (l.tokens_used ?? 0), 0);
const hbAvgCost = hbTotalCalls > 0 ? hbTotalCost / hbTotalCalls : 0;

// Separate auto (pipeline) vs manual (editor) handbook logs
const hbAutoLogs = (handbookLogs ?? []).filter(
  (l: any) => l.debug_meta?.source === 'pipeline'
);
const hbManualLogs = (handbookLogs ?? []).filter(
  (l: any) => !l.debug_meta?.source || l.debug_meta?.source === 'manual'
);

// Compute costs
const hbAutoCost = hbAutoLogs.reduce((s: number, l: any) => s + (parseFloat(l.cost_usd) || 0), 0);
const hbManualCost = hbManualLogs.reduce((s: number, l: any) => s + (parseFloat(l.cost_usd) || 0), 0);
const hbAutoTokens = hbAutoLogs.reduce((s: number, l: any) => s + (l.tokens_used || 0), 0);
const hbManualTokens = hbManualLogs.reduce((s: number, l: any) => s + (l.tokens_used || 0), 0);

// Group by date for chart
function groupByDate(logs: any[]): Record<string, number> {
  const grouped: Record<string, number> = {};
  for (const l of logs) {
    const date = l.created_at?.slice(0, 10) || '';
    if (!date) continue;
    grouped[date] = (grouped[date] || 0) + (parseFloat(l.cost_usd) || 0);
  }
  return grouped;
}

const hbAutoDailyCost = groupByDate(hbAutoLogs);
const hbManualDailyCost = groupByDate(hbManualLogs);
const allDates = [...new Set([...Object.keys(hbAutoDailyCost), ...Object.keys(hbManualDailyCost)])].sort();

// Group by date (handbook logs don't have pipeline_runs)
type HbRunGroup = {
  runKey: string;
  startedAt: string;
  stages: HandbookLog[];
  totalCost: number;
  totalTokens: number;
  termsExtracted: number;
};
const hbRunMap = new Map<string, HbRunGroup>();
for (const log of hbLogs) {
  const dateKey = log.created_at?.slice(0, 10) || 'unknown';
  if (!hbRunMap.has(dateKey)) {
    hbRunMap.set(dateKey, {
      runKey: dateKey,
      startedAt: log.created_at,
      stages: [],
      totalCost: 0,
      totalTokens: 0,
      termsExtracted: 0,
    });
  }
  const group = hbRunMap.get(dateKey)!;
  group.stages.push(log);
  group.totalCost += parseCost(log.cost_usd);
  group.totalTokens += log.tokens_used ?? 0;
  if (log.pipeline_type === 'handbook.extract') {
    const meta = (log.debug_meta ?? {}) as Record<string, unknown>;
    const terms = meta.terms as unknown[];
    group.termsExtracted += Array.isArray(terms) ? terms.length : 0;
  }
}
const hbRuns = Array.from(hbRunMap.values()).sort(
  (a, b) => new Date(a.startedAt).getTime() - new Date(b.startedAt).getTime(),
);

const hbTotalRuns = hbRuns.length;
const hbTotalTerms = hbRuns.reduce((sum, r) => sum + r.termsExtracted, 0);

// Handbook quality scores from dedicated table
type HbQualityEntry = { term: string; score: number; termType: string; date: string };
const hbQualityEntries: HbQualityEntry[] = (hbQualityRows ?? []).map((row: any) => ({
  term: row.term_slug,
  score: row.score,
  termType: row.term_type || '',
  date: row.created_at?.slice(0, 10) || '',
}));

// Chart data
const hbStageNames = ['handbook.extract', 'handbook.auto_generate'];
const hbStageLabels: Record<string, string> = {
  'handbook.extract': 'Extract',
  'handbook.auto_generate': 'Generate',
};
const hbStackedData = hbStageNames.map((stage) => ({
  label: hbStageLabels[stage] || stage,
  costs: hbRuns.map((run) => {
    return run.stages.filter((s) => s.pipeline_type === stage).reduce((sum, s) => sum + parseCost(s.cost_usd), 0);
  }),
  tokens: hbRuns.map((run) => {
    return run.stages.filter((s) => s.pipeline_type === stage).reduce((sum, s) => sum + (s.tokens_used ?? 0), 0);
  }),
}));

const hbChartData = {
  runLabels: hbRuns.map((r) => {
    const d = new Date(r.startedAt);
    return `${d.getMonth() + 1}/${d.getDate()}`;
  }),
  totalCosts: hbRuns.map((r) => Number(r.totalCost.toFixed(4))),
  stacked: hbStackedData.map((s) => ({
    label: s.label,
    costs: s.costs.map((c) => Number(c.toFixed(6))),
    tokens: s.tokens,
  })),
  termsPerRun: hbRuns.map((r) => r.termsExtracted),
};

// Stage stats
type HbStageStatEntry = { totalTokens: number; totalCost: number; count: number };
const hbStageStatsMap = new Map<string, HbStageStatEntry>();
for (const run of hbRuns) {
  for (const log of run.stages) {
    const key = log.pipeline_type;
    const existing = hbStageStatsMap.get(key) ?? { totalTokens: 0, totalCost: 0, count: 0 };
    existing.totalTokens += log.tokens_used ?? 0;
    existing.totalCost += parseCost(log.cost_usd);
    existing.count += 1;
    hbStageStatsMap.set(key, existing);
  }
}
const hbStageStats = Array.from(hbStageStatsMap.entries())
  .map(([stage, s]) => ({
    stage,
    avgTokens: Math.round(s.totalTokens / s.count),
    avgCost: s.totalCost / s.count,
    count: s.count,
  }))
  .sort((a, b) => b.avgCost - a.avgCost);

// Recent calls table
type HandbookRow = {
  date: string;
  type: string;
  term: string;
  tokens: number;
  cost: number;
  source: string;
};
const hbRows: HandbookRow[] = hbLogs.slice(-50).reverse().map((l) => {
  const meta = (l.debug_meta ?? {}) as Record<string, unknown>;
  const parts = l.pipeline_type.split('.');
  const typeLabel = parts.length >= 3 ? parts.slice(1).join('.') : parts.slice(1).join('.') || l.pipeline_type;
  return {
    date: new Date(l.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }),
    type: typeLabel,
    term: (meta.term_title as string) ?? (meta.term as string) ?? '—',
    tokens: l.tokens_used ?? 0,
    cost: parseCost(l.cost_usd),
    source: (meta.source as string) === 'pipeline' ? 'Auto' : 'Manual',
  };
});

const nonce = Astro.locals.cspNonce || '';
---

<MainLayout title="Pipeline Costs" locale="en">
  <AdminSidebar activeSection="pipeline-analytics" />
  <div class="admin-dashboard">
    <div class="admin-main admin-main--pipeline-costs">
      <div class="admin-main-header">
        <div class="admin-main-header-top">
          <button class="admin-mobile-menu-btn" id="mobile-menu-btn" type="button" aria-label="Menu">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 5h14M3 10h14M3 15h14" />
            </svg>
          </button>
          <div>
            <p class="pcosts-eyebrow">AI Pipeline</p>
            <h1 class="admin-main-title">Pipeline Costs</h1>
            <p class="pcosts-subtitle">
              Token usage, API costs, and quality trends across pipelines.
            </p>
          </div>
        </div>
      </div>

      <!-- Tab Switcher -->
      <div class="pcosts-tabs">
        <button class="pcosts-tab pcosts-tab--active" data-tab="news" type="button">News</button>
        <button class="pcosts-tab" data-tab="handbook" type="button">Handbook</button>
        <button class="pcosts-tab" data-tab="blog" type="button">Blog</button>
      </div>

      <div class="pcosts-date-filter">
        <label class="pcosts-date-filter__label">Date Range</label>
        <select id="date-range-select" class="admin-select" style="width:auto">
          <option value="7" selected={filterDays === 7}>Last 7 days</option>
          <option value="14" selected={filterDays === 14}>Last 14 days</option>
          <option value="30" selected={filterDays === 30}>Last 30 days</option>
        </select>
      </div>

      <!-- ═══ News Tab ═══ -->
      <div id="tab-news">

      <!-- Summary Stats -->
      <section class="pcosts-summary-grid">
        <div class="pipeline-run-stat">
          <span class="pipeline-run-stat__label">Runs ({filterDays}d)</span>
          <strong class="pipeline-run-stat__value">{totalRunCount}</strong>
          <span class="pipeline-run-stat__detail">Pipeline executions in window</span>
        </div>
        <div class="pipeline-run-stat">
          <span class="pipeline-run-stat__label">Total Cost</span>
          <strong class="pipeline-run-stat__value">${totalCostAll.toFixed(2)}</strong>
          <span class="pipeline-run-stat__detail">All stages combined</span>
        </div>
        <div class="pipeline-run-stat">
          <span class="pipeline-run-stat__label">Avg Cost / Run</span>
          <strong class="pipeline-run-stat__value">${avgCostPerRun.toFixed(3)}</strong>
          <span class="pipeline-run-stat__detail">Mean cost per execution</span>
        </div>
        <div class="pipeline-run-stat">
          <span class="pipeline-run-stat__label">Total Tokens</span>
          <strong class="pipeline-run-stat__value">{totalTokensAll.toLocaleString()}</strong>
          <span class="pipeline-run-stat__detail">Input + output across all runs</span>
        </div>
        <div class="pipeline-run-stat">
          <span class="pipeline-run-stat__label">Avg Quality</span>
          <strong class="pipeline-run-stat__value">{avgQuality !== null ? `${avgQuality.toFixed(0)}/100` : '—'}</strong>
          <span class="pipeline-run-stat__detail">Mean quality score</span>
        </div>
        <div class="pipeline-run-stat">
          <span class="pipeline-run-stat__label">QC Cost</span>
          <strong class="pipeline-run-stat__value">${qcTotalCost.toFixed(3)}</strong>
          <span class="pipeline-run-stat__detail">{qcRunCount} checks · {qcTotalTokens.toLocaleString()} tokens</span>
        </div>
        <div class="pipeline-run-stat">
          <span class="pipeline-run-stat__label">Success Rate</span>
          <strong class="pipeline-run-stat__value">{successRate !== null ? `${successRate}%` : '—'}</strong>
          <span class="pipeline-run-stat__detail">{successCount}/{totalPipelineRuns} runs · {failCount} failed</span>
        </div>
      </section>

      {runs.length === 0 ? (
        <p class="dashboard-empty">No pipeline runs found in the last {filterDays} days.</p>
      ) : (
        <>
          <section class="pcosts-charts">
            <div class="pcosts-chart-card">
              <h3 class="pcosts-chart-title">Total Cost per Run</h3>
              <div class="pcosts-chart-wrap"><canvas id="chart-total-cost"></canvas></div>
            </div>
            <div class="pcosts-chart-card">
              <h3 class="pcosts-chart-title">Quality Score Trend</h3>
              <div class="pcosts-chart-wrap"><canvas id="chart-quality"></canvas></div>
            </div>
            <div class="pcosts-chart-card pcosts-chart--full">
              <h3 class="pcosts-chart-title">Cost by Stage (Stacked)</h3>
              <div class="pcosts-chart-wrap"><canvas id="chart-stacked-cost"></canvas></div>
            </div>
            <div class="pcosts-chart-card">
              <h3 class="pcosts-chart-title">Token Distribution</h3>
              <div class="pcosts-chart-wrap"><canvas id="chart-token-donut"></canvas></div>
            </div>
            <div class="pcosts-chart-card">
              <h3 class="pcosts-chart-title">Pipeline Duration</h3>
              <div class="pcosts-chart-wrap"><canvas id="chart-duration"></canvas></div>
            </div>
          </section>

          <section class="pipeline-run-section">
            <div class="pipeline-run-section__header">
              <div>
                <h2 class="pipeline-run-section__title">Stage Statistics</h2>
                <p class="pipeline-run-section__hint">
                  Average token usage, cost, and retry rate per stage across all runs in the window.
                </p>
              </div>
            </div>
            <div class="pipeline-cost-table-wrap">
              <table class="pipeline-cost-table">
                <thead>
                  <tr>
                    <th>Stage</th>
                    <th>Runs</th>
                    <th>Avg Tokens</th>
                    <th>Avg Cost</th>
                    <th>Avg Attempts</th>
                  </tr>
                </thead>
                <tbody>
                  {stageStats.map((s) => (
                    <tr>
                      <td class="pipeline-cost-table__stage">{stageLabels[s.stage] || s.stage}</td>
                      <td>{s.count}</td>
                      <td>{s.avgTokens.toLocaleString()}</td>
                      <td>${s.avgCost.toFixed(4)}</td>
                      <td>{s.avgAttempts.toFixed(1)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        </>
      )}

      </div><!-- /tab-news -->

      <!-- ═══ Handbook Tab ═══ -->
      <div id="tab-handbook" style="display:none">
        <section class="pcosts-summary-grid">
          <div class="pipeline-run-stat">
            <span class="pipeline-run-stat__label">Runs ({filterDays}d)</span>
            <strong class="pipeline-run-stat__value">{hbTotalRuns}</strong>
            <span class="pipeline-run-stat__detail">Pipeline runs with handbook stages</span>
          </div>
          <div class="pipeline-run-stat">
            <span class="pipeline-run-stat__label">Total Cost</span>
            <strong class="pipeline-run-stat__value">${hbTotalCost.toFixed(2)}</strong>
            <span class="pipeline-run-stat__detail">All handbook AI calls</span>
          </div>
          <div class="pipeline-run-stat">
            <span class="pipeline-run-stat__label">Avg Cost / Run</span>
            <strong class="pipeline-run-stat__value">${hbTotalRuns > 0 ? (hbTotalCost / hbTotalRuns).toFixed(3) : '0'}</strong>
            <span class="pipeline-run-stat__detail">Mean cost per execution</span>
          </div>
          <div class="pipeline-run-stat">
            <span class="pipeline-run-stat__label">Total Tokens</span>
            <strong class="pipeline-run-stat__value">{hbTotalTokens.toLocaleString()}</strong>
            <span class="pipeline-run-stat__detail">Input + output combined</span>
          </div>
          <div class="pipeline-run-stat">
            <span class="pipeline-run-stat__label">Terms Extracted</span>
            <strong class="pipeline-run-stat__value">{hbTotalTerms}</strong>
            <span class="pipeline-run-stat__detail">Total terms found across all runs</span>
          </div>
          <div class="pipeline-run-stat">
            <span class="pipeline-run-stat__label">Auto (Pipeline)</span>
            <strong class="pipeline-run-stat__value">${hbAutoCost.toFixed(4)}</strong>
            <span class="pipeline-run-stat__detail">{hbAutoLogs.length} calls, {hbAutoTokens.toLocaleString()} tokens</span>
          </div>
          <div class="pipeline-run-stat">
            <span class="pipeline-run-stat__label">Manual (Editor)</span>
            <strong class="pipeline-run-stat__value">${hbManualCost.toFixed(4)}</strong>
            <span class="pipeline-run-stat__detail">{hbManualLogs.length} calls, {hbManualTokens.toLocaleString()} tokens</span>
          </div>
        </section>

        <h3 class="pcosts-section-title" style="margin-top:1.5rem">Daily Cost (Auto vs Manual)</h3>
        <div class="hb-cost-chart">
          {allDates.length === 0 ? (
            <p class="pcosts-empty">No cost data yet.</p>
          ) : (
            <div class="hb-cost-bars">
              {allDates.map(date => {
                const auto = hbAutoDailyCost[date] || 0;
                const manual = hbManualDailyCost[date] || 0;
                const total = auto + manual;
                const maxCost = Math.max(...allDates.map(d => (hbAutoDailyCost[d] || 0) + (hbManualDailyCost[d] || 0)), 0.01);
                const barPct = (total / maxCost) * 100;
                const autoPct = total > 0 ? (auto / total) * 100 : 0;
                return (
                  <div class="hb-cost-bar-row">
                    <span class="hb-cost-bar-date">{date.slice(5)}</span>
                    <div class="hb-cost-bar-track">
                      <div class="hb-cost-bar-fill" style={`width:${barPct}%`}>
                        <div class="hb-cost-bar-auto" style={`width:${autoPct}%`}></div>
                      </div>
                    </div>
                    <span class="hb-cost-bar-value">${total.toFixed(3)}</span>
                  </div>
                );
              })}
            </div>
          )}
          <div class="hb-cost-legend">
            <span><span class="hb-cost-legend-dot hb-cost-legend-dot--auto"></span> Auto (Pipeline)</span>
            <span><span class="hb-cost-legend-dot hb-cost-legend-dot--manual"></span> Manual (Editor)</span>
          </div>
        </div>

        {hbRuns.length === 0 ? (
          <p class="dashboard-empty">No handbook pipeline data found in the last {filterDays} days.</p>
        ) : (
          <>
            <section class="pcosts-charts">
              <div class="pcosts-chart-card">
                <h3 class="pcosts-chart-title">Total Cost per Run</h3>
                <div class="pcosts-chart-wrap"><canvas id="hb-chart-total-cost"></canvas></div>
              </div>
              <div class="pcosts-chart-card">
                <h3 class="pcosts-chart-title">Quality Score Trend</h3>
                {hbQualityEntries.length > 0 ? (
                  <div class="pcosts-chart-wrap"><canvas id="hb-quality-chart"></canvas></div>
                ) : (
                  <div style="display:flex;align-items:center;justify-content:center;height:200px;color:var(--color-text-muted);font-size:0.85rem">
                    No quality data yet
                  </div>
                )}
              </div>
              <div class="pcosts-chart-card pcosts-chart--full">
                <h3 class="pcosts-chart-title">Cost by Stage (Stacked)</h3>
                <div class="pcosts-chart-wrap"><canvas id="hb-chart-stacked-cost"></canvas></div>
              </div>
              <div class="pcosts-chart-card">
                <h3 class="pcosts-chart-title">Token Distribution</h3>
                <div class="pcosts-chart-wrap"><canvas id="hb-chart-token-donut"></canvas></div>
              </div>
              <div class="pcosts-chart-card">
                <h3 class="pcosts-chart-title">Terms Extracted per Run</h3>
                <div class="pcosts-chart-wrap"><canvas id="hb-chart-terms"></canvas></div>
              </div>
            </section>

            <section class="pipeline-run-section">
              <div class="pipeline-run-section__header">
                <div>
                  <h2 class="pipeline-run-section__title">Stage Statistics</h2>
                  <p class="pipeline-run-section__hint">
                    Average token usage and cost per handbook stage across all runs.
                  </p>
                </div>
              </div>
              <div class="pipeline-cost-table-wrap">
                <table class="pipeline-cost-table">
                  <thead>
                    <tr>
                      <th>Stage</th>
                      <th>Runs</th>
                      <th>Avg Tokens</th>
                      <th>Avg Cost</th>
                    </tr>
                  </thead>
                  <tbody>
                    {hbStageStats.map((s) => (
                      <tr>
                        <td class="pipeline-cost-table__stage">{s.stage}</td>
                        <td>{s.count}</td>
                        <td>{s.avgTokens.toLocaleString()}</td>
                        <td>${s.avgCost.toFixed(4)}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </section>
          </>
        )}

        {hbRows.length > 0 && (
          <section class="pipeline-run-section">
            <div class="pipeline-run-section__header">
              <div>
                <h2 class="pipeline-run-section__title">Recent Calls</h2>
                <p class="pipeline-run-section__hint">
                  Last {hbRows.length} handbook AI calls.
                </p>
              </div>
            </div>
            <div class="pipeline-cost-table-wrap">
              <table class="pipeline-cost-table">
                <thead>
                  <tr>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Source</th>
                    <th>Term</th>
                    <th>Tokens</th>
                    <th>Cost</th>
                  </tr>
                </thead>
                <tbody>
                  {hbRows.map((r) => (
                    <tr>
                      <td class="pipeline-cost-table__stage">{r.date}</td>
                      <td>{r.type}</td>
                      <td>{r.source}</td>
                      <td class="pipeline-cost-table__stage">{r.term}</td>
                      <td>{r.tokens.toLocaleString()}</td>
                      <td>${r.cost.toFixed(4)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )}
      </div><!-- /tab-handbook -->

      <!-- ═══ Blog Tab (placeholder) ═══ -->
      <div id="tab-blog" style="display:none">
        <div style="padding:2rem 1rem;text-align:center;color:var(--color-text-muted)">
          <p style="font-size:1.1rem;font-weight:600;margin-bottom:0.5rem">Blog AI Cost Tracking</p>
          <p style="font-size:0.85rem">Coming soon — blog AI advisor and translation cost tracking will be added here.</p>
        </div>
      </div><!-- /tab-blog -->

    </div>
  </div>
</MainLayout>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js" nonce={nonce}></script>
<script is:inline nonce={nonce} define:vars={{ chartData, hbChartData, hbQualityEntries, filterDays, durationData }}>
  (function () {
    if (typeof Chart === 'undefined') return;
    var canvases = document.querySelectorAll('canvas');
    if (canvases.length === 0) return;

    var style = getComputedStyle(document.documentElement);
    var textColor = style.getPropertyValue('--color-text-secondary').trim() || '#888';
    var gridColor = style.getPropertyValue('--color-border').trim() || '#e5e5e5';

    // Color families: Infra=slate, Research=blue, Business=orange, Other=pink
    var stageColorMap = {
      'Collect':           '#94a3b8', // slate-400
      'Classify':          '#64748b', // slate-500
      'Research Expert':   '#2563eb', // blue-600
      'Research Learner':  '#60a5fa', // blue-400
      'Business Expert':   '#ea580c', // orange-600
      'Business Learner':  '#fb923c', // orange-400
      'Research Beginner (legacy)': '#93c5fd', // blue-300
      'Business Beginner (legacy)': '#fdba74', // orange-300
      'Rank':              '#ec4899', // pink-500
      'Research EN':       '#1d4ed8', // blue-700
      'Research KO':       '#3b82f6', // blue-500
      'Business EN':       '#c2410c', // orange-700
      'Business KO':       '#f97316', // orange-500
    };
    var stageColorFallback = '#cbd5e1';
    var commonScales = {
      x: { ticks: { color: textColor, maxRotation: 45 }, grid: { color: gridColor } },
    };

    new Chart(document.getElementById('chart-total-cost'), {
      type: 'line',
      data: {
        labels: chartData.runLabels,
        datasets: [{
          label: 'Total Cost ($)',
          data: chartData.totalCosts,
          borderColor: '#6366f1',
          backgroundColor: 'rgba(99, 102, 241, 0.1)',
          fill: true, tension: 0.3, pointRadius: 4,
        }],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          ...commonScales,
          y: { ticks: { color: textColor, callback: function(v) { return '$' + v; } }, grid: { color: gridColor } },
        },
      },
    });

    new Chart(document.getElementById('chart-stacked-cost'), {
      type: 'bar',
      data: {
        labels: chartData.runLabels,
        datasets: chartData.stacked
          .filter(function(s) { return s.costs.some(function(v) { return v > 0; }); })
          .map(function(s) { return {
            label: s.label, data: s.costs,
            backgroundColor: stageColorMap[s.label] || stageColorFallback,
          }; }),
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        interaction: { mode: 'point', intersect: true },
        plugins: {
          legend: { labels: { color: textColor, boxWidth: 12 } },
          tooltip: { position: 'nearest', callbacks: {
            label: function(ctx) { return ctx.dataset.label + ': $' + ctx.parsed.y.toFixed(4); },
            filter: function(item) { return item.parsed.y > 0; },
          }},
        },
        scales: {
          ...commonScales,
          x: { ...commonScales.x, stacked: true },
          y: { stacked: true, ticks: { color: textColor, callback: function(v) { return '$' + v; } }, grid: { color: gridColor } },
        },
      },
    });

    var donutCanvas = document.getElementById('chart-token-donut');
    if (donutCanvas && chartData.tokenDonut.labels.length > 0) {
      var donutColors = chartData.tokenDonut.labels.map(function(label) {
        return stageColorMap[label] || stageColorFallback;
      });
      var totalTokensDonut = chartData.tokenDonut.values.reduce(function(a, b) { return a + b; }, 0);
      new Chart(donutCanvas, {
        type: 'doughnut',
        data: {
          labels: chartData.tokenDonut.labels,
          datasets: [{
            data: chartData.tokenDonut.values,
            backgroundColor: donutColors,
            borderWidth: 1,
            borderColor: 'rgba(0,0,0,0.1)',
          }],
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          cutout: '55%',
          plugins: {
            legend: {
              position: 'right',
              labels: { color: textColor, boxWidth: 12, padding: 8, font: { size: 11 } },
            },
            tooltip: {
              callbacks: {
                label: function(ctx) {
                  var pct = (ctx.parsed / totalTokensDonut * 100).toFixed(1);
                  return ctx.label + ': ' + ctx.parsed.toLocaleString() + ' (' + pct + '%)';
                },
              },
            },
          },
        },
      });
    }

    // Duration chart
    var durationCanvas = document.getElementById('chart-duration');
    if (durationCanvas && chartData.duration.labels.length > 0) {
      new Chart(durationCanvas, {
        type: 'line',
        data: {
          labels: chartData.duration.labels,
          datasets: [{
            label: 'Duration (s)',
            data: chartData.duration.values,
            borderColor: '#f59e0b',
            backgroundColor: 'rgba(245, 158, 11, 0.1)',
            fill: true, tension: 0.3, pointRadius: 4,
          }],
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            x: { ticks: { color: textColor, maxRotation: 45 }, grid: { color: gridColor } },
            y: {
              ticks: {
                color: textColor,
                callback: function(v) {
                  return v >= 60 ? Math.floor(v / 60) + 'm' : v + 's';
                },
              },
              grid: { color: gridColor },
            },
          },
        },
      });
    }

    var qualityDatasets = [];
    if (chartData.quality.research.length > 0) {
      qualityDatasets.push({
        label: 'Research', data: chartData.quality.research,
        borderColor: '#10b981', backgroundColor: 'rgba(16, 185, 129, 0.1)',
        fill: false, tension: 0.3, pointRadius: 4,
      });
    }
    if (chartData.quality.business.length > 0) {
      qualityDatasets.push({
        label: 'Business', data: chartData.quality.business,
        borderColor: '#8b5cf6', backgroundColor: 'rgba(139, 92, 246, 0.1)',
        fill: false, tension: 0.3, pointRadius: 4,
      });
    }
    var qualityLabels = chartData.quality.researchLabels.length >= chartData.quality.businessLabels.length
      ? chartData.quality.researchLabels : chartData.quality.businessLabels;

    new Chart(document.getElementById('chart-quality'), {
      type: 'line',
      data: {
        labels: qualityLabels,
        datasets: qualityDatasets.length > 0 ? qualityDatasets : [{ label: 'No data', data: [], borderColor: '#ccc' }],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { labels: { color: textColor, boxWidth: 12 } } },
        scales: {
          ...commonScales,
          y: {
            min: (function() {
              var all = [].concat(chartData.quality.research, chartData.quality.business).filter(function(v) { return v > 0; });
              return all.length ? Math.max(0, Math.floor((Math.min.apply(null, all) - 10) / 10) * 10) : 0;
            })(),
            max: 100,
            ticks: { color: textColor, stepSize: 10 },
            grid: { color: gridColor },
          },
        },
      },
    });

    // ─── Handbook Charts ──────────────────────────
    var hbColors = ['#8b5cf6', '#f59e0b'];

    if (document.getElementById('hb-chart-total-cost') && hbChartData.runLabels.length > 0) {
      new Chart(document.getElementById('hb-chart-total-cost'), {
        type: 'line',
        data: {
          labels: hbChartData.runLabels,
          datasets: [{
            label: 'Total Cost ($)',
            data: hbChartData.totalCosts,
            borderColor: '#8b5cf6',
            backgroundColor: 'rgba(139, 92, 246, 0.1)',
            fill: true, tension: 0.3, pointRadius: 4,
          }],
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            ...commonScales,
            y: { ticks: { color: textColor, callback: function(v) { return '$' + v; } }, grid: { color: gridColor } },
          },
        },
      });

      new Chart(document.getElementById('hb-chart-stacked-cost'), {
        type: 'bar',
        data: {
          labels: hbChartData.runLabels,
          datasets: hbChartData.stacked.map(function(s, i) { return {
            label: s.label, data: s.costs,
            backgroundColor: hbColors[i % hbColors.length],
          }; }),
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: { legend: { labels: { color: textColor, boxWidth: 12 } } },
          scales: {
            ...commonScales,
            x: { ...commonScales.x, stacked: true },
            y: { stacked: true, ticks: { color: textColor, callback: function(v) { return '$' + v; } }, grid: { color: gridColor } },
          },
        },
      });

      // Handbook Token Distribution donut
      var hbTokenTotals = hbChartData.stacked
        .map(function(s) { return { label: s.label, total: s.tokens.reduce(function(a, b) { return a + b; }, 0) }; })
        .filter(function(s) { return s.total > 0; })
        .sort(function(a, b) { return b.total - a.total; });
      var hbDonutCanvas = document.getElementById('hb-chart-token-donut');
      if (hbDonutCanvas && hbTokenTotals.length > 0) {
        var hbDonutLabels = hbTokenTotals.map(function(s) { return s.label; });
        var hbDonutValues = hbTokenTotals.map(function(s) { return s.total; });
        var hbDonutColors = hbDonutLabels.map(function(l, i) { return hbColors[i % hbColors.length]; });
        var hbDonutTotal = hbDonutValues.reduce(function(a, b) { return a + b; }, 0);
        new Chart(hbDonutCanvas, {
          type: 'doughnut',
          data: {
            labels: hbDonutLabels,
            datasets: [{ data: hbDonutValues, backgroundColor: hbDonutColors, borderWidth: 1, borderColor: 'rgba(0,0,0,0.1)' }],
          },
          options: {
            responsive: true, maintainAspectRatio: false,
            cutout: '55%',
            plugins: {
              legend: { position: 'right', labels: { color: textColor, boxWidth: 12, padding: 8, font: { size: 11 } } },
              tooltip: { callbacks: {
                label: function(ctx) {
                  var pct = (ctx.parsed / hbDonutTotal * 100).toFixed(1);
                  return ctx.label + ': ' + ctx.parsed.toLocaleString() + ' (' + pct + '%)';
                },
              }},
            },
          },
        });
      }

      new Chart(document.getElementById('hb-chart-terms'), {
        type: 'line',
        data: {
          labels: hbChartData.runLabels,
          datasets: [{
            label: 'Terms Extracted',
            data: hbChartData.termsPerRun,
            borderColor: '#10b981',
            backgroundColor: 'rgba(16, 185, 129, 0.1)',
            fill: true, tension: 0.3, pointRadius: 4,
          }],
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            ...commonScales,
            y: { ticks: { color: textColor, stepSize: 1 }, grid: { color: gridColor } },
          },
        },
      });
    }

    // Handbook Quality Score Trend — scatter + moving average
    var hbQualityCanvas = document.getElementById('hb-quality-chart');
    if (hbQualityCanvas && hbQualityEntries.length > 0) {
      var hbQScores = hbQualityEntries.map(function(e) { return e.score; });
      var hbQDates = hbQualityEntries.map(function(e) {
        var d = new Date(e.date); return (d.getMonth() + 1) + '/' + d.getDate();
      });
      var hbQPointColors = hbQScores.map(function(s) {
        return s >= 80 ? 'rgba(90, 142, 93, 0.85)' : s >= 60 ? 'rgba(200, 170, 60, 0.85)' : 'rgba(200, 80, 80, 0.85)';
      });

      var hbWindow = 5;
      var hbMovingAvg = hbQScores.map(function(_, i) {
        var start = Math.max(0, i - hbWindow + 1);
        var slice = hbQScores.slice(start, i + 1);
        return Math.round(slice.reduce(function(a, b) { return a + b; }, 0) / slice.length);
      });

      var hbMinScore = Math.max(0, Math.floor((Math.min.apply(null, hbQScores) - 10) / 10) * 10);

      new Chart(hbQualityCanvas, {
        type: 'scatter',
        data: {
          labels: hbQDates,
          datasets: [
            {
              label: 'Score',
              data: hbQScores.map(function(s, i) { return { x: i, y: s }; }),
              backgroundColor: hbQPointColors,
              pointRadius: 5,
              pointHoverRadius: 7,
            },
            {
              label: 'Avg (5)',
              data: hbMovingAvg.map(function(s, i) { return { x: i, y: s }; }),
              type: 'line',
              borderColor: 'rgba(99, 102, 241, 0.7)',
              borderWidth: 2,
              pointRadius: 0,
              tension: 0.4,
              fill: false,
            },
          ],
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: {
            legend: { labels: { color: textColor, boxWidth: 10, font: { size: 11 } } },
            tooltip: { callbacks: {
              title: function(items) {
                var idx = items[0].dataIndex;
                return hbQualityEntries[idx] ? hbQualityEntries[idx].term : '';
              },
              label: function(ctx) {
                return ctx.dataset.label + ': ' + ctx.parsed.y;
              },
            }},
          },
          scales: {
            x: {
              type: 'linear', min: 0, max: hbQScores.length - 1,
              ticks: {
                color: textColor, font: { size: 10 },
                callback: function(v) { return hbQDates[v] || ''; },
                maxTicksLimit: 12,
              },
              grid: { color: gridColor },
            },
            y: { min: hbMinScore, max: 100, ticks: { color: textColor, stepSize: 10 }, grid: { color: gridColor } },
          },
        },
      });
    }
  })();
</script>

<script is:inline nonce={nonce}>
  (function () {
    var tabs = document.querySelectorAll('.pcosts-tab');
    var panels = {
      news: document.getElementById('tab-news'),
      handbook: document.getElementById('tab-handbook'),
      blog: document.getElementById('tab-blog'),
    };
    tabs.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var target = btn.getAttribute('data-tab');
        tabs.forEach(function (t) { t.classList.remove('pcosts-tab--active'); });
        btn.classList.add('pcosts-tab--active');
        Object.keys(panels).forEach(function (key) {
          panels[key].style.display = key === target ? '' : 'none';
        });
      });
    });

    // Date range filter
    var dateSelect = document.getElementById('date-range-select');
    if (dateSelect) {
      var params = new URLSearchParams(window.location.search);
      var days = params.get('days');
      if (days) dateSelect.value = days;

      dateSelect.addEventListener('change', function() {
        var url = new URL(window.location.href);
        url.searchParams.set('days', dateSelect.value);
        window.location.href = url.toString();
      });
    }
  })();
</script>

