---
export const prerender = false;

import MainLayout from '../../../../layouts/MainLayout.astro';
import AdminSidebar from '../../../../components/admin/AdminSidebar.astro';
import NewsprintNotice from '../../../../components/newsprint/NewsprintNotice.astro';
import { createClient } from '@supabase/supabase-js';

const { slug } = Astro.params;
const pageSlug = slug ?? '';
const isNew = pageSlug === 'new';

const accessToken = Astro.locals.accessToken;
if (!accessToken) return Astro.redirect('/admin/login');

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
);

let product: any = null;
let fetchError: string | null = null;

const { data: categories } = await supabase
  .from('ai_product_categories')
  .select('*')
  .order('sort_order');

const allCategories = categories ?? [];

if (!isNew) {
  const { data, error } = await supabase
    .from('ai_products')
    .select('*')
    .eq('slug', pageSlug)
    .single();

  if (error?.code === 'PGRST116') {
    fetchError = '404';
  } else if (error) {
    fetchError = error.message;
  } else {
    product = data;
  }
}

const isPublished = product?.is_published ?? false;
const isFeatured = product?.featured ?? false;
---

<MainLayout title={isNew ? 'New Product' : (product ? `Edit: ${product.name}` : 'Product Editor')} locale="en">
  <AdminSidebar activeSection="products" />

  {fetchError === '404' ? (
    <div class="admin-dashboard">
      <div class="admin-main">
        <NewsprintNotice variant="empty" message="Product not found." linkHref="/admin/products/" linkLabel="Back to Products" />
      </div>
    </div>
  ) : fetchError ? (
    <div class="admin-dashboard">
      <div class="admin-main">
        <NewsprintNotice variant="unauthorized" message={`Error: ${fetchError}`} linkHref="/admin/products/" linkLabel="Back" />
      </div>
    </div>
  ) : (
    <div class="admin-editor-layout" id="editor-layout">
      <!-- Top bar -->
      <div class="admin-editor-topbar">
        <div class="admin-editor-topbar-left">
          <a href="/admin/products/" class="admin-editor-back">← Products</a>
          <span class={`admin-status-badge admin-status-badge--${isPublished ? 'published' : 'draft'}`} id="status-badge">
            {isPublished ? 'published' : 'draft'}
          </span>
          <span class="admin-featured-badge" id="featured-badge" hidden={!isFeatured}>featured</span>
        </div>
        <div class="admin-editor-topbar-right">
          <button class="admin-btn" id="ai-panel-toggle" type="button">AI</button>
          <button class="admin-btn" id="save-btn" type="button">Save</button>
          {product && (
            <>
              <button
                class="admin-btn admin-btn-primary"
                id="publish-btn"
                type="button"
                data-action={isPublished ? 'unpublish' : 'publish'}
              >
                {isPublished ? 'Unpublish' : 'Publish'}
              </button>
              <button
                class="admin-btn"
                id="feature-btn"
                type="button"
                data-action={isFeatured ? 'unfeature' : 'feature'}
              >
                {isFeatured ? 'Unfeature' : 'Feature'}
              </button>
              <button class="admin-btn admin-btn-danger" id="delete-btn" type="button">Delete</button>
            </>
          )}
        </div>
      </div>

      <!-- Editor content -->
      <div class="admin-editor-content" id="editor-content">
        <input type="hidden" id="product-id" value={product?.id || ''} />
        <input type="hidden" id="product-demo-media" value={JSON.stringify(product?.demo_media ?? [])} />
        <input type="hidden" id="product-features" value={JSON.stringify(product?.features ?? [])} />
        <input type="hidden" id="product-features-ko" value={JSON.stringify(product?.features_ko ?? [])} />
        <input type="hidden" id="product-use-cases" value={JSON.stringify(product?.use_cases ?? [])} />
        <input type="hidden" id="product-use-cases-ko" value={JSON.stringify(product?.use_cases_ko ?? [])} />

        <div class="admin-editor-meta">
          <div class="admin-editor-meta-row">
            <label class="admin-field-label" for="field-name">Name</label>
            <input class="admin-input" id="field-name" type="text" value={product?.name || ''} placeholder="Product name" required />
          </div>
          <div class="admin-editor-meta-row">
            <label class="admin-field-label" for="field-name-ko">Name KO</label>
            <input class="admin-input" id="field-name-ko" type="text" value={product?.name_ko || ''} placeholder="한국어 이름" />
          </div>
          <div class="admin-editor-meta-row">
            <label class="admin-field-label" for="field-url">URL</label>
            <input class="admin-input" id="field-url" type="url" value={product?.url || ''} placeholder="https://..." />
          </div>
          <div class="admin-editor-meta-row">
            <label class="admin-field-label" for="field-slug">Slug</label>
            <input class="admin-input" id="field-slug" type="text" value={product?.slug || ''} placeholder="auto-generated" />
          </div>
          <div class="admin-editor-meta-row">
            <label class="admin-field-label" for="field-category">Category</label>
            <select class="admin-input" id="field-category">
              <option value="">— Select —</option>
              {allCategories.map((cat) => (
                <option value={cat.id} selected={product?.primary_category === cat.id}>
                  {cat.icon} {cat.label_en}
                </option>
              ))}
            </select>
          </div>

          <div class="admin-editor-meta-row" style="align-items: flex-start;">
            <label class="admin-field-label" style="padding-top: 4px;">Secondary</label>
            <div class="admin-product-checkbox-group">
              {allCategories.map((cat) => (
                <label>
                  <input
                    type="checkbox"
                    class="product-secondary-cat"
                    value={cat.id}
                    checked={(product?.secondary_categories || []).includes(cat.id)}
                  />
                  {cat.icon} {cat.label_en}
                </label>
              ))}
            </div>
          </div>

          <div class="admin-editor-meta-row">
            <label class="admin-field-label" for="field-tagline">Tagline EN</label>
            <input class="admin-input" id="field-tagline" type="text" value={product?.tagline || ''} placeholder="Short one-liner" />
          </div>
          <div class="admin-editor-meta-row">
            <label class="admin-field-label" for="field-tagline-ko">Tagline KO</label>
            <input class="admin-input" id="field-tagline-ko" type="text" value={product?.tagline_ko || ''} placeholder="한줄 설명" />
          </div>

          <div class="admin-editor-meta-row" style="align-items: flex-start;">
            <label class="admin-field-label" style="padding-top: 6px;">Description EN</label>
            <textarea class="admin-input" id="field-description" rows="5" placeholder="Markdown supported">{product?.description || ''}</textarea>
          </div>
          <div class="admin-editor-meta-row" style="align-items: flex-start;">
            <label class="admin-field-label" style="padding-top: 6px;">Description KO</label>
            <textarea class="admin-input" id="field-description-ko" rows="5" placeholder="마크다운 지원">{product?.description_ko || ''}</textarea>
          </div>
        </div>

        <!-- Preview tabs -->
        <div class="product-preview-section">
          <div class="product-preview-tabs">
            <button class="product-preview-tab product-preview-tab--active" data-preview="card" type="button">📇 Card</button>
            <button class="product-preview-tab" data-preview="detail" type="button">📄 Detail</button>
          </div>
          <div class="product-preview-area" id="preview-card">
            <div class="product-preview-card" id="preview-card-inner">
              <div class="product-card-thumbnail" id="preview-thumb"></div>
              <div class="product-card-body">
                <div class="product-card-header">
                  <img id="preview-card-logo" class="product-card-logo" src="" alt="" width="24" height="24" style="display:none" />
                  <span class="product-card-name" id="preview-card-name">Product Name</span>
                </div>
                <p class="product-card-tagline" id="preview-card-tagline"></p>
                <div class="product-card-meta">
                  <span class="product-pricing-badge" id="preview-card-pricing" hidden></span>
                </div>
              </div>
            </div>
          </div>
          <div class="product-preview-area" id="preview-detail" hidden>
            <div class="product-preview-detail-inner">
              <div class="product-preview-detail-header">
                <img id="preview-detail-logo" src="" alt="" style="width:48px;height:48px;object-fit:contain;border-radius:8px;display:none" />
                <div>
                  <h3 id="preview-detail-name" style="margin:0;font-size:1.2rem;">Product Name</h3>
                  <p id="preview-detail-tagline" style="margin:0.25rem 0 0;color:var(--color-text-secondary);font-size:0.9rem;"></p>
                </div>
              </div>
              <div id="preview-detail-description" style="margin-top:1rem;font-size:0.88rem;line-height:1.7;color:var(--color-text-secondary);"></div>
              <div id="preview-detail-meta" style="margin-top:1rem;display:flex;gap:0.5rem;flex-wrap:wrap;"></div>
            </div>
          </div>
        </div>

        <!-- More fields (collapsed) -->
        <details class="admin-editor-meta" style="margin-top: 1.5rem;">
          <summary style="cursor:pointer;font-size:0.85rem;font-weight:600;color:var(--color-text-muted);padding:0.5rem 0;user-select:none;">
            More fields
          </summary>

          <div style="margin-top: 0.75rem;">
            <div class="admin-editor-meta-row">
              <label class="admin-field-label" for="field-logo-url">Logo URL</label>
              <div style="flex:1;">
                <input class="admin-input" id="field-logo-url" type="url" value={product?.logo_url || ''} placeholder="https://..." />
                <img id="logo-preview" class="admin-image-preview" src={product?.logo_url || ''} alt="logo preview" style={product?.logo_url ? '' : 'display:none'} />
              </div>
            </div>
            <div class="admin-editor-meta-row">
              <label class="admin-field-label" for="field-thumbnail-url">Thumbnail</label>
              <div style="flex:1;">
                <input class="admin-input" id="field-thumbnail-url" type="url" value={product?.thumbnail_url || ''} placeholder="https://..." />
                <img id="thumbnail-preview" class="admin-image-preview" src={product?.thumbnail_url || ''} alt="thumbnail preview" style={product?.thumbnail_url ? '' : 'display:none'} />
              </div>
            </div>
            <div class="admin-editor-meta-row" style="align-items: flex-start;">
              <label class="admin-field-label" style="padding-top: 6px;">Media</label>
              <div style="flex:1;">
                <div id="demo-media-list"></div>
                <button class="admin-btn admin-btn--small" id="add-media-btn" type="button" style="margin-top:0.5rem;">
                  + Add Image / Video
                </button>
              </div>
            </div>

            <div class="admin-editor-meta-row" style="align-items: flex-start;">
              <label class="admin-field-label" style="padding-top: 6px;">Features EN</label>
              <div style="flex:1;">
                <div id="features-list"></div>
                <button class="admin-btn admin-btn--small" id="add-feature-btn" type="button" style="margin-top:0.4rem;">+ Add Feature</button>
              </div>
            </div>
            <div class="admin-editor-meta-row" style="align-items: flex-start;">
              <label class="admin-field-label" style="padding-top: 6px;">Features KO</label>
              <div style="flex:1;">
                <div id="features-ko-list"></div>
                <button class="admin-btn admin-btn--small" id="add-feature-ko-btn" type="button" style="margin-top:0.4rem;">+ Add Feature KO</button>
              </div>
            </div>
            <div class="admin-editor-meta-row" style="align-items: flex-start;">
              <label class="admin-field-label" style="padding-top: 6px;">Use Cases EN</label>
              <div style="flex:1;">
                <div id="usecases-list"></div>
                <button class="admin-btn admin-btn--small" id="add-usecase-btn" type="button" style="margin-top:0.4rem;">+ Add Use Case</button>
              </div>
            </div>
            <div class="admin-editor-meta-row" style="align-items: flex-start;">
              <label class="admin-field-label" style="padding-top: 6px;">Use Cases KO</label>
              <div style="flex:1;">
                <div id="usecases-ko-list"></div>
                <button class="admin-btn admin-btn--small" id="add-usecase-ko-btn" type="button" style="margin-top:0.4rem;">+ Add Use Case KO</button>
              </div>
            </div>

            <div class="admin-editor-meta-row">
              <label class="admin-field-label" for="field-pricing">Pricing</label>
              <select class="admin-input" id="field-pricing" style="max-width:180px">
                <option value="">— None —</option>
                {['free', 'freemium', 'paid', 'enterprise'].map((p) => (
                  <option value={p} selected={product?.pricing === p}>{p}</option>
                ))}
              </select>
            </div>
            <div class="admin-editor-meta-row">
              <label class="admin-field-label" for="field-pricing-note">Pricing Note</label>
              <input class="admin-input" id="field-pricing-note" type="text" value={product?.pricing_note || ''} placeholder="e.g. Free up to 10 users" />
            </div>
            <div class="admin-editor-meta-row">
              <label class="admin-field-label" for="field-platform">Platform</label>
              <input class="admin-input" id="field-platform" type="text" value={(product?.platform || []).join(', ')} placeholder="Web, iOS, Android (comma separated)" />
            </div>
            <div class="admin-editor-meta-row">
              <label class="admin-field-label" for="field-tags">Tags</label>
              <input class="admin-input" id="field-tags" type="text" value={(product?.tags || []).join(', ')} placeholder="llm, chatbot, productivity (comma separated)" />
            </div>
            <div class="admin-editor-meta-row">
              <label class="admin-field-label" for="field-released-at">Released At</label>
              <input class="admin-input" id="field-released-at" type="date" value={product?.released_at || ''} style="max-width:180px" />
            </div>
            <div class="admin-editor-meta-row">
              <label class="admin-field-label">Korean Support</label>
              <label style="display:flex;align-items:center;gap:0.4rem;cursor:pointer;">
                <input type="checkbox" id="field-korean-support" checked={product?.korean_support ?? false} />
                Yes
              </label>
            </div>
            <div class="admin-editor-meta-row">
              <label class="admin-field-label">Featured</label>
              <label style="display:flex;align-items:center;gap:0.4rem;cursor:pointer;">
                <input type="checkbox" id="field-featured" checked={product?.featured ?? false} />
                Show in featured section
              </label>
            </div>
            <div class="admin-editor-meta-row">
              <label class="admin-field-label" for="field-featured-order">Featured Order</label>
              <input class="admin-input" id="field-featured-order" type="number" value={product?.featured_order ?? ''} placeholder="1, 2, 3…" style="max-width:100px" />
            </div>
            <div class="admin-editor-meta-row">
              <label class="admin-field-label" for="field-sort-order">Sort Order</label>
              <input class="admin-input" id="field-sort-order" type="number" value={product?.sort_order ?? 0} style="max-width:100px" />
            </div>
          </div>
        </details>

        <div class="admin-feedback" id="feedback" hidden></div>
      </div>

      <!-- AI Panel -->
      <div class="admin-ai-panel" id="ai-panel">
        <div class="admin-ai-panel-header">
          <span class="admin-ai-panel-title">AI Product Advisor</span>
          <button class="admin-ai-panel-toggle" id="ai-panel-close" type="button">✕</button>
        </div>
        <div class="admin-ai-actions">
          <button class="admin-ai-action-btn admin-ai-action-btn--wide" data-action="generate_from_url" type="button">
            Generate from URL
            <span class="ai-btn-model">gpt-4o</span>
          </button>
          <button class="admin-ai-action-btn" data-action="tagline_en" type="button">
            Tagline EN
            <span class="ai-btn-model">gpt-4o-mini</span>
          </button>
          <button class="admin-ai-action-btn" data-action="tagline_ko" type="button">
            Tagline KO
            <span class="ai-btn-model">gpt-4o-mini</span>
          </button>
          <button class="admin-ai-action-btn" data-action="description_en" type="button">
            Description EN
            <span class="ai-btn-model">gpt-4o-mini</span>
          </button>
          <button class="admin-ai-action-btn" data-action="description_ko" type="button">
            Description KO
            <span class="ai-btn-model">gpt-4o-mini</span>
          </button>
        </div>
        <div id="ai-loading" class="admin-ai-loading" hidden>
          <span class="ai-spinner"></span>
          <span id="ai-loading-text">Generating…</span>
        </div>
        <div id="ai-result-area" hidden>
          <div id="ai-result-label" style="font-size:0.75rem;color:var(--color-text-muted);margin-bottom:0.4rem;"></div>
          <div id="ai-result-text" style="font-size:0.85rem;line-height:1.5;white-space:pre-wrap;background:var(--color-bg);border:1px solid var(--color-border);border-radius:6px;padding:0.75rem;"></div>
          <button class="admin-btn admin-btn-primary admin-btn--small" id="ai-apply-btn" type="button" style="margin-top:0.5rem;">Apply</button>
        </div>
        <div class="admin-feedback" id="ai-feedback" hidden></div>
      </div>
    </div>
  )}
</MainLayout>

<script>
  // @ts-nocheck

  // ── Helpers ───────────────────────────────────────────
  function slugify(text) {
    return text.toLowerCase().trim()
      .replace(/[^\w\s-]/g, '')
      .replace(/[\s_]+/g, '-')
      .replace(/-+/g, '-')
      .replace(/^-|-$/g, '');
  }

  function showFeedback(msg, isError = false, elId = 'feedback') {
    const el = document.getElementById(elId);
    if (!el) return;
    el.textContent = msg;
    el.className = isError ? 'admin-feedback admin-feedback--error' : 'admin-feedback';
    el.hidden = false;
    setTimeout(() => { el.hidden = true; }, 4000);
  }

  function getPayload() {
    const nameVal = document.getElementById('field-name')?.value.trim() || '';
    const secondaryCats = Array.from(document.querySelectorAll('.product-secondary-cat:checked'))
      .map((cb) => cb.value);
    const platformStr = document.getElementById('field-platform')?.value || '';
    const tagsStr = document.getElementById('field-tags')?.value || '';
    const featuredOrderVal = document.getElementById('field-featured-order')?.value;
    const sortOrderVal = document.getElementById('field-sort-order')?.value;

    return {
      id: document.getElementById('product-id')?.value || undefined,
      name: nameVal,
      name_ko: document.getElementById('field-name-ko')?.value.trim() || null,
      url: document.getElementById('field-url')?.value.trim() || null,
      slug: document.getElementById('field-slug')?.value.trim() || slugify(nameVal),
      primary_category: document.getElementById('field-category')?.value || null,
      secondary_categories: secondaryCats,
      tagline: document.getElementById('field-tagline')?.value.trim() || null,
      tagline_ko: document.getElementById('field-tagline-ko')?.value.trim() || null,
      description: document.getElementById('field-description')?.value || null,
      description_ko: document.getElementById('field-description-ko')?.value || null,
      logo_url: document.getElementById('field-logo-url')?.value.trim() || null,
      thumbnail_url: document.getElementById('field-thumbnail-url')?.value.trim() || null,
      demo_media: getMediaItems(),
      features: getFeatures(),
      features_ko: getFeaturesKo(),
      use_cases: getUseCases(),
      use_cases_ko: getUseCasesKo(),
      pricing: document.getElementById('field-pricing')?.value || null,
      pricing_note: document.getElementById('field-pricing-note')?.value.trim() || null,
      platform: platformStr.split(',').map((s) => s.trim()).filter(Boolean),
      tags: tagsStr.split(',').map((s) => s.trim()).filter(Boolean),
      korean_support: document.getElementById('field-korean-support')?.checked ?? false,
      released_at: document.getElementById('field-released-at')?.value || null,
      featured: document.getElementById('field-featured')?.checked ?? false,
      featured_order: featuredOrderVal ? Number(featuredOrderVal) : null,
      sort_order: sortOrderVal ? Number(sortOrderVal) : 0,
    };
  }

  // ── Auto-slug from name ───────────────────────────────
  const nameField = document.getElementById('field-name');
  const slugField = document.getElementById('field-slug');
  const productId = document.getElementById('product-id')?.value;

  nameField?.addEventListener('input', () => {
    if (!productId) {
      slugField.value = slugify(nameField.value);
    }
  });

  // ── Image previews ────────────────────────────────────
  document.getElementById('field-logo-url')?.addEventListener('input', (e) => {
    const preview = document.getElementById('logo-preview');
    if (!preview) return;
    const url = e.target.value.trim();
    preview.src = url;
    preview.style.display = url ? '' : 'none';
  });

  document.getElementById('field-thumbnail-url')?.addEventListener('input', (e) => {
    const preview = document.getElementById('thumbnail-preview');
    if (!preview) return;
    const url = e.target.value.trim();
    preview.src = url;
    preview.style.display = url ? '' : 'none';
  });

  // ── Preview tabs ─────────────────────────────────────
  const categoryGradients = {
    assistant: 'linear-gradient(135deg, #C3A370, #8B6D3F)',
    image: 'linear-gradient(135deg, #7C3AED, #4338CA)',
    video: 'linear-gradient(135deg, #EF4444, #DC2626)',
    audio: 'linear-gradient(135deg, #10B981, #059669)',
    coding: 'linear-gradient(135deg, #06B6D4, #0891B2)',
    workflow: 'linear-gradient(135deg, #F59E0B, #D97706)',
    builder: 'linear-gradient(135deg, #6366F1, #4F46E5)',
    platform: 'linear-gradient(135deg, #64748B, #475569)',
    research: 'linear-gradient(135deg, #14B8A6, #0D9488)',
    community: 'linear-gradient(135deg, #F43F5E, #E11D48)',
  };

  function updatePreview() {
    const name = document.getElementById('field-name')?.value || 'Product Name';
    const tagline = document.getElementById('field-tagline')?.value || '';
    const taglineKo = document.getElementById('field-tagline-ko')?.value || '';
    const desc = document.getElementById('field-description')?.value || '';
    const logoUrl = document.getElementById('field-logo-url')?.value?.trim() || '';
    const thumbUrl = document.getElementById('field-thumbnail-url')?.value?.trim() || '';
    const pricing = document.getElementById('field-pricing')?.value || '';
    const platform = document.getElementById('field-platform')?.value || '';
    const tags = document.getElementById('field-tags')?.value || '';
    const koreanSupport = document.getElementById('field-korean-support')?.checked;
    const category = document.getElementById('field-category')?.value || '';

    // First demo_media image
    const firstMediaUrl = document.querySelector('.demo-media-url')?.value?.trim() || '';
    const firstMediaType = document.querySelector('.demo-media-type')?.value || 'image';
    const imageUrl = (firstMediaType === 'image' && firstMediaUrl) ? firstMediaUrl : thumbUrl;

    // Card preview
    const thumb = document.getElementById('preview-thumb');
    if (thumb) {
      if (imageUrl) {
        thumb.innerHTML = `<img src="${imageUrl}" alt="${name}" class="product-card-thumb-img" />`;
      } else {
        const gradient = categoryGradients[category] || 'linear-gradient(135deg, #64748B, #475569)';
        const initial = name.charAt(0) || '?';
        thumb.innerHTML = `<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:${gradient}"><span style="font-size:2rem;font-weight:700;color:#fff">${initial}</span></div>`;
      }
    }

    const cardLogo = document.getElementById('preview-card-logo');
    if (cardLogo) {
      if (logoUrl && imageUrl) { cardLogo.src = logoUrl; cardLogo.style.display = ''; }
      else { cardLogo.style.display = 'none'; }
    }

    const cardName = document.getElementById('preview-card-name');
    if (cardName) cardName.textContent = name;

    const cardTagline = document.getElementById('preview-card-tagline');
    if (cardTagline) cardTagline.textContent = tagline || taglineKo;

    const cardPricing = document.getElementById('preview-card-pricing');
    if (cardPricing) {
      if (pricing) {
        cardPricing.textContent = pricing;
        cardPricing.dataset.pricing = pricing;
        cardPricing.hidden = false;
      } else {
        cardPricing.hidden = true;
      }
    }

    // Detail preview
    const detailLogo = document.getElementById('preview-detail-logo');
    if (detailLogo) {
      if (logoUrl) { detailLogo.src = logoUrl; detailLogo.style.display = ''; }
      else { detailLogo.style.display = 'none'; }
    }

    const detailName = document.getElementById('preview-detail-name');
    if (detailName) detailName.textContent = name;

    const detailTagline = document.getElementById('preview-detail-tagline');
    if (detailTagline) detailTagline.textContent = tagline || taglineKo;

    const detailDesc = document.getElementById('preview-detail-description');
    if (detailDesc) detailDesc.textContent = desc || '(no description)';

    const detailMeta = document.getElementById('preview-detail-meta');
    if (detailMeta) {
      let html = '';
      if (pricing) html += `<span class="product-pricing-badge" data-pricing="${pricing}">${pricing}</span>`;
      if (platform) html += platform.split(',').map(p => `<span style="font-size:0.72rem;padding:0.1rem 0.4rem;background:var(--color-bg-tertiary);border-radius:3px;color:var(--color-text-muted)">${p.trim()}</span>`).join('');
      if (koreanSupport) html += `<span style="font-size:0.72rem;padding:0.1rem 0.4rem;background:var(--color-accent-subtle);border-radius:3px;color:var(--color-accent)">Korean</span>`;
      if (tags) html += tags.split(',').map(t => `<span style="font-size:0.72rem;padding:0.1rem 0.4rem;background:var(--color-bg-secondary);border-radius:3px;color:var(--color-text-muted)">#${t.trim()}</span>`).join('');
      detailMeta.innerHTML = html;
    }
  }

  // Tab switching
  document.querySelectorAll('.product-preview-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.product-preview-tab').forEach(t => t.classList.remove('product-preview-tab--active'));
      tab.classList.add('product-preview-tab--active');
      const target = tab.dataset.preview;
      document.getElementById('preview-card').hidden = target !== 'card';
      document.getElementById('preview-detail').hidden = target !== 'detail';
    });
  });

  // Live update on field changes
  ['field-name', 'field-tagline', 'field-tagline-ko', 'field-description',
   'field-logo-url', 'field-thumbnail-url', 'field-pricing', 'field-platform',
   'field-tags', 'field-korean-support', 'field-category'].forEach((id) => {
    const el = document.getElementById(id);
    if (el) {
      el.addEventListener('input', updatePreview);
      el.addEventListener('change', updatePreview);
    }
  });

  // Also update when demo_media changes
  const mediaObserver = new MutationObserver(updatePreview);
  if (mediaList) mediaObserver.observe(mediaList, { childList: true, subtree: true });

  // Initial render
  updatePreview();

  // ── Demo Media editor ────────────────────────────────
  const mediaList = document.getElementById('demo-media-list');
  const initialMedia = JSON.parse(document.getElementById('product-demo-media')?.value || '[]');

  function getMediaItems() {
    const rows = document.querySelectorAll('.demo-media-row');
    const items = [];
    rows.forEach((row) => {
      const url = row.querySelector('.demo-media-url')?.value.trim();
      const type = row.querySelector('.demo-media-type')?.value;
      const caption = row.querySelector('.demo-media-caption')?.value.trim();
      if (url) items.push({ type, url, ...(caption ? { caption } : {}) });
    });
    return items;
  }

  function addMediaRow(item = null) {
    const row = document.createElement('div');
    row.className = 'demo-media-row';
    row.innerHTML = `
      <div class="demo-media-row-top">
        <select class="admin-input demo-media-type" style="width:90px;flex:0 0 90px;">
          <option value="image"${item?.type === 'image' || !item ? ' selected' : ''}>Image</option>
          <option value="video"${item?.type === 'video' ? ' selected' : ''}>Video</option>
        </select>
        <input class="admin-input demo-media-url" type="url" placeholder="https://..." value="${item?.url || ''}" style="flex:1;" />
        <button class="admin-btn admin-btn-danger admin-btn--small demo-media-remove" type="button">✕</button>
      </div>
      <div class="demo-media-row-bottom">
        <input class="admin-input demo-media-caption" type="text" placeholder="Caption (optional)" value="${item?.caption || ''}" style="flex:1;" />
      </div>
      <div class="demo-media-preview-wrap"></div>
    `;

    row.querySelector('.demo-media-remove').addEventListener('click', () => row.remove());

    const urlInput = row.querySelector('.demo-media-url');
    const typeSelect = row.querySelector('.demo-media-type');
    const previewWrap = row.querySelector('.demo-media-preview-wrap');

    function updatePreview() {
      const url = urlInput.value.trim();
      const type = typeSelect.value;
      previewWrap.innerHTML = '';
      if (!url) return;
      if (type === 'image') {
        const img = document.createElement('img');
        img.src = url;
        img.alt = 'preview';
        img.className = 'demo-media-preview-img';
        img.onerror = () => { img.style.display = 'none'; };
        previewWrap.appendChild(img);
      } else {
        const isYT = url.includes('youtube.com') || url.includes('youtu.be');
        if (isYT) {
          const span = document.createElement('span');
          span.className = 'demo-media-preview-label';
          span.textContent = 'YouTube video';
          previewWrap.appendChild(span);
        } else {
          const span = document.createElement('span');
          span.className = 'demo-media-preview-label';
          span.textContent = 'Video: ' + url.split('/').pop();
          previewWrap.appendChild(span);
        }
      }
    }

    urlInput.addEventListener('input', updatePreview);
    typeSelect.addEventListener('change', updatePreview);
    if (item?.url) updatePreview();

    mediaList.appendChild(row);
  }

  // Initialize with existing data
  if (initialMedia.length > 0) {
    initialMedia.forEach((item) => addMediaRow(item));
  }

  document.getElementById('add-media-btn')?.addEventListener('click', () => addMediaRow());

  // ── String List Editors (features, use_cases) ────────
  function setupStringListEditor(listId, addBtnId, hiddenInputId) {
    const list = document.getElementById(listId);
    if (!list) return () => [];

    let initialData = [];
    try {
      initialData = JSON.parse(document.getElementById(hiddenInputId)?.value || '[]');
    } catch { /* empty */ }

    function addRow(value = '') {
      const row = document.createElement('div');
      row.className = 'string-list-row';
      const input = document.createElement('input');
      input.className = 'admin-input string-list-input';
      input.type = 'text';
      input.value = value || '';
      input.placeholder = 'Enter text...';
      const removeBtn = document.createElement('button');
      removeBtn.className = 'admin-btn admin-btn-danger admin-btn--small string-list-remove';
      removeBtn.type = 'button';
      removeBtn.textContent = '✕';
      removeBtn.addEventListener('click', () => row.remove());
      row.appendChild(input);
      row.appendChild(removeBtn);
      list.appendChild(row);
    }

    if (Array.isArray(initialData)) {
      initialData.forEach((v) => addRow(v));
    }
    document.getElementById(addBtnId)?.addEventListener('click', () => addRow());

    return () => {
      return Array.from(list.querySelectorAll('.string-list-input'))
        .map((input) => input.value.trim())
        .filter(Boolean);
    };
  }

  const getFeatures = setupStringListEditor('features-list', 'add-feature-btn', 'product-features');
  const getFeaturesKo = setupStringListEditor('features-ko-list', 'add-feature-ko-btn', 'product-features-ko');
  const getUseCases = setupStringListEditor('usecases-list', 'add-usecase-btn', 'product-use-cases');
  const getUseCasesKo = setupStringListEditor('usecases-ko-list', 'add-usecase-ko-btn', 'product-use-cases-ko');

  // ── Save ──────────────────────────────────────────────
  document.getElementById('save-btn')?.addEventListener('click', async () => {
    const saveBtn = document.getElementById('save-btn');
    const payload = getPayload();
    if (!payload.name) { showFeedback('Name is required', true); return; }
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving…';
    try {
      const res = await fetch('/api/admin/products/save', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (!res.ok) { showFeedback(data.error || 'Save failed', true); return; }

      if (!payload.id && data.id) {
        document.getElementById('product-id').value = data.id;
        if (data.slug) {
          slugField.value = data.slug;
          history.replaceState(null, '', `/admin/products/edit/${data.slug}`);
        }
      }
      showFeedback('Saved');
    } finally {
      saveBtn.disabled = false;
      saveBtn.textContent = 'Save';
    }
  });

  // ── Publish / Unpublish ───────────────────────────────
  document.getElementById('publish-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('publish-btn');
    const id = document.getElementById('product-id')?.value;
    if (!id) { showFeedback('Save first before publishing', true); return; }
    const action = btn.dataset.action;
    btn.disabled = true;
    try {
      const res = await fetch('/api/admin/products/status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, action }),
      });
      const data = await res.json();
      if (!res.ok) { showFeedback(data.error || 'Failed', true); return; }

      const badge = document.getElementById('status-badge');
      if (action === 'publish') {
        badge.textContent = 'published';
        badge.className = 'admin-status-badge admin-status-badge--published';
        btn.textContent = 'Unpublish';
        btn.dataset.action = 'unpublish';
      } else {
        badge.textContent = 'draft';
        badge.className = 'admin-status-badge admin-status-badge--draft';
        btn.textContent = 'Publish';
        btn.dataset.action = 'publish';
      }
      showFeedback(`${action === 'publish' ? 'Published' : 'Unpublished'}`);
    } finally {
      btn.disabled = false;
    }
  });

  // ── Feature / Unfeature ───────────────────────────────
  document.getElementById('feature-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('feature-btn');
    const id = document.getElementById('product-id')?.value;
    if (!id) { showFeedback('Save first', true); return; }
    const action = btn.dataset.action;
    btn.disabled = true;
    try {
      const res = await fetch('/api/admin/products/status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, action }),
      });
      const data = await res.json();
      if (!res.ok) { showFeedback(data.error || 'Failed', true); return; }

      const featuredBadge = document.getElementById('featured-badge');
      if (action === 'feature') {
        if (featuredBadge) featuredBadge.hidden = false;
        btn.textContent = 'Unfeature';
        btn.dataset.action = 'unfeature';
        document.getElementById('field-featured').checked = true;
      } else {
        if (featuredBadge) featuredBadge.hidden = true;
        btn.textContent = 'Feature';
        btn.dataset.action = 'feature';
        document.getElementById('field-featured').checked = false;
      }
      showFeedback(`${action === 'feature' ? 'Featured' : 'Unfeatured'}`);
    } finally {
      btn.disabled = false;
    }
  });

  // ── Delete ────────────────────────────────────────────
  document.getElementById('delete-btn')?.addEventListener('click', async () => {
    const id = document.getElementById('product-id')?.value;
    const name = document.getElementById('field-name')?.value || 'this product';
    if (!id) { showFeedback('No product to delete', true); return; }
    if (!confirm(`Delete "${name}"? This cannot be undone.`)) return;
    const btn = document.getElementById('delete-btn');
    btn.disabled = true;
    try {
      const res = await fetch('/api/admin/products/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id }),
      });
      if (!res.ok) { showFeedback('Delete failed', true); return; }
      window.location.href = '/admin/products/';
    } finally {
      btn.disabled = false;
    }
  });

  // ── AI Panel ──────────────────────────────────────────
  let aiCurrentAction = null;
  let aiResultTarget = null;

  document.getElementById('ai-panel-toggle')?.addEventListener('click', () => {
    const layout = document.getElementById('editor-layout');
    layout?.classList.toggle('admin-editor-layout--collapsed');
  });

  document.getElementById('ai-panel-close')?.addEventListener('click', () => {
    document.getElementById('editor-layout')?.classList.add('admin-editor-layout--collapsed');
  });

  document.querySelectorAll('.admin-ai-action-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const action = btn.dataset.action;
      const url = document.getElementById('field-url')?.value.trim();
      const name = document.getElementById('field-name')?.value.trim();

      if (action === 'generate_from_url' && !url) {
        showFeedback('Enter a URL first', true, 'ai-feedback');
        return;
      }
      if (!url && !name) {
        showFeedback('Enter a name or URL first', true, 'ai-feedback');
        return;
      }

      aiCurrentAction = action;

      // Dynamic loading text
      const actionLabels = {
        generate_from_url: 'Generate from URL',
        tagline_en: 'Tagline EN',
        tagline_ko: 'Tagline KO',
        description_en: 'Description EN',
        description_ko: 'Description KO',
      };
      const loadingText = document.getElementById('ai-loading-text');
      if (loadingText) loadingText.textContent = `Running ${actionLabels[action] || action}...`;

      document.getElementById('ai-loading').hidden = false;
      document.getElementById('ai-result-area').hidden = true;

      // Disable all + add spinner to active button
      document.querySelectorAll('.admin-ai-action-btn').forEach((b) => b.disabled = true);
      btn.classList.add('admin-ai-action-btn--loading');
      const spinner = document.createElement('span');
      spinner.className = 'ai-btn-spinner';
      btn.prepend(spinner);

      try {
        const res = await fetch('/api/admin/products/ai/generate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action, url, name }),
        });
        const data = await res.json();
        if (!res.ok) {
          showFeedback(data.error || 'AI request failed', true, 'ai-feedback');
          return;
        }

        const resultText = typeof data.result === 'object'
          ? JSON.stringify(data.result, null, 2)
          : String(data.result || '');

        document.getElementById('ai-result-label').textContent = action.replace(/_/g, ' ');
        document.getElementById('ai-result-text').textContent = resultText;
        document.getElementById('ai-result-area').hidden = false;

        // Determine which field(s) to apply to
        const targetMap = {
          tagline_en: 'field-tagline',
          tagline_ko: 'field-tagline-ko',
          description_en: 'field-description',
          description_ko: 'field-description-ko',
        };
        aiResultTarget = targetMap[action] || null;
        document.getElementById('ai-apply-btn').hidden = !aiResultTarget && action !== 'generate_from_url';
      } finally {
        document.getElementById('ai-loading').hidden = true;
        document.querySelectorAll('.admin-ai-action-btn').forEach((b) => {
          b.disabled = false;
          b.classList.remove('admin-ai-action-btn--loading');
          b.querySelector('.ai-btn-spinner')?.remove();
        });
      }
    });
  });

  document.getElementById('ai-apply-btn')?.addEventListener('click', () => {
    const resultText = document.getElementById('ai-result-text')?.textContent || '';

    if (aiCurrentAction === 'generate_from_url') {
      try {
        const parsed = JSON.parse(resultText);
        // Text fields
        const textMap = {
          tagline: 'field-tagline', tagline_en: 'field-tagline',
          tagline_ko: 'field-tagline-ko',
          description_en: 'field-description', description: 'field-description',
          description_ko: 'field-description-ko',
          logo_url: 'field-logo-url',
        };
        for (const [key, fieldId] of Object.entries(textMap)) {
          if (parsed[key]) {
            const el = document.getElementById(fieldId);
            if (el) el.value = parsed[key];
          }
        }
        // Logo preview
        if (parsed.logo_url) {
          const preview = document.getElementById('logo-preview');
          if (preview) { preview.src = parsed.logo_url; preview.style.display = ''; }
        }
        // Pricing select
        if (parsed.pricing) {
          const el = document.getElementById('field-pricing');
          if (el) el.value = parsed.pricing;
        }
        // Platform
        if (Array.isArray(parsed.platform) && parsed.platform.length > 0) {
          const el = document.getElementById('field-platform');
          if (el) el.value = parsed.platform.join(', ');
        }
        // Korean support
        if (typeof parsed.korean_support === 'boolean') {
          const el = document.getElementById('field-korean-support');
          if (el) el.checked = parsed.korean_support;
        }
        // Tags
        if (Array.isArray(parsed.tags) && parsed.tags.length > 0) {
          const el = document.getElementById('field-tags');
          if (el) el.value = parsed.tags.join(', ');
        }
        // Features & Use Cases — clear existing rows and add new ones
        const listConfigs = [
          { key: 'features', listId: 'features-list', addBtnId: 'add-feature-btn' },
          { key: 'features_ko', listId: 'features-ko-list', addBtnId: 'add-feature-ko-btn' },
          { key: 'use_cases', listId: 'usecases-list', addBtnId: 'add-usecase-btn' },
          { key: 'use_cases_ko', listId: 'usecases-ko-list', addBtnId: 'add-usecase-ko-btn' },
        ];
        for (const { key, listId } of listConfigs) {
          if (Array.isArray(parsed[key]) && parsed[key].length > 0) {
            const list = document.getElementById(listId);
            if (list) {
              list.innerHTML = '';
              parsed[key].forEach((val) => {
                const row = document.createElement('div');
                row.className = 'string-list-row';
                const input = document.createElement('input');
                input.className = 'admin-input string-list-input';
                input.type = 'text';
                input.value = String(val);
                const removeBtn = document.createElement('button');
                removeBtn.className = 'admin-btn admin-btn-danger admin-btn--small string-list-remove';
                removeBtn.type = 'button';
                removeBtn.textContent = '✕';
                removeBtn.addEventListener('click', () => row.remove());
                row.appendChild(input);
                row.appendChild(removeBtn);
                list.appendChild(row);
              });
            }
          }
        }
      } catch {
        const el = document.getElementById('field-tagline');
        if (el) el.value = resultText;
      }
    } else if (aiResultTarget) {
      const el = document.getElementById(aiResultTarget);
      if (el) el.value = resultText;
    }
    showFeedback('Applied');
  });
</script>

<style>
  .spin {
    animation: spin 1s linear infinite;
  }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Form container: stack rows vertically */
  .admin-editor-meta {
    flex-direction: column;
    align-items: stretch;
  }

  /* Form rows: inputs fill remaining space */
  .admin-editor-meta-row .admin-input,
  .admin-editor-meta-row .admin-select {
    flex: 1;
    min-width: 0;
  }

  /* Label width: accommodate longer labels (Description EN, Featured Order…) */
  .admin-editor-meta-row .admin-field-label {
    min-width: 120px;
  }

  /* Preview section */
  .product-preview-section {
    margin-top: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
  }

  .product-preview-tabs {
    display: flex;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
  }

  .product-preview-tab {
    padding: 0.5rem 1rem;
    font-size: 0.82rem;
    font-family: var(--font-ui);
    background: none;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all 0.15s ease;
  }

  .product-preview-tab:hover {
    color: var(--color-text-primary);
  }

  .product-preview-tab--active {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .product-preview-area {
    padding: 1.25rem;
    display: flex;
    justify-content: center;
  }

  .product-preview-card {
    width: 280px;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow: hidden;
    background: var(--color-bg-primary);
  }

  .product-preview-card .product-card-thumbnail {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--color-bg-secondary);
  }

  .product-preview-card .product-card-body {
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .product-preview-detail-inner {
    width: 100%;
    max-width: 600px;
  }

  .product-preview-detail-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  /* String list editor rows (features, use_cases) */
  .string-list-row {
    display: flex;
    gap: 0.4rem;
    align-items: center;
    margin-bottom: 0.35rem;
  }

  .string-list-row .string-list-input {
    flex: 1;
  }

  /* Demo Media editor rows */
  .demo-media-row {
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.5rem;
    margin-bottom: 0.5rem;
    background: var(--color-bg-secondary);
  }

  .demo-media-row-top {
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }

  .demo-media-row-bottom {
    display: flex;
    gap: 0.4rem;
    margin-top: 0.4rem;
  }

  .demo-media-preview-wrap {
    margin-top: 0.4rem;
  }

  .demo-media-preview-img {
    max-width: 200px;
    max-height: 120px;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid var(--color-border);
  }

  .demo-media-preview-label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }
</style>
