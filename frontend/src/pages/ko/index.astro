---
export const prerender = false;
import MainLayout from '../../layouts/MainLayout.astro';
import { t } from '../../i18n/index';
import { getSiteContents } from '../../lib/siteContent';

const sc = await getSiteContents(['home_title', 'home_subtitle', 'home_intro'], 'ko');
const homeTitle = sc.home_title || t.ko['home.title'];
const homeSubtitle = sc.home_subtitle || t.ko['home.subtitle'];
const homeIntro =
  sc.home_intro ||
  '가장 빠르게 AI 변화를 읽고, 필요한 용어를 바로 찾고, 읽은 뉴스와 용어를 쌓아가며, 서로의 생각을 나누는 공간입니다.';
const homeIntroParts = homeIntro.split(',').map((part) => part.trim()).filter(Boolean);
---

<MainLayout title={homeTitle} locale="ko" headerAlwaysVisible={true}>
  <section style="text-align: center; padding: 4rem 0;">
    <h1 class="text-display-xl" style={`font-family: var(--font-display); color: var(--color-accent);`}>
      0to1log
    </h1>
    <p class="text-subheading" style={`color: var(--color-text-secondary); margin-top: 1rem;`}>
      {homeSubtitle}
    </p>
    <p style={`max-width: 42rem; margin: 1.75rem auto 0; color: var(--color-text-secondary); line-height: 1.8;`}>
      {homeIntroParts.map((part, index) => (
        <>
          {index > 0 && <br />}
          {index < homeIntroParts.length - 1 ? `${part},` : part}
        </>
      ))}
    </p>
  </section>
</MainLayout>


