---
export const prerender = false;

import MainLayout from '../../layouts/MainLayout.astro';
import { t } from '../../i18n/index';
import { getHomePageData } from '../../lib/pageData/homePage';
import HomeSplitHero from '../../components/home/HomeSplitHero.astro';
import HomeHeroCard from '../../components/home/HomeHeroCard.astro';
import HomeNewsCard from '../../components/home/HomeNewsCard.astro';
import HomeTermCard from '../../components/home/HomeTermCard.astro';
import HomeSectionHeader from '../../components/home/HomeSectionHeader.astro';
import BlogFeaturedCard from '../../components/blog/BlogFeaturedCard.astro';
import HomeProductCard from '../../components/home/HomeProductCard.astro';

const locale = 'ko';
const { news, terms, blog, siteContent, featuredProducts } = await getHomePageData(locale);

const heroNews = news[0] ?? null;
const moreNews = news.slice(1, 4);
const featuredBlog = blog[0] ?? null;
const recentBlog = blog.slice(1, 4);

const homeTitle = siteContent.home_title || t.ko['home.title'];
const homeIntro = siteContent.home_intro ||
  '가장 빠르게 AI 변화를 읽고, 필요한 용어를 바로 찾고, 읽은 뉴스와 용어를 쌓아가며, 서로의 생각을 나누는 공간입니다.';
---

<MainLayout title={homeTitle} locale={locale} headerAlwaysVisible={true}>
  <div class="home-page">

    <!-- Section A: Hero -->
    <HomeSplitHero locale={locale} homeIntro={homeIntro} />

    <!-- Section B: Latest AI News -->
    {news.length > 0 && (
      <section class="home-section home-section--news">
        <HomeSectionHeader
          title={t.ko['home.latestNews']}
          viewAllHref="/ko/news/"
          viewAllLabel={t.ko['home.viewAll']}
        />
        <div class="home-news-featured">
          {heroNews && (
            <HomeHeroCard
              href={`/ko/news/${heroNews.slug}`}
              title={heroNews.title}
              excerpt={heroNews.excerpt}
              category="ai-news"
              publishedAt={heroNews.published_at}
              readingTimeMin={heroNews.reading_time_min}
              tags={heroNews.tags}
              locale={locale}
              postType={heroNews.post_type}
            />
          )}
          {moreNews.slice(0, 2).map((post) => (
            <HomeNewsCard
              href={`/ko/news/${post.slug}`}
              title={post.title}
              excerpt={post.excerpt}
              category="ai-news"
              publishedAt={post.published_at}
              readingTimeMin={post.reading_time_min}
              tags={post.tags}
              locale={locale}
              postType={post.post_type}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Section C+E: Glossary + AI Products (2-col) -->
    {(terms.length > 0 || featuredProducts.length > 0) && (
      <section class="home-section">
        <div class="home-spotlight-grid">
          {terms.length > 0 && (
            <div class="home-spotlight-col">
              <HomeSectionHeader
                title={t.ko['home.glossarySpotlight']}
                viewAllHref="/ko/handbook/"
                viewAllLabel={t.ko['home.viewAll']}
              />
              <div class="home-term-grid">
                {terms.slice(0, 3).map((term) => (
                  <HomeTermCard
                    href={`/ko/handbook/${term.slug}`}
                    term={term.term}
                    koreanName={term.korean_name}
                    definition={term.definition_ko}
                    categories={term.categories}
                    locale={locale}
                  />
                ))}
              </div>
            </div>
          )}
          {featuredProducts.length > 0 && (
            <div class="home-spotlight-col">
              <HomeSectionHeader
                title={t.ko['home.featuredProducts']}
                viewAllHref="/ko/products/"
                viewAllLabel={t.ko['home.viewAll']}
              />
              <div class="home-product-grid">
                {featuredProducts.slice(0, 3).map((product) => (
                  <HomeProductCard
                    href={`/ko/products/${product.slug}/`}
                    name={product.name}
                    tagline={product.tagline_ko || product.tagline}
                    logoUrl={product.logo_url}
                    pricing={product.pricing}
                    locale={locale}
                  />
                ))}
              </div>
            </div>
          )}
        </div>
      </section>
    )}

    <!-- Section D: From the Blog -->
    {(featuredBlog || recentBlog.length > 0) && (
      <section class="home-section">
        <HomeSectionHeader
          title={t.ko['home.fromBlog']}
          viewAllHref="/ko/blog/"
          viewAllLabel={t.ko['home.viewAll']}
        />
        <div class="home-blog-split">
          {featuredBlog && (
            <BlogFeaturedCard
              href={`/ko/blog/${featuredBlog.slug}`}
              title={featuredBlog.title}
              excerpt={featuredBlog.excerpt}
              category={featuredBlog.category}
              tags={featuredBlog.tags}
              locale={locale}
            />
          )}
          {recentBlog.length > 0 && (
            <nav class="home-blog-list" aria-label="최근 블로그 글">
              {recentBlog.map((post) => {
                const dateLabel = post.published_at
                  ? new Date(post.published_at).toLocaleDateString(locale === 'ko' ? 'ko-KR' : 'en-US')
                  : null;
                return (
                  <a href={`/ko/blog/${post.slug}`} class="home-blog-list-item">
                    <h3 class="home-blog-list-item-title">{post.title}</h3>
                    {dateLabel && <time class="home-blog-list-item-meta" datetime={post.published_at ?? undefined}>{dateLabel}</time>}
                  </a>
                );
              })}
            </nav>
          )}
        </div>
      </section>
    )}

  </div>
</MainLayout>
