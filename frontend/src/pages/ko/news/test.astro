---
export const prerender = true;

import MainLayout from '../../../layouts/MainLayout.astro';
---

<MainLayout title="웹훅 연결 완료" description="0to1log AI 뉴스 웹훅이 연결되었습니다." locale="ko">
  <div class="wh-test-page">
    <div class="wh-ticket-wrapper">
      <div class="wh-seal-icon">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" class="seal-svg">
          <circle cx="12" cy="12" r="11" stroke="currentColor" stroke-width="0.8" fill="color-mix(in srgb, var(--color-accent) 8%, transparent)"/>
          <path d="M8 12.5l3 3 5-6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" class="seal-check"/>
        </svg>
      </div>
      
      <div class="wh-ticket-header">
        <h1 class="wh-test-title">준비 완료!</h1>
        <p class="wh-test-sub">
          웹훅 채널이 <strong>0to1log</strong>에 성공적으로 연결되었습니다.<br />
          AI 뉴스가 발행되면 자동으로 알림이 전송됩니다.
        </p>
      </div>

      <div class="wh-menu-list">
        <div class="wh-menu-item">
          <div class="wh-menu-item-info">
            <strong>Research Digest</strong>
            <span>매일 AI 연구 뉴스를 기술적 깊이로 큐레이션</span>
          </div>
        </div>
        <div class="wh-menu-item">
          <div class="wh-menu-item-info">
            <strong>Business Digest</strong>
            <span>매일 AI 비즈니스 뉴스를 전략적 관점으로 큐레이션</span>
          </div>
        </div>
        <div class="wh-menu-item">
          <div class="wh-menu-item-info">
            <strong>Weekly Recap</strong>
            <span>이번 주 베스트 뉴스를 하나로 요약</span>
          </div>
        </div>
      </div>

      <div class="wh-ticket-actions">
        <a href="/ko/news/" class="wh-action-link">
          <span>AI 뉴스 다이제스트 보기</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/ko/handbook/" class="wh-action-link">
          <span>AI 용어집 둘러보기</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <div class="wh-ticket-footer">
        다른 플랫폼으로 받아보기: <a href="https://letters.0to1log.com" target="_blank">이메일 구독</a> &middot; <a href="/ko/rss.xml">RSS 피드</a>
      </div>
    </div>
  </div>
</MainLayout>

<style>
  .wh-test-page {
    display: flex;
    justify-content: center;
    padding: 5rem 1rem;
    min-height: 70vh;
  }

  .wh-ticket-wrapper {
    position: relative;
    max-width: 460px;
    width: 100%;
    margin: 0 auto;
    padding: 4rem 3rem 3.5rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.15);
    text-align: center;
  }
  
  /* Inner dashed border to simulate ticket print */
  .wh-ticket-wrapper::before {
    content: '';
    position: absolute;
    top: 8px;
    left: 8px;
    right: 8px;
    bottom: 8px;
    border: 1px dashed var(--color-border);
    border-radius: 2px;
    pointer-events: none;
    opacity: 0.7;
  }

  /* The Seal */
  .wh-seal-icon {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 2.5rem;
    color: var(--color-accent);
  }
  .seal-check {
    stroke-dasharray: 20;
    stroke-dashoffset: 20;
    animation: drawCheck 1.8s cubic-bezier(0.25, 1, 0.5, 1) forwards 0.4s;
  }
  @keyframes drawCheck {
    to { stroke-dashoffset: 0; }
  }

  /* Typography */
  .wh-ticket-header {
    margin-bottom: 3rem;
  }
  .wh-test-title {
    margin: 0 0 0.8rem;
    font-family: var(--font-heading);
    font-size: 2.2rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
  }
  .wh-test-sub {
    margin: 0;
    font-family: var(--font-ui);
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }
  .wh-test-sub strong { 
    color: var(--color-text-primary); 
    font-weight: 600;
  }

  /* The Menu List */
  .wh-menu-list {
    text-align: left;
    margin: 0 0 3.5rem;
    border-top: 1px solid var(--color-border);
  }
  .wh-menu-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.4rem 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .wh-menu-item-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .wh-menu-item-info strong {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-primary);
  }
  .wh-menu-item-info span {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  /* Footer Actions */
  .wh-ticket-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0 0.5rem;
  }
  .wh-action-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0.8rem;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-primary);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: all 0.2s;
  }
  .wh-action-link:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
  .wh-action-link svg {
    opacity: 0.5;
    transition: transform 0.2s, opacity 0.2s;
  }
  .wh-action-link:hover svg {
    transform: translateX(4px);
    opacity: 1;
  }

  /* Extra Footer */
  .wh-ticket-footer {
    margin-top: 1.5rem;
    padding-top: 1.2rem;
    border-top: 1px dashed var(--color-border);
    font-family: var(--font-ui);
    font-size: 0.73rem;
    color: var(--color-text-muted);
  }
  .wh-ticket-footer a {
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-border);
    transition: all 0.2s;
  }
  .wh-ticket-footer a:hover {
    color: var(--color-accent);
    text-decoration-color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .wh-ticket-wrapper {
      padding: 3rem 1.5rem 2.5rem;
    }
    .wh-test-title {
      font-size: 1.8rem;
    }
  }
</style>
