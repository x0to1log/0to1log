---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import { t } from '../../../i18n/index';
import { supabase } from '../../../lib/supabase';
import { createClient } from '@supabase/supabase-js';
import { normalizeCategorySlug, getPostTypeLabel } from '../../../lib/categories';
import NewsprintShell from '../../../components/newsprint/NewsprintShell.astro';
import NewsprintHeadline from '../../../components/newsprint/NewsprintHeadline.astro';
import NewsprintListCard from '../../../components/newsprint/NewsprintListCard.astro';
import NewsprintListRail from '../../../components/newsprint/NewsprintListRail.astro';
import NewsprintCategoryFilter from '../../../components/newsprint/NewsprintCategoryFilter.astro';
import NewsprintNotice from '../../../components/newsprint/NewsprintNotice.astro';
import { getSiteContents, parseJsonArray } from '../../../lib/siteContent';

let posts: any[] = [];
let fetchError: string | null = null;
const readPostIds = new Set<string>();
const bookmarkedPostIds = new Set<string>();
const user = Astro.locals.user;
const accessToken = Astro.locals.accessToken;

const authSb = (user && accessToken)
  ? createClient(
      import.meta.env.PUBLIC_SUPABASE_URL,
      import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
      { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
    )
  : null;

// Parallel fetch: posts + user data + site content
const [postsResult, histRes, bmRes, sc] = await Promise.all([
  supabase
    ? supabase
        .from('news_posts')
        .select('id, title, slug, category, post_type, published_at, tags, reading_time_min, excerpt')
        .eq('status', 'published')
        .eq('locale', 'ko')
        .eq('category', 'ai-news')
        .order('published_at', { ascending: false })
        .limit(50)
    : Promise.resolve({ data: null, error: null }),
  authSb
    ? authSb.from('reading_history').select('item_id').eq('user_id', user!.id).eq('item_type', 'news')
    : Promise.resolve({ data: null }),
  authSb
    ? authSb.from('user_bookmarks').select('item_id').eq('user_id', user!.id).eq('item_type', 'news')
    : Promise.resolve({ data: null }),
  getSiteContents(
    ['editorial_note', 'news_masthead', 'news_edition_label', 'news_subkicker', 'start_here_sections', 'volume_issue'],
    'ko',
  ),
]);

if (postsResult.error) {
  console.error('[log-list-ko] Supabase error:', postsResult.error.message);
  fetchError = postsResult.error.message;
} else {
  posts = postsResult.data ?? [];
}
(histRes.data ?? []).forEach((r: any) => readPostIds.add(r.item_id));
(bmRes.data ?? []).forEach((r: any) => bookmarkedPostIds.add(r.item_id));

const headline = posts.find(p => p.post_type === 'business') ?? null;
const rest = posts.filter(p => p !== headline);
const railPosts = headline ? rest.slice(0, 4) : posts.slice(0, 4);
const postTypeItems = [
  { value: 'business', label: getPostTypeLabel('ko', 'business') },
  { value: 'research', label: getPostTypeLabel('ko', 'research') },
  { value: 'weekly', label: 'Weekly Recap' },
];
const subkicker = parseJsonArray<string>(sc.news_subkicker, ['AI · 논문', '데일리 큐레이션', '공개 열람']);
const startHereSections = parseJsonArray<{slug: string; label: string; description: string}>(sc.start_here_sections, []);
const searchPlaceholder = 'AI 뉴스 검색';
const searchHints = [searchPlaceholder, 'OpenAI', 'Gemini', 'MCP'];
const searchEmptyMessage = '검색 조건에 맞는 AI 뉴스가 없습니다.';
---

<MainLayout title={t.ko['log.title']} description="개발자와 기획자를 위한 매일 AI 뉴스. 비즈니스·리서치 관점으로 큐레이션하고, 용어 해설과 퀴즈를 함께 제공합니다." locale="ko" slug="news/">
  <NewsprintShell
    locale="ko"
    masthead={sc.news_masthead || '최신 AI 뉴스 모음집'}
    editionLabel={sc.news_edition_label || '빌더스 데일리'}
    subkicker={subkicker}
    volumeLabel={sc.volume_issue || undefined}
  >
    <div class="handbook-search-sticky">
      <input
        type="search"
        id="news-search"
        aria-label={searchPlaceholder}
        placeholder={searchPlaceholder}
        data-placeholder-hints={JSON.stringify(searchHints)}
        class="handbook-search-input"
      />
    </div>

    <NewsprintCategoryFilter locale="ko" items={postTypeItems} filterKey="post_type" />
    <div id="news-result-count" class="handbook-result-count" aria-live="polite" style="display: none;"></div>

    {fetchError ? (
      <NewsprintNotice
        variant="error"
        message={t.ko['log.error']}
        linkHref="/ko/news/"
        linkLabel={t.ko['error.retry']}
      />
    ) : posts.length > 0 ? (
      <div id="news-list-results">
        {headline && (
          <NewsprintHeadline
            href={`/ko/news/${headline.slug}/`}
            title={headline.title}
            excerpt={headline.excerpt}
            category={headline.category}
            publishedAt={headline.published_at}
            readingTimeMin={headline.reading_time_min}
            tags={headline.tags}
            locale="ko"
            isBookmarked={bookmarkedPostIds.has(headline.id)}
            itemId={headline.id}
            itemType="news"
            postType={headline.post_type}
          />
        )}

        {rest.length > 0 && (
          <section class="newsprint-grid-cards">
            {rest.map((post) => (
              <NewsprintListCard
                href={`/ko/news/${post.slug}/`}
                title={post.title}
                category={post.category}
                publishedAt={post.published_at}
                readingTimeMin={post.reading_time_min}
                excerpt={post.excerpt}
                tags={post.tags}
                locale="ko"
                isRead={readPostIds.has(post.id)}
                isBookmarked={bookmarkedPostIds.has(post.id)}
                itemId={post.id}
                itemType="news"
                postType={post.post_type}
              />
            ))}
          </section>
        )}
      </div>
    ) : (
      <NewsprintNotice variant="empty" message={t.ko['log.empty']} />
    )}

    <div id="news-no-results" style="display: none;">
      <NewsprintNotice variant="empty" message={searchEmptyMessage} />
    </div>

    <Fragment slot="rail">
      <NewsprintListRail
        locale="ko"
        posts={railPosts}
        editorialNote={sc.editorial_note || undefined}
        startHereSections={startHereSections.length > 0 ? startHereSections : undefined}
      />
    </Fragment>
  </NewsprintShell>
</MainLayout>

<script>
  import '../../../scripts/bookmark';
</script>

<script>
  import '../../../scripts/handbookSearchHints';
</script>

<script>
  import '../../../scripts/newsListSearch';
</script>
