---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import { t } from '../../../i18n/index';
import { normalizeCategorySlug } from '../../../lib/categories';
import { getNewsDetailPageData } from '../../../lib/pageData/newsDetailPage';
import NewsprintShell from '../../../components/newsprint/NewsprintShell.astro';
import NewsprintSideRail from '../../../components/newsprint/NewsprintSideRail.astro';
import NewsprintArticleLayout from '../../../components/newsprint/NewsprintArticleLayout.astro';
import NewsprintNotice from '../../../components/newsprint/NewsprintNotice.astro';
import ReadingActionsRail from '../../../components/common/ReadingActionsRail.astro';

const { slug } = Astro.params;
const pageSlug = slug ?? '';
const articleFindQuery = Astro.url.searchParams.get('q')?.trim() ?? '';
const previewRequested = Astro.url.searchParams.get('preview') === '1';
const previewMode = previewRequested && !!Astro.locals.isAdmin;
const previewPersona = Astro.url.searchParams.get('previewPersona');

const {
  post,
  postError,
  focusItems,
  articleData,
  nextPost,
  pairedSlug,
  similarPosts,
  isBookmarked,
  isLiked,
  likeCount,
  commentCount,
  handbookTermsJson,
  hasTerms,
  relatedTerms,
  htmlContent,
  analysisHtml,
  factPack,
  sourceCards,
  activePersona,
  personaHtmlMap,
  hasPersonaSwitcher,
} = await getNewsDetailPageData({
  locale: 'ko',
  slug: pageSlug,
  previewMode,
  locals: Astro.locals,
  previewPersona,
});

if (!post && !postError) {
  Astro.response.status = 404;
}

const masthead = '최신 AI 뉴스 모음집';
const editionMap: Record<string, string> = {
  'ai-news': '데일리 디스패치',
  study: '학습 노트',
  career: '커리어 생각',
  project: '프로젝트 기록',
};
const editionLabel = post ? (editionMap[normalizeCategorySlug(post.category) || ''] || '딥 다이브') : '딥 다이브';
const user = Astro.locals.user;
const accessToken = Astro.locals.accessToken;
const pageTitle = post ? post.title : '찾을 수 없음';
const altSlugValue = pairedSlug || undefined;
---

<MainLayout title={pageTitle} locale="ko" slug={`news/${slug}/`} altSlug={altSlugValue} article={articleData} previewMode={previewMode}>
  <NewsprintShell
    locale="ko"
    masthead={masthead}
    editionLabel={editionLabel}
    subkicker={['AI · 논문 · 프로젝트', '데일리 큐레이션', '공개 아카이브']}
  >
    <form class="handbook-detail-search handbook-search-sticky handbook-search-sticky--detail" action="/ko/news/" method="get">
      <input
        type="text"
        name="q"
        aria-label={t.ko['news.search']}
        placeholder={t.ko['news.search']}
        class="handbook-search-input"
      />
    </form>

    {postError ? (
      <NewsprintNotice
        variant="error"
        message={t.ko['log.error']}
        linkHref="/ko/news/"
        linkLabel={t.ko['post.back']}
      />
    ) : !post ? (
      <NewsprintNotice
        variant="notfound"
        message={t.ko['post.notfound']}
        linkHref="/ko/news/"
        linkLabel={t.ko['post.back']}
      />
    ) : (
      <NewsprintArticleLayout
        locale="ko"
        slug={pageSlug}
        showSlug={false}
        title={post.title}
        excerpt={post.excerpt}
        category={post.category}
        publishedAt={post.published_at}
        readingTimeMin={post.reading_time_min}
        tags={post.tags}
        htmlContent={htmlContent}
        analysisHtml={analysisHtml}
        factPack={factPack}
        sourceCards={sourceCards}
        backLabel={t.ko['post.back']}
        nextPost={nextPost}
        isBookmarked={isBookmarked}
        itemId={post.id}
        itemType="news"
        isAdmin={!!Astro.locals.isAdmin && !previewMode}
        isAuthenticated={!!user && !!accessToken}
        likeCount={likeCount}
        commentCount={commentCount}
        isLiked={isLiked}
        activePersona={activePersona}
        personaHtmlMap={hasPersonaSwitcher ? personaHtmlMap : undefined}
        guideItems={post.guide_items}
        initialFindQuery={articleFindQuery}
        previewMode={previewMode}
        showStickyActions={false}
      />
    )}

    <Fragment slot="rail">
      <form class="handbook-detail-search newsprint-rail-search" action="/ko/news/" method="get">
        <input
          type="text"
          name="q"
          aria-label={t.ko['news.search']}
          placeholder={t.ko['news.search']}
          class="handbook-search-input"
        />
      </form>
      <ReadingActionsRail
        className="newsprint-rail-stack"
        locale="ko"
        variant="news"
        title={post?.title || pageTitle}
        shareUrl={`${import.meta.env.PUBLIC_SITE_URL || 'https://0to1log.com'}/ko/news/${pageSlug}/`}
        itemId={post?.id}
        itemType="news"
        isBookmarked={isBookmarked}
        previewMode={previewMode}
        isAuthenticated={!!user && !!accessToken}
        articleRedirect={`/ko/news/${pageSlug}/`}
        commentRedirect={`/ko/news/${pageSlug}/#comments`}
        likeCount={likeCount}
        commentCount={commentCount}
        isLiked={isLiked}
      >
        <NewsprintSideRail locale="ko" focusItems={focusItems} similarPosts={similarPosts} relatedTerms={relatedTerms} />
      </ReadingActionsRail>
    </Fragment>
  </NewsprintShell>
</MainLayout>

{hasTerms && (
  <script type="application/json" id="handbook-terms-data" set:html={JSON.stringify(handbookTermsJson)} />
)}

<script>
  import '../../../scripts/bookmark';
  import '../../../scripts/likes';
  import '../../../scripts/comments';
  import '../../../scripts/handbook-popup';

  function recordReadingHistory(): void {
    if (document.body.dataset.previewMode === 'true') return;
    const postId = document.querySelector('[data-item-id][data-item-type="news"]')?.getAttribute('data-item-id');
    if (!postId) return;
    fetch('/api/user/reading-history', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ item_type: 'news', item_id: postId }),
    }).catch(() => {});
  }

  function initAdminActions(): void {
    if (document.body.dataset.previewMode === 'true') return;
    const actions = document.querySelector('.newsprint-admin-actions') as HTMLElement | null;
    if (!actions) return;

    const btn = actions.querySelector('.newsprint-admin-action-btn--unpublish');
    btn?.addEventListener('click', async () => {
      if (!confirm('이 항목을 비공개로 전환할까요?')) return;

      const id = actions.dataset.toolbarId;
      const api = actions.dataset.toolbarApi;
      if (!id || !api) return;

      try {
        const res = await fetch(api, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, action: 'unpublish' }),
        });

        if (res.ok) {
          const editLink = actions.querySelector('a') as HTMLAnchorElement | null;
          window.location.href = editLink?.href || '/admin';
        } else {
          const err = await res.json().catch(() => ({ error: 'Unknown error' }));
          alert(`비공개 전환 실패: ${err.error || err.detail}`);
        }
      } catch {
        alert('비공개 전환 실패: 네트워크 오류');
      }
    });
  }

  function syncSearchBarVisibility(): void {
    const articleFind = document.querySelector('.newsprint-article-find');
    const stickySearch = document.querySelector<HTMLElement>('.handbook-search-sticky');
    if (!articleFind || !stickySearch) return;

    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          stickySearch.setAttribute('data-hidden-by-find', '');
        } else {
          stickySearch.removeAttribute('data-hidden-by-find');
        }
      },
      { threshold: 0 }
    );
    observer.observe(articleFind);
  }

  document.addEventListener('astro:page-load', recordReadingHistory);
  document.addEventListener('astro:page-load', initAdminActions);
  document.addEventListener('astro:page-load', syncSearchBarVisibility);
</script>
