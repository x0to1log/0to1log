---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import { t } from '../../../i18n/index';
import { getProductsPageData } from '../../../lib/pageData/productsPage';
import ProductSpotlight from '../../../components/products/ProductSpotlight.astro';
import ProductFilterBar from '../../../components/products/ProductFilterBar.astro';
import ProductCard from '../../../components/products/ProductCard.astro';
import { getCategoryIcon } from '../../../lib/productCategoryIcons';

const locale = 'ko';
const PREVIEW_COUNT = 4;
const { categories, spotlightProduct, allProducts, productsByCategory, totalProducts, error } = await getProductsPageData(locale);

const pricingKo: Record<string, string> = { free: '무료', freemium: '무료 프리미엄', paid: '유료', enterprise: '기업용' };
const categoryKo: Record<string, string> = { assistant: '어시스턴트 챗봇', image: '이미지 디자인', video: '영상 비디오', audio: '오디오 음악 음성', coding: '코딩 개발 IDE', workflow: '자동화 워크플로우', builder: '앱빌더 노코드', platform: '플랫폼 API', research: '리서치 논문', community: '커뮤니티' };

const buildSearchText = (product: typeof allProducts[0]) =>
  [
    product.name,
    (product as any).name_ko,
    product.tagline,
    (product as any).tagline_ko,
    product.pricing,
    product.pricing ? pricingKo[product.pricing] : null,
    product.primary_category,
    categoryKo[product.primary_category],
    ...(product.platform ?? []),
    ...(product.tags ?? []),
    (product as any).search_corpus,
  ].filter(Boolean).join(' ').toLowerCase();

const getFirstImageUrl = (product: typeof allProducts[0]) => {
  const first = product.demo_media?.find((m) => m.type === 'image');
  return first?.url ?? null;
};
---

<MainLayout
  title={t.ko['products.title']}
  description={t.ko['products.heroSubtitle']}
  locale={locale}
>
  <div class="products-page" id="products-top">
    {error && <p class="products-error">{t.ko['products.error']}</p>}

    <ProductFilterBar categories={categories} locale={locale} />

    <ProductSpotlight product={spotlightProduct} locale={locale} />

    <!-- Category Preview Mode (default) -->
    <div id="category-preview">
      {categories.map((cat) => {
        const products = productsByCategory[cat.id] ?? [];
        if (products.length === 0) return null;
        const preview = products.slice(0, PREVIEW_COUNT);
        const hasMore = products.length > PREVIEW_COUNT;
        const label = cat.label_ko;
        return (
          <section class="product-category-preview">
            <div class="product-category-preview-header">
              <div class="product-category-preview-title-group">
                <span class="product-category-preview-icon" set:html={getCategoryIcon(cat.id)} />
                <h2 class="product-category-preview-title">{label}</h2>
                <span class="product-category-preview-count">{products.length}</span>
              </div>
              {hasMore && (
                <button class="product-category-see-all" data-category={cat.id} type="button">
                  모두 보기 &rarr;
                </button>
              )}
            </div>
            <div class="product-grid product-grid--preview">
              {preview.map((product) => (
                <ProductCard
                  href={`/${locale}/products/${product.slug}/`}
                  name={product.name_original}
                  tagline={product.tagline}
                  logoUrl={product.logo_url}
                  thumbnailUrl={product.thumbnail_url}
                  demoMediaFirst={getFirstImageUrl(product)}
                  pricing={product.pricing}
                  platform={product.platform}
                  koreanSupport={product.korean_support}
                  locale={locale}
                  searchText={buildSearchText(product)}
                  categoryId={product.primary_category}
                  viewCount={product.view_count}
                  productId={product.id}
                />
              ))}
            </div>
          </section>
        );
      })}
    </div>

    <!-- Filtered Grid Mode (when category or search active) -->
    <div class="product-grid" id="filtered-grid" hidden>
      {allProducts.map((product) => (
        <ProductCard
          href={`/${locale}/products/${product.slug}/`}
          name={product.name}
          tagline={product.tagline}
          logoUrl={product.logo_url}
          thumbnailUrl={product.thumbnail_url}
          demoMediaFirst={getFirstImageUrl(product)}
          pricing={product.pricing}
          platform={product.platform}
          koreanSupport={product.korean_support}
          locale={locale}
          searchText={buildSearchText(product)}
          categoryId={product.primary_category}
          viewCount={product.view_count}
          productId={product.id}
        />
      ))}
    </div>

    <p id="product-search-no-results" class="products-search-no-results" hidden>
      {t.ko['products.searchNoResults']}
    </p>

    {allProducts.length === 0 && !error && (
      <p class="products-empty">{t.ko['products.empty']}</p>
    )}

    <section class="product-outro">
      <h2 class="product-outro-title">{t.ko['products.outroTitle']}</h2>
      <p class="product-outro-body">{t.ko['products.outroBody']}</p>
    </section>

    <p class="products-trademark-disclaimer">
      제품명, 로고 및 상표는 각 소유자의 자산입니다. 별도 표기가 없는 한, 0to1log는 나열된 회사와 제휴, 보증 또는 후원 관계가 없습니다.
    </p>
  </div>
</MainLayout>

<script>
  import '../../../scripts/handbookSearchHints';
  import '../../../scripts/productLike';

  document.addEventListener('astro:page-load', () => {
    const input = document.getElementById('product-search') as HTMLInputElement | null;
    if (!input) return;
    const noResults = document.getElementById('product-search-no-results');
    const preview = document.getElementById('category-preview');
    const filtered = document.getElementById('filtered-grid');
    const cards = filtered ? Array.from(filtered.querySelectorAll<HTMLElement>('.product-card')) : [];

    let currentCategory = 'all';
    let currentQuery = '';

    function switchToFiltered(cat: string) {
      currentCategory = cat;
      if (preview) preview.hidden = true;
      if (filtered) filtered.hidden = false;
      applyFilters();

      document.querySelectorAll<HTMLElement>('.product-filter-tab').forEach((t) =>
        t.classList.toggle('active', t.dataset.category === cat)
      );
    }

    function switchToPreview() {
      currentCategory = 'all';
      currentQuery = '';
      if (input) input.value = '';
      if (preview) preview.hidden = false;
      if (filtered) filtered.hidden = true;
      if (noResults) noResults.hidden = true;

      history.replaceState(null, '', location.pathname);

      document.querySelectorAll<HTMLElement>('.product-filter-tab').forEach((t) =>
        t.classList.toggle('active', t.dataset.category === 'all')
      );
    }

    function applyFilters() {
      const q = currentQuery.trim().toLowerCase();
      let totalVisible = 0;

      cards.forEach((card) => {
        const text = card.dataset.searchText ?? '';
        const cat = card.dataset.category ?? '';

        const matchesCategory = currentCategory === 'all' || cat === currentCategory;
        const matchesSearch = !q || text.includes(q);
        const visible = matchesCategory && matchesSearch;

        if (visible) { card.removeAttribute('hidden'); totalVisible++; }
        else card.setAttribute('hidden', '');
      });

      if (noResults) {
        if (totalVisible === 0 && (q || currentCategory !== 'all')) noResults.removeAttribute('hidden');
        else noResults.setAttribute('hidden', '');
      }
    }

    input.addEventListener('input', () => {
      currentQuery = input.value;
      const url = new URL(window.location.href);
      if (currentQuery) {
        url.searchParams.set('q', currentQuery);
        url.searchParams.delete('cat');
        currentCategory = 'all';
        if (preview) preview.hidden = true;
        if (filtered) filtered.hidden = false;
      } else if (currentCategory === 'all') {
        url.searchParams.delete('q');
        switchToPreview();
        return;
      } else {
        url.searchParams.delete('q');
      }
      history.replaceState(null, '', url.toString());
      applyFilters();
    });

    document.addEventListener('product-filter', ((e: CustomEvent) => {
      const cat = e.detail.category;
      if (cat === 'all' && !currentQuery) {
        switchToPreview();
      } else {
        switchToFiltered(cat);
      }
    }) as EventListener);

    document.querySelectorAll<HTMLButtonElement>('.product-category-see-all').forEach((btn) => {
      btn.addEventListener('click', () => {
        const cat = btn.dataset.category ?? '';
        const url = new URL(window.location.href);
        url.searchParams.set('cat', cat);
        history.replaceState(null, '', url.toString());
        switchToFiltered(cat);
      });
    });

    const params = new URLSearchParams(location.search);
    const urlQ = params.get('q') ?? '';
    const urlCat = params.get('cat') ?? '';
    if (urlQ) {
      input.value = urlQ;
      currentQuery = urlQ;
      switchToFiltered(urlCat || 'all');
    } else if (urlCat) {
      switchToFiltered(urlCat);
    }
  });
</script>
