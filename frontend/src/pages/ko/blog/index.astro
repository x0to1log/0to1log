---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import { t } from '../../../i18n/index';
import { supabase } from '../../../lib/supabase';
import { createClient } from '@supabase/supabase-js';
import { BLOG_CATEGORIES } from '../../../lib/categories';
import { buildBlogSidebarDataset, toSidebarPost } from '../../../lib/pageData/blogSidebar';
import BlogShell from '../../../components/blog/BlogShell.astro';
import BlogFeaturedCard from '../../../components/blog/BlogFeaturedCard.astro';
import BlogListItem from '../../../components/blog/BlogListItem.astro';
import NewsprintNotice from '../../../components/newsprint/NewsprintNotice.astro';

let posts: any[] = [];
let fetchError: string | null = null;

if (supabase) {
  const { data, error } = await supabase
    .from('blog_posts')
    .select('id, title, slug, category, published_at, tags, reading_time_min, og_image_url, excerpt')
    .eq('status', 'published')
    .eq('locale', 'ko')
    .in('category', BLOG_CATEGORIES)
    .order('created_at', { ascending: false });

  if (error) {
    console.error('[blog-list-ko] Supabase error:', error.message);
    fetchError = error.message;
  } else {
    posts = data ?? [];
  }
}

// User reading history & bookmarks
const readPostIds = new Set<string>();
const bookmarkedPostIds = new Set<string>();
const user = Astro.locals.user;
const accessToken = Astro.locals.accessToken;
if (user && accessToken) {
  const authSb = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
    { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
  );
  const [histRes, bmRes] = await Promise.all([
    authSb.from('reading_history').select('item_id').eq('user_id', user.id).eq('item_type', 'blog'),
    authSb.from('user_bookmarks').select('item_id').eq('user_id', user.id).eq('item_type', 'blog'),
  ]);
  (histRes.data ?? []).forEach((r: any) => readPostIds.add(r.item_id));
  (bmRes.data ?? []).forEach((r: any) => bookmarkedPostIds.add(r.item_id));
}

const FEATURED_COUNT = 4;
const BATCH_SIZE = 10;

const featuredPosts = posts.slice(0, FEATURED_COUNT);
const sidebarPosts = buildBlogSidebarDataset(
  posts.map((post) =>
    toSidebarPost({
      title: post.title,
      slug: post.slug,
      category: post.category,
      published_at: post.published_at,
    }),
  ),
);

// Split ALL posts into batches for infinite scroll in "All Posts" section
const allPostBatches: any[][] = [];
for (let i = 0; i < posts.length; i += BATCH_SIZE) {
  allPostBatches.push(posts.slice(i, i + BATCH_SIZE));
}
---

<MainLayout title={t.ko['blog.title']} locale="ko" slug="blog/">
  <BlogShell locale="ko" sidebarPosts={sidebarPosts} totalCount={posts.length} mode="index">
    <!-- Mobile toggle button -->
    <div class="blog-mobile-toolbar">
      <button class="blog-mobile-toggle" data-sidebar-toggle aria-label="Menu">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 5h14M3 10h14M3 15h14" />
        </svg>
      </button>
    </div>

    <!-- Masthead -->
    <h1 class="blog-masthead-title">–도록: do log</h1>

    {fetchError ? (
      <NewsprintNotice variant="error" message={t.ko['blog.error']} linkHref="/ko/blog/" linkLabel={t.ko['error.retry']} />
    ) : posts.length > 0 ? (
      <>
        <!-- FEATURED section -->
        {featuredPosts.length > 0 && (
          <>
            <h2 class="blog-section-header">{t.ko['blog.featured']}</h2>
            <div class="blog-featured-grid">
              {featuredPosts.map(post => (
                <BlogFeaturedCard
                  href={`/ko/blog/${post.slug}/`}
                  title={post.title}
                  excerpt={post.excerpt}
                  category={post.category}
                  readingTimeMin={post.reading_time_min}
                  tags={post.tags}
                  locale="ko"
                  isBookmarked={bookmarkedPostIds.has(post.id)}
                  itemId={post.id}
                  itemType="blog"
                />
              ))}
            </div>
          </>
        )}

        <!-- ALL POSTS section with infinite scroll -->
        <h2 class="blog-section-header">{t.ko['blog.allPosts']}</h2>
        <div class="blog-list-section" data-blog-list>
          {allPostBatches.map((batch, batchIdx) => (
            <div
              class="blog-list-batch"
              data-blog-batch={batchIdx}
              {...(batchIdx > 0 && { hidden: true })}
            >
              {batch.map(post => (
                <BlogListItem
                  href={`/ko/blog/${post.slug}/`}
                  title={post.title}
                  category={post.category}
                  publishedAt={post.published_at}
                  readingTimeMin={post.reading_time_min}
                  locale="ko"
                  isRead={readPostIds.has(post.id)}
                  isBookmarked={bookmarkedPostIds.has(post.id)}
                  itemId={post.id}
                  itemType="blog"
                />
              ))}
            </div>
          ))}
        </div>
        {allPostBatches.length > 1 && (
          <div class="blog-scroll-sentinel" data-blog-sentinel></div>
        )}
      </>
    ) : (
      <div class="blog-empty-state">
        <div class="blog-empty-icon">📝</div>
        <h2>준비 중</h2>
        <p>글을 준비하고 있어요. 곧 만나요!</p>
      </div>
    )}
  </BlogShell>
</MainLayout>

<script>
  import '../../../scripts/bookmark';

  // Mobile sidebar toggle
  // Infinite scroll — reveal next hidden batch when sentinel enters viewport
  function initInfiniteScroll() {
    const sentinel = document.querySelector('[data-blog-sentinel]');
    if (!sentinel) return;

    let currentBatch = 0;

    const observer = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;

        currentBatch++;
        const next = document.querySelector(`[data-blog-batch="${currentBatch}"]`) as HTMLElement | null;
        if (next) {
          next.hidden = false;
        }

        // Check if there are more batches
        const afterNext = document.querySelector(`[data-blog-batch="${currentBatch + 1}"]`);
        if (!afterNext) {
          observer.disconnect();
          sentinel.remove();
        }
      }
    }, { rootMargin: '200px' });

    observer.observe(sentinel);
  }

  document.addEventListener('DOMContentLoaded', () => {
    initInfiniteScroll();
  });
  initInfiniteScroll();
</script>
