---
export const prerender = false;
import MainLayout from '../../../layouts/MainLayout.astro';
import { t } from '../../../i18n/index';
import { supabase } from '../../../lib/supabase';
import NewsprintShell from '../../../components/newsprint/NewsprintShell.astro';
import NewsprintListCard from '../../../components/newsprint/NewsprintListCard.astro';
import NewsprintSideRail from '../../../components/newsprint/NewsprintSideRail.astro';
import NewsprintCategoryFilter from '../../../components/newsprint/NewsprintCategoryFilter.astro';
import NewsprintNotice from '../../../components/newsprint/NewsprintNotice.astro';

let posts: any[] = [];
let fetchError: string | null = null;

if (supabase) {
  const { data, error } = await supabase
    .from('posts')
    .select('id, title, slug, category, published_at, tags, reading_time_min, og_image_url, excerpt')
    .eq('status', 'published')
    .eq('locale', 'ko')
    .order('published_at', { ascending: false });

  if (error) {
    console.error('[log-list-ko] Supabase error:', error.message);
    fetchError = error.message;
  } else {
    posts = data ?? [];
  }
}

const featured = posts[0] ?? null;
const rest = featured ? posts.slice(1) : [];
const railPosts = posts.slice(0, 4);
const categories = Array.from(new Set(posts.map((post) => post.category).filter(Boolean))).slice(0, 6);
---

<MainLayout title={t.ko['log.title']} locale="ko" slug="log/">
  <NewsprintShell locale="ko" masthead="가치를 담는 기록" editionLabel="빌더스 데일리"
    subkicker={['AI · 논문 · 프로젝트', '데일리 큐레이션', '무료']}>

    <NewsprintCategoryFilter locale="ko" />

    {fetchError ? (
      <NewsprintNotice
        variant="error"
        message={t.ko['log.error']}
        linkHref="/ko/log/"
        linkLabel={t.ko['error.retry']}
      />
    ) : featured ? (
      <>
        <a href={`/ko/log/${featured.slug}/`} class="newsprint-featured newsprint-card" data-category={featured.category}>
          <span class="newsprint-category">{featured.category}</span>
          <h2 class="newsprint-lead-title">{featured.title}</h2>
          {featured.excerpt && <p class="newsprint-excerpt">{featured.excerpt}</p>}
          <div class="newsprint-tags">
            {(featured.tags ?? []).slice(0, 5).map((tag: string) => <span class="newsprint-tag">{tag}</span>)}
          </div>
          <div class="newsprint-meta">
            {featured.published_at && <time>{new Date(featured.published_at).toLocaleDateString('ko-KR')}</time>}
            {featured.reading_time_min && <span>{featured.reading_time_min}분 읽기</span>}
          </div>
        </a>

        {rest.length > 0 && (
          <section class="newsprint-grid-cards">
            {rest.map((post) => (
              <NewsprintListCard
                href={`/ko/log/${post.slug}/`}
                title={post.title}
                category={post.category}
                publishedAt={post.published_at}
                readingTimeMin={post.reading_time_min}
                excerpt={post.excerpt}
                tags={post.tags}
                locale="ko"
              />
            ))}
          </section>
        )}
      </>
    ) : (
      <NewsprintNotice variant="empty" message={t.ko['log.empty']} />
    )}

    <Fragment slot="rail">
      <NewsprintSideRail locale="ko" posts={railPosts} categories={categories} />
    </Fragment>
  </NewsprintShell>
</MainLayout>
