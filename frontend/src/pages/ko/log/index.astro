---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import { t } from '../../../i18n/index';
import { supabase } from '../../../lib/supabase';
import { createClient } from '@supabase/supabase-js';
import { getCategoryLabel, normalizeCategorySlug } from '../../../lib/categories';
import NewsprintShell from '../../../components/newsprint/NewsprintShell.astro';
import NewsprintListCard from '../../../components/newsprint/NewsprintListCard.astro';
import NewsprintListRail from '../../../components/newsprint/NewsprintListRail.astro';
import NewsprintCategoryFilter from '../../../components/newsprint/NewsprintCategoryFilter.astro';
import NewsprintNotice from '../../../components/newsprint/NewsprintNotice.astro';

let posts: any[] = [];
let fetchError: string | null = null;

if (supabase) {
  const { data, error } = await supabase
    .from('posts')
    .select('id, title, slug, category, published_at, tags, reading_time_min, og_image_url, excerpt')
    .eq('status', 'published')
    .eq('locale', 'ko')
    .order('published_at', { ascending: false });

  if (error) {
    console.error('[log-list-ko] Supabase error:', error.message);
    fetchError = error.message;
  } else {
    posts = data ?? [];
  }
}

// User reading history & bookmarks
const readPostIds = new Set<string>();
const bookmarkedPostIds = new Set<string>();
const user = Astro.locals.user;
const accessToken = Astro.locals.accessToken;
if (user && accessToken) {
  const authSb = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
    { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
  );
  const [histRes, bmRes] = await Promise.all([
    authSb.from('reading_history').select('item_id').eq('user_id', user.id).eq('item_type', 'post'),
    authSb.from('user_bookmarks').select('item_id').eq('user_id', user.id).eq('item_type', 'post'),
  ]);
  (histRes.data ?? []).forEach((r: any) => readPostIds.add(r.item_id));
  (bmRes.data ?? []).forEach((r: any) => bookmarkedPostIds.add(r.item_id));
}

const featured = posts[0] ?? null;
const rest = featured ? posts.slice(1) : [];
const railPosts = featured ? posts.slice(1, 5) : posts.slice(0, 4);
const categories = Array.from(
  new Set(
    posts
      .map((post) => normalizeCategorySlug(post.category))
      .filter((category): category is string => Boolean(category)),
  ),
).slice(0, 6);
---

<MainLayout title={t.ko['log.title']} locale="ko" slug="log/">
  <NewsprintShell
    locale="ko"
    masthead="AI의 모든 것"
    editionLabel="빌더의 데일리"
    subkicker={['AI · 논문 · 프로젝트', '데일리 큐레이션', '공개 열람']}
  >
    <NewsprintCategoryFilter locale="ko" categories={categories} />

    {fetchError ? (
      <NewsprintNotice
        variant="error"
        message={t.ko['log.error']}
        linkHref="/ko/log/"
        linkLabel={t.ko['error.retry']}
      />
    ) : featured ? (
      <>
        <a
          href={`/ko/log/${featured.slug}/`}
          class={`newsprint-featured newsprint-card${featured.og_image_url ? ' newsprint-featured--has-img' : ''}`}
          data-category={normalizeCategorySlug(featured.category)}
        >
          {featured.og_image_url && (
            <div class="newsprint-featured-img-frame">
              <img
                src={featured.og_image_url}
                alt={featured.title}
                class="newsprint-featured-img img-newsprint"
                width="600"
                height="400"
                loading="eager"
                fetchpriority="high"
              />
            </div>
          )}
          <div>
            <h2 class="newsprint-lead-title">{featured.title}</h2>
            {featured.excerpt && <p class="newsprint-excerpt">{featured.excerpt}</p>}
            <div class="newsprint-card-bottom" style="font-size: 0.85rem;">
              <span class="newsprint-category">{getCategoryLabel('ko', featured.category)}</span>
              {(featured.tags ?? []).slice(0, 5).map((tag: string) => <span class="newsprint-tag">{tag}</span>)}
              <span class="newsprint-meta-inline">
                {featured.reading_time_min && <span>약 {featured.reading_time_min}분</span>}
                {featured.published_at && <time datetime={featured.published_at}>{new Date(featured.published_at).toLocaleDateString('ko-KR')}</time>}
              </span>
            </div>
          </div>
        </a>

        {rest.length > 0 && (
          <section class="newsprint-grid-cards">
            {rest.map((post) => (
              <NewsprintListCard
                href={`/ko/log/${post.slug}/`}
                title={post.title}
                category={post.category}
                publishedAt={post.published_at}
                readingTimeMin={post.reading_time_min}
                excerpt={post.excerpt}
                tags={post.tags}
                locale="ko"
                isRead={readPostIds.has(post.id)}
                isBookmarked={bookmarkedPostIds.has(post.id)}
                itemId={post.id}
                itemType="post"
              />
            ))}
          </section>
        )}
      </>
    ) : (
      <NewsprintNotice variant="empty" message={t.ko['log.empty']} />
    )}

    <Fragment slot="rail">
      <NewsprintListRail locale="ko" posts={railPosts} />
    </Fragment>
  </NewsprintShell>
</MainLayout>

<script>
  import '../../../scripts/bookmark';
</script>
