---
export const prerender = false;
import MainLayout from '../../../layouts/MainLayout.astro';
import { t } from '../../../i18n/index';
import { supabase } from '../../../lib/supabase';
import NewsprintShell from '../../../components/newsprint/NewsprintShell.astro';
import NewsprintSideRail from '../../../components/newsprint/NewsprintSideRail.astro';
import NewsprintArticleLayout from '../../../components/newsprint/NewsprintArticleLayout.astro';
import NewsprintNotice from '../../../components/newsprint/NewsprintNotice.astro';

const { slug } = Astro.params;

let post = null;
let postError: string | null = null;

if (supabase && slug) {
  const { data, error } = await supabase
    .from('posts')
    .select('*')
    .eq('slug', slug)
    .eq('status', 'published')
    .eq('locale', 'ko')
    .single();

  if (error && error.code !== 'PGRST116') {
    console.error('[log-detail-ko] Supabase error:', error.message);
    postError = error.message;
  } else {
    post = data;
  }
}

if (!post && !postError) {
  Astro.response.status = 404;
}

const masthead = '가치를 담는 기록';
const editionMap: Record<string, string> = {
  'ai-news': '데일리 디스패치',
  'tech': '서재 노트',
  'career': '커리어 노트',
  'project': '빌드 로그',
};
const editionLabel = post ? (editionMap[post.category] || '딥 다이브') : '딥 다이브';

let recentPosts: any[] = [];
let railCategories: string[] = [];
let articleData: any = undefined;

if (post) {
  recentPosts = supabase
    ? (await supabase
        .from('posts')
        .select('title, slug, category')
        .eq('status', 'published')
        .eq('locale', 'ko')
        .neq('slug', slug)
        .order('published_at', { ascending: false })
        .limit(4)
      ).data ?? []
    : [];

  railCategories = Array.from(new Set([post.category, ...(post.tags ?? [])].filter(Boolean))).slice(0, 6);

  articleData = post.published_at
    ? { datePublished: post.published_at, dateModified: post.updated_at || post.published_at, image: post.og_image_url }
    : undefined;
}

const pageTitle = post ? post.title : '찾을 수 없음';
---

<MainLayout title={pageTitle} locale="ko" slug={`log/${slug}/`} article={articleData}>
  <NewsprintShell locale="ko" masthead={masthead} editionLabel={editionLabel}
    subkicker={['AI · 논문 · 프로젝트', '데일리 큐레이션', '무료']}>

    {postError ? (
      <NewsprintNotice
        variant="error"
        message={t.ko['log.error']}
        linkHref="/ko/log/"
        linkLabel={t.ko['post.back']}
      />
    ) : !post ? (
      <NewsprintNotice
        variant="notfound"
        message={t.ko['post.notfound']}
        linkHref="/ko/log/"
        linkLabel={t.ko['post.back']}
      />
    ) : (
      <NewsprintArticleLayout
        locale="ko"
        slug={slug}
        title={post.title}
        category={post.category}
        publishedAt={post.published_at}
        readingTimeMin={post.reading_time_min}
        tags={post.tags}
        htmlContent={post.content_original || post.content_beginner || ''}
        backLabel={t.ko['post.back']}
      />
    )}

    <Fragment slot="rail">
      <NewsprintSideRail locale="ko" posts={recentPosts} categories={railCategories} />
    </Fragment>
  </NewsprintShell>
</MainLayout>
