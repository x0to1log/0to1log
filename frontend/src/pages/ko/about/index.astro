---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import { getSiteContents } from '../../../lib/siteContent';

const links = [
  { label: 'GitHub', href: 'https://github.com/ming2tofu33' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/ming2tofu33/' },
  { label: 'Email', href: 'mailto:ming2tofu33@gmail.com' },
];

const steps = [
  { label: '발견', desc: '리서치, 제품 출시, 툴 업데이트에서 중요한 AI 변화를 먼저 골라냅니다.' },
  { label: '선별', desc: '화제성보다 실제로 남는 신호를 중심으로 우선순위를 정합니다.' },
  { label: '정리', desc: '무엇이 바뀌었는지, 왜 중요한지, 어떻게 읽어야 하는지 맥락을 붙여 설명합니다.' },
  { label: '발행', desc: '선별된 기사와 용어는 검토를 거쳐 한국어와 영어로 정리됩니다.' },
];

const stack = ['Astro', 'FastAPI', 'Supabase', 'OpenAI', 'Tailwind CSS', 'Vercel', 'Railway'];

const sc = await getSiteContents(
  [
    'about_tagline',
    'about_publication_intro',
    'about_publication_detail',
    'about_editor_intro',
  ],
  'ko',
);

const aboutTagline = sc.about_tagline || 'AI를 만들고, 기록하는 사람';
const aboutPublicationIntro =
  sc.about_publication_intro ||
  '매일 수백 건의 AI 소식이 쏟아집니다. 0to1log는 그중 정말 중요한 것만 골라내고, 모든 수준의 독자를 위해 맥락을 더합니다.';
const aboutPublicationDetail =
  sc.about_publication_detail ||
  '각 기사는 세 가지 버전으로 전달됩니다. 입문자를 위한 쉬운 요약, 학습자를 위한 기술적 분석, 그리고 비즈니스 시사점과 실행 가능한 인사이트를 담은 현직자 분석입니다.';
const aboutEditorIntro =
  sc.about_editor_intro ||
  'Amy Domin Kim — LLM 애플리케이션, 데이터 분석, 웹 개발의 교차점에서 작업하는 AI 엔지니어입니다. 0to1log는 개인 학습 기록에서 시작해, AI 뉴스를 큐레이션하고 맥락을 더하는 풀스택 플랫폼으로 성장했습니다. AI 커뮤니티를 위한 일간 리소스이자 엔드투엔드 엔지니어링 포트폴리오이기도 합니다.';
---

<MainLayout title="소개" locale="ko" headerAlwaysVisible={true}>
  <div class="about-page">
    <section class="about-hero">
      <p class="about-overline">소개</p>
      <h1 class="about-title">0to1log</h1>
      <p class="about-tagline">{aboutTagline}</p>
      <div class="about-ornament" aria-hidden="true">&mdash;&thinsp;&diams;&thinsp;&mdash;</div>
    </section>

    <section class="about-section">
      <h2 class="about-heading">퍼블리케이션</h2>
      <p>{aboutPublicationIntro}</p>
      <p>{aboutPublicationDetail}</p>
      <p>
        <a href="/ko/handbook/">AI 용어집</a>은 뉴스 피드와 함께 움직이며, 중요한 기술 용어를 쉽게 다시 찾아볼 수 있게 돕습니다.
      </p>
    </section>

    <section class="about-section">
      <h2 class="about-heading">운영 방식</h2>
      <ol class="about-steps">
        {steps.map((step) => (
          <li class="about-step">
            <strong>{step.label}</strong>
            <span>{step.desc}</span>
          </li>
        ))}
      </ol>
    </section>

    <section class="about-section">
      <h2 class="about-heading">에디터</h2>
      <p>{aboutEditorIntro}</p>
      <nav class="about-links" aria-label="소셜 링크">
        {links.map((link, i) => (
          <>
            {i > 0 && <span class="about-link-sep" aria-hidden="true">&middot;</span>}
            <a href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
              {link.label}
            </a>
          </>
        ))}
      </nav>
      <p class="about-portfolio-link">
        <a href="/portfolio/">포트폴리오 보기 &rarr;</a>
      </p>
    </section>

    <section class="about-section">
      <h2 class="about-heading">기술 스택</h2>
      <div class="about-stack">
        {stack.map((tech) => (
          <span class="about-tag">{tech}</span>
        ))}
      </div>
    </section>

    <section class="about-section about-connect">
      <h2 class="about-heading">연결</h2>
      <p>
        <a href="/rss.xml">RSS 구독</a>으로 새 글을 받아볼 수 있습니다.
      </p>
      <nav class="about-links" aria-label="연락 링크">
        {links.map((link, i) => (
          <>
            {i > 0 && <span class="about-link-sep" aria-hidden="true">&middot;</span>}
            <a href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
              {link.label}
            </a>
          </>
        ))}
      </nav>
    </section>

    <div class="about-footer-ornament" aria-hidden="true">
      &mdash;&thinsp;&diams;&thinsp;&mdash;
    </div>
  </div>
</MainLayout>

<style>
  .about-page {
    max-width: 640px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
  }

  .about-hero {
    text-align: center;
    margin-bottom: 3rem;
  }
  .about-overline {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }
  .about-title {
    font-family: var(--font-masthead);
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
    line-height: 1.1;
  }
  .about-tagline {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.125rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
  }
  .about-ornament {
    margin-top: 1.25rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    letter-spacing: 0.2em;
  }

  .about-section {
    margin-bottom: 2.5rem;
  }
  .about-heading {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }
  .about-section p {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }
  .about-section a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .about-steps {
    list-style: none;
    padding: 0;
    counter-reset: step;
  }
  .about-step {
    counter-increment: step;
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
  }
  .about-step::before {
    content: counter(step);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-text-muted);
    margin-top: 0.15rem;
  }
  .about-step strong {
    display: inline;
    margin-right: 0.25rem;
  }

  .about-links {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }
  .about-links a {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .about-link-sep {
    color: var(--color-text-muted);
    font-size: 0.75rem;
  }
  .about-portfolio-link {
    margin-top: 0.75rem;
  }

  .about-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .about-tag {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    padding: 0.25rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 2px;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  .about-footer-ornament {
    text-align: center;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    letter-spacing: 0.2em;
    margin-top: 2rem;
  }
</style>
