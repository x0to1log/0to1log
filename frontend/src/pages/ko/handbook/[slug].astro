---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import { t } from '../../../i18n/index';
import { supabase } from '../../../lib/supabase';
import { createClient } from '@supabase/supabase-js';
import { getHandbookCategoryLabel } from '../../../lib/handbookCategories';
import { localField, difficultyLabel, difficultyColor } from '../../../lib/handbookUtils';
import { renderMarkdown } from '../../../lib/markdown';
import NewsprintShell from '../../../components/newsprint/NewsprintShell.astro';
import NewsprintNotice from '../../../components/newsprint/NewsprintNotice.astro';

const locale = 'ko';
const { slug } = Astro.params;
const pageSlug = slug ?? '';

let term: any = null;
let termError: string | null = null;

if (supabase && slug) {
  const { data, error } = await supabase
    .from('handbook_terms')
    .select('*')
    .eq('slug', pageSlug)
    .eq('status', 'published')
    .single();

  if (error && error.code !== 'PGRST116') {
    console.error('[handbook-detail-ko] Supabase error:', error.message);
    termError = error.message;
  } else {
    term = data;
  }
}

if (!term && !termError) {
  Astro.response.status = 404;
}

const definition = term ? localField(term, 'definition', locale) : '';
const plainExplanation = term ? localField(term, 'plain_explanation', locale) : '';
const exampleAnalogy = term ? localField(term, 'example_analogy', locale) : '';
const bodyMarkdown = term ? localField(term, 'body_markdown', locale) : '';
const htmlContent = bodyMarkdown ? await renderMarkdown(bodyMarkdown) : '';

let relatedArticles: any[] = [];
if (supabase && term) {
  const { data: articles } = await supabase
    .from('posts')
    .select('title, slug, category, published_at')
    .eq('status', 'published')
    .contains('tags', [term.term.toLowerCase()])
    .limit(5);
  relatedArticles = articles ?? [];
}

let relatedTerms: any[] = [];
if (supabase && term?.related_term_slugs?.length) {
  const { data: related } = await supabase
    .from('handbook_terms')
    .select('term, slug, korean_name, difficulty')
    .eq('status', 'published')
    .in('slug', term.related_term_slugs);
  relatedTerms = related ?? [];
}

// User bookmark + learning state
let isBookmarked = false;
let learningStatus: string | null = null;
let learningProgressId: string | null = null;
const user = Astro.locals.user;
const accessToken = Astro.locals.accessToken;
if (user && accessToken && term) {
  const authSb = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
    { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
  );
  const [bmRes, lpRes] = await Promise.all([
    authSb.from('user_bookmarks').select('id').eq('user_id', user.id).eq('item_type', 'term').eq('item_id', term.id).maybeSingle(),
    authSb.from('learning_progress').select('id, status').eq('user_id', user.id).eq('term_id', term.id).maybeSingle(),
  ]);
  isBookmarked = !!bmRes.data;
  learningStatus = lpRes.data?.status ?? null;
  learningProgressId = lpRes.data?.id ?? null;
}

const pageTitle = term
  ? (term.korean_name ? `${term.term} (${term.korean_name})` : term.term)
  : t[locale]['handbook.notfound'];
const pageDescription = definition ? definition.slice(0, 150) : '';
---

<MainLayout
  title={`${pageTitle} — 기술 핸드북`}
  description={pageDescription}
  locale={locale}
  slug={`handbook/${pageSlug}/`}
>
  <NewsprintShell locale={locale} masthead="기술 핸드북" editionLabel={term?.category ? getHandbookCategoryLabel(locale, term.category) || '' : ''}>
    {termError ? (
      <NewsprintNotice
        variant="error"
        message={t[locale]['handbook.error']}
        linkHref={`/${locale}/handbook/`}
        linkLabel={t[locale]['handbook.back']}
      />
    ) : !term ? (
      <NewsprintNotice
        variant="notfound"
        message={t[locale]['handbook.notfound']}
        linkHref={`/${locale}/handbook/`}
        linkLabel={t[locale]['handbook.back']}
      />
    ) : (
      <article>
        <a href={`/${locale}/handbook/`} style="font-size: 0.85rem; color: var(--color-text-muted); text-decoration: none; display: inline-block; margin-bottom: 1rem;">
          ← {t[locale]['handbook.back']}
        </a>

        <header style="margin-bottom: 1.5rem;">
          <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem;">
            <h1 style="font-family: var(--font-heading); font-size: 2rem; font-weight: 700; margin: 0; flex: 1;">
              {term.term}
            </h1>
            <button
              class={`newsprint-bookmark-icon newsprint-bookmark-icon--detail ${isBookmarked ? 'newsprint-bookmark-icon--active' : ''}`}
              data-item-id={term.id}
              data-item-type="term"
              data-bookmarked={isBookmarked ? 'true' : 'false'}
              aria-label={isBookmarked ? '북마크 제거' : '북마크 추가'}
              style="margin-top: 0.5rem;"
            >
              <svg viewBox="0 0 24 24" fill={isBookmarked ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2">
                <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" />
              </svg>
            </button>
          </div>
          {term.korean_name && (
            <p style="font-size: 1rem; color: var(--color-text-muted); margin: 0.25rem 0 0;">
              {term.korean_name}
            </p>
          )}
          <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem; align-items: center;">
            {term.difficulty && (
              <span style={`font-size: 0.75rem; padding: 0.15rem 0.5rem; border: 1px solid ${difficultyColor(term.difficulty)}; color: ${difficultyColor(term.difficulty)};`}>
                {difficultyLabel(locale, term.difficulty)}
              </span>
            )}
            {term.category && (
              <span style="font-size: 0.75rem; color: var(--color-text-muted);">
                {getHandbookCategoryLabel(locale, term.category)}
              </span>
            )}
            {user && (
              <button
                class={`learning-check ${learningStatus === 'learned' ? 'learning-check--done' : ''}`}
                data-learning-id={learningProgressId}
                data-term-id={term.id}
                data-status={learningStatus || 'none'}
                style="margin-left: auto;"
              >
                {learningStatus === 'learned' ? '✓ 학습 완료' : '○ 학습 완료 표시'}
              </button>
            )}
          </div>
        </header>

        <div style="padding: 1.25rem; border: 1px solid var(--color-border); background: var(--color-bg-secondary); margin-bottom: 2rem;">
          {definition && (
            <div style="margin-bottom: 0.75rem;">
              <strong style="font-size: 0.8rem; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em;">정의</strong>
              <p style="margin: 0.25rem 0 0; line-height: 1.5;">{definition}</p>
            </div>
          )}
          {plainExplanation && (
            <div style="margin-bottom: 0.75rem;">
              <strong style="font-size: 0.8rem; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em;">쉬운 설명</strong>
              <p style="margin: 0.25rem 0 0; line-height: 1.5;">{plainExplanation}</p>
            </div>
          )}
          {exampleAnalogy && (
            <div>
              <strong style="font-size: 0.8rem; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em;">예시 / 비유</strong>
              <p style="margin: 0.25rem 0 0; line-height: 1.5;">{exampleAnalogy}</p>
            </div>
          )}
        </div>

        {htmlContent && (
          <div class="newsprint-prose">
            <Fragment set:html={htmlContent} />
          </div>
        )}

        {relatedTerms.length > 0 && (
          <div style="margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid var(--color-border);">
            <h2 style="font-family: var(--font-heading); font-size: 1.1rem; margin-bottom: 0.75rem;">
              {t[locale]['handbook.relatedTerms']}
            </h2>
            <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
              {relatedTerms.map((rt) => (
                <a
                  href={`/${locale}/handbook/${rt.slug}/`}
                  style="padding: 0.35rem 0.75rem; border: 1px solid var(--color-border); text-decoration: none; color: var(--color-text); font-size: 0.85rem;"
                >
                  {rt.term}
                </a>
              ))}
            </div>
          </div>
        )}

        {relatedArticles.length > 0 && (
          <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--color-border);">
            <h2 style="font-family: var(--font-heading); font-size: 1.1rem; margin-bottom: 0.75rem;">
              {t[locale]['handbook.relatedArticles']}
            </h2>
            {relatedArticles.map((article) => (
              <a
                href={`/${locale}/log/${article.slug}/`}
                style="display: block; padding: 0.5rem 0; text-decoration: none; color: var(--color-text); border-bottom: 1px solid var(--color-border);"
              >
                <span style="font-size: 0.9rem;">{article.title}</span>
                {article.published_at && (
                  <span style="font-size: 0.75rem; color: var(--color-text-muted); margin-left: 0.5rem;">
                    {new Date(article.published_at).toLocaleDateString('ko-KR')}
                  </span>
                )}
              </a>
            ))}
          </div>
        )}
      </article>
    )}
  </NewsprintShell>
</MainLayout>

<script>
  import '../../../scripts/bookmark';

  function initHandbookUserFeatures(): void {
    const termId = document.querySelector('[data-term-id]')?.getAttribute('data-term-id');
    if (termId) {
      fetch('/api/user/reading-history', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ item_type: 'term', item_id: termId }),
      }).catch(() => {});

      fetch('/api/user/learning-progress', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ term_id: termId }),
      }).catch(() => {});
    }

    const checkBtn = document.querySelector('.learning-check') as HTMLButtonElement | null;
    if (!checkBtn) return;

    checkBtn.addEventListener('click', async () => {
      const lpId = checkBtn.dataset.learningId;
      const currentStatus = checkBtn.dataset.status;
      if (!lpId) return;

      const newStatus = currentStatus === 'learned' ? 'read' : 'learned';
      try {
        const res = await fetch(`/api/user/learning-progress?id=${lpId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status: newStatus }),
        });
        if (!res.ok) return;

        checkBtn.dataset.status = newStatus;
        checkBtn.classList.toggle('learning-check--done', newStatus === 'learned');
        checkBtn.textContent = newStatus === 'learned' ? '✓ 학습 완료' : '○ 학습 완료 표시';
      } catch { /* ignore */ }
    });
  }

  document.addEventListener('astro:page-load', initHandbookUserFeatures);
</script>
