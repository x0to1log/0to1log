---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import { t } from '../../../i18n/index';
import { supabase } from '../../../lib/supabase';
import { createClient } from '@supabase/supabase-js';
import { getHandbookCategoryLabel } from '../../../lib/handbookCategories';
import { localField, difficultyLabel, difficultyColor } from '../../../lib/handbookUtils';
import { renderMarkdown } from '../../../lib/markdown';
import NewsprintShell from '../../../components/newsprint/NewsprintShell.astro';
import NewsprintNotice from '../../../components/newsprint/NewsprintNotice.astro';
import HandbookSideRail from '../../../components/newsprint/HandbookSideRail.astro';

const locale = 'ko';
const { slug } = Astro.params;
const pageSlug = slug ?? '';

let term: any = null;
let termError: string | null = null;

if (supabase && slug) {
  const { data, error } = await supabase
    .from('handbook_terms')
    .select('*')
    .eq('slug', pageSlug)
    .eq('status', 'published')
    .single();

  if (error && error.code !== 'PGRST116') {
    console.error('[handbook-detail-ko] Supabase error:', error.message);
    termError = error.message;
  } else {
    term = data;
  }
}

if (!term && !termError) {
  Astro.response.status = 404;
}

const definition = term ? localField(term, 'definition', locale) : '';
const plainExplanation = term ? localField(term, 'plain_explanation', locale) : '';
const technicalDescription = term ? localField(term, 'technical_description', locale) : '';
const exampleAnalogy = term ? localField(term, 'example_analogy', locale) : '';
const bodyMarkdown = term ? localField(term, 'body_markdown', locale) : '';
const htmlContent = bodyMarkdown ? await renderMarkdown(bodyMarkdown) : '';

let relatedArticles: any[] = [];
if (supabase && term) {
  const { data: articles } = await supabase
    .from('news_posts')
    .select('title, slug, category, published_at')
    .eq('status', 'published')
    .contains('tags', [term.term.toLowerCase()])
    .limit(5);
  relatedArticles = articles ?? [];
}

let relatedTerms: any[] = [];
if (supabase && term?.related_term_slugs?.length) {
  const { data: related } = await supabase
    .from('handbook_terms')
    .select('term, slug, korean_name, difficulty')
    .eq('status', 'published')
    .in('slug', term.related_term_slugs);
  relatedTerms = related ?? [];
}

let sameCategoryTerms: any[] = [];
if (supabase && term?.categories?.length) {
  const { data } = await supabase
    .from('handbook_terms')
    .select('term, slug, korean_name, difficulty')
    .eq('status', 'published')
    .neq('slug', pageSlug)
    .overlaps('categories', term.categories)
    .limit(5);
  sameCategoryTerms = data ?? [];
}

// User bookmark + learning state
let isBookmarked = false;
let learningStatus: string | null = null;
let learningProgressId: string | null = null;
const user = Astro.locals.user;
const accessToken = Astro.locals.accessToken;
if (user && accessToken && term) {
  const authSb = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
    { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
  );
  const [bmRes, lpRes] = await Promise.all([
    authSb.from('user_bookmarks').select('id').eq('user_id', user.id).eq('item_type', 'term').eq('item_id', term.id).maybeSingle(),
    authSb.from('learning_progress').select('id, status').eq('user_id', user.id).eq('term_id', term.id).maybeSingle(),
  ]);
  isBookmarked = !!bmRes.data;
  learningStatus = lpRes.data?.status ?? null;
  learningProgressId = lpRes.data?.id ?? null;
}

const pageTitle = term
  ? (term.korean_name ? `${term.term} (${term.korean_name})` : term.term)
  : t[locale]['handbook.notfound'];
const pageDescription = definition ? definition.slice(0, 150) : '';
---

<MainLayout
  title={`${pageTitle} — AI 용어집`}
  description={pageDescription}
  locale={locale}
  slug={`handbook/${pageSlug}/`}
>
  <NewsprintShell locale={locale} masthead="AI 용어집" editionLabel="CS · AI · Infra" subkicker={['용어 사전', '레퍼런스', '학습']}>
    <form class="handbook-detail-search handbook-search-sticky" action={`/${locale}/handbook/`} method="get">
      <input
        type="text"
        name="q"
        aria-label={t[locale]['handbook.search']}
        placeholder={t[locale]['handbook.search']}
        class="handbook-search-input"
      />
    </form>

    {termError ? (
      <NewsprintNotice
        variant="error"
        message={t[locale]['handbook.error']}
        linkHref={`/${locale}/handbook/`}
        linkLabel={t[locale]['handbook.back']}
      />
    ) : !term ? (
      <NewsprintNotice
        variant="notfound"
        message={t[locale]['handbook.notfound']}
        linkHref={`/${locale}/handbook/`}
        linkLabel={t[locale]['handbook.back']}
      />
    ) : (
      <article>
        <header style="margin-bottom: 1.5rem;">
          <div class="handbook-detail-meta">
            {term.difficulty && (
              <span style={`font-size: 0.75rem; padding: 0.15rem 0.5rem; border: 1px solid ${difficultyColor(term.difficulty)}; color: ${difficultyColor(term.difficulty)};`}>
                {difficultyLabel(locale, term.difficulty)}
              </span>
            )}
            {(term.categories || []).map((cat: string) => (
              <span style="font-size: 0.8rem; color: var(--color-text-muted);">
                {getHandbookCategoryLabel(locale, cat)}
              </span>
            ))}
          </div>

          <h1 class="handbook-detail-title" style="margin-top: 0.75rem;">
            {term.term}
          </h1>
          {term.korean_name && (
            <p class="handbook-detail-subtitle">{term.korean_name}</p>
          )}
        </header>

        {definition && (
          <p class="handbook-definition">{definition}</p>
        )}

        <div class="newsprint-divider"></div>

        {plainExplanation && (
          <div class="handbook-section">
            <span class="handbook-section-label">{t[locale]['handbook.plainExplanation']}</span>
            <p class="handbook-section-body">{plainExplanation}</p>
          </div>
        )}

        {technicalDescription && (
          <div class="handbook-section">
            <span class="handbook-section-label">{t[locale]['handbook.technicalDescription']}</span>
            <p class="handbook-section-body">{technicalDescription}</p>
          </div>
        )}

        {exampleAnalogy && (
          <div class="handbook-section">
            <span class="handbook-section-label">{t[locale]['handbook.exampleAnalogy']}</span>
            <p class="handbook-section-body">{exampleAnalogy}</p>
          </div>
        )}

        {htmlContent && (
          <div class="newsprint-prose newsprint-prose--no-dropcap">
            <Fragment set:html={htmlContent} />
          </div>
        )}

        {user && (
          <div class="handbook-action-bar">
            <button
              class={`learning-check ${learningStatus === 'learned' ? 'learning-check--done' : ''}`}
              data-learning-id={learningProgressId}
              data-term-id={term.id}
              data-status={learningStatus || 'none'}
            >
              {learningStatus === 'learned' ? '✓ 학습 완료' : '○ 학습 완료 표시'}
            </button>
          </div>
        )}

        <!-- Engagement Bar -->
        <div class="newsprint-engagement-bar">
          <div class="newsprint-engagement-left"></div>
          <div class="newsprint-engagement-right">
            <button
              type="button"
              class={`newsprint-engage-btn newsprint-bookmark-icon ${isBookmarked ? 'newsprint-bookmark-icon--active' : ''}`}
              data-item-id={term.id}
              data-item-type="term"
              data-bookmarked={isBookmarked ? 'true' : 'false'}
              aria-label={isBookmarked ? '북마크 제거' : '북마크 추가'}
            >
              <svg viewBox="0 0 24 24" fill={isBookmarked ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" width="20" height="20">
                <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
              </svg>
            </button>
            <div class="newsprint-share-wrapper">
              <button type="button" class="newsprint-engage-btn" data-share-toggle aria-label="공유">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                  <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
                  <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
                </svg>
              </button>
              <div class="newsprint-share-dropdown" data-share-url={`${import.meta.env.PUBLIC_SITE_URL || 'https://0to1log.com'}/${locale}/handbook/${pageSlug}/`} data-share-title={pageTitle} style="display:none;">
                <button type="button" class="newsprint-share-dropdown-btn" data-share-native style="display:none;">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
                  <span>공유</span>
                </button>
                <button type="button" class="newsprint-share-dropdown-btn" data-share-x>
                  <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  <span>X</span>
                </button>
                <button type="button" class="newsprint-share-dropdown-btn" data-share-linkedin>
                  <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  <span>LinkedIn</span>
                </button>
                <button type="button" class="newsprint-share-dropdown-btn" data-share-copy>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                  <span>URL 복사</span>
                </button>
                <span class="newsprint-share-toast">복사됨</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Admin Actions (admin only) -->
        {Astro.locals.isAdmin && (
          <div class="newsprint-admin-actions" data-toolbar-id={term.id} data-toolbar-api="/api/admin/handbook/status">
            <a href={`/admin/handbook/edit/${pageSlug}`} class="newsprint-admin-action-btn">Edit</a>
            <button type="button" class="newsprint-admin-action-btn newsprint-admin-action-btn--unpublish">Unpublish</button>
          </div>
        )}

        <nav class="handbook-bottom-nav" aria-label="핸드북 내비게이션">
          <a href={`/${locale}/handbook/`} class="handbook-nav-link">
            ← {t[locale]['handbook.back']}
          </a>
        </nav>
      </article>
    )}

    <Fragment slot="rail">
      <HandbookSideRail
        locale={locale}
        relatedTerms={relatedTerms}
        sameCategoryTerms={sameCategoryTerms}
        relatedArticles={relatedArticles}
      />
    </Fragment>
  </NewsprintShell>
</MainLayout>

<script>
  import '../../../scripts/bookmark';
  import '../../../scripts/share';

  function initHandbookUserFeatures(): void {
    const termId = document.querySelector('[data-term-id]')?.getAttribute('data-term-id');
    if (termId) {
      fetch('/api/user/reading-history', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ item_type: 'term', item_id: termId }),
      }).catch(() => {});

      fetch('/api/user/learning-progress', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ term_id: termId }),
      }).catch(() => {});
    }

    const checkBtn = document.querySelector('.learning-check') as HTMLButtonElement | null;
    if (!checkBtn) return;

    checkBtn.addEventListener('click', async () => {
      const lpId = checkBtn.dataset.learningId;
      const currentStatus = checkBtn.dataset.status;
      if (!lpId || checkBtn.disabled) return;

      checkBtn.disabled = true;
      const prevText = checkBtn.textContent;
      checkBtn.textContent = '\u2026';

      const newStatus = currentStatus === 'learned' ? 'read' : 'learned';
      try {
        const res = await fetch(`/api/user/learning-progress?id=${lpId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status: newStatus }),
        });
        if (!res.ok) {
          checkBtn.textContent = prevText;
          checkBtn.disabled = false;
          return;
        }

        checkBtn.dataset.status = newStatus;
        checkBtn.classList.toggle('learning-check--done', newStatus === 'learned');
        checkBtn.textContent = newStatus === 'learned' ? '✓ 학습 완료' : '○ 학습 완료 표시';
      } catch {
        checkBtn.textContent = prevText;
      } finally {
        checkBtn.disabled = false;
      }
    });
  }

  function initAdminActions(): void {
    const actions = document.querySelector('.newsprint-admin-actions') as HTMLElement | null;
    if (!actions) return;

    const btn = actions.querySelector('.newsprint-admin-action-btn--unpublish');
    btn?.addEventListener('click', async () => {
      if (!confirm('이 용어를 비공개로 전환할까요?')) return;

      const id = actions.dataset.toolbarId;
      const api = actions.dataset.toolbarApi;
      if (!id || !api) return;

      try {
        const res = await fetch(api, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, action: 'unpublish' }),
        });

        if (res.ok) {
          const editLink = actions.querySelector('a') as HTMLAnchorElement | null;
          window.location.href = editLink?.href || '/admin';
        } else {
          const err = await res.json().catch(() => ({ error: 'Unknown error' }));
          alert(`비공개 전환 실패: ${err.error || err.detail}`);
        }
      } catch {
        alert('비공개 전환 실패: 네트워크 오류');
      }
    });
  }

  document.addEventListener('astro:page-load', initHandbookUserFeatures);
  document.addEventListener('astro:page-load', initAdminActions);
</script>
