---
import MainLayout from '../layouts/MainLayout.astro';

export const prerender = false;

if (Astro.locals.user) {
  const raw = Astro.url.searchParams.get('redirectTo');
  const redirectTo = !raw || !raw.startsWith('/') || raw.startsWith('//') ? '/' : raw;
  return Astro.redirect(redirectTo);
}

const langParam = Astro.url.searchParams.get('lang');
const cookieLocale = Astro.cookies.get('site-locale')?.value;
const acceptLang = Astro.request.headers.get('accept-language') || '';
const browserLocale = acceptLang.split(',').some((l) => l.trim().startsWith('ko')) ? 'ko' : 'en';
const locale =
  langParam === 'ko' || langParam === 'en'
    ? langParam
    : cookieLocale === 'ko' || cookieLocale === 'en'
      ? cookieLocale
      : browserLocale;

const errorParam = Astro.url.searchParams.get('error');

const copy =
  locale === 'ko'
    ? {
        title: '로그인',
        subtitle: '나만의 AI 학습 공간을 만들어보세요.',
        github: 'GitHub로 계속',
        google: 'Google로 계속',
        kakao: 'Kakao로 계속',
        terms: '로그인하면 이용약관과 개인정보 처리방침에 동의한 것으로 간주됩니다.',
        signingIn: '로그인 중...',
        comingSoon: '이 로그인 옵션은 곧 열릴 예정입니다.',
        errorNoCode: '인증에 실패했습니다. 인증 코드를 받지 못했습니다.',
        errorExchange: '인증에 실패했습니다. 로그인 정보를 확인하지 못했습니다.',
        errorConfig: '인증 설정이 아직 완료되지 않았습니다.',
        errorGeneric: '로그인 중 오류가 발생했습니다.',
        feat1: '북마크',
        feat1desc: '마음에 드는 글을 저장하세요',
        feat2: '읽기 기록',
        feat2desc: '어디까지 읽었는지 이어가세요',
        feat3: '학습 현황',
        feat3desc: 'AI 용어 학습 진행을 추적하세요',
      }
    : {
        title: 'Sign In',
        subtitle: 'Build your personal AI learning space.',
        github: 'Continue with GitHub',
        google: 'Continue with Google',
        kakao: 'Continue with Kakao',
        terms: 'By signing in, you agree to our terms of service and privacy policy.',
        signingIn: 'Signing in...',
        comingSoon: 'This sign-in option is coming soon.',
        errorNoCode: 'Authentication failed: no authorization code received.',
        errorExchange: 'Authentication failed: could not verify credentials.',
        errorConfig: 'Authentication is not configured.',
        errorGeneric: 'An authentication error occurred.',
        feat1: 'Bookmarks',
        feat1desc: 'Save articles you love',
        feat2: 'Reading History',
        feat2desc: 'Pick up where you left off',
        feat3: 'Learning Progress',
        feat3desc: 'Track your AI glossary journey',
      };
---

<MainLayout title={`${copy.title} | 0to1log`} locale={locale as 'en' | 'ko'} headerAlwaysVisible={true}>
  <div class="login-page">
    <div class="login-card-container">
      <!-- Left: Brand + Features -->
      <div class="login-brand">
        <a href={`/${locale}/`} class="login-logo">0to1log</a>
        <p class="login-brand-subtitle">{copy.subtitle}</p>

        <div class="login-features">
          <div class="login-feature">
            <div class="login-feature-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
            </div>
            <div>
              <strong class="login-feature-title">{copy.feat1}</strong>
              <span class="login-feature-desc">{copy.feat1desc}</span>
            </div>
          </div>
          <div class="login-feature">
            <div class="login-feature-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <strong class="login-feature-title">{copy.feat2}</strong>
              <span class="login-feature-desc">{copy.feat2desc}</span>
            </div>
          </div>
          <div class="login-feature">
            <div class="login-feature-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            </div>
            <div>
              <strong class="login-feature-title">{copy.feat3}</strong>
              <span class="login-feature-desc">{copy.feat3desc}</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Login Form -->
      <div class="login-form-panel">
        <h1 class="login-form-title">{copy.title}</h1>

        {errorParam && (
          <div class="login-error">
            {errorParam === 'no_code' && copy.errorNoCode}
            {errorParam === 'exchange_failed' && copy.errorExchange}
            {errorParam === 'config' && copy.errorConfig}
            {!['no_code', 'exchange_failed', 'config'].includes(errorParam) && copy.errorGeneric}
          </div>
        )}

        <div
          class="login-oauth-group"
          data-oauth-root
          data-signing-in={copy.signingIn}
          data-coming-soon-message={copy.comingSoon}
        >
          <button class="login-oauth-btn" data-provider="google" data-signing-in={copy.signingIn}>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            {copy.google}
          </button>
          <button class="login-oauth-btn" data-provider="github" data-signing-in={copy.signingIn}>
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            {copy.github}
          </button>

          <div class="login-divider">
            <div class="login-divider-line"></div>
            <span class="login-divider-text">{locale === 'ko' ? '곧 추가 예정' : 'Coming soon'}</span>
            <div class="login-divider-line"></div>
          </div>

          <button
            class="login-oauth-btn"
            data-provider="kakao"
            data-signing-in={copy.signingIn}
            data-coming-soon-message={copy.comingSoon}
            style="opacity: 0.45; cursor: default;"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 3C6.48 3 2 6.58 2 10.9c0 2.78 1.86 5.22 4.66 6.62-.15.53-.96 3.41-1 3.58 0 0-.02.17.09.23.11.07.24.01.24.01.32-.04 3.7-2.44 4.28-2.86.57.08 1.15.12 1.73.12 5.52 0 10-3.58 10-7.9C22 6.58 17.52 3 12 3z"/></svg>
            {copy.kakao}
          </button>
        </div>

        <p class="login-terms">{copy.terms}</p>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  import { initOAuthButtons } from '../scripts/auth-oauth';

  initOAuthButtons();
</script>
