---
export const prerender = false;

import MainLayout from '../../layouts/MainLayout.astro';
import { createClient } from '@supabase/supabase-js';
import { difficultyColor, difficultyLabel } from '../../lib/handbookUtils';
import { getHandbookCategoryLabel } from '../../lib/handbookCategories';

// Redirect if not logged in
if (!Astro.locals.user || !Astro.locals.accessToken) {
  return Astro.redirect(`/login?redirectTo=${encodeURIComponent('/library/')}`);
}

const user = Astro.locals.user;
const accessToken = Astro.locals.accessToken;
const profile = Astro.locals.profile;
const langParam = Astro.url.searchParams.get('lang');
const cookieLocale = Astro.cookies.get('site-locale')?.value;
const acceptLang = Astro.request.headers.get('accept-language') || '';
const browserLocale = acceptLang.split(',').some(l => l.trim().startsWith('ko')) ? 'ko' : 'en';
const locale = (langParam === 'ko' || langParam === 'en') ? langParam
  : (cookieLocale === 'ko' || cookieLocale === 'en') ? cookieLocale
  : profile?.preferred_locale === 'ko' ? 'ko'
  : profile?.preferred_locale === 'en' ? 'en'
  : browserLocale;

const copy = locale === 'ko'
  ? {
      title: '나의 서재',
      tabSaved: '저장한 글',
      tabRead: '읽은 글',
      tabProgress: '학습 현황',
      emptyRead: '아직 읽은 기록이 없습니다. 기사와 용어를 탐색해 보세요!',
      emptySaved: '아직 저장한 글이 없습니다. 기사와 용어를 저장해 보세요!',
      subArticles: '기사',
      subTerms: '용어',
      emptyArticles: '저장한 기사가 없습니다.',
      emptyTerms: '저장한 용어가 없습니다.',
      readingTime: '분',
      emptyProgress: '용어집을 방문하면 학습 현황이 기록됩니다!',
      badgeArticle: '기사',
      badgeTerm: '용어',
      savedPrefix: '저장일',
      overallProgress: '전체 학습 현황',
      learned: '학습 완료',
      visited: '방문',
      removeBookmark: '북마크 해제',
      dateLocale: 'ko-KR',
    }
  : {
      title: 'My Library',
      tabSaved: 'Saved',
      tabRead: 'Read',
      tabProgress: 'Progress',
      emptyRead: 'No reading history yet. Start exploring articles and terms!',
      emptySaved: 'No bookmarks yet. Save articles and terms to find them here!',
      subArticles: 'Articles',
      subTerms: 'Terms',
      emptyArticles: 'No saved articles yet.',
      emptyTerms: 'No saved terms yet.',
      readingTime: 'min',
      emptyProgress: 'Visit handbook terms to start tracking your learning progress!',
      badgeArticle: 'Article',
      badgeTerm: 'Term',
      savedPrefix: 'Saved',
      overallProgress: 'Overall Progress',
      learned: 'learned',
      visited: 'visited',
      removeBookmark: 'Remove bookmark',
      dateLocale: 'en-US',
    };
const authSb = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
);

// Fetch all user data in parallel
const [historyRes, bookmarksRes, progressRes, likesRes] = await Promise.all([
  authSb.from('reading_history').select('id, item_type, item_id, read_at').eq('user_id', user.id).order('read_at', { ascending: false }),
  authSb.from('user_bookmarks').select('id, item_type, item_id, created_at').eq('user_id', user.id).order('created_at', { ascending: false }),
  authSb.from('learning_progress').select('id, term_id, status, read_at, learned_at').eq('user_id', user.id),
  authSb.from('post_likes').select('id, post_id, created_at').eq('user_id', user.id).order('created_at', { ascending: false }),
]);

const historyItems = historyRes.data ?? [];
const bookmarkItems = bookmarksRes.data ?? [];
const progressItems = progressRes.data ?? [];
const likedItems = likesRes.data ?? [];

// Collect IDs to batch-fetch metadata
const postIds = new Set<string>();
const termIds = new Set<string>();
[...historyItems, ...bookmarkItems].forEach((item) => {
  if (item.item_type === 'post') postIds.add(item.item_id);
  if (item.item_type === 'term') termIds.add(item.item_id);
});
likedItems.forEach((item) => postIds.add(item.post_id));
progressItems.forEach((p) => termIds.add(p.term_id));

// Fetch post and term metadata
const { supabase } = await import('../../lib/supabase');
const postMap = new Map<string, any>();
const termMap = new Map<string, any>();

if (supabase && postIds.size > 0) {
  const { data } = await supabase.from('posts').select('id, title, slug, category, locale, reading_time_min').in('id', [...postIds]);
  (data ?? []).forEach((p: any) => postMap.set(p.id, p));
}
if (supabase && termIds.size > 0) {
  const { data } = await supabase.from('handbook_terms').select('id, term, slug, korean_name, category, difficulty').in('id', [...termIds]);
  (data ?? []).forEach((t: any) => termMap.set(t.id, t));
}

// Aggregate learning progress by category
const categoryProgress = new Map<string, { total: number; read: number; learned: number }>();
progressItems.forEach((p) => {
  const t = termMap.get(p.term_id);
  const cat = t?.category || 'uncategorized';
  if (!categoryProgress.has(cat)) categoryProgress.set(cat, { total: 0, read: 0, learned: 0 });
  const c = categoryProgress.get(cat)!;
  c.total++;
  if (p.status === 'read') c.read++;
  if (p.status === 'learned') c.learned++;
});
const totalLearned = progressItems.filter((p) => p.status === 'learned').length;
const totalRead = progressItems.length;

// Split bookmarks by type for sub-tabs
const articleBookmarks = bookmarkItems.filter((i) => i.item_type === 'post');
const termBookmarks = bookmarkItems.filter((i) => i.item_type === 'term');

// Lookup sets for dual icons
const likedPostIds = new Set(likedItems.map((i) => i.post_id));
const bookmarkedItemIds = new Set(bookmarkItems.map((i) => `${i.item_type}:${i.item_id}`));
---

<MainLayout title={`${copy.title} — 0to1log`} locale={locale as 'en' | 'ko'} headerAlwaysVisible={true}>
  <div class="newsprint-page" style="max-width: 800px;">
    <h1 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; margin-bottom: 1.5rem;">
      {copy.title}
    </h1>

    <div class="library-tabs">
      <button class="library-tab library-tab--active" data-tab="saved">{copy.tabSaved}</button>
      <button class="library-tab" data-tab="read">{copy.tabRead}</button>
      <button class="library-tab" data-tab="progress">{copy.tabProgress}</button>
    </div>

    <!-- Saved Tab (default active) -->
    <div data-tab-content="saved">
      {bookmarkItems.length === 0 ? (
        <p style="color: var(--color-text-muted); padding: 2rem 0; text-align: center;">
          {copy.emptySaved}
        </p>
      ) : (
        <div>
          <div class="library-sub-tabs">
            <button class="library-sub-tab library-sub-tab--active" data-sub-tab="articles">
              {copy.subArticles} ({articleBookmarks.length})
            </button>
            <button class="library-sub-tab" data-sub-tab="terms">
              {copy.subTerms} ({termBookmarks.length})
            </button>
          </div>

          <!-- Articles sub-tab -->
          <div data-sub-content="articles">
            {articleBookmarks.length === 0 ? (
              <p style="color: var(--color-text-muted); padding: 2rem 0; text-align: center;">
                {copy.emptyArticles}
              </p>
            ) : (
              articleBookmarks.map((item) => {
                const post = postMap.get(item.item_id);
                const title = post?.title || 'Unknown';
                const href = post ? `/${post.locale || 'en'}/log/${post.slug}/` : '#';
                const isLiked = likedPostIds.has(item.item_id);
                return (
                  <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid var(--color-border);">
                    <div style="flex: 1; min-width: 0;">
                      <a href={href} style="font-weight: 600; text-decoration: none; color: inherit; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: block;">
                        {title}
                      </a>
                      <div style="display: flex; align-items: center; gap: 0.5rem; margin-top: 0.25rem; font-size: 0.75rem; color: var(--color-text-muted);">
                        {post?.category && <span class="library-type-badge">{post.category}</span>}
                        {post?.reading_time_min && <span>{post.reading_time_min}{copy.readingTime}</span>}
                        <span>{copy.savedPrefix} {new Date(item.created_at).toLocaleDateString(copy.dateLocale)}</span>
                      </div>
                    </div>
                    <div style="display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0;">
                      <button type="button" class="library-icon-btn" data-toggle-like data-post-id={item.item_id} data-active={isLiked ? 'true' : 'false'} aria-label="Like" style="background:none;border:none;cursor:pointer;padding:0.2rem;line-height:1;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill={isLiked ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" style={`color: ${isLiked ? 'var(--color-accent)' : 'var(--color-text-muted)'}; opacity: ${isLiked ? '1' : '0.35'};`}>
                          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                        </svg>
                      </button>
                      <button type="button" class="library-icon-btn" data-toggle-bookmark data-item-id={item.item_id} data-item-type="post" data-active="true" aria-label="Bookmark" style="background:none;border:none;cursor:pointer;padding:0.2rem;line-height:1;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1.5" style="color: var(--color-accent);">
                          <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
                        </svg>
                      </button>
                    </div>
                  </div>
                );
              })
            )}
          </div>

          <!-- Terms sub-tab -->
          <div data-sub-content="terms" style="display: none;">
            {termBookmarks.length === 0 ? (
              <p style="color: var(--color-text-muted); padding: 2rem 0; text-align: center;">
                {copy.emptyTerms}
              </p>
            ) : (
              termBookmarks.map((item) => {
                const term = termMap.get(item.item_id);
                const title = term?.term || 'Unknown';
                const href = term ? `/en/handbook/${term.slug}/` : '#';
                return (
                  <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid var(--color-border);">
                    <div style="flex: 1; min-width: 0;">
                      <div style="display: flex; align-items: baseline; gap: 0.4rem;">
                        <a href={href} style="font-weight: 600; text-decoration: none; color: inherit; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                          {title}
                        </a>
                        {term?.korean_name && locale === 'ko' && (
                          <span style="font-size: 0.78rem; color: var(--color-text-muted);">{term.korean_name}</span>
                        )}
                      </div>
                      <div style="display: flex; align-items: center; gap: 0.5rem; margin-top: 0.25rem; font-size: 0.75rem; color: var(--color-text-muted);">
                        {term?.difficulty && (
                          <span style={`padding: 0.1rem 0.35rem; border: 1px solid ${difficultyColor(term.difficulty)}; color: ${difficultyColor(term.difficulty)}; font-size: 0.65rem; font-weight: 600;`}>
                            {difficultyLabel(locale as 'en' | 'ko', term.difficulty)}
                          </span>
                        )}
                        {term?.category && (
                          <span>{getHandbookCategoryLabel(locale as 'en' | 'ko', term.category)}</span>
                        )}
                        <span>{copy.savedPrefix} {new Date(item.created_at).toLocaleDateString(copy.dateLocale)}</span>
                      </div>
                    </div>
                    <div style="display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0;">
                      <button type="button" class="library-icon-btn" data-toggle-bookmark data-item-id={item.item_id} data-item-type="term" data-active="true" aria-label="Bookmark" style="background:none;border:none;cursor:pointer;padding:0.2rem;line-height:1;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1.5" style="color: var(--color-accent);">
                          <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
                        </svg>
                      </button>
                    </div>
                  </div>
                );
              })
            )}
          </div>
        </div>
      )}
    </div>

    <!-- Read Tab -->
    <div data-tab-content="read" style="display: none;">
      {historyItems.length === 0 ? (
        <p style="color: var(--color-text-muted); padding: 2rem 0; text-align: center;">
          {copy.emptyRead}
        </p>
      ) : (
        <div>
          {historyItems.map((item) => {
            const post = item.item_type === 'post' ? postMap.get(item.item_id) : null;
            const term = item.item_type === 'term' ? termMap.get(item.item_id) : null;
            const title = post?.title || term?.term || 'Unknown';
            const href = post ? `/${post.locale || 'en'}/log/${post.slug}/` : term ? `/en/handbook/${term.slug}/` : '#';
            const isLiked = item.item_type === 'post' && likedPostIds.has(item.item_id);
            const isBm = bookmarkedItemIds.has(`${item.item_type}:${item.item_id}`);
            return (
              <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid var(--color-border);">
                <div style="flex: 1; min-width: 0;">
                  <div style="display: flex; align-items: center; gap: 0.5rem;">
                    <span class="library-type-badge">{item.item_type === 'post' ? copy.badgeArticle : copy.badgeTerm}</span>
                    <a href={href} style="font-weight: 600; text-decoration: none; color: inherit; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                      {title}
                    </a>
                  </div>
                  <div style="font-size: 0.78rem; color: var(--color-text-muted); margin-top: 0.2rem;">
                    {new Date(item.read_at).toLocaleDateString(copy.dateLocale)}
                  </div>
                </div>
                <div style="display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0;">
                  {item.item_type === 'post' && (
                    <button type="button" class="library-icon-btn" data-toggle-like data-post-id={item.item_id} data-active={isLiked ? 'true' : 'false'} aria-label="Like" style="background:none;border:none;cursor:pointer;padding:0.2rem;line-height:1;">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill={isLiked ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" style={`color: ${isLiked ? 'var(--color-accent)' : 'var(--color-text-muted)'}; opacity: ${isLiked ? '1' : '0.35'};`}>
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                      </svg>
                    </button>
                  )}
                  <button type="button" class="library-icon-btn" data-toggle-bookmark data-item-id={item.item_id} data-item-type={item.item_type} data-active={isBm ? 'true' : 'false'} aria-label="Bookmark" style="background:none;border:none;cursor:pointer;padding:0.2rem;line-height:1;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill={isBm ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="1.5" style={`color: ${isBm ? 'var(--color-accent)' : 'var(--color-text-muted)'}; opacity: ${isBm ? '1' : '0.35'};`}>
                      <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
                    </svg>
                  </button>
                  <button type="button" class="library-delete-btn" data-delete-type="history" data-delete-id={item.id} data-item-type={item.item_type} data-item-id={item.item_id} data-removed="false" aria-label="Remove" style="background:none;border:none;cursor:pointer;padding:0.2rem;line-height:1;color:var(--color-text-muted);opacity:0.35;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                  </button>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </div>

    <!-- Progress Tab -->
    <div data-tab-content="progress" style="display: none;">
      <div style="margin-bottom: 2rem; padding: 1.25rem; border: 1px solid var(--color-border); background: var(--color-bg-secondary);">
        <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.75rem;">
          <span style="font-weight: 700;">{copy.overallProgress}</span>
          <span style="font-size: 0.85rem; color: var(--color-text-muted);">
            {totalLearned} {copy.learned} / {totalRead} {copy.visited}
          </span>
        </div>
        <div class="learning-progress-bar">
          <div class="learning-progress-fill" style={`width: ${totalRead > 0 ? Math.round((totalLearned / totalRead) * 100) : 0}%;`}></div>
        </div>
      </div>

      {categoryProgress.size === 0 ? (
        <p style="color: var(--color-text-muted); padding: 2rem 0; text-align: center;">
          {copy.emptyProgress}
        </p>
      ) : (
        <div>
          {[...categoryProgress.entries()].map(([cat, stats]) => (
            <div style="padding: 0.75rem 0; border-bottom: 1px solid var(--color-border);">
              <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.4rem;">
                <span style="font-weight: 600; text-transform: capitalize;">{cat}</span>
                <span style="font-size: 0.78rem; color: var(--color-text-muted);">
                  {stats.learned}/{stats.total} {copy.learned}
                </span>
              </div>
              <div class="learning-progress-bar">
                <div class="learning-progress-fill" style={`width: ${stats.total > 0 ? Math.round((stats.learned / stats.total) * 100) : 0}%;`}></div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</MainLayout>

<script>
  function initLibrary(): void {
    // Tab switching
    const tabs = document.querySelectorAll<HTMLButtonElement>('.library-tab');
    const contents = document.querySelectorAll<HTMLElement>('[data-tab-content]');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;
        tabs.forEach((t) => t.classList.remove('library-tab--active'));
        tab.classList.add('library-tab--active');
        contents.forEach((c) => {
          c.style.display = c.dataset.tabContent === target ? 'block' : 'none';
        });
      });
    });

    // Sub-tab switching (inside Saved tab)
    const subTabs = document.querySelectorAll<HTMLButtonElement>('.library-sub-tab');
    const subContents = document.querySelectorAll<HTMLElement>('[data-sub-content]');

    subTabs.forEach((st) => {
      st.addEventListener('click', () => {
        const target = st.dataset.subTab;
        subTabs.forEach((s) => s.classList.remove('library-sub-tab--active'));
        st.classList.add('library-sub-tab--active');
        subContents.forEach((c) => {
          c.style.display = c.dataset.subContent === target ? 'block' : 'none';
        });
      });
    });

    // Like toggle buttons
    document.querySelectorAll<HTMLButtonElement>('[data-toggle-like]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const postId = btn.dataset.postId;
        if (!postId) return;
        try {
          const res = await fetch('/api/user/likes', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ post_id: postId }),
          });
          if (res.status === 401) {
            window.location.href = `/login?redirectTo=${encodeURIComponent(window.location.pathname)}`;
            return;
          }
          if (!res.ok) return;
          const data = await res.json();
          const active = data.liked;
          btn.dataset.active = active ? 'true' : 'false';
          const svg = btn.querySelector('svg');
          if (svg) {
            svg.setAttribute('fill', active ? 'currentColor' : 'none');
            svg.style.color = active ? 'var(--color-accent)' : 'var(--color-text-muted)';
            svg.style.opacity = active ? '1' : '0.35';
          }
        } catch { /* ignore */ }
      });
    });

    // Bookmark toggle buttons
    document.querySelectorAll<HTMLButtonElement>('[data-toggle-bookmark]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const itemId = btn.dataset.itemId;
        const itemType = btn.dataset.itemType;
        if (!itemId || !itemType) return;
        try {
          const res = await fetch('/api/user/bookmarks', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ item_id: itemId, item_type: itemType }),
          });
          if (res.status === 401) {
            window.location.href = `/login?redirectTo=${encodeURIComponent(window.location.pathname)}`;
            return;
          }
          if (!res.ok) return;
          const data = await res.json();
          const active = data.bookmarked;
          btn.dataset.active = active ? 'true' : 'false';
          const svg = btn.querySelector('svg');
          if (svg) {
            svg.setAttribute('fill', active ? 'currentColor' : 'none');
            svg.style.color = active ? 'var(--color-accent)' : 'var(--color-text-muted)';
            svg.style.opacity = active ? '1' : '0.35';
          }
        } catch { /* ignore */ }
      });
    });

    // Delete/restore toggle buttons (X ↔ +)
    document.querySelectorAll<HTMLButtonElement>('.library-delete-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const row = btn.closest('[style]') as HTMLElement;
        const svg = btn.querySelector('svg');
        if (!row || !svg) return;

        const removed = btn.dataset.removed === 'true';

        if (!removed) {
          const id = btn.dataset.deleteId;
          if (!id) return;
          try {
            const res = await fetch(`/api/user/reading-history?id=${id}`, { method: 'DELETE' });
            if (!res.ok) return;
            btn.dataset.removed = 'true';
            row.style.opacity = '0.4';
            svg.innerHTML = '<line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>';
            btn.setAttribute('aria-label', 'Restore');
          } catch { /* ignore */ }
        } else {
          const itemType = btn.dataset.itemType;
          const itemId = btn.dataset.itemId;
          if (!itemType || !itemId) return;
          try {
            const res = await fetch('/api/user/reading-history', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ item_type: itemType, item_id: itemId }),
            });
            if (!res.ok) return;
            btn.dataset.removed = 'false';
            row.style.opacity = '1';
            svg.innerHTML = '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>';
            btn.setAttribute('aria-label', 'Remove');
          } catch { /* ignore */ }
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initLibrary);
</script>
