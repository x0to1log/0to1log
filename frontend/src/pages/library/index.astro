---
export const prerender = false;

import MainLayout from '../../layouts/MainLayout.astro';
import { createClient } from '@supabase/supabase-js';

// Redirect if not logged in
if (!Astro.locals.user || !Astro.locals.accessToken) {
  return Astro.redirect(`/login?redirectTo=${encodeURIComponent('/library/')}`);
}

const user = Astro.locals.user;
const accessToken = Astro.locals.accessToken;
const profile = Astro.locals.profile;
const langParam = Astro.url.searchParams.get('lang');
const cookieLocale = Astro.cookies.get('site-locale')?.value;
const acceptLang = Astro.request.headers.get('accept-language') || '';
const browserLocale = acceptLang.split(',').some(l => l.trim().startsWith('ko')) ? 'ko' : 'en';
const locale = (langParam === 'ko' || langParam === 'en') ? langParam
  : (cookieLocale === 'ko' || cookieLocale === 'en') ? cookieLocale
  : profile?.preferred_locale === 'ko' ? 'ko'
  : profile?.preferred_locale === 'en' ? 'en'
  : browserLocale;

const copy = locale === 'ko'
  ? {
      title: '나의 서재',
      tabRead: '읽은 글',
      tabSaved: '저장한 글',
      tabProgress: '학습 현황',
      emptyRead: '아직 읽은 기록이 없습니다. 기사와 용어를 탐색해 보세요!',
      emptySaved: '아직 저장한 글이 없습니다. 기사와 용어를 저장해 보세요!',
      emptyProgress: '용어집을 방문하면 학습 현황이 기록됩니다!',
      badgeArticle: '기사',
      badgeTerm: '용어',
      savedPrefix: '저장일',
      overallProgress: '전체 학습 현황',
      learned: '학습 완료',
      visited: '방문',
      removeBookmark: '북마크 해제',
      dateLocale: 'ko-KR',
    }
  : {
      title: 'My Library',
      tabRead: 'Read',
      tabSaved: 'Saved',
      tabProgress: 'Progress',
      emptyRead: 'No reading history yet. Start exploring articles and terms!',
      emptySaved: 'No bookmarks yet. Save articles and terms to find them here!',
      emptyProgress: 'Visit handbook terms to start tracking your learning progress!',
      badgeArticle: 'Article',
      badgeTerm: 'Term',
      savedPrefix: 'Saved',
      overallProgress: 'Overall Progress',
      learned: 'learned',
      visited: 'visited',
      removeBookmark: 'Remove bookmark',
      dateLocale: 'en-US',
    };
const authSb = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
);

// Fetch all user data in parallel
const [historyRes, bookmarksRes, progressRes] = await Promise.all([
  authSb.from('reading_history').select('id, item_type, item_id, read_at').eq('user_id', user.id).order('read_at', { ascending: false }),
  authSb.from('user_bookmarks').select('id, item_type, item_id, created_at').eq('user_id', user.id).order('created_at', { ascending: false }),
  authSb.from('learning_progress').select('id, term_id, status, read_at, learned_at').eq('user_id', user.id),
]);

const historyItems = historyRes.data ?? [];
const bookmarkItems = bookmarksRes.data ?? [];
const progressItems = progressRes.data ?? [];

// Collect IDs to batch-fetch metadata
const postIds = new Set<string>();
const termIds = new Set<string>();
[...historyItems, ...bookmarkItems].forEach((item) => {
  if (item.item_type === 'post') postIds.add(item.item_id);
  if (item.item_type === 'term') termIds.add(item.item_id);
});
progressItems.forEach((p) => termIds.add(p.term_id));

// Fetch post and term metadata
const { supabase } = await import('../../lib/supabase');
const postMap = new Map<string, any>();
const termMap = new Map<string, any>();

if (supabase && postIds.size > 0) {
  const { data } = await supabase.from('posts').select('id, title, slug, category, locale').in('id', [...postIds]);
  (data ?? []).forEach((p: any) => postMap.set(p.id, p));
}
if (supabase && termIds.size > 0) {
  const { data } = await supabase.from('handbook_terms').select('id, term, slug, korean_name, category, difficulty').in('id', [...termIds]);
  (data ?? []).forEach((t: any) => termMap.set(t.id, t));
}

// Aggregate learning progress by category
const categoryProgress = new Map<string, { total: number; read: number; learned: number }>();
progressItems.forEach((p) => {
  const t = termMap.get(p.term_id);
  const cat = t?.category || 'uncategorized';
  if (!categoryProgress.has(cat)) categoryProgress.set(cat, { total: 0, read: 0, learned: 0 });
  const c = categoryProgress.get(cat)!;
  c.total++;
  if (p.status === 'read') c.read++;
  if (p.status === 'learned') c.learned++;
});
const totalLearned = progressItems.filter((p) => p.status === 'learned').length;
const totalRead = progressItems.length;
---

<MainLayout title={`${copy.title} — 0to1log`} locale={locale as 'en' | 'ko'} headerAlwaysVisible={true}>
  <div class="newsprint-page" style="max-width: 800px;">
    <h1 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; margin-bottom: 1.5rem;">
      {copy.title}
    </h1>

    <div class="library-tabs">
      <button class="library-tab library-tab--active" data-tab="read">{copy.tabRead}</button>
      <button class="library-tab" data-tab="saved">{copy.tabSaved}</button>
      <button class="library-tab" data-tab="progress">{copy.tabProgress}</button>
    </div>

    <!-- Read Tab -->
    <div data-tab-content="read">
      {historyItems.length === 0 ? (
        <p style="color: var(--color-text-muted); padding: 2rem 0; text-align: center;">
          {copy.emptyRead}
        </p>
      ) : (
        <div>
          {historyItems.map((item) => {
            const post = item.item_type === 'post' ? postMap.get(item.item_id) : null;
            const term = item.item_type === 'term' ? termMap.get(item.item_id) : null;
            const title = post?.title || term?.term || 'Unknown';
            const href = post ? `/${post.locale || 'en'}/log/${post.slug}/` : term ? `/en/handbook/${term.slug}/` : '#';
            return (
              <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid var(--color-border);">
                <div style="flex: 1; min-width: 0;">
                  <div style="display: flex; align-items: center; gap: 0.5rem;">
                    <span class="library-type-badge">{item.item_type === 'post' ? copy.badgeArticle : copy.badgeTerm}</span>
                    <a href={href} style="font-weight: 600; text-decoration: none; color: inherit; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                      {title}
                    </a>
                  </div>
                  <div style="font-size: 0.78rem; color: var(--color-text-muted); margin-top: 0.2rem;">
                    {new Date(item.read_at).toLocaleDateString(copy.dateLocale)}
                  </div>
                </div>
                <button class="library-delete-btn" data-delete-type="history" data-delete-id={item.id} style="background: none; border: none; color: var(--color-text-muted); cursor: pointer; font-size: 1.1rem; padding: 0.35rem; line-height: 1;">
                  ×
                </button>
              </div>
            );
          })}
        </div>
      )}
    </div>

    <!-- Saved Tab -->
    <div data-tab-content="saved" style="display: none;">
      {bookmarkItems.length === 0 ? (
        <p style="color: var(--color-text-muted); padding: 2rem 0; text-align: center;">
          {copy.emptySaved}
        </p>
      ) : (
        <div>
          {bookmarkItems.map((item) => {
            const post = item.item_type === 'post' ? postMap.get(item.item_id) : null;
            const term = item.item_type === 'term' ? termMap.get(item.item_id) : null;
            const title = post?.title || term?.term || 'Unknown';
            const href = post ? `/${post.locale || 'en'}/log/${post.slug}/` : term ? `/en/handbook/${term.slug}/` : '#';
            return (
              <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid var(--color-border);">
                <div style="flex: 1; min-width: 0;">
                  <div style="display: flex; align-items: center; gap: 0.5rem;">
                    <span class="library-type-badge">{item.item_type === 'post' ? copy.badgeArticle : copy.badgeTerm}</span>
                    <a href={href} style="font-weight: 600; text-decoration: none; color: inherit; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                      {title}
                    </a>
                  </div>
                  <div style="font-size: 0.78rem; color: var(--color-text-muted); margin-top: 0.2rem;">
                    {copy.savedPrefix} {new Date(item.created_at).toLocaleDateString(copy.dateLocale)}
                  </div>
                </div>
                <button class="library-delete-btn" data-delete-type="bookmark" data-delete-id={item.id} style="background: none; border: none; color: var(--color-text-muted); cursor: pointer; padding: 0.35rem; line-height: 1;" title={copy.removeBookmark}>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1.5"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
                </button>
              </div>
            );
          })}
        </div>
      )}
    </div>

    <!-- Progress Tab -->
    <div data-tab-content="progress" style="display: none;">
      <div style="margin-bottom: 2rem; padding: 1.25rem; border: 1px solid var(--color-border); background: var(--color-bg-secondary);">
        <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.75rem;">
          <span style="font-weight: 700;">{copy.overallProgress}</span>
          <span style="font-size: 0.85rem; color: var(--color-text-muted);">
            {totalLearned} {copy.learned} / {totalRead} {copy.visited}
          </span>
        </div>
        <div class="learning-progress-bar">
          <div class="learning-progress-fill" style={`width: ${totalRead > 0 ? Math.round((totalLearned / totalRead) * 100) : 0}%;`}></div>
        </div>
      </div>

      {categoryProgress.size === 0 ? (
        <p style="color: var(--color-text-muted); padding: 2rem 0; text-align: center;">
          {copy.emptyProgress}
        </p>
      ) : (
        <div>
          {[...categoryProgress.entries()].map(([cat, stats]) => (
            <div style="padding: 0.75rem 0; border-bottom: 1px solid var(--color-border);">
              <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.4rem;">
                <span style="font-weight: 600; text-transform: capitalize;">{cat}</span>
                <span style="font-size: 0.78rem; color: var(--color-text-muted);">
                  {stats.learned}/{stats.total} {copy.learned}
                </span>
              </div>
              <div class="learning-progress-bar">
                <div class="learning-progress-fill" style={`width: ${stats.total > 0 ? Math.round((stats.learned / stats.total) * 100) : 0}%;`}></div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</MainLayout>

<script>
  function initLibrary(): void {
    // Tab switching
    const tabs = document.querySelectorAll<HTMLButtonElement>('.library-tab');
    const contents = document.querySelectorAll<HTMLElement>('[data-tab-content]');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;
        tabs.forEach((t) => t.classList.remove('library-tab--active'));
        tab.classList.add('library-tab--active');
        contents.forEach((c) => {
          c.style.display = c.dataset.tabContent === target ? 'block' : 'none';
        });
      });
    });

    // Delete buttons
    document.querySelectorAll<HTMLButtonElement>('.library-delete-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const type = btn.dataset.deleteType;
        const id = btn.dataset.deleteId;
        if (!type || !id) return;

        const endpoint = type === 'history' ? '/api/user/reading-history' : '/api/user/bookmarks';
        try {
          const res = await fetch(`${endpoint}?id=${id}`, { method: 'DELETE' });
          if (res.ok) {
            const row = btn.closest('[style]') as HTMLElement;
            if (row) row.remove();
          }
        } catch { /* ignore */ }
      });
    });
  }

  document.addEventListener('astro:page-load', initLibrary);
</script>
