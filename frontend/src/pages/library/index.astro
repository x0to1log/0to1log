---
export const prerender = false;

import MainLayout from '../../layouts/MainLayout.astro';
import { createClient } from '@supabase/supabase-js';
import { localField } from '../../lib/handbookUtils';
import { getHandbookCategoryLabel } from '../../lib/handbookCategories';
import { getSiteContents } from '../../lib/siteContent';
import { fetchLikedProducts } from '../../lib/pageData/productsPage';
import ProductCard from '../../components/products/ProductCard.astro';
const user = Astro.locals.user;
const accessToken = Astro.locals.accessToken;
const isAuthenticated = !!user && !!accessToken;
const profile = Astro.locals.profile;
const langParam = Astro.url.searchParams.get('lang');
const cookieLocale = Astro.cookies.get('site-locale')?.value;
const acceptLang = Astro.request.headers.get('accept-language') || '';
const browserLocale = acceptLang.split(',').some((l) => l.trim().startsWith('ko')) ? 'ko' : 'en';
const locale = (langParam === 'ko' || langParam === 'en') ? langParam
  : (cookieLocale === 'ko' || cookieLocale === 'en') ? cookieLocale
  : profile?.preferred_locale === 'ko' ? 'ko'
  : profile?.preferred_locale === 'en' ? 'en'
  : browserLocale;

const siteContent = await getSiteContents([
  'library_empty_saved',
  'library_empty_read',
  'library_empty_progress',
], locale as 'en' | 'ko');

function relativeDate(dateStr: string, loc: string): string {
  const now = new Date();
  const date = new Date(dateStr);
  const diffDays = Math.floor((now.getTime() - date.getTime()) / 86400000);
  if (diffDays === 0) return loc === 'ko' ? '오늘' : 'Today';
  if (diffDays === 1) return loc === 'ko' ? '어제' : 'Yesterday';
  if (diffDays < 7) return loc === 'ko' ? `${diffDays}일 전` : `${diffDays} days ago`;
  return date.toLocaleDateString(loc === 'ko' ? 'ko-KR' : 'en-US', { month: 'short', day: 'numeric' });
}

function spineColor(category?: string | null): string {
  switch (category) {
    case 'ai-news': return 'var(--color-cat-ainews)';
    case 'study': return 'var(--color-cat-study)';
    case 'career': return 'var(--color-cat-career)';
    case 'project': return 'var(--color-cat-project)';
    default: return 'var(--color-border)';
  }
}

const copy = locale === 'ko'
  ? {
      title: '나의 서재',
      tabSaved: '저장한 글',
      tabRead: '읽은 글',
      tabProgress: '나의 학습 현황',
      tabRecommended: '추천 읽기',
      tabLikedTools: '찜한 AI 도구',
      emptyLikedTools: '아직 찜한 AI 도구가 없습니다',
      browseLikedTools: 'AI 도구 탐색하기 →',
      emptyRead: siteContent.library_empty_read || '아직 읽은 글이 없어요\n흥미로운 글을 찾아 읽어보세요',
      emptySaved: siteContent.library_empty_saved || '아직 저장한 글이 없어요\n관심 가는 글에서 🔖 버튼을 눌러보세요\n이곳에 차곡차곡 쌓여갈 거예요',
      subArticles: '글',
      subTerms: '용어',
      emptyArticles: '저장한 글이 없습니다.',
      emptyTerms: '저장한 용어가 없습니다.',
      readingTime: '분',
      emptyProgress: siteContent.library_empty_progress || '용어집을 읽기 시작하면\n학습 현황이 여기에 쌓입니다',
      emptyRecommended: '읽기 기록이 쌓이면 맞춤 추천이 생겨요',
      badgeNews: '뉴스',
      badgeBlog: '블로그',
      badgeTerm: '용어',
      savedPrefix: '저장일',
      overallProgress: '전체 학습 현황',
      learned: '학습 완료',
      visited: '방문',
      removeBookmark: '북마크 해제',
      dateLocale: 'ko-KR',
      subtitle: (read: number, learned: number) =>
        read > 0 || learned > 0
          ? `${read}편의 글을 읽고, ${learned}개의 용어를 학습했어요`
          : '서재에 오신 것을 환영합니다',
      previewSubtitle: '저장한 글, 읽던 글, 학습 흐름을 나만의 서재에 모아보세요.',
      previewCards: {
        saved: {
          kicker: '저장한 글',
          title: '나중에 다시 볼 글을 한곳에',
          items: ['북마크한 뉴스와 블로그를 바로 다시 열기', '중요한 글을 주제별로 천천히 쌓아두기'],
        },
        history: {
          kicker: '읽은 기록',
          title: '읽던 흐름을 끊기지 않게',
          items: ['최근에 읽은 글을 다시 이어서 보기', '관심이 갔던 주제를 자연스럽게 되짚기'],
        },
        progress: {
          kicker: '학습 현황',
          title: '용어 학습 진척을 한눈에',
          items: ['읽은 용어와 익힌 용어의 비율 확인', '카테고리별 학습 흐름을 꾸준히 관리'],
        },
      },
      previewCta: '로그인하고 내 서재 만들기',
      previewNote: '로그인하면 저장한 글, 읽기 기록, 학습 현황이 같은 서재 안에서 이어집니다.',
    }
  : {
      title: 'My Library',
      tabSaved: 'Saved',
      tabRead: 'Read',
      tabProgress: 'My Progress',
      tabRecommended: 'For You',
      tabLikedTools: 'Liked Tools',
      emptyLikedTools: 'No liked AI tools yet',
      browseLikedTools: 'Browse AI tools →',
      emptyRead: siteContent.library_empty_read || 'No reading history yet\nExplore articles and start reading',
      emptySaved: siteContent.library_empty_saved || 'Your shelf is empty\nTap 🔖 on articles you\'d like to keep\nThey\'ll be waiting for you here',
      subArticles: 'Posts',
      subTerms: 'Terms',
      emptyArticles: 'No saved posts yet.',
      emptyTerms: 'No saved terms yet.',
      readingTime: 'min',
      emptyProgress: siteContent.library_empty_progress || 'Visit handbook terms to start\ntracking your learning progress',
      emptyRecommended: "Read a few articles and we'll suggest more",
      badgeNews: 'News',
      badgeBlog: 'Blog',
      badgeTerm: 'Term',
      savedPrefix: 'Saved',
      overallProgress: 'Overall Progress',
      learned: 'learned',
      visited: 'visited',
      removeBookmark: 'Remove bookmark',
      dateLocale: 'en-US',
      subtitle: (read: number, learned: number) =>
        read > 0 || learned > 0
          ? `${read} articles read, ${learned} terms learned`
          : 'Welcome to your reading room',
      previewSubtitle: 'Keep saved posts, reading history, and learning momentum together in one place.',
      previewCards: {
        saved: {
          kicker: 'Saved posts',
          title: 'Keep the posts you want to revisit',
          items: ['Return to bookmarked news and blog posts anytime', 'Build a shelf of posts worth keeping close'],
        },
        history: {
          kicker: 'Reading history',
          title: 'Pick up where you left off',
          items: ['Jump back into the posts you recently opened', 'Reconnect with themes that caught your attention'],
        },
        progress: {
          kicker: 'Learning progress',
          title: 'See your handbook progress at a glance',
          items: ['Track what you visited and what you learned', 'Build steady momentum across categories'],
        },
      },
      previewCta: 'Sign in to create my library',
      previewNote: 'Signing in connects your saved posts, reading trail, and learning progress in one reading room.',
    };
const { supabase } = await import('../../lib/supabase');
const postMap = new Map<string, any>();
const termMap = new Map<string, any>();
let historyItems: any[] = [];
let bookmarkItems: any[] = [];
let progressItems: any[] = [];
let likedItems: any[] = [];
let likedProducts: Awaited<ReturnType<typeof fetchLikedProducts>> = [];
let recommendedPosts: { post_id: string; slug: string; title: string; category: string }[] = [];

if (isAuthenticated) {
  const authSb = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
    { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
  );

  const [historyRes, bookmarksRes, progressRes, likesRes, likedProductsData] = await Promise.all([
    authSb.from('reading_history').select('id, item_type, item_id, read_at').eq('user_id', user.id).order('read_at', { ascending: false }),
    authSb.from('user_bookmarks').select('id, item_type, item_id, created_at').eq('user_id', user.id).order('created_at', { ascending: false }),
    authSb.from('learning_progress').select('id, term_id, status, read_at, learned_at').eq('user_id', user.id),
    authSb.from('news_likes').select('id, post_id, created_at').eq('user_id', user.id).order('created_at', { ascending: false }),
    fetchLikedProducts(accessToken, locale as 'en' | 'ko'),
  ]);

  historyItems = historyRes.data ?? [];
  bookmarkItems = bookmarksRes.data ?? [];
  progressItems = progressRes.data ?? [];
  likedItems = likesRes.data ?? [];
  likedProducts = likedProductsData;

  const postIds = new Set<string>();
  const termIds = new Set<string>();
  [...historyItems, ...bookmarkItems].forEach((item) => {
    if (item.item_type === 'news' || item.item_type === 'blog') postIds.add(item.item_id);
    if (item.item_type === 'term') termIds.add(item.item_id);
  });
  likedItems.forEach((item) => postIds.add(item.post_id));
  progressItems.forEach((item) => termIds.add(item.term_id));

  if (supabase && (postIds.size > 0 || termIds.size > 0)) {
    const [newsPostRes, blogPostRes, termRes] = await Promise.all([
      postIds.size > 0
        ? supabase.from('news_posts').select('id, title, slug, category, locale, reading_time_min').in('id', [...postIds])
        : Promise.resolve({ data: null }),
      postIds.size > 0
        ? supabase.from('blog_posts').select('id, title, slug, category, locale, reading_time_min').in('id', [...postIds])
        : Promise.resolve({ data: null }),
      termIds.size > 0
        ? supabase.from('handbook_terms').select('id, term, slug, korean_name, category, difficulty').in('id', [...termIds])
        : Promise.resolve({ data: null }),
    ]);
    (newsPostRes.data ?? []).forEach((post: any) => postMap.set(post.id, { ...post, type: 'news' }));
    (blogPostRes.data ?? []).forEach((post: any) => postMap.set(post.id, { ...post, type: 'blog' }));
    (termRes.data ?? []).forEach((term: any) => termMap.set(term.id, term));
  }

  const fastapiUrl = import.meta.env.FASTAPI_URL;
  if (fastapiUrl && user?.id) {
    try {
      const res = await fetch(
        `${fastapiUrl}/api/recommendations/for-you?user_id=${user.id}&locale=${locale}`,
        { signal: AbortSignal.timeout(4000) }
      );
      if (res.ok) recommendedPosts = await res.json();
    } catch {
      // Non-fatal
    }
  }
}

const categoryProgress = new Map<string, { total: number; read: number; learned: number }>();
progressItems.forEach((item) => {
  const term = termMap.get(item.term_id);
  const category = term?.category || 'uncategorized';
  if (!categoryProgress.has(category)) categoryProgress.set(category, { total: 0, read: 0, learned: 0 });
  const stats = categoryProgress.get(category)!;
  stats.total++;
  if (item.status === 'read') stats.read++;
  if (item.status === 'learned') stats.learned++;
});
const totalLearned = progressItems.filter((item) => item.status === 'learned').length;
const totalRead = progressItems.length;
const articleBookmarks = bookmarkItems.filter((item) => item.item_type === 'news' || item.item_type === 'blog');
const termBookmarks = bookmarkItems.filter((item) => item.item_type === 'term');
const likedPostIds = new Set(likedItems.map((item) => item.post_id));
const bookmarkedItemIds = new Set(bookmarkItems.map((item) => `${item.item_type}:${item.item_id}`));
---

<MainLayout title={copy.title} locale={locale as 'en' | 'ko'} headerAlwaysVisible={true}>
  <div class="newsprint-page" style="max-width: 800px;">
    <div class="library-header">
      <h1 class="library-title">{copy.title}</h1>
      <div class="library-ornament">✦</div>
      <p class="library-subtitle">{isAuthenticated ? copy.subtitle(historyItems.length, totalLearned) : copy.previewSubtitle}</p>
    </div>
    {isAuthenticated ? (
      <>
        <div class="library-tabs">
          <button class="library-tab library-tab--active" data-tab="saved">{copy.tabSaved}</button>
          <button class="library-tab" data-tab="read">{copy.tabRead}</button>
          <button class="library-tab" data-tab="liked-tools">{copy.tabLikedTools}</button>
          <button class="library-tab" data-tab="progress">{copy.tabProgress}</button>
          <button class="library-tab" data-tab="recommended">{copy.tabRecommended}</button>
        </div>

        <!-- Saved Tab (default active) -->
        <div data-tab-content="saved">
          {bookmarkItems.length === 0 ? (
            <p class="library-empty">{copy.emptySaved}</p>
          ) : (
            <div>
              <div class="library-sub-tabs">
                <button class="library-sub-tab library-sub-tab--active" data-sub-tab="articles">
                  {copy.subArticles} ({articleBookmarks.length})
                </button>
                <button class="library-sub-tab" data-sub-tab="terms">
                  {copy.subTerms} ({termBookmarks.length})
                </button>
              </div>

              <div data-sub-content="articles">
                {articleBookmarks.length === 0 ? (
                  <p class="library-empty">{copy.emptyArticles}</p>
                ) : (
                  <div class="library-shelf">
                    {articleBookmarks.map((item) => {
                      const post = postMap.get(item.item_id);
                      const title = post?.title || 'Unknown';
                      const href = post ? `/${post.locale || 'en'}/${post.type === 'blog' ? 'blog' : 'news'}/${post.slug}/` : '#';
                      const isLiked = post?.type === 'news' && likedPostIds.has(item.item_id);
                      return (
                        <div class="library-item">
                          <div class="library-item-spine" style={`background: ${spineColor(post?.category)};`}></div>
                          <div class="library-item-content">
                            <div class="library-item-row">
                              <a href={href} class="library-item-title">{title}</a>
                              <div class="library-item-actions">
                                {post?.type === 'news' && (
                                  <button type="button" class={`library-action-btn ${isLiked ? 'library-action-btn--active' : 'library-action-btn--muted'}`} data-toggle-like data-post-id={item.item_id} data-active={isLiked ? 'true' : 'false'} aria-label="Like">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill={isLiked ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2">
                                      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                                    </svg>
                                  </button>
                                )}
                                <button type="button" class="library-action-btn library-action-btn--active" data-toggle-bookmark data-item-id={item.item_id} data-item-type={item.item_type} data-active="true" aria-label="Bookmark">
                                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1.5">
                                    <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
                                  </svg>
                                </button>
                              </div>
                            </div>
                            <div class="library-item-meta">
                              {post?.category && <span class="library-type-badge">{post.category}</span>}
                              {post?.reading_time_min && <span>{post.reading_time_min}{copy.readingTime}</span>}
                              <span>{relativeDate(item.created_at, locale)}</span>
                            </div>
                          </div>
                        </div>
                      );
                    })}
                  </div>
                )}
              </div>

              <div data-sub-content="terms" style="display: none;">
                {termBookmarks.length === 0 ? (
                  <p class="library-empty">{copy.emptyTerms}</p>
                ) : (
                  <div class="library-shelf">
                    {termBookmarks.map((item) => {
                      const term = termMap.get(item.item_id);
                      const title = term?.term || 'Unknown';
                      const href = term ? `/${locale}/handbook/${term.slug}/` : '#';
                      return (
                        <div class="library-item">
                          <div class="library-item-spine" style="background: var(--color-text-muted);"></div>
                          <div class="library-item-content">
                            <div class="library-item-row">
                              <div style="min-width: 0; flex: 1;">
                                <a href={href} class="library-item-title">
                                  {title}
                                  {term?.korean_name && locale === 'ko' && (
                                    <span style="font-size: 0.78rem; color: var(--color-text-muted); font-weight: 400; margin-left: 0.4rem;">{term.korean_name}</span>
                                  )}
                                </a>
                              </div>
                              <div class="library-item-actions">
                                <button type="button" class="library-action-btn library-action-btn--active" data-toggle-bookmark data-item-id={item.item_id} data-item-type="term" data-active="true" aria-label="Bookmark">
                                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1.5">
                                    <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
                                  </svg>
                                </button>
                              </div>
                            </div>
                            <div class="library-item-meta">
                              {term?.category && (
                                <span>{getHandbookCategoryLabel(locale as 'en' | 'ko', term.category)}</span>
                              )}
                              <span>{relativeDate(item.created_at, locale)}</span>
                            </div>
                          </div>
                        </div>
                      );
                    })}
                  </div>
                )}
              </div>
            </div>
          )}
        </div>

        <div data-tab-content="read" style="display: none;">
          {historyItems.length === 0 ? (
            <p class="library-empty">{copy.emptyRead}</p>
          ) : (
            <div class="library-shelf">
              {historyItems.map((item) => {
                const post = item.item_type === 'news' || item.item_type === 'blog' ? postMap.get(item.item_id) : null;
                const term = item.item_type === 'term' ? termMap.get(item.item_id) : null;
                const title = post?.title || term?.term || 'Unknown';
                const href = post ? `/${post.locale || 'en'}/${post.type === 'blog' ? 'blog' : 'news'}/${post.slug}/` : term ? `/${locale}/handbook/${term.slug}/` : '#';
                const isLiked = item.item_type === 'news' && likedPostIds.has(item.item_id);
                const isBm = bookmarkedItemIds.has(`${item.item_type}:${item.item_id}`);
                const color = item.item_type === 'news' || item.item_type === 'blog' ? spineColor(post?.category) : 'var(--color-text-muted)';
                return (
                  <div class="library-item">
                    <div class="library-item-spine" style={`background: ${color};`}></div>
                    <div class="library-item-content">
                      <div class="library-item-row">
                        <div style="display: flex; align-items: center; gap: 0.5rem; min-width: 0; flex: 1;">
                          <span class="library-type-badge">{item.item_type === 'news' ? copy.badgeNews : item.item_type === 'blog' ? copy.badgeBlog : copy.badgeTerm}</span>
                          <a href={href} class="library-item-title">{title}</a>
                        </div>
                        <div class="library-item-actions">
                          {item.item_type === 'news' && (
                            <button type="button" class={`library-action-btn ${isLiked ? 'library-action-btn--active' : 'library-action-btn--muted'}`} data-toggle-like data-post-id={item.item_id} data-active={isLiked ? 'true' : 'false'} aria-label="Like">
                              <svg width="16" height="16" viewBox="0 0 24 24" fill={isLiked ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2">
                                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                              </svg>
                            </button>
                          )}
                          <button type="button" class={`library-action-btn ${isBm ? 'library-action-btn--active' : 'library-action-btn--muted'}`} data-toggle-bookmark data-item-id={item.item_id} data-item-type={item.item_type} data-active={isBm ? 'true' : 'false'} aria-label="Bookmark">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill={isBm ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="1.5">
                              <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
                            </svg>
                          </button>
                          <button type="button" class="library-action-btn library-action-btn--muted library-delete-btn" data-delete-type="history" data-delete-id={item.id} data-item-type={item.item_type} data-item-id={item.item_id} data-removed="false" aria-label="Remove">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                            </svg>
                          </button>
                        </div>
                      </div>
                      <div class="library-item-meta">
                        <span>{relativeDate(item.read_at, locale)}</span>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          )}
        </div>

        <div data-tab-content="liked-tools" style="display: none;">
          {likedProducts.length === 0 ? (
            <div class="library-liked-empty">
              <p class="library-empty">{copy.emptyLikedTools}</p>
              <a href={`/${locale}/products/`} class="library-liked-browse-link">{copy.browseLikedTools}</a>
            </div>
          ) : (
            <div class="product-grid library-liked-grid">
              {likedProducts.map((product) => {
                const firstImg = product.demo_media?.find((m) => m.type === 'image');
                return (
                  <ProductCard
                    href={`/${locale}/products/${product.slug}/`}
                    name={product.name_original}
                    tagline={product.tagline}
                    logoUrl={product.logo_url}
                    thumbnailUrl={product.thumbnail_url}
                    demoMediaFirst={firstImg?.url ?? null}
                    pricing={product.pricing}
                    platform={product.platform}
                    koreanSupport={product.korean_support}
                    locale={locale as 'en' | 'ko'}
                    categoryId={product.primary_category}
                    viewCount={product.view_count}
                    productId={product.id}
                  />
                );
              })}
            </div>
          )}
        </div>

        <div data-tab-content="recommended" style="display: none;">
          {recommendedPosts.length === 0 ? (
            <p class="library-empty">{copy.emptyRecommended}</p>
          ) : (
            <div class="library-shelf">
              {recommendedPosts.map((item) => (
                <div class="library-item">
                  <div class="library-item-spine" style={`background: ${spineColor(item.category)};`}></div>
                  <div class="library-item-content">
                    <div class="library-item-row">
                      <a href={`/${locale}/news/${item.slug}/`} class="library-item-title">{item.title}</a>
                    </div>
                    <div class="library-item-meta">
                      {item.category && <span class="library-type-badge">{item.category}</span>}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>

        <div data-tab-content="progress" style="display: none;">
          <div class="library-progress-card">
            <div class="library-progress-header">
              <span class="library-progress-label">{copy.overallProgress}</span>
              <span class="library-progress-stat">
                {totalLearned} {copy.learned} / {totalRead} {copy.visited}
              </span>
            </div>
            <div class="learning-progress-bar">
              <div class="learning-progress-fill" style={`width: ${totalRead > 0 ? Math.round((totalLearned / totalRead) * 100) : 0}%;`}></div>
            </div>
          </div>

          {categoryProgress.size === 0 ? (
            <p class="library-empty">{copy.emptyProgress}</p>
          ) : (
            <div>
              {[...categoryProgress.entries()].map(([cat, stats]) => (
                <div class="library-progress-row">
                  <div class="library-progress-row-header">
                    <span class="library-progress-cat">{getHandbookCategoryLabel(locale as 'en' | 'ko', cat)}</span>
                    <span class="library-progress-stat">
                      {stats.learned}/{stats.total} {copy.learned}
                    </span>
                  </div>
                  <div class="learning-progress-bar">
                    <div class="learning-progress-fill" style={`width: ${stats.total > 0 ? Math.round((stats.learned / stats.total) * 100) : 0}%;`}></div>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      </>
    ) : (
      <>
        <div class="library-preview-grid">
          <section class="library-preview-card library-preview-card--saved">
            <div class="library-preview-card-spine" aria-hidden="true"></div>
            <div class="library-preview-card-content">
              <div class="library-preview-card-header">
                <p class="library-preview-kicker">{copy.previewCards.saved.kicker}</p>
                <span class="library-preview-index">01</span>
              </div>
              <h2 class="library-preview-title">{copy.previewCards.saved.title}</h2>
              <ul class="library-preview-list">
                {copy.previewCards.saved.items.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </section>
          <section class="library-preview-card library-preview-card--history">
            <div class="library-preview-card-spine" aria-hidden="true"></div>
            <div class="library-preview-card-content">
              <div class="library-preview-card-header">
                <p class="library-preview-kicker">{copy.previewCards.history.kicker}</p>
                <span class="library-preview-index">02</span>
              </div>
              <h2 class="library-preview-title">{copy.previewCards.history.title}</h2>
              <ul class="library-preview-list">
                {copy.previewCards.history.items.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </section>
          <section class="library-preview-card library-preview-card--progress">
            <div class="library-preview-card-spine" aria-hidden="true"></div>
            <div class="library-preview-card-content">
              <div class="library-preview-card-header">
                <p class="library-preview-kicker">{copy.previewCards.progress.kicker}</p>
                <span class="library-preview-index">03</span>
              </div>
              <h2 class="library-preview-title">{copy.previewCards.progress.title}</h2>
              <ul class="library-preview-list">
                {copy.previewCards.progress.items.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </section>
        </div>

        <div class="library-preview-actions">
          <button
            type="button"
            class="newsprint-comment-submit"
            data-auth-gate
            data-auth-action="library"
            data-auth-redirect="/library/"
          >
            {copy.previewCta}
          </button>
          <p class="library-preview-note">{copy.previewNote}</p>
        </div>
      </>
    )}
  </div>
</MainLayout>

<script>
  import { openAuthPrompt } from '../../scripts/auth-prompt';
  import '../../scripts/productLike';

  function initLibrary(): void {
    // Tab switching
    const tabs = document.querySelectorAll<HTMLButtonElement>('.library-tab');
    const contents = document.querySelectorAll<HTMLElement>('[data-tab-content]');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;
        tabs.forEach((t) => t.classList.remove('library-tab--active'));
        tab.classList.add('library-tab--active');
        contents.forEach((c) => {
          c.style.display = c.dataset.tabContent === target ? 'block' : 'none';
        });
      });
    });

    // Sub-tab switching (inside Saved tab)
    const subTabs = document.querySelectorAll<HTMLButtonElement>('.library-sub-tab');
    const subContents = document.querySelectorAll<HTMLElement>('[data-sub-content]');

    subTabs.forEach((st) => {
      st.addEventListener('click', () => {
        const target = st.dataset.subTab;
        subTabs.forEach((s) => s.classList.remove('library-sub-tab--active'));
        st.classList.add('library-sub-tab--active');
        subContents.forEach((c) => {
          c.style.display = c.dataset.subContent === target ? 'block' : 'none';
        });
      });
    });

    function updateActionBtn(btn: HTMLButtonElement, active: boolean): void {
      btn.dataset.active = active ? 'true' : 'false';
      btn.classList.toggle('library-action-btn--active', active);
      btn.classList.toggle('library-action-btn--muted', !active);
      const svg = btn.querySelector('svg');
      if (svg) svg.setAttribute('fill', active ? 'currentColor' : 'none');
    }

    function checkSavedRowDim(row: HTMLElement): void {
      if (!row.closest('[data-tab-content="saved"]')) return;
      const likeBtn = row.querySelector<HTMLButtonElement>('[data-toggle-like]');
      const bookmarkBtn = row.querySelector<HTMLButtonElement>('[data-toggle-bookmark]');
      const bothOff = likeBtn?.dataset.active !== 'true' && bookmarkBtn?.dataset.active !== 'true';
      row.style.opacity = bothOff ? '0.4' : '1';
    }

    // Like toggle buttons
    document.querySelectorAll<HTMLButtonElement>('[data-toggle-like]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const postId = btn.dataset.postId;
        if (!postId) return;
        try {
          const res = await fetch('/api/user/likes', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ post_id: postId }),
          });
          if (res.status === 401) {
            openAuthPrompt({ action: 'like', redirectTo: `${window.location.pathname}${window.location.search}${window.location.hash}` });
            return;
          }
          if (!res.ok) return;
          const data = await res.json();
          updateActionBtn(btn, data.liked);
          const row = btn.closest('.library-item') as HTMLElement;
          if (row) checkSavedRowDim(row);
        } catch { /* ignore */ }
      });
    });

    // Bookmark toggle buttons
    document.querySelectorAll<HTMLButtonElement>('[data-toggle-bookmark]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const itemId = btn.dataset.itemId;
        const itemType = btn.dataset.itemType;
        if (!itemId || !itemType) return;
        try {
          const res = await fetch('/api/user/bookmarks', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ item_id: itemId, item_type: itemType }),
          });
          if (res.status === 401) {
            openAuthPrompt({ action: 'bookmark', redirectTo: `${window.location.pathname}${window.location.search}${window.location.hash}` });
            return;
          }
          if (!res.ok) return;
          const data = await res.json();
          updateActionBtn(btn, data.bookmarked);
          const row = btn.closest('.library-item') as HTMLElement;
          if (row) checkSavedRowDim(row);
        } catch { /* ignore */ }
      });
    });

    // Delete/restore toggle buttons (X / +)
    document.querySelectorAll<HTMLButtonElement>('.library-delete-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const row = btn.closest('.library-item') as HTMLElement;
        const svg = btn.querySelector('svg');
        if (!row || !svg) return;

        const removed = btn.dataset.removed === 'true';

        if (!removed) {
          const id = btn.dataset.deleteId;
          if (!id) return;
          try {
            const res = await fetch(`/api/user/reading-history?id=${id}`, { method: 'DELETE' });
            if (!res.ok) return;
            btn.dataset.removed = 'true';
            row.style.opacity = '0.4';
            svg.innerHTML = '<line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>';
            btn.setAttribute('aria-label', 'Restore');
          } catch { /* ignore */ }
        } else {
          const itemType = btn.dataset.itemType;
          const itemId = btn.dataset.itemId;
          if (!itemType || !itemId) return;
          try {
            const res = await fetch('/api/user/reading-history', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ item_type: itemType, item_id: itemId }),
            });
            if (!res.ok) return;
            btn.dataset.removed = 'false';
            row.style.opacity = '1';
            svg.innerHTML = '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>';
            btn.setAttribute('aria-label', 'Remove');
          } catch { /* ignore */ }
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initLibrary);
</script>
