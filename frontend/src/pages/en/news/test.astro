---
export const prerender = true;

import MainLayout from '../../../layouts/MainLayout.astro';
---

<MainLayout title="You're Invited" description="Your webhook is connected to 0to1log AI News." locale="en">
  <div class="wh-test-page">
    <div class="wh-ticket-wrapper">
      <div class="wh-seal-icon">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" class="seal-svg">
          <circle cx="12" cy="12" r="11" stroke="currentColor" stroke-width="0.8" fill="color-mix(in srgb, var(--color-accent) 8%, transparent)"/>
          <path d="M8 12.5l3 3 5-6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" class="seal-check"/>
        </svg>
      </div>

      <div class="wh-ticket-header">
        <h1 class="wh-test-title">You're all set!</h1>
        <p class="wh-test-sub">
          Your channel is now connected to <strong>0to1log</strong>.<br />
          AI news will be delivered automatically when published.
        </p>
      </div>

      <div class="wh-menu-list">
        <div class="wh-menu-item">
          <div class="wh-menu-item-info">
            <strong>Research Digest</strong>
            <span>Daily AI research news curated for technical depth</span>
          </div>
        </div>
        <div class="wh-menu-item">
          <div class="wh-menu-item-info">
            <strong>Business Digest</strong>
            <span>Daily AI business news for strategic decisions</span>
          </div>
        </div>
        <div class="wh-menu-item">
          <div class="wh-menu-item-info">
            <strong>Weekly Recap</strong>
            <span>Best stories of the week in one summary</span>
          </div>
        </div>
      </div>

      <div class="wh-ticket-actions">
        <a href="/en/news/" class="wh-action-link">
          <span>Browse AI News Digests</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/en/handbook/" class="wh-action-link">
          <span>Explore IT Glossary</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </div>
</MainLayout>

<style>
  .wh-test-page {
    display: flex;
    justify-content: center;
    padding: 5rem 1rem;
    min-height: 70vh;
  }

  .wh-ticket-wrapper {
    position: relative;
    max-width: 460px;
    width: 100%;
    margin: 0 auto;
    padding: 4rem 3rem 3.5rem;
    background: var(--color-bg-primary);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.04);
    text-align: center;
  }

  .wh-ticket-wrapper::before {
    content: '';
    position: absolute;
    top: 8px;
    left: 8px;
    right: 8px;
    bottom: 8px;
    border: 1px dashed var(--color-border);
    border-radius: 2px;
    pointer-events: none;
    opacity: 0.5;
  }

  .wh-seal-icon {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 2.5rem;
    color: var(--color-accent);
  }
  .seal-check {
    stroke-dasharray: 20;
    stroke-dashoffset: 20;
    animation: drawCheck 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards 0.3s;
  }
  @keyframes drawCheck {
    to { stroke-dashoffset: 0; }
  }

  .wh-ticket-header {
    margin-bottom: 3rem;
  }
  .wh-test-title {
    margin: 0 0 0.8rem;
    font-family: var(--font-heading);
    font-size: 2.2rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
  }
  .wh-test-sub {
    margin: 0;
    font-family: var(--font-ui);
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }
  .wh-test-sub strong {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .wh-menu-list {
    text-align: left;
    margin: 0 0 3.5rem;
    border-top: 1px solid var(--color-border);
  }
  .wh-menu-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.4rem 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .wh-menu-item-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .wh-menu-item-info strong {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-primary);
  }
  .wh-menu-item-info span {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .wh-ticket-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0 0.5rem;
  }
  .wh-action-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0.8rem;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-primary);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: all 0.2s;
  }
  .wh-action-link:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
  .wh-action-link svg {
    opacity: 0.5;
    transition: transform 0.2s, opacity 0.2s;
  }
  .wh-action-link:hover svg {
    transform: translateX(4px);
    opacity: 1;
  }

  @media (max-width: 640px) {
    .wh-ticket-wrapper {
      padding: 3rem 1.5rem 2.5rem;
    }
    .wh-test-title {
      font-size: 1.8rem;
    }
  }
</style>
