---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import { t } from '../../../i18n/index';
import { normalizeCategorySlug, getCategoryLabel } from '../../../lib/categories';
import { getNewsDetailPageData } from '../../../lib/pageData/newsDetailPage';
import NewsprintShell from '../../../components/newsprint/NewsprintShell.astro';
import NewsprintSideRail from '../../../components/newsprint/NewsprintSideRail.astro';
import NewsprintArticleLayout from '../../../components/newsprint/NewsprintArticleLayout.astro';
import NewsprintNotice from '../../../components/newsprint/NewsprintNotice.astro';
import ReadingActionsRail from '../../../components/common/ReadingActionsRail.astro';

const { slug } = Astro.params;
const pageSlug = slug ?? '';
const articleFindQuery = Astro.url.searchParams.get('q')?.trim() ?? '';
const previewRequested = Astro.url.searchParams.get('preview') === '1';
const previewMode = previewRequested && !!Astro.locals.isAdmin;
const previewPersona = Astro.url.searchParams.get('previewPersona');

const {
  post,
  postError,
  focusItems,
  articleData,
  nextPost,
  pairedSlug,
  similarPosts,
  isBookmarked,
  isLiked,
  likeCount,
  commentCount,
  handbookTermsJson,
  hasTerms,
  relatedTerms,
  htmlContent,
  analysisHtml,
  factPack,
  sourceCards,
  activePersona,
  availablePersonas,
  personaHtmlMap,
  hasPersonaSwitcher,
} = await getNewsDetailPageData({
  locale: 'en',
  slug: pageSlug,
  previewMode,
  locals: Astro.locals,
  previewPersona,
});

if (!post && !postError) {
  Astro.response.status = 404;
}

// CDN cache for all non-admin users (bookmark/like status hydrated client-side)
if (post && !previewMode && !Astro.locals.isAdmin) {
  Astro.response.headers.set('Cache-Control', 'public, s-maxage=3600, stale-while-revalidate=86400');
}

const masthead = 'Latest AI News';
const editionMap: Record<string, string> = {
  'ai-news': 'Daily Dispatch',
  study: 'Study Notes',
  career: 'Career Notes',
  project: 'Build Log',
};
const editionLabel = post ? (editionMap[normalizeCategorySlug(post.category) || ''] || 'Deep Dive') : 'Deep Dive';
const user = Astro.locals.user;
const accessToken = Astro.locals.accessToken;
const pageTitle = post ? post.title : 'Not Found';
const pageDescription = post?.excerpt?.slice(0, 155) || undefined;
const altSlugValue = pairedSlug || undefined;
const isWeekly = post?.post_type === 'weekly';
const weekTerms: Array<{slug: string; term: string; definition: string}> = isWeekly ? (post?.guide_items?.week_terms || []) : [];
const weekTool: {name?: string; description?: string; url?: string} | null = isWeekly ? (post?.guide_items?.week_tool || null) : null;
---

<MainLayout title={pageTitle} description={pageDescription} locale="en" slug={`news/${slug}/`} altSlug={altSlugValue} article={articleData} previewMode={previewMode} needsKatex={true}>
  <NewsprintShell
    locale="en"
    masthead={masthead}
    editionLabel={editionLabel}
    subkicker={['AI · Papers', 'Daily Curation', 'Open Access']}
    publishedAt={post?.published_at}
  >
    <form class="handbook-detail-search handbook-search-sticky handbook-search-sticky--detail" action="/en/news/" method="get">
      <input
        type="text"
        name="q"
        aria-label={t.en['news.search']}
        placeholder={t.en['news.search']}
        class="handbook-search-input"
      />
    </form>

    {postError ? (
      <NewsprintNotice
        variant="error"
        message={t.en['log.error']}
        linkHref="/en/news/"
        linkLabel={t.en['post.back']}
      />
    ) : !post ? (
      <NewsprintNotice
        variant="notfound"
        message={t.en['post.notfound']}
        linkHref="/en/news/"
        linkLabel={t.en['post.back']}
      />
    ) : (
      <NewsprintArticleLayout
        locale="en"
        slug={pageSlug}
        showSlug={false}
        title={post.title}
        excerpt={post.excerpt}
        category={post.category}
        publishedAt={post.published_at}
        readingTimeMin={post.reading_time_min}
        tags={post.tags}
        htmlContent={htmlContent}
        analysisHtml={analysisHtml}
        factPack={factPack}
        sourceCards={sourceCards}
        backLabel={t.en['post.back']}
        nextPost={nextPost}
        isBookmarked={isBookmarked}
        itemId={post.id}
        itemType="news"
        isAdmin={!!Astro.locals.isAdmin && !previewMode}
        isAuthenticated={!!user && !!accessToken}
        likeCount={likeCount}
        commentCount={commentCount}
        isLiked={isLiked}
        activePersona={activePersona}
        availablePersonas={availablePersonas}
        personaHtmlMap={personaHtmlMap}
        guideItems={post.guide_items}
        initialFindQuery={articleFindQuery}
        previewMode={previewMode}
        showStickyActions={false}
        postType={post.post_type}
      />
    )}

    {isWeekly && (weekTerms.length > 0 || weekTool?.name) && (
      <div class="weekly-bottom-cards">
        {weekTerms.length > 0 && (
          <div class="weekly-card">
            <h3 class="weekly-card-heading">Terms of the Week</h3>
            {weekTerms.map(t => (
              <a href={`/en/handbook/${t.slug}/`} class="weekly-card-link">
                <strong>{t.term}</strong> <span class="weekly-card-def">{t.definition}</span>
              </a>
            ))}
          </div>
        )}
        {weekTool?.name && (
          <div class="weekly-card">
            <h3 class="weekly-card-heading">Tool of the Week</h3>
            <a href={weekTool.url} target="_blank" rel="noopener" class="weekly-card-link">
              <strong>{weekTool.name}</strong> <span class="weekly-card-def">{weekTool.description}</span>
            </a>
          </div>
        )}
      </div>
    )}

    <Fragment slot="rail">
      <form class="handbook-detail-search newsprint-rail-search" action="/en/news/" method="get">
        <input
          type="text"
          name="q"
          aria-label={t.en['news.search']}
          placeholder={t.en['news.search']}
          class="handbook-search-input"
        />
      </form>
      <ReadingActionsRail
        className="newsprint-rail-stack"
        locale="en"
        variant="news"
        title={post?.title || pageTitle}
        shareUrl={`${import.meta.env.PUBLIC_SITE_URL || 'https://0to1log.com'}/en/news/${pageSlug}/`}
        itemId={post?.id}
        itemType="news"
        isBookmarked={isBookmarked}
        previewMode={previewMode}
        isAuthenticated={!!user && !!accessToken}
        articleRedirect={`/en/news/${pageSlug}/`}
        commentRedirect={`/en/news/${pageSlug}/#comments`}
        likeCount={likeCount}
        commentCount={commentCount}
        isLiked={isLiked}
      >
        <NewsprintSideRail locale="en" focusItems={focusItems} similarPosts={similarPosts} relatedTerms={relatedTerms} />
      </ReadingActionsRail>
    </Fragment>
  </NewsprintShell>
</MainLayout>

{hasTerms && (
  <script type="application/json" id="handbook-terms-data" set:html={JSON.stringify(handbookTermsJson)} />
)}

<script>
  import '../../../scripts/bookmark';
  import '../../../scripts/likes';
  import '../../../scripts/comments';
  import '../../../scripts/handbook-popup';
  import '../../../scripts/contentFeedback';

  function recordReadingHistory(): void {
    if (document.body.dataset.previewMode === 'true') return;
    const postId = document.querySelector('[data-item-id][data-item-type="news"]')?.getAttribute('data-item-id');
    if (!postId) return;
    fetch('/api/user/reading-history', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ item_type: 'news', item_id: postId }),
    }).catch(() => {});
  }

  function initAdminActions(): void {
    if (document.body.dataset.previewMode === 'true') return;
    const actions = document.querySelector('.newsprint-admin-actions') as HTMLElement | null;
    if (!actions) return;

    const btn = actions.querySelector('.newsprint-admin-action-btn--unpublish');
    btn?.addEventListener('click', async () => {
      if (!confirm('Unpublish this item?')) return;

      const id = actions.dataset.toolbarId;
      const api = actions.dataset.toolbarApi;
      if (!id || !api) return;

      try {
        const res = await fetch(api, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, action: 'unpublish' }),
        });

        if (res.ok) {
          const editLink = actions.querySelector('a') as HTMLAnchorElement | null;
          window.location.href = editLink?.href || '/admin';
        } else {
          const err = await res.json().catch(() => ({ error: 'Unknown error' }));
          alert(`Unpublish failed: ${err.error || err.detail}`);
        }
      } catch {
        alert('Unpublish failed: network error');
      }
    });
  }

  function syncSearchBarVisibility(): void {
    const articleFind = document.querySelector('.newsprint-article-find');
    const stickySearch = document.querySelector<HTMLElement>('.handbook-search-sticky');
    if (!articleFind || !stickySearch) return;

    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          stickySearch.setAttribute('data-hidden-by-find', '');
        } else {
          stickySearch.removeAttribute('data-hidden-by-find');
        }
      },
      { threshold: 0 }
    );
    observer.observe(articleFind);
  }

  function syncPersonaFromCookie(): void {
    const match = document.cookie.match(/(?:^|;\s*)persona=(\w+)/);
    if (!match) return;
    const preferred = match[1];
    const activeBtn = document.querySelector('.persona-switcher-btn--active') as HTMLElement | null;
    if (!activeBtn) return;
    const current = activeBtn.dataset.persona;
    if (current === preferred) return;
    const targetBtn = document.querySelector(`.persona-switcher-btn[data-persona="${preferred}"]`) as HTMLButtonElement | null;
    if (targetBtn) targetBtn.click();
  }

  document.addEventListener('astro:page-load', recordReadingHistory);
  document.addEventListener('astro:page-load', initAdminActions);
  document.addEventListener('astro:page-load', syncSearchBarVisibility);
  document.addEventListener('astro:page-load', syncPersonaFromCookie);
</script>
