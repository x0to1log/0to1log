---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import { t } from '../../../i18n/index';
import { supabase } from '../../../lib/supabase';
import { createClient } from '@supabase/supabase-js';
import { normalizeCategorySlug, getPostTypeLabel } from '../../../lib/categories';
import { resolveDisplayTitleExcerpt, getEffectivePersona } from '../../../lib/personaTitle';
import NewsprintShell from '../../../components/newsprint/NewsprintShell.astro';
import NewsprintHeadline from '../../../components/newsprint/NewsprintHeadline.astro';
import NewsprintListCard from '../../../components/newsprint/NewsprintListCard.astro';
import NewsprintListRail from '../../../components/newsprint/NewsprintListRail.astro';
import NewsprintCategoryFilter from '../../../components/newsprint/NewsprintCategoryFilter.astro';
import NewsprintNotice from '../../../components/newsprint/NewsprintNotice.astro';
import { getSiteContents, parseJsonArray } from '../../../lib/siteContent';

let posts: any[] = [];
let fetchError: string | null = null;
const readPostIds = new Set<string>();
const bookmarkedPostIds = new Set<string>();
const user = Astro.locals.user;
const accessToken = Astro.locals.accessToken;

const authSb = (user && accessToken)
  ? createClient(
      import.meta.env.PUBLIC_SUPABASE_URL,
      import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
      { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
    )
  : null;

// Parallel fetch: daily posts + weekly posts (separate queries so weekly always appears) + user data + site content
// Weekly is published ~1/week; daily is 2/day. Without a separate query, weekly
// gets pushed out of any single top-N window as posts accumulate.
const POSTS_FIELDS = 'id, title, slug, category, post_type, published_at, tags, reading_time_min, excerpt, guide_items';

const [dailyRes, weeklyRes, histRes, bmRes, sc] = await Promise.all([
  supabase
    ? supabase
        .from('news_posts')
        .select(POSTS_FIELDS)
        .eq('status', 'published')
        .eq('locale', 'en')
        .eq('category', 'ai-news')
        .in('post_type', ['business', 'research'])
        .order('published_at', { ascending: false })
        .limit(100)
    : Promise.resolve({ data: null, error: null }),
  supabase
    ? supabase
        .from('news_posts')
        .select(POSTS_FIELDS)
        .eq('status', 'published')
        .eq('locale', 'en')
        .eq('category', 'ai-news')
        .eq('post_type', 'weekly')
        .order('published_at', { ascending: false })
        .limit(20)
    : Promise.resolve({ data: null, error: null }),
  authSb
    ? authSb.from('reading_history').select('item_id').eq('user_id', user!.id).eq('item_type', 'news')
    : Promise.resolve({ data: null }),
  authSb
    ? authSb.from('user_bookmarks').select('item_id').eq('user_id', user!.id).eq('item_type', 'news')
    : Promise.resolve({ data: null }),
  getSiteContents(
    ['editorial_note', 'news_masthead', 'news_edition_label', 'news_subkicker', 'start_here_sections', 'volume_issue'],
    'en',
  ),
]);

if (dailyRes.error || weeklyRes.error) {
  const err = dailyRes.error || weeklyRes.error;
  console.error('[log-list-en] Supabase error:', err!.message);
  fetchError = err!.message;
} else {
  posts = [...(dailyRes.data ?? []), ...(weeklyRes.data ?? [])];
}
(histRes.data ?? []).forEach((r: any) => readPostIds.add(r.item_id));
(bmRes.data ?? []).forEach((r: any) => bookmarkedPostIds.add(r.item_id));

// Resolve persona-aware title/excerpt for each post (learner default for anonymous)
const persona = getEffectivePersona(Astro.locals.profile);
for (const p of posts) {
  const resolved = resolveDisplayTitleExcerpt(p, persona);
  p.display_title = resolved.title;
  p.display_excerpt = resolved.excerpt;
}

// Group by publication date, with in-day priority: weekly → business → research
const TYPE_ORDER: Record<string, number> = { weekly: 0, business: 1, research: 2 };
const dateKey = (p: any): string => (p?.published_at ?? '').slice(0, 10);
posts.sort((a, b) => {
  const d = dateKey(b).localeCompare(dateKey(a));
  if (d !== 0) return d;
  return (TYPE_ORDER[a.post_type] ?? 99) - (TYPE_ORDER[b.post_type] ?? 99);
});

const businessHeadline = posts.find(p => p.post_type === 'business') ?? null;
const researchHeadline = posts.find(p => p.post_type === 'research') ?? null;
const weeklyHeadline = posts.find(p => p.post_type === 'weekly') ?? null;

// Promote weekly to 'All' headline on days when a weekly was published
const latestDate = dateKey(posts[0]);
const latestDayHasWeekly = !!latestDate && posts.some(p => p.post_type === 'weekly' && dateKey(p) === latestDate);
const allHeadlineType: 'weekly' | 'business' = latestDayHasWeekly ? 'weekly' : 'business';
const allHeadline = allHeadlineType === 'weekly' ? weeklyHeadline : businessHeadline;

// Only exclude the "All" headline from grid. Other-type latest posts still appear as grid cards.
const rest = allHeadline ? posts.filter(p => p !== allHeadline) : posts;
const railPosts = rest.slice(0, 4);
const postTypeItems = [
  { value: 'business', label: getPostTypeLabel('en', 'business') },
  { value: 'research', label: getPostTypeLabel('en', 'research') },
  { value: 'weekly', label: 'Weekly' },
];
const subkicker = parseJsonArray<string>(sc.news_subkicker, ['AI · Papers', 'Daily Curation', 'Open Access']);
const startHereSections = parseJsonArray<{slug: string; label: string; description: string}>(sc.start_here_sections, []);
const searchPlaceholder = 'Search AI news';
const searchHints = [searchPlaceholder, 'OpenAI', 'Gemini', 'MCP'];
const searchEmptyMessage = 'No AI news matches that search.';
---

<MainLayout title={t.en['log.title']} description="Daily AI news curated for developers and product thinkers. Business and research perspectives with glossary-linked terms and quizzes." locale="en" slug="news/">
  <NewsprintShell
    locale="en"
    masthead={sc.news_masthead || 'Latest AI News'}
    editionLabel={sc.news_edition_label || 'Log Daily'}
    subkicker={subkicker}
    volumeLabel={sc.volume_issue || undefined}
  >
    <div class="handbook-search-sticky">
      <input
        type="search"
        id="news-search"
        aria-label={searchPlaceholder}
        placeholder={searchPlaceholder}
        data-placeholder-hints={JSON.stringify(searchHints)}
        class="handbook-search-input"
      />
    </div>

    <NewsprintCategoryFilter locale="en" items={postTypeItems} filterKey="post_type" />
    <div id="news-result-count" class="handbook-result-count" aria-live="polite" style="display: none;"></div>

    {fetchError ? (
      <NewsprintNotice
        variant="error"
        message={t.en['log.error']}
        linkHref="/en/news/"
        linkLabel={t.en['error.retry']}
      />
    ) : posts.length > 0 ? (
      <div id="news-list-results" data-multi-headline data-all-headline={allHeadlineType}>
        {businessHeadline && (
          <NewsprintHeadline
            href={`/en/news/${businessHeadline.slug}/`}
            title={businessHeadline.display_title || businessHeadline.title}
            excerpt={businessHeadline.display_excerpt || businessHeadline.excerpt}
            category={businessHeadline.category}
            publishedAt={businessHeadline.published_at}
            readingTimeMin={businessHeadline.reading_time_min}
            tags={businessHeadline.tags}
            locale="en"
            isBookmarked={bookmarkedPostIds.has(businessHeadline.id)}
            itemId={businessHeadline.id}
            itemType="news"
            postType={businessHeadline.post_type}
          />
        )}
        {researchHeadline && (
          <NewsprintHeadline
            href={`/en/news/${researchHeadline.slug}/`}
            title={researchHeadline.display_title || researchHeadline.title}
            excerpt={researchHeadline.display_excerpt || researchHeadline.excerpt}
            category={researchHeadline.category}
            publishedAt={researchHeadline.published_at}
            readingTimeMin={researchHeadline.reading_time_min}
            tags={researchHeadline.tags}
            locale="en"
            isBookmarked={bookmarkedPostIds.has(researchHeadline.id)}
            itemId={researchHeadline.id}
            itemType="news"
            postType={researchHeadline.post_type}
          />
        )}
        {weeklyHeadline && (
          <NewsprintHeadline
            href={`/en/news/${weeklyHeadline.slug}/`}
            title={weeklyHeadline.display_title || weeklyHeadline.title}
            excerpt={weeklyHeadline.display_excerpt || weeklyHeadline.excerpt}
            category={weeklyHeadline.category}
            publishedAt={weeklyHeadline.published_at}
            readingTimeMin={weeklyHeadline.reading_time_min}
            tags={weeklyHeadline.tags}
            locale="en"
            isBookmarked={bookmarkedPostIds.has(weeklyHeadline.id)}
            itemId={weeklyHeadline.id}
            itemType="news"
            postType={weeklyHeadline.post_type}
          />
        )}

        {rest.length > 0 && (
          <section class="newsprint-grid-cards">
            {rest.map((post) => (
              <NewsprintListCard
                href={`/en/news/${post.slug}/`}
                title={post.display_title || post.title}
                excerpt={post.display_excerpt || post.excerpt}
                category={post.category}
                publishedAt={post.published_at}
                readingTimeMin={post.reading_time_min}
                tags={post.tags}
                locale="en"
                isRead={readPostIds.has(post.id)}
                isBookmarked={bookmarkedPostIds.has(post.id)}
                itemId={post.id}
                itemType="news"
                postType={post.post_type}
              />
            ))}
          </section>
        )}
      </div>
    ) : (
      <NewsprintNotice variant="empty" message={t.en['log.empty']} />
    )}

    <div id="news-no-results" style="display: none;">
      <NewsprintNotice variant="empty" message={searchEmptyMessage} />
    </div>

    <Fragment slot="rail">
      <NewsprintListRail
        locale="en"
        posts={railPosts}
        editorialNote={sc.editorial_note || undefined}
        startHereSections={startHereSections.length > 0 ? startHereSections : undefined}
      />
    </Fragment>
  </NewsprintShell>
</MainLayout>

<script>
  import '../../../scripts/bookmark';
</script>

<script>
  import '../../../scripts/handbookSearchHints';
</script>

<script>
  import '../../../scripts/newsListSearch';
</script>

<script>
  import '../../../scripts/newsListMultiHeadline';
</script>
