---
export const prerender = false;

import MainLayout from '../../layouts/MainLayout.astro';
import { t } from '../../i18n/index';
import { getHomePageData } from '../../lib/pageData/homePage';
import HomeMasthead from '../../components/home/HomeMasthead.astro';
import HomeHeroCard from '../../components/home/HomeHeroCard.astro';
import HomeNewsCard from '../../components/home/HomeNewsCard.astro';
import HomeTermCard from '../../components/home/HomeTermCard.astro';
import HomeSectionHeader from '../../components/home/HomeSectionHeader.astro';
import BlogFeaturedCard from '../../components/blog/BlogFeaturedCard.astro';
import HomeProductCard from '../../components/home/HomeProductCard.astro';

const locale = 'en';
const { news, terms, blog, siteContent, featuredProducts } = await getHomePageData(locale);

const heroNews = news[0] ?? null;
const moreNews = news.slice(1, 4);
const featuredBlog = blog[0] ?? null;
const recentBlog = blog.slice(1, 4);

const homeTitle = siteContent.home_title || t.en['home.title'];
const homeIntro = siteContent.home_intro ||
  'An AI publication where readers can follow the latest shifts quickly, look up key terms instantly, build their own archive of news and concepts, and share their interpretations with others.';
---

<MainLayout title={homeTitle} locale={locale} headerAlwaysVisible={true}>
  <div class="home-page">

    <!-- Section A: Masthead -->
    <HomeMasthead locale={locale} />

    <!-- Hero Headline -->
    {heroNews ? (
      <HomeHeroCard
        href={`/en/news/${heroNews.slug}`}
        title={heroNews.title}
        excerpt={heroNews.excerpt}
        category="ai-news"
        publishedAt={heroNews.published_at}
        readingTimeMin={heroNews.reading_time_min}
        tags={heroNews.tags}
        locale={locale}
        postType={heroNews.post_type}
      />
    ) : (
      <p class="home-coming-soon">{t.en['home.comingSoon']}</p>
    )}

    <!-- Section B: Latest AI News -->
    {moreNews.length > 0 && (
      <section class="home-section">
        <HomeSectionHeader
          title={t.en['home.latestNews']}
          viewAllHref="/en/news/"
          viewAllLabel={t.en['home.viewAll']}
        />
        <div class="home-news-grid">
          {moreNews.map((post) => (
            <HomeNewsCard
              href={`/en/news/${post.slug}`}
              title={post.title}
              excerpt={post.excerpt}
              category="ai-news"
              publishedAt={post.published_at}
              readingTimeMin={post.reading_time_min}
              tags={post.tags}
              locale={locale}
              postType={post.post_type}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Section C: Glossary Spotlight -->
    {terms.length > 0 && (
      <section class="home-section">
        <HomeSectionHeader
          title={t.en['home.glossarySpotlight']}
          viewAllHref="/en/handbook/"
          viewAllLabel={t.en['home.viewAll']}
        />
        <div class="home-term-grid">
          {terms.map((term) => (
            <HomeTermCard
              href={`/en/handbook/${term.slug}`}
              term={term.term}
              koreanName={term.korean_name}
              definition={term.definition_en}
              categories={term.categories}
              locale={locale}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Section D: From the Blog -->
    {(featuredBlog || recentBlog.length > 0) && (
      <section class="home-section">
        <HomeSectionHeader
          title={t.en['home.fromBlog']}
          viewAllHref="/en/blog/"
          viewAllLabel={t.en['home.viewAll']}
        />
        <div class="home-blog-split">
          {featuredBlog && (
            <BlogFeaturedCard
              href={`/en/blog/${featuredBlog.slug}`}
              title={featuredBlog.title}
              excerpt={featuredBlog.excerpt}
              category={featuredBlog.category}
              tags={featuredBlog.tags}
              locale={locale}
            />
          )}
          {recentBlog.length > 0 && (
            <nav class="home-blog-list" aria-label="Recent blog posts">
              {recentBlog.map((post) => {
                const dateLabel = post.published_at
                  ? new Date(post.published_at).toLocaleDateString('en-US')
                  : null;
                return (
                  <a href={`/en/blog/${post.slug}`} class="home-blog-list-item">
                    <h3 class="home-blog-list-item-title">{post.title}</h3>
                    {dateLabel && <time class="home-blog-list-item-meta" datetime={post.published_at ?? undefined}>{dateLabel}</time>}
                  </a>
                );
              })}
            </nav>
          )}
        </div>
      </section>
    )}

    <!-- Section E: Featured AI Products -->
    {featuredProducts.length > 0 && (
      <section class="home-section">
        <HomeSectionHeader
          title={t.en['home.featuredProducts']}
          viewAllHref="/en/products/"
          viewAllLabel={t.en['home.viewAll']}
        />
        <div class="home-product-grid">
          {featuredProducts.map((product) => (
            <HomeProductCard
              href={`/en/products/${product.slug}/`}
              name={product.name}
              tagline={product.tagline}
              logoUrl={product.logo_url}
              pricing={product.pricing}
              locale={locale}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Section F: Start Here -->
    <section class="home-section home-start-here">
      <h2 class="home-start-here-title">Start Here</h2>
      <div class="home-start-here-grid">
        <a href="/en/news/" class="home-start-here-card">
          <strong>AI News</strong>
          <p>Read the most important AI shifts first.</p>
        </a>
        <a href="/en/handbook/" class="home-start-here-card">
          <strong>AI Glossary</strong>
          <p>Look up unfamiliar terms without leaving the flow.</p>
        </a>
        <a href="/en/products/" class="home-start-here-card">
          <strong>AI Products</strong>
          <p>Explore AI tools you can put to work right away.</p>
        </a>
        <a href="/library/" class="home-start-here-card">
          <strong>My Library</strong>
          <p>Keep the news and terms that stay with you.</p>
        </a>
        <a href="/en/blog/" class="home-start-here-card">
          <strong>IT Blog</strong>
          <p>Explore the builds, reflections, and technical work behind the product.</p>
        </a>
      </div>
    </section>

  </div>
</MainLayout>
