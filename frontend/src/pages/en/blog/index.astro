---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import { t } from '../../../i18n/index';
import { supabase } from '../../../lib/supabase';
import { createClient } from '@supabase/supabase-js';
import { buildBlogSidebarDataset, toSidebarPost } from '../../../lib/pageData/blogSidebar';
import { fetchCategories } from '../../../lib/pageData/blogCategories';
import BlogShell from '../../../components/blog/BlogShell.astro';
import BlogFeaturedCard from '../../../components/blog/BlogFeaturedCard.astro';
import BlogListItem from '../../../components/blog/BlogListItem.astro';
import NewsprintNotice from '../../../components/newsprint/NewsprintNotice.astro';

let posts: any[] = [];
let fetchError: string | null = null;
const readPostIds = new Set<string>();
const bookmarkedPostIds = new Set<string>();
const user = Astro.locals.user;
const accessToken = Astro.locals.accessToken;

// Parallel: posts + user data + categories (no dependencies between them)
const authSb = (user && accessToken) ? createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
) : null;

const [postsRes, histRes, bmRes, dbCategories] = await Promise.all([
  supabase
    ? supabase.from('blog_posts')
        .select('id, title, slug, category, published_at, tags, reading_time_min, excerpt')
        .eq('status', 'published')
        .eq('locale', 'en')
        .order('created_at', { ascending: false })
        .limit(100)
    : Promise.resolve({ data: null, error: null }),
  authSb
    ? authSb.from('reading_history').select('item_id').eq('user_id', user?.id).eq('item_type', 'blog')
    : Promise.resolve({ data: null }),
  authSb
    ? authSb.from('user_bookmarks').select('item_id').eq('user_id', user?.id).eq('item_type', 'blog')
    : Promise.resolve({ data: null }),
  supabase ? fetchCategories(supabase) : Promise.resolve([]),
]);

if (postsRes.error) {
  console.error('[blog-list-en] Supabase error:', postsRes.error.message);
  fetchError = postsRes.error.message;
} else {
  posts = postsRes.data ?? [];
}
(histRes.data ?? []).forEach((r: any) => readPostIds.add(r.item_id));
(bmRes.data ?? []).forEach((r: any) => bookmarkedPostIds.add(r.item_id));

const FEATURED_COUNT = 4;
const BATCH_SIZE = 10;

const CATEGORY_ICONS: Record<string, string> = {
  study: '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>',
  project: '<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>',
  career: '<rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>',
  'work-note': '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/>',
  daily: '<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>',
};
const visibleCategories = dbCategories.filter(c => c.is_visible);
const postCountByCategory = posts.reduce((acc, p) => {
  acc[p.category] = (acc[p.category] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

const featuredPosts = posts.slice(0, FEATURED_COUNT);
const sidebarPosts = buildBlogSidebarDataset(
  posts.map((post) =>
    toSidebarPost({
      title: post.title,
      slug: post.slug,
      category: post.category,
      published_at: post.published_at,
    }),
  ),
);

// Split ALL posts into batches for infinite scroll in "All Posts" section
const allPostBatches: any[][] = [];
for (let i = 0; i < posts.length; i += BATCH_SIZE) {
  allPostBatches.push(posts.slice(i, i + BATCH_SIZE));
}
---

<MainLayout title={t.en['blog.title']} locale="en" slug="blog/">
  <BlogShell locale="en" sidebarPosts={sidebarPosts} totalCount={posts.length} mode="index">
    <!-- Mobile toggle button -->
    <div class="blog-mobile-toolbar">
      <button class="blog-mobile-toggle" data-sidebar-toggle aria-label="Menu">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 5h14M3 10h14M3 15h14" />
        </svg>
      </button>
    </div>

    <!-- Masthead -->
    <h1 class="blog-masthead-title">–도록: do log</h1>

    {visibleCategories.length > 0 && (
      <section class="blog-category-showcase">
        <div class="blog-category-showcase-grid">
          {visibleCategories.map(cat => {
            const count = postCountByCategory[cat.slug] || 0;
            const iconSvg = CATEGORY_ICONS[cat.slug] || '';
            return (
              <a href={`/en/blog/category/${cat.slug}/`} class="blog-category-showcase-card" style={`--cat-color: ${cat.color}`}>
                <div class="blog-category-showcase-header">
                  {iconSvg && (
                    <svg class="blog-category-showcase-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
                         set:html={iconSvg} />
                  )}
                  <strong class="blog-category-showcase-name">{cat.label_en}</strong>
                  <span class="blog-category-showcase-count">({count})</span>
                </div>
                {cat.description_en && <p class="blog-category-showcase-desc">{cat.description_en}</p>}
              </a>
            );
          })}
        </div>
      </section>
    )}

    {fetchError ? (
      <NewsprintNotice variant="error" message={t.en['blog.error']} linkHref="/en/blog/" linkLabel={t.en['error.retry']} />
    ) : posts.length > 0 ? (
      <>
        <!-- FEATURED section -->
        {featuredPosts.length > 0 && (
          <>
            <h2 class="blog-section-header">{t.en['blog.featured']}</h2>
            <div class="blog-featured-grid">
              {featuredPosts.map(post => (
                <BlogFeaturedCard
                  href={`/en/blog/${post.slug}/`}
                  title={post.title}
                  excerpt={post.excerpt}
                  category={post.category}
                  readingTimeMin={post.reading_time_min}
                  tags={post.tags}
                  locale="en"
                  isBookmarked={bookmarkedPostIds.has(post.id)}
                  itemId={post.id}
                  itemType="blog"
                  categories={dbCategories}
                />
              ))}
            </div>
          </>
        )}

        <!-- ALL POSTS section with infinite scroll -->
        <h2 class="blog-section-header">{t.en['blog.allPosts']}</h2>
        <div class="blog-list-section" data-blog-list>
          {allPostBatches.map((batch, batchIdx) => (
            <div
              class="blog-list-batch"
              data-blog-batch={batchIdx}
              {...(batchIdx > 0 && { hidden: true })}
            >
              {batch.map(post => (
                <BlogListItem
                  href={`/en/blog/${post.slug}/`}
                  title={post.title}
                  category={post.category}
                  publishedAt={post.published_at}
                  readingTimeMin={post.reading_time_min}
                  locale="en"
                  isRead={readPostIds.has(post.id)}
                  isBookmarked={bookmarkedPostIds.has(post.id)}
                  itemId={post.id}
                  itemType="blog"
                  categories={dbCategories}
                />
              ))}
            </div>
          ))}
        </div>
        {allPostBatches.length > 1 && (
          <div class="blog-scroll-sentinel" data-blog-sentinel></div>
        )}
      </>
    ) : (
      <div class="blog-empty-state">
        <div class="blog-empty-icon">📝</div>
        <h2>Coming Soon</h2>
        <p>Posts are being prepared. Check back soon!</p>
      </div>
    )}
  </BlogShell>
</MainLayout>

<script>
  import '../../../scripts/bookmark';

  // Mobile sidebar toggle
  // Infinite scroll — reveal next hidden batch when sentinel enters viewport
  function initInfiniteScroll() {
    const sentinel = document.querySelector('[data-blog-sentinel]');
    if (!sentinel) return;

    let currentBatch = 0;

    const observer = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;

        currentBatch++;
        const next = document.querySelector(`[data-blog-batch="${currentBatch}"]`) as HTMLElement | null;
        if (next) {
          next.hidden = false;
        }

        // Check if there are more batches
        const afterNext = document.querySelector(`[data-blog-batch="${currentBatch + 1}"]`);
        if (!afterNext) {
          observer.disconnect();
          sentinel.remove();
        }
      }
    }, { rootMargin: '200px' });

    observer.observe(sentinel);
  }

  document.addEventListener('DOMContentLoaded', () => {
    initInfiniteScroll();
  });
  initInfiniteScroll();
</script>
