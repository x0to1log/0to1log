---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import { t } from '../../../i18n/index';
import { supabase } from '../../../lib/supabase';
import { createClient } from '@supabase/supabase-js';
import { BLOG_CATEGORIES } from '../../../lib/categories';
import BlogShell from '../../../components/blog/BlogShell.astro';
import BlogFeaturedCard from '../../../components/blog/BlogFeaturedCard.astro';
import BlogListItem from '../../../components/blog/BlogListItem.astro';
import NewsprintCategoryFilter from '../../../components/newsprint/NewsprintCategoryFilter.astro';
import NewsprintNotice from '../../../components/newsprint/NewsprintNotice.astro';

let posts: any[] = [];
let fetchError: string | null = null;

if (supabase) {
  const { data, error } = await supabase
    .from('blog_posts')
    .select('id, title, slug, category, published_at, tags, reading_time_min, og_image_url, excerpt')
    .eq('status', 'published')
    .eq('locale', 'en')
    .in('category', BLOG_CATEGORIES)
    .order('created_at', { ascending: false });

  if (error) {
    console.error('[blog-list-en] Supabase error:', error.message);
    fetchError = error.message;
  } else {
    posts = data ?? [];
  }
}

// User reading history & bookmarks
const readPostIds = new Set<string>();
const bookmarkedPostIds = new Set<string>();
const user = Astro.locals.user;
const accessToken = Astro.locals.accessToken;
if (user && accessToken) {
  const authSb = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
    { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
  );
  const [histRes, bmRes] = await Promise.all([
    authSb.from('reading_history').select('item_id').eq('user_id', user.id).eq('item_type', 'blog'),
    authSb.from('user_bookmarks').select('item_id').eq('user_id', user.id).eq('item_type', 'blog'),
  ]);
  (histRes.data ?? []).forEach((r: any) => readPostIds.add(r.item_id));
  (bmRes.data ?? []).forEach((r: any) => bookmarkedPostIds.add(r.item_id));
}

const featuredPosts = posts.slice(0, 3);
const remainingPosts = posts.slice(3);
const sidebarPosts = posts.map(p => ({ title: p.title, slug: p.slug, category: p.category }));
---

<MainLayout title={t.en['blog.title']} locale="en" slug="blog/">
  <BlogShell locale="en" sidebarPosts={sidebarPosts} totalCount={posts.length}>
    <!-- Mobile toggle button -->
    <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
      <button class="blog-mobile-toggle" data-sidebar-toggle aria-label="Menu">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 5h14M3 10h14M3 15h14" />
        </svg>
      </button>
    </div>

    <!-- Masthead -->
    <div class="blog-masthead-section">
      <div class="blog-masthead-kicker">
        <span>Study · Career · Projects</span>
      </div>
      <h1 class="blog-masthead-title">IT Blog</h1>
      <div class="blog-masthead-subkicker">
        <span>Builder's Notes</span>
        <span>Personal Blog</span>
        <span>Open Access</span>
      </div>
    </div>

    <!-- Category filter tabs -->
    <NewsprintCategoryFilter locale="en" categories={BLOG_CATEGORIES} />

    {fetchError ? (
      <NewsprintNotice variant="error" message={t.en['blog.error']} linkHref="/en/blog/" linkLabel={t.en['error.retry']} />
    ) : posts.length > 0 ? (
      <>
        <!-- FEATURED section -->
        {featuredPosts.length > 0 && (
          <>
            <h2 class="blog-section-header">{t.en['blog.featured']}</h2>
            <div class="blog-featured-grid">
              {featuredPosts.map(post => (
                <BlogFeaturedCard
                  href={`/en/blog/${post.slug}/`}
                  title={post.title}
                  excerpt={post.excerpt}
                  category={post.category}
                  tags={post.tags}
                  locale="en"
                />
              ))}
            </div>
          </>
        )}

        <!-- ALL POSTS section -->
        {remainingPosts.length > 0 && (
          <>
            <h2 class="blog-section-header">{t.en['blog.allPosts']}</h2>
            <div class="blog-list-section">
              {remainingPosts.map(post => (
                <BlogListItem
                  href={`/en/blog/${post.slug}/`}
                  title={post.title}
                  category={post.category}
                  publishedAt={post.published_at}
                  locale="en"
                  isRead={readPostIds.has(post.id)}
                />
              ))}
            </div>
          </>
        )}
      </>
    ) : (
      <NewsprintNotice variant="empty" message={t.en['blog.empty']} />
    )}
  </BlogShell>
</MainLayout>

<script>
  import '../../../scripts/bookmark';

  // Mobile sidebar toggle
  function initBlogMobileToggle() {
    const toggleBtn = document.querySelector('[data-sidebar-toggle]');
    const sidebar = document.querySelector('.blog-sidebar');
    const overlay = document.querySelector('[data-sidebar-overlay]');
    if (!toggleBtn || !sidebar) return;

    toggleBtn.addEventListener('click', () => {
      sidebar.classList.add('blog-sidebar--open');
      overlay?.classList.add('blog-sidebar-overlay--open');
    });
  }
  document.addEventListener('DOMContentLoaded', initBlogMobileToggle);
  initBlogMobileToggle();
</script>
