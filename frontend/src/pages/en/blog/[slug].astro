---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import { t } from '../../../i18n/index';
import { supabase } from '../../../lib/supabase';
import { createClient } from '@supabase/supabase-js';
import { normalizeCategorySlug, BLOG_CATEGORIES } from '../../../lib/categories';
import { renderMarkdown, renderMarkdownWithTerms, type TermsMap } from '../../../lib/markdown';
import NewsprintNotice from '../../../components/newsprint/NewsprintNotice.astro';
import BlogShell from '../../../components/blog/BlogShell.astro';
import BlogArticleLayout from '../../../components/blog/BlogArticleLayout.astro';
import BlogTOC from '../../../components/blog/BlogTOC.astro';

const { slug } = Astro.params;
const pageSlug = slug ?? '';

let post = null;
let postError: string | null = null;

if (supabase && slug) {
  const { data, error } = await supabase
    .from('blog_posts')
    .select('*')
    .eq('slug', pageSlug)
    .eq('status', 'published')
    .eq('locale', 'en')
    .in('category', BLOG_CATEGORIES)
    .single();

  if (error && error.code !== 'PGRST116') {
    console.error('[blog-detail-en] Supabase error:', error.message);
    postError = error.message;
  } else {
    post = data;
  }
}

if (!post && !postError) {
  Astro.response.status = 404;
}

const masthead = 'IT Blog';
const editionMap: Record<string, string> = {
  study: 'Study Notes',
  career: 'Career Notes',
  project: 'Build Log',
};
const editionLabel = post ? (editionMap[normalizeCategorySlug(post.category) || ''] || 'Deep Dive') : 'Deep Dive';

let recentPosts: any[] = [];
let articleData: any = undefined;
let nextPost: { title: string; slug: string; category: string | null } | null = null;
let pairedSlug: string | null = null;
let isBookmarked = false;
let isLiked = false;
let likeCount = 0;
let commentCount = 0;
let handbookTermsMap: TermsMap = new Map();
let handbookTermsJson: Record<string, any> = {};

const user = Astro.locals.user;
const accessToken = Astro.locals.accessToken;

if (post && supabase) {
  const authSb = (user && accessToken) ? createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
    { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
  ) : null;

  const [
    recentRes,
    nextRes,
    pairedRes,
    likeCountRes,
    commentCountRes,
    bookmarkRes,
    likeRes,
    hbTermsRes,
  ] = await Promise.all([
    // recentPosts
    supabase
      .from('blog_posts')
      .select('title, slug, category')
      .eq('status', 'published')
      .eq('locale', 'en')
      .in('category', BLOG_CATEGORIES)
      .neq('slug', pageSlug)
      .order('published_at', { ascending: false })
      .limit(4),
    // nextPost
    post.published_at
      ? supabase
          .from('blog_posts')
          .select('title, slug, category')
          .eq('status', 'published')
          .eq('locale', 'en')
          .in('category', BLOG_CATEGORIES)
          .lt('published_at', post.published_at)
          .order('published_at', { ascending: false })
          .limit(1)
          .single()
      : Promise.resolve({ data: null }),
    // pairedSlug
    post.translation_group_id
      ? supabase
          .from('blog_posts')
          .select('slug')
          .eq('translation_group_id', post.translation_group_id)
          .eq('locale', 'ko')
          .eq('status', 'published')
          .single()
      : Promise.resolve({ data: null }),
    // likeCount
    supabase
      .from('blog_likes')
      .select('id', { count: 'exact', head: true })
      .eq('post_id', post.id),
    // commentCount
    supabase
      .from('blog_comments')
      .select('id', { count: 'exact', head: true })
      .eq('post_id', post.id),
    // isBookmarked
    authSb
      ? authSb
          .from('user_bookmarks')
          .select('id')
          .eq('user_id', user.id)
          .eq('item_type', 'blog')
          .eq('item_id', post.id)
          .maybeSingle()
      : Promise.resolve({ data: null }),
    // isLiked
    authSb
      ? authSb
          .from('blog_likes')
          .select('id')
          .eq('user_id', user.id)
          .eq('post_id', post.id)
          .maybeSingle()
      : Promise.resolve({ data: null }),
    // handbookTerms
    supabase
      .from('handbook_terms')
      .select('term, slug, korean_name, categories, definition_en')
      .eq('status', 'published'),
  ]);

  recentPosts = recentRes.data ?? [];
  nextPost = nextRes.data;
  pairedSlug = pairedRes.data?.slug ?? null;
  likeCount = likeCountRes.count ?? 0;
  commentCount = commentCountRes.count ?? 0;
  isBookmarked = !!bookmarkRes.data;
  isLiked = !!likeRes.data;

  const hbTerms = hbTermsRes.data;
  if (hbTerms && hbTerms.length > 0) {
    for (const t of hbTerms) {
      const entry = { slug: t.slug, term: t.term };
      handbookTermsMap.set(t.term.toLowerCase(), entry);
      if (t.korean_name) handbookTermsMap.set(t.korean_name.toLowerCase(), entry);
      handbookTermsJson[t.slug] = {
        term: t.term,
        korean_name: t.korean_name || '',
        categories: t.categories || [],
        definition: t.definition_en || '',
      };
    }
  }

  articleData = post.published_at
    ? { datePublished: post.published_at, dateModified: post.updated_at || post.published_at, image: post.og_image_url }
    : undefined;
}

const pageTitle = post ? post.title : 'Not Found';

const hasTerms = handbookTermsMap.size > 0;
const renderMd = hasTerms
  ? (md: string) => renderMarkdownWithTerms(md, handbookTermsMap)
  : (md: string) => renderMarkdown(md);

const rawContent = post ? (post.content || '') : '';
const htmlContent = rawContent ? await renderMd(rawContent) : '';

const altSlugValue = pairedSlug ? `/ko/blog/${pairedSlug}/` : undefined;

const sidebarPosts = recentPosts.map(p => ({ title: p.title, slug: p.slug, category: p.category }));
---

<MainLayout title={pageTitle} locale="en" slug={`blog/${slug}/`} altSlug={pairedSlug ?? undefined} article={articleData}>
  <BlogShell locale="en" sidebarPosts={sidebarPosts} currentSlug={pageSlug} totalCount={sidebarPosts.length} showTOC={!!post}>
    <!-- Mobile toggle -->
    <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
      <button class="blog-mobile-toggle" data-sidebar-toggle aria-label="Menu">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 5h14M3 10h14M3 15h14" />
        </svg>
      </button>
    </div>

    {postError ? (
      <NewsprintNotice
        variant="error"
        message={t.en['blog.error']}
        linkHref="/en/blog/"
        linkLabel={t.en['blog.back']}
      />
    ) : !post ? (
      <NewsprintNotice
        variant="notfound"
        message={t.en['post.notfound']}
        linkHref="/en/blog/"
        linkLabel={t.en['blog.back']}
      />
    ) : (
      <BlogArticleLayout
        locale="en"
        slug={pageSlug}
        title={post.title}
        excerpt={post.excerpt}
        category={post.category}
        publishedAt={post.published_at}
        readingTimeMin={post.reading_time_min}
        tags={post.tags}
        htmlContent={htmlContent}
        backLabel={t.en['blog.back']}
        nextPost={nextPost}
        basePath="/en/blog"
        isBookmarked={isBookmarked}
        itemId={post.id}
        itemType="blog"
        isAdmin={!!Astro.locals.isAdmin}
        likeCount={likeCount}
        commentCount={commentCount}
        isLiked={isLiked}
      />
    )}

    <Fragment slot="toc">
      <BlogTOC locale="en" />
    </Fragment>
  </BlogShell>
</MainLayout>

{hasTerms && (
  <script type="application/json" id="handbook-terms-data" set:html={JSON.stringify(handbookTermsJson)} />
)}

<script>
  import '../../../scripts/bookmark';
  import '../../../scripts/likes';
  import '../../../scripts/comments';
  import '../../../scripts/handbook-popup';

  function recordReadingHistory(): void {
    const postId = document.querySelector('[data-item-id][data-item-type="blog"]')?.getAttribute('data-item-id');
    if (!postId) return;
    fetch('/api/user/reading-history', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ item_type: 'blog', item_id: postId }),
    }).catch(() => {});
  }

  function initAdminActions(): void {
    const actions = document.querySelector('.newsprint-admin-actions') as HTMLElement | null;
    if (!actions) return;

    const btn = actions.querySelector('.newsprint-admin-action-btn--unpublish');
    btn?.addEventListener('click', async () => {
      if (!confirm('Unpublish this item?')) return;

      const id = actions.dataset.toolbarId;
      const api = actions.dataset.toolbarApi;
      if (!id || !api) return;

      try {
        const res = await fetch(api, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, action: 'unpublish' }),
        });

        if (res.ok) {
          const editLink = actions.querySelector('a') as HTMLAnchorElement | null;
          window.location.href = editLink?.href || '/admin';
        } else {
          const err = await res.json().catch(() => ({ error: 'Unknown error' }));
          alert(`Unpublish failed: ${err.error || err.detail}`);
        }
      } catch {
        alert('Unpublish failed: network error');
      }
    });
  }

  function initBlogMobileToggle() {
    const toggleBtn = document.querySelector('[data-sidebar-toggle]');
    const sidebar = document.querySelector('.blog-sidebar');
    const overlay = document.querySelector('[data-sidebar-overlay]');
    if (!toggleBtn || !sidebar) return;
    toggleBtn.addEventListener('click', () => {
      sidebar.classList.add('blog-sidebar--open');
      overlay?.classList.add('blog-sidebar-overlay--open');
    });
  }

  document.addEventListener('astro:page-load', recordReadingHistory);
  document.addEventListener('astro:page-load', initAdminActions);
  document.addEventListener('DOMContentLoaded', initBlogMobileToggle);
  initBlogMobileToggle();
</script>
