---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import { t } from '../../../i18n/index';
import { getBlogDetailPageData } from '../../../lib/pageData/blogDetailPage';
import NewsprintNotice from '../../../components/newsprint/NewsprintNotice.astro';
import BlogShell from '../../../components/blog/BlogShell.astro';
import BlogArticleLayout from '../../../components/blog/BlogArticleLayout.astro';
import BlogTOC from '../../../components/blog/BlogTOC.astro';
import ReadingActionsRail from '../../../components/common/ReadingActionsRail.astro';

const { slug } = Astro.params;
const pageSlug = slug ?? '';
const previewRequested = Astro.url.searchParams.get('preview') === '1';
const previewMode = previewRequested && !!Astro.locals.isAdmin;
const {
  post,
  postError,
  articleData,
  nextPost,
  pairedSlug,
  isBookmarked,
  isLiked,
  likeCount,
  commentCount,
  handbookTermsJson,
  hasTerms,
  htmlContent,
  sidebarPosts,
} = await getBlogDetailPageData({
  locale: 'en',
  slug: pageSlug,
  previewMode,
  locals: Astro.locals,
 });

if (!post && !postError) {
  Astro.response.status = 404;
}

const masthead = 'IT Blog';
const editionMap: Record<string, string> = {
  study: 'Study Notes',
  career: 'Career Notes',
  project: 'Build Log',
};
const editionLabel = post ? (editionMap[normalizeCategorySlug(post.category) || ''] || 'Deep Dive') : 'Deep Dive';

const user = Astro.locals.user;
const accessToken = Astro.locals.accessToken;

const pageTitle = post ? post.title : 'Not Found';
const altSlugValue = pairedSlug
  ? `/ko/blog/${pairedSlug}/${previewMode ? '?preview=1' : ''}`
  : undefined;
---

<MainLayout title={pageTitle} locale="en" slug={`blog/${slug}/`} altSlug={altSlugValue} article={articleData} previewMode={previewMode}>
  <BlogShell
    locale="en"
    sidebarPosts={sidebarPosts}
    currentSlug={pageSlug}
    currentCategory={post?.category}
    totalCount={sidebarPosts.length}
    mode="detail"
    showTOC={!!post}
  >
    <!-- Mobile toggle -->
    <div class="blog-mobile-toolbar">
      <button class="blog-mobile-toggle" data-sidebar-toggle aria-label="Menu">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 5h14M3 10h14M3 15h14" />
        </svg>
      </button>
    </div>

    {postError ? (
      <NewsprintNotice
        variant="error"
        message={t.en['blog.error']}
        linkHref="/en/blog/"
        linkLabel={t.en['blog.back']}
      />
    ) : !post ? (
      <NewsprintNotice
        variant="notfound"
        message={t.en['post.notfound']}
        linkHref="/en/blog/"
        linkLabel={t.en['blog.back']}
      />
    ) : (
      <BlogArticleLayout
        locale="en"
        slug={pageSlug}
        title={post.title}
        excerpt={post.excerpt}
        category={post.category}
        publishedAt={post.published_at}
        readingTimeMin={post.reading_time_min}
        tags={post.tags}
        htmlContent={htmlContent}
        backLabel={t.en['blog.back']}
        nextPost={nextPost}
        basePath="/en/blog"
        isBookmarked={isBookmarked}
        itemId={post.id}
        itemType="blog"
        isAdmin={!!Astro.locals.isAdmin && !previewMode}
        isAuthenticated={!!user && !!accessToken}
        likeCount={likeCount}
        commentCount={commentCount}
        isLiked={isLiked}
        previewMode={previewMode}
        showStickyActions={false}
      />
    )}

    <Fragment slot="toc">
      <ReadingActionsRail
        className="blog-rail"
        contentClassName="blog-rail__content"
        locale="en"
        variant="blog"
        title={post?.title || pageTitle}
        shareUrl={`${import.meta.env.PUBLIC_SITE_URL || 'https://0to1log.com'}/en/blog/${pageSlug}/`}
        itemId={post?.id}
        itemType="blog"
        isBookmarked={isBookmarked}
        previewMode={previewMode}
        isAuthenticated={!!user && !!accessToken}
        articleRedirect={`/en/blog/${pageSlug}/`}
        commentRedirect={`/en/blog/${pageSlug}/#comments`}
        likeCount={likeCount}
        commentCount={commentCount}
        isLiked={isLiked}
      >
        <BlogTOC locale="en" />
      </ReadingActionsRail>
    </Fragment>
  </BlogShell>
</MainLayout>

{hasTerms && (
  <script type="application/json" id="handbook-terms-data" set:html={JSON.stringify(handbookTermsJson)} />
)}

<script>
  import '../../../scripts/bookmark';
  import '../../../scripts/likes';
  import '../../../scripts/comments';
  import '../../../scripts/handbook-popup';

  function recordReadingHistory(): void {
    if (document.body.dataset.previewMode === 'true') return;
    const postId = document.querySelector('[data-item-id][data-item-type="blog"]')?.getAttribute('data-item-id');
    if (!postId) return;
    fetch('/api/user/reading-history', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ item_type: 'blog', item_id: postId }),
    }).catch(() => {});
  }

  function initAdminActions(): void {
    if (document.body.dataset.previewMode === 'true') return;
    const actions = document.querySelector('.newsprint-admin-actions') as HTMLElement | null;
    if (!actions) return;

    const btn = actions.querySelector('.newsprint-admin-action-btn--unpublish');
    btn?.addEventListener('click', async () => {
      if (!confirm('Unpublish this item?')) return;

      const id = actions.dataset.toolbarId;
      const api = actions.dataset.toolbarApi;
      if (!id || !api) return;

      try {
        const res = await fetch(api, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, action: 'unpublish' }),
        });

        if (res.ok) {
          const editLink = actions.querySelector('a') as HTMLAnchorElement | null;
          window.location.href = editLink?.href || '/admin';
        } else {
          const err = await res.json().catch(() => ({ error: 'Unknown error' }));
          alert(`Unpublish failed: ${err.error || err.detail}`);
        }
      } catch {
        alert('Unpublish failed: network error');
      }
    });
  }

  document.addEventListener('astro:page-load', recordReadingHistory);
  document.addEventListener('astro:page-load', initAdminActions);
</script>
