---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import { t } from '../../../i18n/index';
import { createClient } from '@supabase/supabase-js';
import { getHandbookCategoryLabel, getHandbookCategories, getHandbookCategoryDescription } from '../../../lib/handbookCategories';
import { getHandbookCategoryIcon } from '../../../lib/handbookCategoryIcons';
import { localField } from '../../../lib/handbookUtils';
import NewsprintShell from '../../../components/newsprint/NewsprintShell.astro';
import NewsprintNotice from '../../../components/newsprint/NewsprintNotice.astro';
import HandbookListRail from '../../../components/newsprint/HandbookListRail.astro';
import { getSiteContents, parseJsonArray } from '../../../lib/siteContent';
import { getHandbookPageData } from '../../../lib/pageData/handbookPage';
import { supabase } from '../../../lib/supabase';

const locale = 'en';
const PREVIEW_COUNT = 4;

const { allTerms, termsByCategory, totalTerms, error: fetchError } = await getHandbookPageData(locale);

const handbookTags: Record<string, string> = {
  'ai-ml': 'ChatGPT · Deep Learning · Neural Net · Prompt',
  'db-data': 'SQL · NoSQL · Redis · Vector DB',
  backend: 'API · Server · REST · Microservices',
  'frontend-ux': 'React · CSS · Responsive · Dark Mode',
  network: 'HTTP · DNS · CDN · Load Balancing',
  security: 'Login · Encryption · Token · Firewall',
  'os-core': 'CPU · Memory · Process · Linux',
  devops: 'Docker · CI/CD · Deploy · Monitoring',
  performance: 'Cache · Speed · Optimization · Cost',
  web3: 'Blockchain · NFT · Smart Contract · Wallet',
  'ai-business': 'AI Trends · Automation · Startup · Investment',
};

// User reading history & bookmarks
const readTermIds = new Set<string>();
const bookmarkedTermIds = new Set<string>();
const user = Astro.locals.user;
const accessToken = Astro.locals.accessToken;
if (user && accessToken) {
  const authSb = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
    { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
  );
  const [histRes, bmRes] = await Promise.all([
    authSb.from('reading_history').select('item_id').eq('user_id', user.id).eq('item_type', 'term'),
    authSb.from('user_bookmarks').select('item_id').eq('user_id', user.id).eq('item_type', 'term'),
  ]);
  (histRes.data ?? []).forEach((r: any) => readTermIds.add(r.item_id));
  (bmRes.data ?? []).forEach((r: any) => bookmarkedTermIds.add(r.item_id));
}

// Popular terms (view_count based, fallback to latest published)
let popularTerms: any[] = [];
if (supabase) {
  const { data } = await supabase
    .from('handbook_terms')
    .select('term, slug, view_count')
    .eq('status', 'published')
    .order('view_count', { ascending: false })
    .limit(10);
  popularTerms = data ?? [];
}
if (popularTerms.length === 0 || popularTerms.every((t: any) => !t.view_count)) {
  if (supabase) {
    const { data } = await supabase
      .from('handbook_terms')
      .select('term, slug')
      .eq('status', 'published')
      .order('published_at', { ascending: false })
      .limit(10);
    popularTerms = data ?? [];
  }
}
const railTerms = popularTerms.slice(0, 5);

const categories = getHandbookCategories();

// Site content from DB (fallback to hardcoded values)
const sc = await getSiteContents(
  ['handbook_intro', 'handbook_masthead', 'handbook_edition_label', 'handbook_subkicker', 'volume_issue'],
  'en',
);
const hbSubkicker = parseJsonArray<string>(sc.handbook_subkicker, ['Glossary', 'Reference', 'Learn']);
---

<MainLayout title={t[locale]['handbook.title']} locale={locale} slug="handbook/">
  <NewsprintShell
    locale={locale}
    masthead={sc.handbook_masthead || 'AI Glossary'}
    editionLabel={sc.handbook_edition_label || 'CS · AI · Infra'}
    subkicker={hbSubkicker}
    volumeLabel={sc.volume_issue || undefined}
  >
    <p class="handbook-hero-stats">
      <span><strong>{totalTerms}+</strong> terms</span>
      <span class="handbook-hero-stats-sep" aria-hidden="true">&middot;</span>
      <span><strong>{categories.length}</strong> categories</span>
    </p>

    <div class="handbook-search-sticky">
      <input
        type="text"
        id="handbook-search"
        aria-label={t[locale]['handbook.search']}
        placeholder={t[locale]['handbook.search']}
        data-placeholder-hints={JSON.stringify([t[locale]['handbook.search'], 'RAG', 'MCP', 'Embedding'])}
        class="handbook-search-input"
      />
    </div>

    {/* Trending Terms */}
    {popularTerms.length > 0 && (
      <section class="handbook-trending">
        <h3 class="handbook-trending-title">Trending Terms</h3>
        <ol class="handbook-trending-list">
          {popularTerms.map((pt: any, i: number) => (
            <li>
              <a href={`/${locale}/handbook/${pt.slug}/`} class="handbook-trending-link">
                <span class="handbook-trending-rank">{i + 1}</span>
                <span>{pt.term}</span>
              </a>
            </li>
          ))}
        </ol>
      </section>
    )}

    <!-- Category showcase cards -->
    <section class="product-category-showcase" id="handbook-showcase">
      <div class="product-category-showcase-grid">
        {categories.map((cat) => {
          const catTerms = termsByCategory[cat] ?? [];
          const topNames = handbookTags[cat] || '';
          const desc = getHandbookCategoryDescription(locale, cat);
          return (
            <a href={`/${locale}/handbook/category/${cat}/`} class="product-category-showcase-card">
              <div class="product-category-showcase-card-header">
                <span class="product-category-showcase-icon" set:html={getHandbookCategoryIcon(cat)} />
                <strong class="product-category-showcase-name">{getHandbookCategoryLabel(locale, cat)}</strong>
              </div>
              {topNames && <p class="product-category-showcase-tags">{topNames}</p>}
              {desc && <p class="product-category-showcase-desc">{desc}</p>}
            </a>
          );
        })}
      </div>
    </section>

    <div id="handbook-controls" class="handbook-controls">
      <div id="handbook-filters" class="handbook-filter-row">
        <button type="button" class="handbook-filter-btn active" data-filter="all" aria-pressed="true">
          {t[locale]['handbook.allCategories']}
        </button>
        {categories.map((cat) => (
          <button type="button" class="handbook-filter-btn" data-filter={cat} aria-pressed="false">
            <span class="handbook-filter-icon" set:html={getHandbookCategoryIcon(cat)} />
            {getHandbookCategoryLabel(locale, cat)}
          </button>
        ))}
      </div>
    </div>
    <div id="handbook-result-count" class="handbook-result-count" aria-live="polite" style="display: none;"></div>

    {fetchError ? (
      <NewsprintNotice
        variant="error"
        message={t[locale]['handbook.error']}
        linkHref={`/${locale}/handbook/`}
        linkLabel={t[locale]['handbook.back']}
      />
    ) : allTerms.length === 0 ? (
      <NewsprintNotice variant="empty" message={t[locale]['handbook.empty']} />
    ) : (
      <>
        <script type="application/json" id="handbook-terms-data" set:html={JSON.stringify(allTerms.map(t => {
          const def = localField(t, 'definition', locale) || '';
          return {
            s: t.slug, t: t.term, k: t.korean_name || '', c: t.categories || [],
            cl: (t.categories || []).map((cat: string) => getHandbookCategoryLabel(locale, cat) || cat),
            d: def.length > 120 ? def.slice(0, 120) + '\u2026' : def,
            id: t.id, r: readTermIds.has(t.id), b: bookmarkedTermIds.has(t.id),
          };
        }))} />
        <div id="search-results" style="display: none;"></div>
      </>
    )}

    <div id="handbook-no-results" style="display: none;">
      <NewsprintNotice variant="empty" message={t[locale]['handbook.searchNoResults']} />
    </div>

    <Fragment slot="rail">
      <HandbookListRail locale={locale} terms={railTerms} editorialNote={sc.handbook_intro || undefined} />
    </Fragment>
  </NewsprintShell>
</MainLayout>

<script>
  import '../../../scripts/bookmark';
</script>

<script>
  import '../../../scripts/handbookSearchHints';
</script>

<script>
  function initHandbookFilters(): void {
    const search = document.getElementById('handbook-search') as HTMLInputElement | null;
    const searchResults = document.getElementById('search-results');
    const noResults = document.getElementById('handbook-no-results');
    const countEl = document.getElementById('handbook-result-count');
    const filterBtns = document.querySelectorAll('.handbook-filter-btn');
    if (!search || !searchResults) return;

    let activeCategory = 'all';

    // Parse JSON term data and build DOM cards lazily on first search
    const termsDataEl = document.getElementById('handbook-terms-data');
    type TermEntry = { s: string; t: string; k: string; c: string[]; cl: string[]; d: string; id: string; r: boolean; b: boolean };
    let termsData: TermEntry[] | null = null;
    let cardsBuilt = false;

    const BATCH_SIZE = 20;
    let batchOffset = 0;
    let isDefaultMode = false;
    let sortedCards: HTMLElement[] = [];
    let sentinel: HTMLDivElement | null = null;

    function ensureCards(): void {
      if (cardsBuilt) return;
      cardsBuilt = true;
      if (!termsDataEl || !searchResults) return;
      termsData = JSON.parse(termsDataEl.textContent || '[]');
      termsData.sort((a, b) => a.t.localeCompare(b.t, undefined, { sensitivity: 'base' }));
      const locale = document.documentElement.lang || 'en';
      const frag = document.createDocumentFragment();
      for (const t of termsData!) {
        const a = document.createElement('a');
        a.href = `/${locale}/handbook/${t.s}/`;
        a.className = 'handbook-card' + (t.r ? ' newsprint-card--read' : '');
        a.dataset.categories = JSON.stringify(t.c);
        a.dataset.term = t.t;
        a.dataset.korean = t.k;
        a.dataset.def = t.d;
        let html = '<div class="handbook-card-meta">';
        for (let i = 0; i < t.c.length; i++) {
          html += `<span class="handbook-cat-pill">${t.cl[i]}</span>`;
        }
        html += '</div><div class="handbook-card-title-row"><div class="handbook-card-title">' +
          t.t + '</div><button class="newsprint-bookmark-icon' + (t.b ? ' newsprint-bookmark-icon--active' : '') +
          '" data-item-id="' + t.id + '" data-item-type="term" data-bookmarked="' + (t.b ? 'true' : 'false') +
          '" aria-label="' + (t.b ? 'Remove bookmark' : 'Add bookmark') + '">' +
          '<svg viewBox="0 0 24 24" fill="' + (t.b ? 'currentColor' : 'none') + '" stroke="currentColor" stroke-width="2">' +
          '<path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" /></svg></button></div>';
        if (t.k) html += '<div class="handbook-card-korean">' + t.k + '</div>';
        if (t.d) html += '<div class="handbook-card-def">' + t.d + '</div>';
        a.innerHTML = html;
        frag.appendChild(a);
      }
      searchResults.appendChild(frag);
    }

    function showSearchMode(): void {
      isDefaultMode = false;
      if (sentinel) sentinel.style.display = 'none';
      if (searchResults) searchResults.style.display = 'block';
    }

    function showNextBatch(): void {
      const end = Math.min(batchOffset + BATCH_SIZE, sortedCards.length);
      for (let i = batchOffset; i < end; i++) sortedCards[i].style.display = 'block';
      batchOffset = end;
      if (sentinel) sentinel.style.display = batchOffset < sortedCards.length ? 'block' : 'none';
    }

    function ensureSentinel(): void {
      if (sentinel) { sentinel.style.display = batchOffset < sortedCards.length ? 'block' : 'none'; return; }
      sentinel = document.createElement('div');
      sentinel.style.height = '1px';
      searchResults!.insertAdjacentElement('afterend', sentinel);
      new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting && isDefaultMode) showNextBatch();
      }, { rootMargin: '200px' }).observe(sentinel);
    }

    function enterDefaultMode(): void {
      isDefaultMode = true;
      ensureCards();
      if (!searchResults) return;
      sortedCards = Array.from(searchResults.querySelectorAll<HTMLElement>('.handbook-card'));
      sortedCards.forEach(c => c.style.display = 'none');
      batchOffset = 0;
      searchResults.style.display = 'block';
      if (noResults) noResults.style.display = 'none';
      if (countEl) { countEl.textContent = ''; countEl.style.display = 'none'; }
      showNextBatch();
      ensureSentinel();
    }

    function debounce(fn: () => void, ms: number): () => void {
      let timer: ReturnType<typeof setTimeout>;
      return () => { clearTimeout(timer); timer = setTimeout(fn, ms); };
    }

    function filter(): void {
      const query = search!.value.toLowerCase().trim();

      if (!query && activeCategory === 'all') {
        enterDefaultMode();
        return;
      }

      ensureCards();
      showSearchMode();

      const cards = searchResults!.querySelectorAll('.handbook-card') as NodeListOf<HTMLElement>;
      let visible = 0;

      cards.forEach((card) => {
        const cats: string[] = (card as any).__cats ??= JSON.parse(card.dataset.categories || '[]');
        const term = (card.dataset.term || '').toLowerCase();
        const korean = (card.dataset.korean || '').toLowerCase();
        const def = (card.dataset.def || '').toLowerCase();

        const matchesCategory = activeCategory === 'all' || cats.includes(activeCategory);
        const matchesSearch = !query || term.includes(query) || korean.includes(query) || def.includes(query);

        const show = matchesCategory && matchesSearch;
        card.style.display = show ? 'block' : 'none';
        if (show) visible++;
      });

      if (noResults) {
        noResults.style.display = visible === 0 ? 'block' : 'none';
      }
      if (countEl) {
        const total = cards.length;
        const isFiltered = query || activeCategory !== 'all';
        countEl.textContent = isFiltered ? `${visible} / ${total}` : '';
        countEl.style.display = isFiltered ? 'block' : 'none';
      }
    }

    search.addEventListener('input', debounce(filter, 150));

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        filterBtns.forEach((b) => {
          (b as HTMLElement).classList.remove('active');
          (b as HTMLElement).setAttribute('aria-pressed', 'false');
        });
        (btn as HTMLElement).classList.add('active');
        (btn as HTMLElement).setAttribute('aria-pressed', 'true');
        activeCategory = (btn as HTMLElement).dataset.filter || 'all';
        filter();
      });
    });

    // Read URL query params and auto-activate filters
    const params = new URLSearchParams(window.location.search);

    const urlCategory = params.get('category');
    if (urlCategory) {
      activeCategory = urlCategory;
      filterBtns.forEach((b) => {
        const el = b as HTMLElement;
        const isMatch = el.dataset.filter === urlCategory;
        el.classList.toggle('active', isMatch);
        el.setAttribute('aria-pressed', isMatch ? 'true' : 'false');
      });
    }

    const urlQuery = params.get('q');
    if (urlQuery) {
      search.value = urlQuery;
    }

    if (urlCategory || urlQuery) {
      filter();
    }

  }

  document.addEventListener('astro:page-load', initHandbookFilters);
  initHandbookFilters();
</script>
