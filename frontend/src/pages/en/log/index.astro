---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import { t } from '../../../i18n/index';
import { supabase } from '../../../lib/supabase';
import { getCategoryLabel, normalizeCategorySlug } from '../../../lib/categories';
import NewsprintShell from '../../../components/newsprint/NewsprintShell.astro';
import NewsprintListCard from '../../../components/newsprint/NewsprintListCard.astro';
import NewsprintListRail from '../../../components/newsprint/NewsprintListRail.astro';
import NewsprintCategoryFilter from '../../../components/newsprint/NewsprintCategoryFilter.astro';
import NewsprintNotice from '../../../components/newsprint/NewsprintNotice.astro';

let posts: any[] = [];
let fetchError: string | null = null;

if (supabase) {
  const { data, error } = await supabase
    .from('posts')
    .select('id, title, slug, category, published_at, tags, reading_time_min, og_image_url, excerpt')
    .eq('status', 'published')
    .eq('locale', 'en')
    .order('published_at', { ascending: false });

  if (error) {
    console.error('[log-list-en] Supabase error:', error.message);
    fetchError = error.message;
  } else {
    posts = data ?? [];
  }
}

const featured = posts[0] ?? null;
const rest = featured ? posts.slice(1) : [];
const railPosts = featured ? posts.slice(1, 5) : posts.slice(0, 4);
const categories = Array.from(
  new Set(
    posts
      .map((post) => normalizeCategorySlug(post.category))
      .filter((category): category is string => Boolean(category)),
  ),
).slice(0, 6);
---

<MainLayout title={t.en['log.title']} locale="en" slug="log/">
  <NewsprintShell
    locale="en"
    masthead="All About AI"
    editionLabel="Builder's Daily"
    subkicker={['AI · Papers · Projects', 'Daily Curation', 'Open Access']}
  >
    <NewsprintCategoryFilter locale="en" categories={categories} />

    {fetchError ? (
      <NewsprintNotice
        variant="error"
        message={t.en['log.error']}
        linkHref="/en/log/"
        linkLabel={t.en['error.retry']}
      />
    ) : featured ? (
      <>
        <a
          href={`/en/log/${featured.slug}/`}
          class={`newsprint-featured newsprint-card${featured.og_image_url ? ' newsprint-featured--has-img' : ''}`}
          data-category={normalizeCategorySlug(featured.category)}
        >
          {featured.og_image_url && (
            <div class="newsprint-featured-img-frame">
              <img
                src={featured.og_image_url}
                alt={featured.title}
                class="newsprint-featured-img img-newsprint"
                loading="lazy"
              />
            </div>
          )}
          <div>
            <span class="newsprint-category">{getCategoryLabel('en', featured.category)}</span>
            <h2 class="newsprint-lead-title">{featured.title}</h2>
            {featured.excerpt && <p class="newsprint-excerpt">{featured.excerpt}</p>}
            <div class="newsprint-meta">
              {featured.published_at && <time>{new Date(featured.published_at).toLocaleDateString('en-US')}</time>}
              {featured.reading_time_min && <span>{featured.reading_time_min} min read</span>}
            </div>
            <div class="newsprint-tags">
              {(featured.tags ?? []).slice(0, 5).map((tag: string) => <span class="newsprint-tag">{tag}</span>)}
            </div>
          </div>
        </a>

        {rest.length > 0 && (
          <section class="newsprint-grid-cards">
            {rest.map((post) => (
              <NewsprintListCard
                href={`/en/log/${post.slug}/`}
                title={post.title}
                excerpt={post.excerpt}
                category={post.category}
                publishedAt={post.published_at}
                readingTimeMin={post.reading_time_min}
                tags={post.tags}
                locale="en"
              />
            ))}
          </section>
        )}
      </>
    ) : (
      <NewsprintNotice variant="empty" message={t.en['log.empty']} />
    )}

    <Fragment slot="rail">
      <NewsprintListRail locale="en" posts={railPosts} />
    </Fragment>
  </NewsprintShell>
</MainLayout>
