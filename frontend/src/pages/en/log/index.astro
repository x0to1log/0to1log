---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import { t } from '../../../i18n/index';
import { supabase } from '../../../lib/supabase';
import { createClient } from '@supabase/supabase-js';
import { normalizeCategorySlug } from '../../../lib/categories';
import NewsprintShell from '../../../components/newsprint/NewsprintShell.astro';
import NewsprintHeadline from '../../../components/newsprint/NewsprintHeadline.astro';
import NewsprintListCard from '../../../components/newsprint/NewsprintListCard.astro';
import NewsprintListRail from '../../../components/newsprint/NewsprintListRail.astro';
import NewsprintCategoryFilter from '../../../components/newsprint/NewsprintCategoryFilter.astro';
import NewsprintNotice from '../../../components/newsprint/NewsprintNotice.astro';
import { getSiteContents, parseJsonArray } from '../../../lib/siteContent';

let posts: any[] = [];
let fetchError: string | null = null;

if (supabase) {
  const { data, error } = await supabase
    .from('posts')
    .select('id, title, slug, category, post_type, published_at, tags, reading_time_min, og_image_url, excerpt')
    .eq('status', 'published')
    .eq('locale', 'en')
    .order('published_at', { ascending: false });

  if (error) {
    console.error('[log-list-en] Supabase error:', error.message);
    fetchError = error.message;
  } else {
    posts = data ?? [];
  }
}

// User reading history & bookmarks
const readPostIds = new Set<string>();
const bookmarkedPostIds = new Set<string>();
const user = Astro.locals.user;
const accessToken = Astro.locals.accessToken;
if (user && accessToken) {
  const authSb = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
    { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
  );
  const [histRes, bmRes] = await Promise.all([
    authSb.from('reading_history').select('item_id').eq('user_id', user.id).eq('item_type', 'post'),
    authSb.from('user_bookmarks').select('item_id').eq('user_id', user.id).eq('item_type', 'post'),
  ]);
  (histRes.data ?? []).forEach((r: any) => readPostIds.add(r.item_id));
  (bmRes.data ?? []).forEach((r: any) => bookmarkedPostIds.add(r.item_id));
}

const headline = posts.find(p => p.post_type === 'business') ?? null;
const rest = posts.filter(p => p !== headline);
const railPosts = headline ? rest.slice(0, 4) : posts.slice(0, 4);
const categories = Array.from(
  new Set(
    posts
      .map((post) => normalizeCategorySlug(post.category))
      .filter((category): category is string => Boolean(category)),
  ),
).slice(0, 6);

// Site content from DB (fallback to hardcoded values)
const sc = await getSiteContents(
  ['editorial_note', 'news_masthead', 'news_edition_label', 'news_subkicker', 'start_here_sections', 'volume_issue'],
  'en',
);
const subkicker = parseJsonArray<string>(sc.news_subkicker, ['AI · Papers · Projects', 'Daily Curation', 'Open Access']);
const startHereSections = parseJsonArray<{slug: string; label: string; description: string}>(sc.start_here_sections, []);
---

<MainLayout title={t.en['log.title']} locale="en" slug="log/">
  <NewsprintShell
    locale="en"
    masthead={sc.news_masthead || 'Latest AI News'}
    editionLabel={sc.news_edition_label || "Builder's Daily"}
    subkicker={subkicker}
    volumeLabel={sc.volume_issue || undefined}
  >
    <NewsprintCategoryFilter locale="en" />

    {fetchError ? (
      <NewsprintNotice
        variant="error"
        message={t.en['log.error']}
        linkHref="/en/log/"
        linkLabel={t.en['error.retry']}
      />
    ) : posts.length > 0 ? (
      <>
        {headline && (
          <NewsprintHeadline
            href={`/en/log/${headline.slug}/`}
            title={headline.title}
            excerpt={headline.excerpt}
            category={headline.category}
            publishedAt={headline.published_at}
            readingTimeMin={headline.reading_time_min}
            tags={headline.tags}
            locale="en"
            isBookmarked={bookmarkedPostIds.has(headline.id)}
            itemId={headline.id}
            itemType="post"
          />
        )}

        {rest.length > 0 && (
          <section class="newsprint-grid-cards">
            {rest.map((post) => (
              <NewsprintListCard
                href={`/en/log/${post.slug}/`}
                title={post.title}
                excerpt={post.excerpt}
                category={post.category}
                publishedAt={post.published_at}
                readingTimeMin={post.reading_time_min}
                tags={post.tags}
                locale="en"
                isRead={readPostIds.has(post.id)}
                isBookmarked={bookmarkedPostIds.has(post.id)}
                itemId={post.id}
                itemType="post"
              />
            ))}
          </section>
        )}
      </>
    ) : (
      <NewsprintNotice variant="empty" message={t.en['log.empty']} />
    )}

    <Fragment slot="rail">
      <NewsprintListRail
        locale="en"
        posts={railPosts}
        editorialNote={sc.editorial_note || undefined}
        startHereSections={startHereSections.length > 0 ? startHereSections : undefined}
      />
    </Fragment>
  </NewsprintShell>
</MainLayout>

<script>
  import '../../../scripts/bookmark';
</script>
