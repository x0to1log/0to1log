---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import { t } from '../../../i18n/index';
import { supabase } from '../../../lib/supabase';
import { normalizeCategorySlug } from '../../../lib/categories';
import { getArticleFocusItems } from '../../../lib/articleRail';
import { renderMarkdown } from '../../../lib/markdown';
import NewsprintShell from '../../../components/newsprint/NewsprintShell.astro';
import NewsprintSideRail from '../../../components/newsprint/NewsprintSideRail.astro';
import NewsprintArticleLayout from '../../../components/newsprint/NewsprintArticleLayout.astro';
import NewsprintNotice from '../../../components/newsprint/NewsprintNotice.astro';

const { slug } = Astro.params;
const pageSlug = slug ?? '';

let post = null;
let postError: string | null = null;

if (supabase && slug) {
  const { data, error } = await supabase
    .from('posts')
    .select('*')
    .eq('slug', pageSlug)
    .eq('status', 'published')
    .eq('locale', 'en')
    .single();

  if (error && error.code !== 'PGRST116') {
    console.error('[log-detail-en] Supabase error:', error.message);
    postError = error.message;
  } else {
    post = data;
  }
}

if (!post && !postError) {
  Astro.response.status = 404;
}

const masthead = 'All About AI';
const editionMap: Record<string, string> = {
  'ai-news': 'Daily Dispatch',
  study: 'Study Notes',
  career: 'Career Notes',
  project: 'Build Log',
};
const editionLabel = post ? (editionMap[normalizeCategorySlug(post.category) || ''] || 'Deep Dive') : 'Deep Dive';

let recentPosts: any[] = [];
let focusItems: string[] = [];
let articleData: any = undefined;
let nextPost: { title: string; slug: string; category: string | null } | null = null;

if (post) {
  recentPosts = supabase
    ? (await supabase
        .from('posts')
        .select('title, slug, category')
        .eq('status', 'published')
        .eq('locale', 'en')
        .neq('slug', pageSlug)
        .order('published_at', { ascending: false })
        .limit(4)
      ).data ?? []
    : [];

  if (supabase && post.published_at) {
    const { data: nextData } = await supabase
      .from('posts')
      .select('title, slug, category')
      .eq('status', 'published')
      .eq('locale', 'en')
      .lt('published_at', post.published_at)
      .order('published_at', { ascending: false })
      .limit(1)
      .single();
    nextPost = nextData;
  }

  focusItems = getArticleFocusItems('en', post.category);

  articleData = post.published_at
    ? { datePublished: post.published_at, dateModified: post.updated_at || post.published_at, image: post.og_image_url }
    : undefined;
}

const pageTitle = post ? post.title : 'Not Found';
const rawContent = post ? (post.content_original || post.content_beginner || '') : '';
const htmlContent = rawContent ? await renderMarkdown(rawContent) : '';
---

<MainLayout title={pageTitle} locale="en" slug={`log/${slug}/`} article={articleData}>
  <NewsprintShell
    locale="en"
    masthead={masthead}
    editionLabel={editionLabel}
    subkicker={['AI · Papers · Projects', 'Daily Curation', 'Open Access']}
  >
    {postError ? (
      <NewsprintNotice
        variant="error"
        message={t.en['log.error']}
        linkHref="/en/log/"
        linkLabel={t.en['post.back']}
      />
    ) : !post ? (
      <NewsprintNotice
        variant="notfound"
        message={t.en['post.notfound']}
        linkHref="/en/log/"
        linkLabel={t.en['post.back']}
      />
    ) : (
      <NewsprintArticleLayout
        locale="en"
        slug={pageSlug}
        showSlug={false}
        title={post.title}
        excerpt={post.excerpt}
        category={post.category}
        publishedAt={post.published_at}
        readingTimeMin={post.reading_time_min}
        tags={post.tags}
        htmlContent={htmlContent}
        backLabel={t.en['post.back']}
        nextPost={nextPost}
      />
    )}

    <Fragment slot="rail">
      <NewsprintSideRail locale="en" posts={recentPosts} focusItems={focusItems} />
    </Fragment>
  </NewsprintShell>
</MainLayout>
