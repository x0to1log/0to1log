---
export const prerender = false;

import MainLayout from '../../../layouts/MainLayout.astro';
import { t } from '../../../i18n/index';
import { supabase } from '../../../lib/supabase';
import { createClient } from '@supabase/supabase-js';
import { normalizeCategorySlug } from '../../../lib/categories';
import { getArticleFocusItems } from '../../../lib/articleRail';
import { renderMarkdown } from '../../../lib/markdown';
import NewsprintShell from '../../../components/newsprint/NewsprintShell.astro';
import NewsprintSideRail from '../../../components/newsprint/NewsprintSideRail.astro';
import NewsprintArticleLayout from '../../../components/newsprint/NewsprintArticleLayout.astro';
import NewsprintNotice from '../../../components/newsprint/NewsprintNotice.astro';
import AdminToolbar from '../../../components/admin/AdminToolbar.astro';

const { slug } = Astro.params;
const pageSlug = slug ?? '';

let post = null;
let postError: string | null = null;

if (supabase && slug) {
  const { data, error } = await supabase
    .from('posts')
    .select('*')
    .eq('slug', pageSlug)
    .eq('status', 'published')
    .eq('locale', 'en')
    .single();

  if (error && error.code !== 'PGRST116') {
    console.error('[log-detail-en] Supabase error:', error.message);
    postError = error.message;
  } else {
    post = data;
  }
}

if (!post && !postError) {
  Astro.response.status = 404;
}

const masthead = 'Latest AI News';
const editionMap: Record<string, string> = {
  'ai-news': 'Daily Dispatch',
  study: 'Study Notes',
  career: 'Career Notes',
  project: 'Build Log',
};
const editionLabel = post ? (editionMap[normalizeCategorySlug(post.category) || ''] || 'Deep Dive') : 'Deep Dive';

let recentPosts: any[] = [];
let focusItems: string[] = [];
let articleData: any = undefined;
let nextPost: { title: string; slug: string; category: string | null } | null = null;
let pairedSlug: string | null = null;

if (post) {
  // "More in This Issue" — prefer same batch, fallback to recent
  if (supabase && post.pipeline_batch_id) {
    const { data: batchPosts } = await supabase
      .from('posts')
      .select('title, slug, category')
      .eq('status', 'published')
      .eq('locale', 'en')
      .eq('pipeline_batch_id', post.pipeline_batch_id)
      .neq('slug', pageSlug)
      .order('published_at', { ascending: false })
      .limit(4);
    if (batchPosts && batchPosts.length > 0) {
      recentPosts = batchPosts;
    }
  }
  if (recentPosts.length === 0 && supabase) {
    recentPosts = (await supabase
      .from('posts')
      .select('title, slug, category')
      .eq('status', 'published')
      .eq('locale', 'en')
      .neq('slug', pageSlug)
      .order('published_at', { ascending: false })
      .limit(4)
    ).data ?? [];
  }

  if (supabase && post.published_at) {
    const { data: nextData } = await supabase
      .from('posts')
      .select('title, slug, category')
      .eq('status', 'published')
      .eq('locale', 'en')
      .lt('published_at', post.published_at)
      .order('published_at', { ascending: false })
      .limit(1)
      .single();
    nextPost = nextData;
  }

  // Focus items: use post-level data if available, fallback to category template
  focusItems = (post.focus_items && post.focus_items.length > 0)
    ? post.focus_items
    : getArticleFocusItems('en', post.category);

  if (supabase && post.translation_group_id) {
    const { data: paired } = await supabase
      .from('posts')
      .select('slug')
      .eq('translation_group_id', post.translation_group_id)
      .eq('locale', 'ko')
      .eq('status', 'published')
      .single();
    pairedSlug = paired?.slug ?? null;
  }

  articleData = post.published_at
    ? { datePublished: post.published_at, dateModified: post.updated_at || post.published_at, image: post.og_image_url }
    : undefined;
}

// User bookmark state
let isBookmarked = false;
const user = Astro.locals.user;
const accessToken = Astro.locals.accessToken;
if (user && accessToken && post) {
  const authSb = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
    { global: { headers: { Authorization: `Bearer ${accessToken}` } } },
  );
  const { data: bm } = await authSb
    .from('user_bookmarks')
    .select('id')
    .eq('user_id', user.id)
    .eq('item_type', 'post')
    .eq('item_id', post.id)
    .maybeSingle();
  isBookmarked = !!bm;
}

const pageTitle = post ? post.title : 'Not Found';
const rawContent = post ? (post.content_original || post.content_beginner || '') : '';
const htmlContent = rawContent ? await renderMarkdown(rawContent) : '';
---

<MainLayout title={pageTitle} locale="en" slug={`log/${slug}/`} altSlug={pairedSlug ?? undefined} article={articleData}>
  <NewsprintShell
    locale="en"
    masthead={masthead}
    editionLabel={editionLabel}
    subkicker={['AI · Papers · Projects', 'Daily Curation', 'Open Access']}
  >
    {postError ? (
      <NewsprintNotice
        variant="error"
        message={t.en['log.error']}
        linkHref="/en/log/"
        linkLabel={t.en['post.back']}
      />
    ) : !post ? (
      <NewsprintNotice
        variant="notfound"
        message={t.en['post.notfound']}
        linkHref="/en/log/"
        linkLabel={t.en['post.back']}
      />
    ) : (
      <NewsprintArticleLayout
        locale="en"
        slug={pageSlug}
        showSlug={false}
        title={post.title}
        excerpt={post.excerpt}
        category={post.category}
        publishedAt={post.published_at}
        readingTimeMin={post.reading_time_min}
        tags={post.tags}
        htmlContent={htmlContent}
        backLabel={t.en['post.back']}
        nextPost={nextPost}
        isBookmarked={isBookmarked}
        itemId={post.id}
        itemType="post"
      />
    )}

    <Fragment slot="rail">
      <NewsprintSideRail locale="en" posts={recentPosts} focusItems={focusItems} />
    </Fragment>
  </NewsprintShell>
  {Astro.locals.isAdmin && post && (
    <AdminToolbar itemId={post.id} slug={pageSlug} type="post" />
  )}
</MainLayout>

<script>
  import '../../../scripts/bookmark';

  function recordReadingHistory(): void {
    const postId = document.querySelector('[data-item-id][data-item-type="post"]')?.getAttribute('data-item-id');
    if (!postId) return;
    fetch('/api/user/reading-history', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ item_type: 'post', item_id: postId }),
    }).catch(() => {});
  }

  document.addEventListener('astro:page-load', recordReadingHistory);
</script>
