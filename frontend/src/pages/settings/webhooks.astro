---
export const prerender = false;
import MainLayout from '../../layouts/MainLayout.astro';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect(`/login?redirectTo=/settings/webhooks/`);
}

const langParam = Astro.url.searchParams.get('lang');
const cookieLocale = Astro.cookies.get('site-locale')?.value;
const profile = Astro.locals.profile;
const acceptLang = Astro.request.headers.get('accept-language') || '';
const browserLocale = acceptLang.split(',').some(l => l.trim().startsWith('ko')) ? 'ko' : 'en';
const locale = (langParam === 'ko' || langParam === 'en') ? langParam
  : (cookieLocale === 'ko' || cookieLocale === 'en') ? cookieLocale
  : profile?.preferred_locale === 'ko' ? 'ko'
  : profile?.preferred_locale === 'en' ? 'en'
  : browserLocale;

const isKo = locale === 'ko';

const copy = isKo
  ? {
      title: 'Webhook 알림 설정',
      back: '프로필 설정',
      empty: '등록된 webhook이 없습니다.',
      emptyDesc: 'Discord, Slack 또는 커스텀 webhook으로 AI 뉴스 알림을 받아보세요.',
      addTitle: 'Webhook 추가',
      label: '이름',
      labelPlaceholder: '예: 내 디스코드',
      platform: '플랫폼',
      locale: '언어',
      localeAll: '전체',
      url: 'Webhook URL',
      urlPlaceholder: 'https://',
      add: '추가',
      adding: '추가 중...',
      test: '테스트',
      testing: '전송 중...',
      testOk: '테스트 성공!',
      testFail: '전송 실패',
      edit: '수정',
      delete: '삭제',
      deleteConfirm: '정말 삭제할까요?',
      save: '저장',
      saving: '저장 중...',
      cancel: '취소',
      active: '활성',
      inactive: '비활성',
      lastFired: '마지막 발송',
      failures: '연속 실패',
      maxReached: '최대 5개까지 등록할 수 있습니다.',
      guideDiscord: '서버 설정 → 연동 → 웹후크 → URL 복사',
      guideSlack: '앱 관리 → Incoming Webhooks → URL 복사',
      guideCustom: 'POST 요청을 받을 HTTPS 엔드포인트를 입력하세요',
    }
  : {
      title: 'Webhook Notifications',
      back: 'Profile Settings',
      empty: 'No webhooks registered.',
      emptyDesc: 'Get AI news notifications via Discord, Slack, or custom webhooks.',
      addTitle: 'Add Webhook',
      label: 'Label',
      labelPlaceholder: 'e.g. My Discord',
      platform: 'Platform',
      locale: 'Language',
      localeAll: 'All',
      url: 'Webhook URL',
      urlPlaceholder: 'https://',
      add: 'Add',
      adding: 'Adding...',
      test: 'Test',
      testing: 'Sending...',
      testOk: 'Test sent!',
      testFail: 'Send failed',
      edit: 'Edit',
      delete: 'Delete',
      deleteConfirm: 'Are you sure you want to delete this webhook?',
      save: 'Save',
      saving: 'Saving...',
      cancel: 'Cancel',
      active: 'Active',
      inactive: 'Inactive',
      lastFired: 'Last fired',
      failures: 'Consecutive failures',
      maxReached: 'Maximum 5 webhooks allowed.',
      guideDiscord: 'Server Settings → Integrations → Webhooks → Copy URL',
      guideSlack: 'App Management → Incoming Webhooks → Copy URL',
      guideCustom: 'Enter an HTTPS endpoint that accepts POST requests',
    };
---

<MainLayout title={copy.title} locale={locale as 'en' | 'ko'} headerAlwaysVisible={true}>
  <div class="wh-page">
    <div class="wh-page-header">
      <a href="/settings/" class="wh-back-link">&larr; {copy.back}</a>
      <h1 class="wh-page-title">{copy.title}</h1>
    </div>

    <div id="wh-feedback" class="admin-feedback admin-feedback--toast" hidden></div>

    <!-- Webhook List -->
    <div id="wh-list"
      data-active={copy.active}
      data-inactive={copy.inactive}
      data-test={copy.test}
      data-delete={copy.delete}
      data-delete-confirm={copy.deleteConfirm}
      data-last-fired={copy.lastFired}
      data-failures={copy.failures}
      data-enable={isKo ? '활성화' : 'Enable'}
      data-disable={isKo ? '비활성화' : 'Disable'}
      data-msg-added={isKo ? 'Webhook이 추가되었습니다.' : 'Webhook added!'}
      data-msg-deleted={isKo ? '삭제되었습니다.' : 'Deleted.'}
      data-msg-test-ok={copy.testOk}
      data-msg-test-fail={copy.testFail}
    ></div>

    <!-- Empty State -->
    <div id="wh-empty" class="wh-empty" hidden>
      <p class="wh-empty-title">{copy.empty}</p>
      <p class="wh-empty-desc">{copy.emptyDesc}</p>
    </div>

    <!-- Add Form -->
    <section class="wh-add-section">
      <div class="wh-section-header">
        <h2 class="wh-section-title">{copy.addTitle}</h2>
        <span id="wh-count" class="wh-count"></span>
      </div>
      <form id="wh-add-form" class="wh-form">
        <div class="wh-form-row">
          <div class="admin-field" style="flex: 1;">
            <label for="wh-label">{copy.label}</label>
            <input type="text" id="wh-label" class="admin-input" placeholder={copy.labelPlaceholder} required maxlength="50" />
          </div>
          <div class="admin-field">
            <label for="wh-platform">{copy.platform}</label>
            <select id="wh-platform" class="admin-select">
              <option value="discord">Discord</option>
              <option value="slack">Slack</option>
              <option value="custom">Custom</option>
            </select>
          </div>
          <div class="admin-field">
            <label for="wh-locale">{copy.locale}</label>
            <select id="wh-locale" class="admin-select">
              <option value="all">{copy.localeAll}</option>
              <option value="en">English</option>
              <option value="ko">한국어</option>
            </select>
          </div>
        </div>
        <div class="admin-field">
          <label for="wh-url">{copy.url}</label>
          <div class="wh-url-row">
            <input type="url" id="wh-url" class="admin-input" placeholder={copy.urlPlaceholder} required />
            <button type="submit" class="admin-btn admin-btn-primary wh-add-btn" id="wh-add-btn">{copy.add}</button>
          </div>
          <p class="wh-guide" id="wh-guide"
            data-discord={copy.guideDiscord}
            data-slack={copy.guideSlack}
            data-custom={copy.guideCustom}
          >{copy.guideDiscord}</p>
        </div>
        <p class="wh-max-msg" id="wh-max-msg" hidden>{copy.maxReached}</p>
      </form>
    </section>
  </div>
</MainLayout>

<style>
  .wh-page {
    max-width: 640px;
    margin: 0 auto;
    padding: 1rem 0 3rem;
  }

  .wh-page-header { margin-bottom: 2rem; }

  .wh-back-link {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .wh-back-link:hover { color: var(--color-accent); }

  .wh-page-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-top: 0.5rem;
  }

  .wh-section-header {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .wh-section-title {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text-primary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0;
  }

  .wh-count {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-text-muted);
  }

  /* Empty State */
  .wh-empty {
    text-align: center;
    padding: 2.5rem 1rem;
    border: 1px dashed var(--color-border);
    border-radius: 8px;
    margin-bottom: 2rem;
  }
  .wh-empty-title {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin: 0 0 0.25rem;
  }
  .wh-empty-desc {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Cards */
  .wh-card {
    border: 1px solid var(--color-border);
    border-left-width: 3px;
    border-radius: 8px;
    padding: 1rem;
    margin-bottom: 0.75rem;
    background: var(--color-bg-card, var(--color-bg-secondary));
    transition: opacity 0.2s;
  }
  .wh-card--inactive { opacity: 0.5; }

  .wh-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .wh-card-label-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .wh-card-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }
  .wh-card-label {
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--color-text-primary);
  }
  .wh-card-badges {
    display: flex;
    gap: 0.35rem;
    align-items: center;
  }
  .wh-badge {
    font-family: var(--font-ui);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    background: var(--color-accent-subtle);
    color: var(--color-accent);
  }
  .wh-badge--inactive {
    background: color-mix(in srgb, var(--color-error) 10%, transparent);
    color: var(--color-error);
  }
  .wh-card-url {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
    letter-spacing: 0.01em;
  }
  .wh-card-meta {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    margin-bottom: 0.15rem;
  }
  .wh-card-actions {
    display: flex;
    gap: 0.4rem;
    margin-top: 0.6rem;
  }
  .wh-card-btn {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .wh-card-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .wh-card-btn--danger:hover {
    border-color: var(--color-error);
    color: var(--color-error);
  }
  .wh-card-btn--toggle { min-width: 4.5rem; }

  /* Add Form */
  .wh-add-section {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }
  .wh-form-row {
    display: flex;
    gap: 0.75rem;
    align-items: flex-end;
    margin-bottom: 0.5rem;
  }
  .wh-url-row {
    display: flex;
    gap: 0.5rem;
    align-items: stretch;
  }
  .wh-url-row .admin-input { flex: 1; }
  .wh-add-btn { flex-shrink: 0; }
  .wh-guide {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin: 0.25rem 0 0;
  }
  .wh-max-msg {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--color-error);
    margin: 0.5rem 0 0;
  }

  @media (max-width: 640px) {
    .wh-form-row { flex-direction: column; align-items: stretch; }
  }
</style>

<script>
  function initWebhooks() {
    const list = document.getElementById('wh-list')!;
    const empty = document.getElementById('wh-empty')!;
    const form = document.getElementById('wh-add-form') as HTMLFormElement;
    const addBtn = document.getElementById('wh-add-btn') as HTMLButtonElement;
    const feedback = document.getElementById('wh-feedback')!;
    const guide = document.getElementById('wh-guide')!;
    const maxMsg = document.getElementById('wh-max-msg')!;
    const countEl = document.getElementById('wh-count')!;
    const platformSelect = document.getElementById('wh-platform') as HTMLSelectElement;

    if (!form || !list) return;

    // i18n from data attributes
    const L = list.dataset;
    const i18n = {
      active: L.active || 'Active',
      inactive: L.inactive || 'Inactive',
      test: L.test || 'Test',
      del: L.delete || 'Delete',
      delConfirm: L.deleteConfirm || 'Delete this webhook?',
      lastFired: L.lastFired || 'Last fired',
      failures: L.failures || 'Failures',
      enable: L.enable || 'Enable',
      disable: L.disable || 'Disable',
      msgAdded: L.msgAdded || 'Webhook added!',
      msgDeleted: L.msgDeleted || 'Deleted.',
      msgTestOk: L.msgTestOk || 'Test sent!',
      msgTestFail: L.msgTestFail || 'Send failed',
    };

    const ICONS: Record<string, string> = {
      discord: '<svg class="wh-card-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>',
      slack: '<svg class="wh-card-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zm1.271 0a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313zM8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zm0 1.271a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312zm10.122 2.521a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zm-1.268 0a2.528 2.528 0 0 1-2.523 2.521 2.527 2.527 0 0 1-2.52-2.521V2.522A2.527 2.527 0 0 1 15.165 0a2.528 2.528 0 0 1 2.523 2.522v6.312zm-2.523 10.122a2.528 2.528 0 0 1 2.523 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zm0-1.268a2.527 2.527 0 0 1-2.52-2.523 2.526 2.526 0 0 1 2.52-2.52h6.313A2.527 2.527 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.523h-6.313z"/></svg>',
      custom: '<svg class="wh-card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>',
    };

    const BORDER_COLORS: Record<string, string> = {
      discord: '#5865F2',
      slack: '#4A154B',
      custom: 'var(--color-text-muted)',
    };

    let webhooks: any[] = [];

    function flash(msg: string, type: 'success' | 'error') {
      feedback.textContent = msg;
      feedback.className = `admin-feedback admin-feedback--toast admin-feedback--${type}`;
      feedback.hidden = false;
      setTimeout(() => { feedback.hidden = true; }, 3000);
    }

    function esc(s: string) {
      const d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }

    function maskUrl(url: string): string {
      if (url.length <= 45) return url;
      return url.slice(0, 30) + '...' + url.slice(-12);
    }

    function render() {
      empty.hidden = webhooks.length > 0;
      maxMsg.hidden = webhooks.length < 5;
      countEl.textContent = `${webhooks.length} / 5`;
      (form.querySelector('button[type="submit"]') as HTMLButtonElement).disabled = webhooks.length >= 5;

      list.innerHTML = webhooks.map(h => `
        <div class="wh-card${h.is_active ? '' : ' wh-card--inactive'}" data-id="${h.id}" style="border-left-color: ${BORDER_COLORS[h.platform] || 'var(--color-border)'}">
          <div class="wh-card-header">
            <div class="wh-card-label-row">
              ${ICONS[h.platform] || ICONS.custom}
              <span class="wh-card-label">${esc(h.label)}</span>
            </div>
            <div class="wh-card-badges">
              <span class="wh-badge">${h.locale === 'all' ? 'ALL' : h.locale.toUpperCase()}</span>
              <span class="wh-badge${h.is_active ? '' : ' wh-badge--inactive'}">${h.is_active ? i18n.active : i18n.inactive}</span>
            </div>
          </div>
          <div class="wh-card-url">${esc(maskUrl(h.url))}</div>
          ${h.last_fired_at ? `<div class="wh-card-meta">${i18n.lastFired}: ${new Date(h.last_fired_at).toLocaleString()}</div>` : ''}
          ${h.fail_count > 0 ? `<div class="wh-card-meta" style="color: var(--color-error);">${i18n.failures}: ${h.fail_count}${h.last_error ? ' — ' + esc(h.last_error) : ''}</div>` : ''}
          <div class="wh-card-actions">
            <button type="button" class="wh-card-btn wh-card-btn--toggle" data-action="toggle" data-id="${h.id}">${h.is_active ? i18n.disable : i18n.enable}</button>
            <button type="button" class="wh-card-btn" data-action="test" data-id="${h.id}">${i18n.test}</button>
            <button type="button" class="wh-card-btn wh-card-btn--danger" data-action="delete" data-id="${h.id}">${i18n.del}</button>
          </div>
        </div>
      `).join('');

      list.querySelectorAll('[data-action]').forEach(btn => {
        btn.addEventListener('click', () => handleAction(btn as HTMLButtonElement));
      });
    }

    async function load() {
      try {
        const res = await fetch('/api/user/webhooks');
        if (res.ok) webhooks = await res.json();
      } catch { /* silent */ }
      render();
    }

    // Platform guide switch
    platformSelect.addEventListener('change', () => {
      guide.textContent = guide.dataset[platformSelect.value] || '';
    });

    // Add webhook
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const label = (document.getElementById('wh-label') as HTMLInputElement).value.trim();
      const url = (document.getElementById('wh-url') as HTMLInputElement).value.trim();
      const platform = platformSelect.value;
      const locale = (document.getElementById('wh-locale') as HTMLSelectElement).value;

      addBtn.disabled = true;
      try {
        const res = await fetch('/api/user/webhooks', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ label, url, platform, locale }),
        });
        const data = await res.json();
        if (!res.ok) { flash(data.error || 'Failed', 'error'); return; }
        webhooks.push(data);
        render();
        form.reset();
        flash(i18n.msgAdded, 'success');
      } catch { flash('Failed', 'error'); }
      finally { addBtn.disabled = false; }
    });

    async function handleAction(btn: HTMLButtonElement) {
      const action = btn.dataset.action!;
      const id = btn.dataset.id!;

      if (action === 'delete') {
        if (!confirm(i18n.delConfirm)) return;
        const res = await fetch('/api/user/webhooks', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });
        if (res.ok) {
          webhooks = webhooks.filter(h => h.id !== id);
          render();
          flash(i18n.msgDeleted, 'success');
        }
      } else if (action === 'toggle') {
        const hook = webhooks.find(h => h.id === id);
        if (!hook) return;
        const res = await fetch('/api/user/webhooks', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, is_active: !hook.is_active }),
        });
        if (res.ok) {
          const updated = await res.json();
          webhooks = webhooks.map(h => h.id === id ? updated : h);
          render();
        }
      } else if (action === 'test') {
        btn.disabled = true;
        btn.textContent = '...';
        try {
          const res = await fetch('/api/user/webhooks-test', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id }),
          });
          const data = await res.json();
          flash(data.success ? i18n.msgTestOk : (data.error || i18n.msgTestFail), data.success ? 'success' : 'error');
          if (data.success) await load();
        } catch { flash(i18n.msgTestFail, 'error'); }
        finally {
          btn.disabled = false;
          btn.textContent = i18n.test;
        }
      }
    }

    load();
  }

  document.addEventListener('astro:page-load', initWebhooks);
  initWebhooks();
</script>
