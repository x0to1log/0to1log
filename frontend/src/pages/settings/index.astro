---
export const prerender = false;
import MainLayout from '../../layouts/MainLayout.astro';

const user = Astro.locals.user!;
const profile = Astro.locals.profile;
const isOnboarding = Astro.url.searchParams.get('onboarding') === 'true';

const langParam = Astro.url.searchParams.get('lang');
const cookieLocale = Astro.cookies.get('site-locale')?.value;
const acceptLang = Astro.request.headers.get('accept-language') || '';
const browserLocale = acceptLang.split(',').some(l => l.trim().startsWith('ko')) ? 'ko' : 'en';
const locale = (langParam === 'ko' || langParam === 'en') ? langParam
  : (cookieLocale === 'ko' || cookieLocale === 'en') ? cookieLocale
  : profile?.preferred_locale === 'ko' ? 'ko'
  : profile?.preferred_locale === 'en' ? 'en'
  : browserLocale;

const copy = locale === 'ko'
  ? {
      title: '프로필 설정',
      onboardingBanner: '프로필을 설정해주세요. 저장하면 완료됩니다.',
      avatarSection: '프로필 이미지',
      avatarUpload: '이미지 업로드',
      avatarRemove: '기본으로 되돌리기',
      avatarHint: 'JPEG, PNG, WebP, GIF · 최대 2MB',
      basicSection: '기본 정보',
      displayName: '표시 이름',
      displayNameHint: '다른 사용자에게 보이는 이름 · 기본값: 소셜 로그인 이름',
      userId: '사용자 아이디 (선택)',
      userIdHint: '고유 ID (예: jane-doe) · 3~20자, 소문자/숫자/하이픈만',
      bio: '소개',
      bioHint: '짧은 자기소개 (선택)',
      prefsSection: '선호 설정',
      persona: '읽기 수준',
      personaHint: 'AI 뉴스 기사의 기본 설명 수준',
      personaBeginner: '입문자',
      personaLearner: '학습자',
      personaExpert: '현직자',
      personaNone: '미설정',
      handbookLevel: '용어집 수준',
      handbookLevelHint: 'AI 용어집(핸드북) 기본 설명 수준',
      handbookLevelBasic: '기초',
      handbookLevelAdvanced: '심화',
      preferredLocale: '기본 언어',
      visibilitySection: '공개 설정',
      isPublic: '프로필 공개',
      isPublicHint: '다른 사용자가 내 프로필을 볼 수 있습니다',
      save: '저장',
      saving: '저장 중...',
      successMsg: '프로필이 저장되었습니다.',
      dangerSection: '계정',
      deleteAccount: '계정 탈퇴',
      deleteHint: '모든 데이터(프로필, 북마크, 읽기 기록)가 영구 삭제됩니다.',
      deleteConfirmMsg: '이 작업은 되돌릴 수 없습니다. 확인하려면 아래에 "탈퇴합니다"를 입력하세요.',
      deleteConfirmWord: '탈퇴합니다',
      deleteBtn: '계정 영구 삭제',
      deleting: '삭제 중...',
      userIdTaken: '이미 존재하는 아이디입니다.',
      userIdCooldown: '아이디는 30일에 한 번만 변경할 수 있습니다.',
    }
  : {
      title: 'Profile Settings',
      onboardingBanner: 'Set up your profile. Save when ready.',
      avatarSection: 'Profile Image',
      avatarUpload: 'Upload Image',
      avatarRemove: 'Reset to Default',
      avatarHint: 'JPEG, PNG, WebP, GIF · Max 2MB',
      basicSection: 'Basic Information',
      displayName: 'Display Name',
      displayNameHint: 'Name visible to other users · Default: your social login name',
      userId: 'User ID (optional)',
      userIdHint: 'Unique ID (e.g. jane-doe) · 3-20 chars, lowercase/numbers/hyphens',
      bio: 'Bio',
      bioHint: 'A short introduction (optional)',
      prefsSection: 'Preferences',
      persona: 'Reading Level',
      personaHint: 'Default explanation level for AI News articles',
      personaBeginner: 'Beginner',
      personaLearner: 'Learner',
      personaExpert: 'Expert',
      personaNone: 'Not set',
      handbookLevel: 'Glossary Level',
      handbookLevelHint: 'Default explanation level for AI Glossary (Handbook)',
      handbookLevelBasic: 'Basic',
      handbookLevelAdvanced: 'Advanced',
      preferredLocale: 'Default Language',
      visibilitySection: 'Visibility',
      isPublic: 'Public Profile',
      isPublicHint: 'Other users can view your profile',
      save: 'Save',
      saving: 'Saving...',
      successMsg: 'Profile saved.',
      dangerSection: 'Account',
      deleteAccount: 'Delete Account',
      deleteHint: 'All data (profile, bookmarks, reading history) will be permanently deleted.',
      deleteConfirmMsg: 'This action cannot be undone. Type "delete my account" below to confirm.',
      deleteConfirmWord: 'delete my account',
      deleteBtn: 'Permanently Delete Account',
      deleting: 'Deleting...',
      userIdTaken: 'This User ID is already taken.',
      userIdCooldown: 'You can only change your User ID once every 30 days.',
    };

const avatarUrl = profile?.avatar_url || user.user_metadata?.avatar_url || null;
const displayName = profile?.display_name || user.user_metadata?.full_name || '';
const username = profile?.username || '';
const asciiName = displayName
  .toLowerCase()
  .replace(/[^a-z0-9\s-]/g, '')
  .trim()
  .replace(/\s+/g, '-')
  .replace(/-+/g, '-')
  .slice(0, 20);
const emailPrefix = (user.email || '')
  .split('@')[0]
  .toLowerCase()
  .replace(/[^a-z0-9-]/g, '')
  .slice(0, 20);
const usernamePlaceholder = asciiName || emailPrefix || 'jane-doe';
const bio = profile?.bio || '';
const persona = profile?.persona || '';
const handbookLevel = profile?.handbook_level || 'basic';
const preferredLocale = profile?.preferred_locale || browserLocale;
const isPublic = profile?.is_public || false;

// Username change cooldown (30 days)
const usernameChangedAt = profile?.username_changed_at ? new Date(profile.username_changed_at) : null;
const COOLDOWN_DAYS = 30;
const now = new Date();
const userIdLocked = usernameChangedAt
  ? (now.getTime() - usernameChangedAt.getTime()) < COOLDOWN_DAYS * 24 * 60 * 60 * 1000
  : false;
const userIdUnlockDate = usernameChangedAt
  ? new Date(usernameChangedAt.getTime() + COOLDOWN_DAYS * 24 * 60 * 60 * 1000)
  : null;
---

<MainLayout title={copy.title} locale={locale as 'en' | 'ko'} headerAlwaysVisible={true}>
  <div class="settings-page">
    {isOnboarding && (
      <div class="admin-feedback admin-feedback--success" id="onboarding-banner">
        <span>{copy.onboardingBanner}</span>
      </div>
    )}

    <h1 class="settings-title">{copy.title}</h1>

    <div id="feedback" class="admin-feedback admin-feedback--toast" hidden></div>

    <!-- Avatar Section -->
    <section class="settings-section">
      <h2 class="settings-section-title">{copy.avatarSection}</h2>
      <div class="settings-avatar-row">
        <div class="settings-avatar-preview" id="avatar-preview">
          {avatarUrl ? (
            <img src={avatarUrl} alt={displayName} id="avatar-img" />
          ) : (
            <span class="settings-avatar-initials" id="avatar-initials">
              {displayName ? displayName.charAt(0).toUpperCase() : '?'}
            </span>
          )}
        </div>
        <div class="settings-avatar-controls">
          <label class="admin-btn" style="cursor: pointer;">
            {copy.avatarUpload}
            <input type="file" accept="image/jpeg,image/png,image/webp,image/gif" id="avatar-input" style="display: none;" />
          </label>
          <button type="button" class="admin-btn" id="avatar-remove-btn">{copy.avatarRemove}</button>
          <p class="settings-hint">{copy.avatarHint}</p>
        </div>
      </div>
    </section>

    <!-- Basic Info -->
    <form id="profile-form">
      <section class="settings-section">
        <h2 class="settings-section-title">{copy.basicSection}</h2>

        <div class="admin-field">
          <label for="display_name">{copy.displayName}</label>
          <input type="text" id="display_name" name="display_name" class="admin-input" value={displayName} maxlength="100" />
          <p class="settings-hint">{copy.displayNameHint}</p>
        </div>

        <div class="admin-field">
          <label for="username">{copy.userId}</label>
          <input
            type="text"
            id="username"
            name="username"
            class="admin-input"
            value={username}
            placeholder={usernamePlaceholder}
            maxlength="20"
            pattern="[a-z0-9][a-z0-9\-]{1,18}[a-z0-9]"
            disabled={userIdLocked}
          />
          {userIdLocked && userIdUnlockDate ? (
            <p class="settings-hint settings-hint--locked">
              {locale === 'ko'
                ? `${userIdUnlockDate.toLocaleDateString('ko-KR')} 이후 변경 가능`
                : `Can be changed after ${userIdUnlockDate.toLocaleDateString('en-US')}`}
            </p>
          ) : (
            <p class="settings-hint">{copy.userIdHint}</p>
          )}
          <p class="settings-field-error" id="username-error" hidden
            data-username-taken={copy.userIdTaken}
            data-cooldown-msg={copy.userIdCooldown}></p>
        </div>

        <div class="admin-field">
          <label for="bio">{copy.bio}</label>
          <textarea id="bio" name="bio" class="admin-textarea" rows="3" maxlength="500">{bio}</textarea>
          <p class="settings-hint">{copy.bioHint}</p>
        </div>
      </section>

      <!-- Preferences -->
      <section class="settings-section">
        <h2 class="settings-section-title">{copy.prefsSection}</h2>

        <div class="admin-field">
          <label>{copy.persona}</label>
          <div class="settings-radio-group">
            <label class="settings-radio-item">
              <input type="radio" name="persona" value="" checked={!persona} />
              <span>{copy.personaNone}</span>
            </label>
            <label class="settings-radio-item">
              <input type="radio" name="persona" value="learner" checked={persona === 'learner'} />
              <span>{copy.personaLearner}</span>
            </label>
            <label class="settings-radio-item">
              <input type="radio" name="persona" value="expert" checked={persona === 'expert'} />
              <span>{copy.personaExpert}</span>
            </label>
          </div>
          <p class="settings-hint">{copy.personaHint}</p>
        </div>

        <div class="admin-field">
          <label>{copy.handbookLevel}</label>
          <div class="settings-radio-group">
            <label class="settings-radio-item">
              <input type="radio" name="handbook_level" value="basic" checked={handbookLevel === 'basic'} />
              <span>{copy.handbookLevelBasic}</span>
            </label>
            <label class="settings-radio-item">
              <input type="radio" name="handbook_level" value="advanced" checked={handbookLevel === 'advanced'} />
              <span>{copy.handbookLevelAdvanced}</span>
            </label>
          </div>
          <p class="settings-hint">{copy.handbookLevelHint}</p>
        </div>

        <div class="admin-field">
          <label for="preferred_locale">{copy.preferredLocale}</label>
          <select id="preferred_locale" name="preferred_locale" class="admin-select">
            <option value="ko" selected={preferredLocale === 'ko'}>한국어</option>
            <option value="en" selected={preferredLocale === 'en'}>English</option>
          </select>
        </div>
      </section>

      <!-- Visibility -->
      <section class="settings-section">
        <h2 class="settings-section-title">{copy.visibilitySection}</h2>
        <label class="settings-toggle-row">
          <input type="checkbox" name="is_public" id="is_public" checked={isPublic} />
          <span>{copy.isPublic}</span>
        </label>
        <p class="settings-hint">{copy.isPublicHint}</p>
      </section>

      <!-- Save -->
      <div class="settings-actions">
        <button type="submit" class="admin-btn admin-btn-primary" id="save-btn">
          {copy.save}
        </button>
      </div>
    </form>

    <!-- Danger Zone -->
    <section class="settings-section settings-danger-zone">
      <h2 class="settings-section-title settings-section-title--danger">{copy.dangerSection}</h2>
      <div class="settings-danger-card">
        <div>
          <strong>{copy.deleteAccount}</strong>
          <p class="settings-hint">{copy.deleteHint}</p>
        </div>
        <button type="button" class="admin-btn-danger" id="delete-account-btn">{copy.deleteAccount}</button>
      </div>

      <div class="settings-delete-confirm" id="delete-confirm" hidden>
        <p class="settings-delete-confirm-msg">{copy.deleteConfirmMsg}</p>
        <input
          type="text"
          id="delete-confirm-input"
          class="admin-input"
          placeholder={copy.deleteConfirmWord}
          autocomplete="off"
        />
        <button
          type="button"
          class="admin-btn-danger"
          id="delete-confirm-btn"
          disabled
          data-confirm-word={copy.deleteConfirmWord}
          data-deleting-label={copy.deleting}
        >
          {copy.deleteBtn}
        </button>
      </div>
    </section>
  </div>
</MainLayout>

<style>
  .settings-page {
    max-width: 640px;
    margin: 0 auto;
    padding: 1rem 0 3rem;
  }

  .settings-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 2rem;
  }

  .settings-section {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .settings-section:last-of-type {
    border-bottom: none;
  }

  .settings-section-title {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .settings-hint {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }

  .settings-hint--locked {
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .settings-field-error {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--color-error);
    margin-top: 0.25rem;
  }

  /* Avatar */
  .settings-avatar-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .settings-avatar-preview {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--color-bg-tertiary);
    border: 2px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .settings-avatar-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .settings-avatar-initials {
    font-family: var(--font-ui);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-secondary);
  }

  .settings-avatar-controls {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: flex-start;
  }

  .settings-avatar-controls .settings-hint {
    width: 100%;
  }

  /* Radio Group */
  .settings-radio-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .settings-radio-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--color-text-primary);
    cursor: pointer;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    transition: border-color 150ms ease, background 150ms ease;
  }

  .settings-radio-item:has(input:checked) {
    border-color: var(--color-accent);
    background: var(--color-accent-subtle);
  }

  .settings-radio-item input[type="radio"] {
    display: none;
  }

  /* Toggle */
  .settings-toggle-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: var(--color-text-primary);
    cursor: pointer;
  }

  .settings-toggle-row input[type="checkbox"] {
    width: 1.1rem;
    height: 1.1rem;
    accent-color: var(--color-accent);
  }

  /* Actions */
  .settings-actions {
    padding-top: 1rem;
  }

  /* Danger Zone */
  .settings-danger-zone {
    margin-top: 2rem;
    border-top: 1px solid var(--color-error);
    padding-top: 1.5rem;
  }

  .settings-section-title--danger {
    color: var(--color-error);
  }

  .settings-danger-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .settings-delete-confirm {
    margin-top: 1rem;
    padding: 1rem;
    border: 1px solid var(--color-error);
    border-radius: 8px;
    background: rgba(168, 82, 75, 0.05);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .settings-delete-confirm-msg {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--color-error);
    margin: 0;
  }

  @media (max-width: 640px) {
    .settings-avatar-row {
      flex-direction: column;
      align-items: flex-start;
    }
    .settings-danger-card {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<script>
  function initSettings() {
    const form = document.getElementById('profile-form') as HTMLFormElement | null;
    const saveBtn = document.getElementById('save-btn') as HTMLButtonElement | null;
    const feedback = document.getElementById('feedback') as HTMLElement | null;
    const avatarInput = document.getElementById('avatar-input') as HTMLInputElement | null;
    const avatarRemoveBtn = document.getElementById('avatar-remove-btn') as HTMLButtonElement | null;
    const avatarPreview = document.getElementById('avatar-preview') as HTMLElement | null;
    const usernameError = document.getElementById('username-error') as HTMLElement | null;
    if (!form || !saveBtn) return;

    const isOnboarding = new URLSearchParams(window.location.search).get('onboarding') === 'true';

    function showFeedback(message: string, type: 'success' | 'error') {
      if (!feedback) return;
      feedback.textContent = message;
      feedback.className = `admin-feedback admin-feedback--toast admin-feedback--${type}`;
      feedback.hidden = false;
      setTimeout(() => { feedback.hidden = true; }, 3000);
    }

    // Avatar upload
    avatarInput?.addEventListener('change', async () => {
      const file = avatarInput.files?.[0];
      if (!file) return;

      if (file.size > 2 * 1024 * 1024) {
        showFeedback('File too large (max 2MB)', 'error');
        return;
      }

      const formData = new FormData();
      formData.append('avatar', file);

      try {
        const res = await fetch('/api/user/avatar', { method: 'POST', body: formData });
        const data = await res.json();
        if (!res.ok) {
          showFeedback(data.error || 'Upload failed', 'error');
          return;
        }
        // Update preview
        if (avatarPreview) {
          avatarPreview.innerHTML = `<img src="${data.avatar_url}" alt="Avatar" id="avatar-img" style="width:100%;height:100%;object-fit:cover;" />`;
        }
        showFeedback('Avatar updated', 'success');
      } catch (err) {
        console.error('[Avatar upload] error:', err);
        showFeedback('Upload failed', 'error');
      }
      avatarInput.value = '';
    });

    // Avatar remove
    avatarRemoveBtn?.addEventListener('click', async () => {
      try {
        const res = await fetch('/api/user/avatar', { method: 'DELETE' });
        const data = await res.json();
        if (!res.ok) {
          showFeedback(data.error || 'Failed to remove avatar', 'error');
          return;
        }
        if (avatarPreview) {
          if (data.avatar_url) {
            avatarPreview.innerHTML = `<img src="${data.avatar_url}" alt="Avatar" id="avatar-img" style="width:100%;height:100%;object-fit:cover;" />`;
          } else {
            const initials = (document.getElementById('display_name') as HTMLInputElement)?.value?.charAt(0)?.toUpperCase() || '?';
            avatarPreview.innerHTML = `<span class="settings-avatar-initials" id="avatar-initials">${initials}</span>`;
          }
        }
        showFeedback('Avatar reset', 'success');
      } catch {
        showFeedback('Failed to remove avatar', 'error');
      }
    });

    // Profile form save
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (usernameError) usernameError.hidden = true;

      saveBtn.disabled = true;
      const originalText = saveBtn.textContent;
      saveBtn.textContent = saveBtn.dataset.savingLabel || 'Saving...';

      const formData = new FormData(form);
      const payload: Record<string, unknown> = {
        display_name: formData.get('display_name') || null,
        username: formData.get('username') || null,
        bio: formData.get('bio') || null,
        persona: formData.get('persona') || null,
        handbook_level: formData.get('handbook_level') || 'basic',
        preferred_locale: formData.get('preferred_locale') || 'ko',
        is_public: formData.has('is_public'),
      };

      if (isOnboarding) {
        payload.onboarding_completed = true;
      }

      try {
        const res = await fetch('/api/user/profile', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json();

        if (!res.ok) {
          if (res.status === 409) {
            if (usernameError) {
              usernameError.textContent = usernameError.dataset.usernameTaken || data.error || 'User ID already taken';
              usernameError.hidden = false;
            }
          }
          if (res.status === 429) {
            if (usernameError) {
              usernameError.textContent = usernameError.dataset.cooldownMsg || data.error || 'Too soon to change User ID';
              usernameError.hidden = false;
            }
          }
          showFeedback(data.error || 'Save failed', 'error');
          return;
        }

        showFeedback(saveBtn.dataset.successLabel || 'Profile saved.', 'success');

        // Sync persona preference to cookie for CDN-cached pages
        const savedPersona = formData.get('persona') || 'learner';
        document.cookie = `persona=${savedPersona}; path=/; max-age=${60 * 60 * 24 * 365}; SameSite=Lax`;

        // If onboarding, remove banner and clean URL
        if (isOnboarding) {
          const banner = document.getElementById('onboarding-banner');
          if (banner) banner.hidden = true;
          window.history.replaceState({}, '', '/settings/');
        }
      } catch {
        showFeedback('Save failed', 'error');
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = originalText;
      }
    });

    // Account deletion
    const deleteBtn = document.getElementById('delete-account-btn') as HTMLButtonElement | null;
    const deleteConfirm = document.getElementById('delete-confirm') as HTMLElement | null;
    const deleteInput = document.getElementById('delete-confirm-input') as HTMLInputElement | null;
    const deleteConfirmBtn = document.getElementById('delete-confirm-btn') as HTMLButtonElement | null;

    deleteBtn?.addEventListener('click', () => {
      if (deleteConfirm) deleteConfirm.hidden = false;
      deleteBtn.hidden = true;
    });

    deleteInput?.addEventListener('input', () => {
      if (deleteConfirmBtn) {
        const confirmWord = deleteConfirmBtn.dataset.confirmWord || '';
        deleteConfirmBtn.disabled = deleteInput.value.trim() !== confirmWord;
      }
    });

    deleteConfirmBtn?.addEventListener('click', async () => {
      deleteConfirmBtn.disabled = true;
      const originalText = deleteConfirmBtn.textContent;
      deleteConfirmBtn.textContent = deleteConfirmBtn.dataset.deletingLabel || 'Deleting...';

      try {
        const res = await fetch('/api/user/account', { method: 'DELETE' });
        if (res.ok) {
          localStorage.removeItem('onboarding_seen');
          window.location.href = '/';
        } else {
          const data = await res.json();
          showFeedback(data.error || 'Failed to delete account', 'error');
          deleteConfirmBtn.disabled = false;
          deleteConfirmBtn.textContent = originalText;
        }
      } catch {
        showFeedback('Failed to delete account', 'error');
        deleteConfirmBtn.disabled = false;
        deleteConfirmBtn.textContent = originalText;
      }
    });
  }

  document.addEventListener('astro:page-load', initSettings);
  initSettings();
</script>
