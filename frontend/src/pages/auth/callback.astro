---
export const prerender = false;
const nonce = Astro.locals.cspNonce || '';
---

<html lang="en" data-theme="light">
  <head>
    <title>Signing in...</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;600&display=swap" rel="stylesheet" />
    <script is:inline nonce={nonce}>
      (function() {
        var stored = localStorage.getItem('theme');
        if (stored === 'midnight') { stored = 'pink'; localStorage.setItem('theme', stored); }
        if (stored) {
          document.documentElement.setAttribute('data-theme', stored);
        } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
    <style>
      [data-theme="dark"] { --bg: #1F1A17; --fg: #E0D8C3; }
      [data-theme="light"] { --bg: #F4F1EA; --fg: #333333; }
      [data-theme="pink"] { --bg: #FFF0F3; --fg: #2D1F22; }
      body {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        margin: 0;
        font-family: Lora, 'Pretendard', Georgia, serif;
        color: var(--fg);
        background: var(--bg);
        transition: background 0.2s, color 0.2s;
      }
      .signing-in {
        font-size: clamp(1.75rem, 6vw, 2.1rem);
        letter-spacing: 0.02em;
      }
      .signing-in-dots::after {
        content: '';
        animation: dots 1.4s steps(4, end) infinite;
      }
      @keyframes dots {
        0%  { content: ''; }
        25% { content: '.'; }
        50% { content: '..'; }
        75% { content: '...'; }
      }
    </style>
  </head>
  <body>
    <div class="signing-in">Signing in<span class="signing-in-dots"></span></div>

    <script>
      import { createClient } from '@supabase/supabase-js';

      async function handleCallback() {
        const rawRedirect = sessionStorage.getItem('oauth_redirect') || '/';
        const redirectTo = (rawRedirect.startsWith('/') && !rawRedirect.startsWith('//')) ? rawRedirect : '/';
        sessionStorage.removeItem('oauth_redirect');

        const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
        const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
        if (!supabaseUrl || !supabaseKey) {
          window.location.href = '/login?error=config';
          return;
        }

        // Clear stale Supabase session from localStorage to prevent
        // race condition where old session is restored before new OAuth code exchange
        try {
          Object.keys(localStorage).filter(k => k.startsWith('sb-')).forEach(k => localStorage.removeItem(k));
        } catch { /* localStorage may be unavailable */ }

        const supabase = createClient(supabaseUrl, supabaseKey);

        let handled = false;

        async function setSessionAndRedirect(session: { access_token: string; refresh_token: string }) {
          if (handled) return;
          handled = true;

          try {
            const res = await fetch('/api/auth/callback', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                access_token: session.access_token,
                refresh_token: session.refresh_token,
              }),
            });

            if (res.ok) {
              // Check onboarding status — redirect to settings if not completed
              try {
                const profileRes = await fetch('/api/user/profile');
                if (profileRes.ok) {
                  const profile = await profileRes.json();
                  if (!profile.onboarding_completed) {
                    window.location.href = '/settings/?onboarding=true';
                    return;
                  }
                }
              } catch {
                // Profile check failure should not block login
              }
              window.location.href = redirectTo;
            } else {
              window.location.href = '/login?error=exchange_failed';
            }
          } catch {
            window.location.href = '/login?error=exchange_failed';
          }
        }

        supabase.auth.onAuthStateChange(async (_event, session) => {
          if (session) {
            await setSessionAndRedirect(session);
          }
        });

        setTimeout(async () => {
          if (handled) return;
          const { data: { session } } = await supabase.auth.getSession();
          if (session) {
            await setSessionAndRedirect(session);
          }
        }, 1500);

        setTimeout(() => {
          if (!handled) {
            window.location.href = '/login?error=no_code';
          }
        }, 8000);
      }

      handleCallback();
    </script>
  </body>
</html>
