---
import Head from '../components/Head.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import AuthPromptSheet from '../components/auth/AuthPromptSheet.astro';
import CookieConsent from '../components/CookieConsent.astro';
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

interface ArticleData {
  datePublished: string;
  dateModified?: string;
  image?: string;
}

interface Props {
  title: string;
  description?: string;
  locale?: 'en' | 'ko';
  slug?: string;
  altSlug?: string;
  article?: ArticleData;
  headerAlwaysVisible?: boolean;
  previewMode?: boolean;
}

const { title, description, locale = 'en', slug, altSlug, article, headerAlwaysVisible = false, previewMode = false } = Astro.props;
const isAdmin = Astro.url.pathname.startsWith('/admin');
const nonce = Astro.locals.cspNonce || '';

const gaId = import.meta.env.PUBLIC_GA4_ID || '';
const clarityId = import.meta.env.PUBLIC_CLARITY_ID || '';
---

<!doctype html>
<html lang={locale} data-theme="light">
  <Head title={title} description={description} locale={locale} slug={slug} article={article} />

  <!-- FOUC Prevention: must run before paint -->
  <script is:inline nonce={nonce}>
    (function() {
      var stored = localStorage.getItem('theme');
      var tc = { dark: '#241F1C', light: '#F4F1EA', pink: '#FFF0F3', midnight: '#1A1A1A' };
      var cs = { dark: 'dark', light: 'light', pink: 'light', midnight: 'dark' };
      var theme = stored;
      if (stored) {
        document.documentElement.setAttribute('data-theme', stored);
      } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        document.documentElement.setAttribute('data-theme', 'dark');
        theme = 'dark';
      }
      document.documentElement.style.colorScheme = cs[theme] || 'light';
      var m = document.querySelector('meta[name="theme-color"]');
      if (m) m.setAttribute('content', tc[theme || 'dark'] || tc.dark);
    })();
  </script>

  <!-- Restore theme after ViewTransitions page swap (before paint) -->
  <script is:inline nonce={nonce}>
    document.addEventListener('astro:after-swap', function() {
      var stored = localStorage.getItem('theme');
      if (stored) {
        document.documentElement.setAttribute('data-theme', stored);
      }
    });
  </script>

  {!isAdmin && <ViewTransitions />}

  <body
    data-authenticated={Astro.locals.user ? 'true' : 'false'}
    data-preview-mode={previewMode ? 'true' : 'false'}
    style={`min-height: ${previewMode ? 'auto' : '100vh'}; display: flex; flex-direction: column; background-color: var(--color-bg-primary); color: var(--color-text-primary); margin: 0;`}
  >
    <!-- Analytics: consent-gated (GDPR opt-in) -->
    <script is:inline nonce={nonce} define:vars={{ gaId, clarityId }}>
      (function() {
        if (localStorage.getItem('cookieConsent') !== 'accepted') return;

        // GA4 — skip if already loaded (ViewTransitions re-execution guard)
        if (gaId && !window.gtag) {
          var gs = document.createElement('script');
          gs.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaId;
          gs.async = true;
          document.head.appendChild(gs);
          window.dataLayer = window.dataLayer || [];
          function gtag(){window.dataLayer.push(arguments);}
          window.gtag = gtag;
          gtag('js', new Date());
          gtag('config', gaId);
        }

        // Clarity — skip if already loaded
        if (clarityId && !window.clarity) {
          (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src='https://www.clarity.ms/tag/'+i;
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
          })(window,document,'clarity','script',clarityId);
        }
      })();
    </script>

    <!-- Skip Navigation -->
    <a href="#main-content" class="skip-link">
      Skip to content
    </a>

    {!isAdmin && <Navigation locale={locale} alwaysVisible={headerAlwaysVisible} altSlug={altSlug} />}

    <main id="main-content" class={isAdmin ? 'main-admin' : 'main-public'}>
      <slot />
    </main>

    {!isAdmin && <Footer locale={locale} pathname={Astro.url.pathname} />}
    {!isAdmin && <CookieConsent locale={locale} />}
    {!isAdmin && <AuthPromptSheet locale={locale} />}
  </body>
</html>
